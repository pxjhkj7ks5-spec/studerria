<!doctype html>
<html lang="<%= lang || 'uk' %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studerria Vision</title>
    <link rel="stylesheet" href="/css/studerria-codex.css" />
  </head>
  <body class="theme-light page-codex-showcase" data-theme="light">
    <%- include('partials/codex-showcase/background') %>

    <div class="showcase-shell">
      <header class="showcase-header">
        <a href="/" class="showcase-logo" aria-label="Studerria home">Studerria</a>
        <nav class="showcase-nav" aria-label="Primary">
          <a href="#hero">Огляд</a>
          <a href="#threads">Threads</a>
          <a href="#conversation">Conversation</a>
          <a href="#contacts">Контакти</a>
        </nav>
        <div class="showcase-header-actions">
          <button
            type="button"
            class="theme-toggle"
            id="showcaseThemeToggle"
            data-light-label="Світла"
            data-dark-label="Темна"
            aria-label="Toggle theme"
          >
            Темна
          </button>
          <a class="signup-btn" href="/register">Sign up</a>
        </div>
      </header>

      <main class="showcase-main">
        <section class="hero-section" id="hero">
          <div class="hero-copy">
            <p class="hero-kicker">Studerria interface lab</p>
            <h1>Открий нову еру кодування</h1>
            <p>
              Інтерактивна панель для розкладу, предметів і командної комунікації, де все працює в одному
              просторі з живим фоном та швидкими сценаріями для студентів і викладачів.
            </p>
            <div class="hero-actions">
              <a href="/login" class="btn-primary">Почати</a>
              <a href="#threads" class="btn-secondary">Вивчити більше</a>
            </div>
          </div>

          <article class="code-diff-card" aria-label="Code diff demo">
            <header>
              <div class="diff-badge">GPT</div>
              <div>
                <strong>Code diff</strong>
                <p>Швидка підготовка навчальних сценаріїв</p>
              </div>
            </header>
            <div class="diff-columns">
              <div class="diff-column before" aria-label="Before snippet">
                <h3>Before</h3>
                <pre><code><span>- export const schedule = [];</span>
<span>- const note = "manual updates";</span>
<span>- function publishHomework() {}</span>
<span>- // no reusable templates</span></code></pre>
              </div>
              <div class="diff-column after" aria-label="After snippet">
                <h3>After</h3>
                <pre><code><span>+ export const schedule = buildWeekFlow();</span>
<span>+ const template = createLessonTemplate();</span>
<span>+ publishHomework({ syncJournal: true });</span>
<span>+ notifyGroup("Deadline added");</span></code></pre>
              </div>
            </div>
          </article>
        </section>

        <section class="workspace-section" id="threads">
          <aside class="threads-panel" aria-label="Thread list">
            <div class="panel-head">
              <h2>Threads</h2>
              <p>Швидкі модулі для розкладу, профілю та системних параметрів.</p>
            </div>
            <div class="threads-list">
              <%- include('partials/codex-showcase/thread-schedule') %>
              <%- include('partials/codex-showcase/thread-profile') %>
              <%- include('partials/codex-showcase/thread-settings') %>
            </div>
          </aside>

          <section class="conversation-panel" id="conversation" aria-label="Conversation preview">
            <header class="conversation-head">
              <div class="avatar" aria-hidden="true">S</div>
              <div>
                <h2>Conversation</h2>
                <p>Помічник по курсам, дедлайнам та доступам</p>
              </div>
            </header>

            <div class="conversation-stream" role="log" aria-live="polite">
              <article class="message from-user">
                <h3>Куратор курсу</h3>
                <p>Потрібно оновити розклад магістратури на новий семестр і перевірити конфлікти.</p>
              </article>
              <article class="message from-assistant">
                <h3>Studerria Assistant</h3>
                <p>
                  Знайшов 2 перетини пар. Можу автоматично розвести аудиторії та створити шаблон для
                  домашніх завдань на перші 4 тижні.
                </p>
              </article>
              <article class="message from-user">
                <h3>Деканат</h3>
                <p>Опублікуй стислий рейтинг груп і надішли контактні дані відповідальних викладачів.</p>
              </article>
            </div>

            <form class="conversation-compose" action="#" method="post" onsubmit="return false;">
              <label for="conversationInput" class="sr-only">Message</label>
              <input id="conversationInput" type="text" placeholder="Напишіть запит щодо курсів, розкладу або контактів..." />
              <button type="submit">Надіслати</button>
            </form>

            <footer id="contacts">
              <span>📞 +380 44 000 00 00</span>
              <span>✉️ support@studerria.edu</span>
              <strong>Powered by OpenAI</strong>
            </footer>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/studerria-codex.js" defer></script>
  </body>
</html>
