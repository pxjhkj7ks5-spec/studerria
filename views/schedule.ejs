      function bindTeamworkDeadlineCards(root = document) {
        if (!teamworkMap) return;
        root.querySelectorAll('.deadline-item[data-teamwork-id]').forEach((el) => {
          if (el.dataset.deadlineTeamworkBound === '1') return;
          el.dataset.deadlineTeamworkBound = '1';
          el.addEventListener('click', () => {
