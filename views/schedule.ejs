          setDrawerOpen(!isOpen);
        });
      }

      if (scheduleDrawerClose && scheduleDrawer) {
        scheduleDrawerClose.addEventListener('click', () => setDrawerOpen(false));
      }

      document.addEventListener('click', (event) => {
        if (!scheduleDrawer || !document.body.classList.contains('schedule-drawer-open')) return;
        const insideDrawer = scheduleDrawer.contains(event.target);
        const onToggle = scheduleDrawerToggle && scheduleDrawerToggle.contains(event.target);
        if (!insideDrawer && !onToggle) {
          setDrawerOpen(false);
        }
      });

      let isWeekSwitching = false;
      let weekDebounceUntil = 0;
      const weekDebounceMs = 240;

      function clampWeek(value) {
        const parsed = Number(value);
        if (Number.isNaN(parsed)) return 1;
        return Math.max(1, Math.min(totalWeeks, parsed));
      }

      function parseDateUtc(dateStr) {
        if (!dateStr || !/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return null;
        const [y, m, d] = dateStr.split('-').map((n) => Number(n));
        if (!y || !m || !d) return null;
        return Date.UTC(y, m - 1, d);
      }

      function getWeekRange(week) {
        const startUtc = parseDateUtc(semesterStartDate);
        if (startUtc === null) return null;
        const safeWeek = clampWeek(week);
        const start = new Date(startUtc + ((safeWeek - 1) * 7 * 86400000));
        const end = new Date(startUtc + (((safeWeek - 1) * 7) + 6) * 86400000);
        return { start, end };
      }

      function formatWeekRange(week) {
        const range = getWeekRange(week);
        if (!range) return scheduleViewText.weekRangeFallback;
        try {
          if (typeof kyivWeekFormatter.formatRange === 'function') {
            return kyivWeekFormatter.formatRange(range.start, range.end);
          }
        } catch (error) {
        }
        return `${kyivWeekFormatter.format(range.start)} - ${kyivWeekFormatter.format(range.end)}`;
      }

      function getKyivAcademicWeek() {
        if (!semesterStartDate) return clampWeek(currentWeek);
        const startUtc = parseDateUtc(semesterStartDate);
        if (startUtc === null) return clampWeek(currentWeek);
        const { year, month, day } = getKyivDateParts();
        const kyivDayUtc = Date.UTC(year, month - 1, day);
        const diffDays = Math.floor((kyivDayUtc - startUtc) / 86400000);
        let week = Math.floor(diffDays / 7) + 1;
        if (diffDays < 0) week = 1;
        return clampWeek(week);
      }

      function syncWeekAtKyivMidnight() {
        const actualWeek = getKyivAcademicWeek();
        if (actualWeek !== currentWeek) {
          updateSchedule(actualWeek);
        }
      }

      function updateSchedule(week) {
        const safe = clampWeek(week);
        const params = new URLSearchParams(window.location.search);
        params.set('week', safe);
        window.location.search = params.toString();
      }

      function syncWeekPager(week) {
        const safe = clampWeek(week);
        const displayWeek = String(safe).padStart(2, '0');
        currentWeek = safe;
        const weekRangeLabel = document.getElementById('scheduleWeekRangeLabel');
        if (weekNumberLabel) {
          weekNumberLabel.textContent = `${weekTitlePrefix} ${displayWeek}`;
        }
        if (weekPillCount) {
          weekPillCount.textContent = `${displayWeek} / ${String(totalWeeks).padStart(2, '0')}`;
        }
        if (weekRangeLabel) {
          weekRangeLabel.textContent = formatWeekRange(safe);
        }
        if (weekPillRange) {
          weekPillRange.textContent = formatWeekRange(safe);
        }
        if (weekPrev) weekPrev.disabled = safe <= 1;
        if (weekNext) weekNext.disabled = safe >= totalWeeks;
        if (weekPill) weekPill.setAttribute('aria-label', `${weekLabelText} ${safe}`);
      }

      function goToWeek(targetWeek) {
        const safeWeek = clampWeek(targetWeek);
        if (safeWeek === currentWeek || isWeekSwitching) return;

        const now = Date.now();
        if (now < weekDebounceUntil) return;
        weekDebounceUntil = now + weekDebounceMs;
        isWeekSwitching = true;
        if (weekPager) {
          weekPager.dataset.direction = safeWeek > currentWeek ? 'forward' : 'backward';
        }

        syncWeekPager(safeWeek);
        setTimeout(() => {
          isWeekSwitching = false;
          if (weekPager) {
            delete weekPager.dataset.direction;
          }
        }, 260);
        requestAnimationFrame(() => updateSchedule(safeWeek));
      }

      function animateWeekChange(nextWeek) {
        goToWeek(nextWeek);
      }

      if (weekPager) {
        if (weekPrev) {
          weekPrev.addEventListener('click', () => {
            goToWeek(currentWeek - 1);
          });
        }

        if (weekNext) {
          weekNext.addEventListener('click', () => {
            goToWeek(currentWeek + 1);
          });
        }

        if (weekTodayBtn) {
          weekTodayBtn.addEventListener('click', () => {
            const todayPill = document.querySelector('.schedule-day-pill.is-today');
            if (todayPill instanceof HTMLElement) {
              todayPill.click();
              return;
            }
            const firstPill = document.querySelector('.schedule-day-pill');
            if (firstPill instanceof HTMLElement) {
              firstPill.click();
            }
          });
        }

        if (weekCurrentBtn) {
          weekCurrentBtn.addEventListener('click', () => {
            goToWeek(getKyivAcademicWeek());
          });
        }

        let pagerTouchStartX = 0;
        let pagerTouchStartY = 0;
        weekPager.addEventListener('touchstart', (event) => {
          const touch = event.touches[0];
          pagerTouchStartX = touch.clientX;
          pagerTouchStartY = touch.clientY;
        }, { passive: true });

        weekPager.addEventListener('touchend', (event) => {
          const touch = event.changedTouches[0];
          const dx = touch.clientX - pagerTouchStartX;
          const dy = touch.clientY - pagerTouchStartY;
          if (Math.abs(dx) < 42 || Math.abs(dx) < Math.abs(dy)) return;
          if (dx < 0) goToWeek(currentWeek + 1);
          if (dx > 0) goToWeek(currentWeek - 1);
        }, { passive: true });

        syncWeekPager(currentWeek);
      }

      window.addEventListener('resize', () => {
        if (window.innerWidth < 992) {
          setDrawerOpen(false);
        }
        syncWeekPager(currentWeek);
      });
      if (messagesBtnMobile) {
        messagesBtnMobile.addEventListener('click', () => {
