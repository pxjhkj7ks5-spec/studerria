      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && document.body.classList.contains('schedule-drawer-open')) {
          setDrawerOpen(false);
          return;
        }
        if (event.key === 'ArrowRight') {
          animateWeekChange(currentWeek + 1);
        }
        if (event.key === 'ArrowLeft') {
          animateWeekChange(currentWeek - 1);
        }
      });

      let scrollTimer = null;
      window.addEventListener('scroll', () => {
        document.body.classList.add('is-scrolling');
        if (scrollTimer) clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          document.body.classList.remove('is-scrolling');
        }, 140);
      }, { passive: true });

      window.addEventListener('load', () => {
        document.body.style.transform = 'translateZ(0)';
        void document.body.offsetHeight;
        document.body.style.transform = '';

        const content = document.querySelector('.schedule-content');
        if (!content) return;
        requestAnimationFrame(() => {
          content.classList.add('enter-active');
          content.classList.remove('enter');
        });
      });

      const scheduleTimeZone = 'Europe/Kyiv';
      const scheduleNextMarkerStorageKey = `schedule-next-marker:<%= selectedCourseId || 'all' %>:<%= userId || 'guest' %>:<%= role || 'user' %>:<%= viewAs || 'none' %>`;

      function getTimeZoneOffsetMinutes(timeZone, date) {
        const dtf = new Intl.DateTimeFormat('en-US', {
          timeZone,
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: false,
        });
        const parts = dtf.formatToParts(date);
        const values = {};
        parts.forEach((part) => {
          values[part.type] = part.value;
        });
        const asUTC = Date.UTC(
          Number(values.year),
          Number(values.month) - 1,
          Number(values.day),
          Number(values.hour),
          Number(values.minute),
          Number(values.second)
        );
        return (asUTC - date.getTime()) / 60000;
      }

      function buildLocalTime(dateStr, timeStr, timeZone) {
        if (!dateStr || !timeStr) return null;
        const [y, m, d] = dateStr.split('-').map((n) => Number(n));
        const [hh, mm] = timeStr.split(':').map((n) => Number(n));
        if (!y || !m || !d || Number.isNaN(hh) || Number.isNaN(mm)) return null;
        const naiveUTC = Date.UTC(y, m - 1, d, hh, mm);
        const offsetMin = getTimeZoneOffsetMinutes(timeZone, new Date(naiveUTC));
        return new Date(naiveUTC - offsetMin * 60000);
      }

      function formatLocalRange(dateStr, start, end, timeZone) {
        const startDate = buildLocalTime(dateStr, start, timeZone);
        const endDate = buildLocalTime(dateStr, end, timeZone);
        if (!startDate || !endDate) return null;
        const opts = { hour: '2-digit', minute: '2-digit', hour12: false };
        const startLabel = startDate.toLocaleTimeString(undefined, opts);
        const endLabel = endDate.toLocaleTimeString(undefined, opts);
        return `${startLabel} - ${endLabel}`;
      }

      function applyLocalWeekTimes() {
        const items = document.querySelectorAll('[data-time-base][data-date]');
        items.forEach((btn) => {
          if (btn.dataset.useLocalTime !== '1') return;
          const baseRange = btn.dataset.timeBase || '';
          const dateStr = btn.dataset.date;
          const [start, end] = baseRange.split('-').map((s) => s.trim());
          if (!start || !end || !dateStr) return;
          const localRange = formatLocalRange(dateStr, start, end, scheduleTimeZone);
          if (!localRange) return;
          const label = btn.querySelector('.schedule-time');
          if (label) label.textContent = localRange;
          btn.dataset.time = localRange;
          const detail = btn.dataset.detail || '';
          if (detail) {
            const parts = detail.split(' • ');
            if (parts.length >= 4) {
              parts[3] = localRange;
              btn.dataset.detail = parts.join(' • ');
            }
          }
        });
      }

      applyLocalWeekTimes();

      const scheduleCacheKey = `schedule-cache:<%= currentWeek || 1 %>:<%= selectedCourseId || 'all' %>:<%= userId || 'guest' %>:<%= role || 'user' %>`;
      let lastSyncTs = Date.now();

      function initTooltips(root = document) {
        root.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
          if (bootstrap.Tooltip.getInstance(el)) return;
          new bootstrap.Tooltip(el);
        });
      }

      function formatRelativeTime(ts) {
        if (!ts) return 'ніколи';
        const diff = Math.max(0, Date.now() - ts);
        if (diff < 60000) return 'щойно';
        const minutes = Math.round(diff / 60000);
        if (minutes < 60) return `${minutes} хв тому`;
        const hours = Math.round(minutes / 60);
        if (hours < 24) return `${hours} год тому`;
        const days = Math.round(hours / 24);
        return `${days} дн тому`;
      }

      function updateSyncStatus(state = {}) {
        const online = navigator.onLine;
        const failed = state.failed === true;
        if (syncDot) {
          syncDot.classList.toggle('offline', !online);
        }
        if (syncStatusLabel) {
          syncStatusLabel.textContent = online ? 'Онлайн' : 'Офлайн';
        }
        if (syncStatusMeta) {
          const prefix = failed
            ? 'Не вдалося оновити · кеш '
            : online
              ? 'Оновлено '
              : 'Офлайн · кеш ';
          syncStatusMeta.textContent = `${prefix}${formatRelativeTime(lastSyncTs)}`;
        }
      }

      updateSyncStatus = function updateSharedSyncStatus() {
        if (typeof window.__updateFooterNetworkStatus === 'function') {
          window.__updateFooterNetworkStatus();
        }
      };

      function readScheduleCache() {
        try {
          const raw = localStorage.getItem(scheduleCacheKey);
          return raw ? JSON.parse(raw) : null;
        } catch (err) {
          return null;
        }
      }

      function writeScheduleCache(html) {
        if (!html) return;
        lastSyncTs = Date.now();
        try {
          localStorage.setItem(scheduleCacheKey, JSON.stringify({ ts: lastSyncTs, html }));
        } catch (err) {
          // ignore storage failures
        }
        updateSyncStatus();
      }

      function updateSmartHighlights() {
        const now = new Date();
        const kyivToday = now.toLocaleDateString('en-CA', { timeZone: scheduleTimeZone });
        // Keep the "Next" marker working even when today's visible day exists but has no classes.
        const dayCards = Array.from(document.querySelectorAll('.day-card'));
        const visibleWeekHasToday = dayCards.some((card) => (card.dataset.dayDate || '') === kyivToday);
        const markerKeyForCard = (card) => [
          String(card.dataset.subjectid || ''),
          String(card.dataset.day || ''),
          String(card.dataset.classnum || ''),
          String(card.dataset.date || ''),
          String(card.dataset.groupnum || ''),
        ].join('|');
        const storedNextKey = (() => {
          try {
            return localStorage.getItem(scheduleNextMarkerStorageKey) || '';
          } catch (err) {
            return '';
          }
        })();
        dayCards.forEach((card) => {
          const dayDate = card.dataset.dayDate || '';
          card.classList.toggle('is-today', dayDate && dayDate === kyivToday);
        });
        const entries = [];
        const entriesByKey = new Map();
        document.querySelectorAll('.schedule-card[data-time-base][data-date]').forEach((btn) => {
          btn.classList.remove('is-now', 'is-next');
          const baseRange = btn.dataset.timeBase || '';
          const dateStr = btn.dataset.date;
          const key = markerKeyForCard(btn);
          if (key) {
            entriesByKey.set(key, btn);
          }
          const [start, end] = baseRange.split('-').map((s) => s.trim());
          if (!start || !end || !dateStr) return;
          const startDate = buildLocalTime(dateStr, start, scheduleTimeZone);
          const endDate = buildLocalTime(dateStr, end, scheduleTimeZone);
          if (!startDate || !endDate) return;
          entries.push({ start: startDate.getTime(), end: endDate.getTime(), el: btn });
        });
        if (!entries.length) return;
        entries.sort((a, b) => a.start - b.start);
        const nowMs = now.getTime();
        const current = entries.find((entry) => nowMs >= entry.start && nowMs < entry.end);
        let nextKey = storedNextKey;
        if (current) current.el.classList.add('is-now');
        if (visibleWeekHasToday) {
          const next = entries.find((entry) => entry.start > nowMs);
          nextKey = next ? markerKeyForCard(next.el) : '';
          try {
            if (nextKey) {
              localStorage.setItem(scheduleNextMarkerStorageKey, nextKey);
            } else {
              localStorage.removeItem(scheduleNextMarkerStorageKey);
            }
          } catch (err) {
            // ignore storage failures
          }
        }
        if (nextKey && entriesByKey.has(nextKey)) {
          entriesByKey.get(nextKey).classList.add('is-next');
        }
      }

      function bindScheduleCardInteractions(root = document) {
        root.querySelectorAll('.schedule-card[role="button"]').forEach((card) => {
          if (card.dataset.keyboardBound === '1') return;
          card.dataset.keyboardBound = '1';
          card.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter' && event.key !== ' ') return;
            event.preventDefault();
            card.click();
          });
        });
      }

      function applySubjectTones(root = document) {
        const dayCards = root.querySelectorAll('.day-card');
        dayCards.forEach((dayCard) => {
          const cards = Array.from(dayCard.querySelectorAll('.schedule-card'));
          const groups = new Map();
          cards.forEach((card) => {
            card.style.setProperty('--subject-shift', '0');
            const subjectKey = (card.dataset.subject || card.dataset.class || '').trim().toLowerCase();
            if (!subjectKey) return;
            if (!groups.has(subjectKey)) groups.set(subjectKey, []);
            groups.get(subjectKey).push(card);
          });
          groups.forEach((subjectCards) => {
            const total = subjectCards.length;
            subjectCards.forEach((card, index) => {
              let shift = 0;
              if (total > 1) {
                const progress = total === 1 ? 0 : index / (total - 1);
                shift = Math.round((progress - 0.5) * 6);
              }
              card.style.setProperty('--subject-shift', String(shift));
            });
          });
        });
      }

      function setDensityChip(chip, label, detail, opacity) {
        if (!chip) return;
        chip.textContent = label;
        chip.style.setProperty('--chip-opacity', String(Math.max(0.12, Math.min(0.36, opacity))));
        chip.setAttribute('data-bs-title', detail);
        const tooltip = bootstrap.Tooltip.getInstance(chip);
        if (tooltip) tooltip.dispose();
        new bootstrap.Tooltip(chip);
      }

      function updateDensitySummary(root = document) {
        const dayCards = Array.from(root.querySelectorAll('.day-card'));
        const dayStats = dayCards.map((card) => {
          const dayName = card.querySelector('.day-name') ? card.querySelector('.day-name').textContent.trim() : scheduleViewText.dayFallback;
          const classCards = Array.from(card.querySelectorAll('.schedule-card'));
          const count = classCards.length;
          const eveningCount = classCards.filter((entry) => Number(entry.dataset.classnum || 0) >= 6).length;
          return { dayName, count, eveningCount };
        }).filter((stat) => stat.count > 0);

        if (!dayStats.length) {
          setDensityChip(densityChipBalance, scheduleViewText.dayBalanceNone, scheduleViewText.dayBalanceNoneDetail, 0.14);
          setDensityChip(densityChipEvening, scheduleViewText.eveningLight, scheduleViewText.eveningLightDetail, 0.14);
          setDensityChip(densityChipPeak, scheduleViewText.peakNone, scheduleViewText.peakNoneDetail, 0.14);
          return;
        }

        const counts = dayStats.map((stat) => stat.count);
        const totalClasses = counts.reduce((sum, value) => sum + value, 0);
        const average = totalClasses / dayStats.length;
        const maxCount = Math.max(...counts);
        const minCount = Math.min(...counts);
        const spread = maxCount - minCount;
        const eveningClasses = dayStats.reduce((sum, stat) => sum + stat.eveningCount, 0);
        const eveningRatio = totalClasses ? eveningClasses / totalClasses : 0;
        const peak = dayStats.reduce((best, stat) => (stat.count > best.count ? stat : best), dayStats[0]);

        let balanceLabel = scheduleViewText.dayBalanceSteady;
        if (spread >= 3) {
          balanceLabel = scheduleViewText.dayBalanceUneven;
        } else if (spread >= 2) {
          balanceLabel = scheduleViewText.dayBalanceMixed;
        }

        let eveningLabel = scheduleViewText.eveningLight;
        if (eveningRatio >= 0.28) {
          eveningLabel = scheduleViewText.eveningHeavy;
        } else if (eveningRatio >= 0.14) {
          eveningLabel = scheduleViewText.eveningModerate;
        }

        setDensityChip(
          densityChipBalance,
          balanceLabel,
          `${scheduleViewText.averagePrefix} ${average.toFixed(1)} ${scheduleViewText.classesPerDay}. ${scheduleViewText.spreadLabel}: ${minCount} ${scheduleViewText.toWord} ${maxCount}.`,
          0.14 + Math.min(0.18, spread * 0.06)
        );
        setDensityChip(
          densityChipEvening,
          eveningLabel,
          `${eveningClasses} ${scheduleViewText.ofWord} ${totalClasses} ${scheduleViewText.lateSlotsSuffix}`,
          0.14 + Math.min(0.2, eveningRatio * 0.6)
        );
        setDensityChip(
          densityChipPeak,
          `${scheduleViewText.peakPrefix} ${peak.dayName}`,
          `${peak.dayName} ${scheduleViewText.peakHasWord} ${peak.count} ${scheduleViewText.peakClassesThisWeek}`,
          0.14 + Math.min(0.18, peak.count / Math.max(1, maxCount) * 0.18)
        );
      }

      async function refreshSchedule() {
        if (!weekGrid) return;
        if (document.hidden) return;
        if (document.body.classList.contains('modal-open')) return;
        if (!navigator.onLine) {
          updateSyncStatus();
          return;
        }
        const url = `${window.location.pathname}${window.location.search}${window.location.search ? '&' : '?'}refresh=1&_=${Date.now()}`;
        try {
          const res = await fetch(url, { headers: { 'X-Requested-With': 'schedule-refresh' } });
          if (!res.ok) throw new Error('bad');
          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const nextGrid = doc.getElementById('scheduleWeekGrid');
          if (nextGrid) {
            weekGrid.innerHTML = nextGrid.innerHTML;
            applyLocalWeekTimes();
            bindCustomDeadlineCards(weekGrid);
            bindTeamworkDeadlineCards(weekGrid);
            bindScheduleCardInteractions(weekGrid);
            updateSmartHighlights();
            applySubjectTones(weekGrid);
            updateDensitySummary(weekGrid);
            applyScheduleMode(currentScheduleMode, { persist: false, bounce: false });
            initTooltips(weekGrid);
            initLiquidScheduleStatus();
            writeScheduleCache(weekGrid.innerHTML);
          }
        } catch (err) {
          updateSyncStatus({ failed: true });
          return;
        }
        updateSyncStatus();
      }

      const cachedSchedule = readScheduleCache();
      if (cachedSchedule && cachedSchedule.ts) {
        lastSyncTs = cachedSchedule.ts;
      }
      if (weekGrid) {
        writeScheduleCache(weekGrid.innerHTML);
      }
      bindScheduleCardInteractions();
      updateSmartHighlights();
      applySubjectTones();
      updateDensitySummary();
      initTooltips();

      setInterval(updateSmartHighlights, 30000);
      const scheduleRefreshMinutes = Number(<%= (settings && settings.schedule_refresh_minutes) ? settings.schedule_refresh_minutes : 5 %>);
      const scheduleRefreshMs = Math.max(60000, scheduleRefreshMinutes * 60 * 1000);
      setInterval(refreshSchedule, scheduleRefreshMs);
      window.addEventListener('online', () => refreshSchedule());

      let messageListRequestToken = 0;
      let unreadBadgeRequestToken = 0;

      async function refreshUnreadBadges() {
        const targets = [messagesBadge, mobileMenuBadge].filter(Boolean);
        if (!targets.length) return;
        const requestToken = ++unreadBadgeRequestToken;
        try {
          const res = await fetch('/messages.json', {
            cache: 'no-store',
            headers: {
              Accept: 'application/json',
            },
          });
          if (!res.ok) throw new Error('bad');
          const data = await res.json();
          if (requestToken !== unreadBadgeRequestToken) return;
          updateUnreadBadges(Number(data.unread_count) || 0);
        } catch (err) {
          // keep last unread state on network failures
        }
      }

      async function loadMessages(options = {}) {
        const { markAsRead = false, showLoading = true } = options;
        if (!messagesList) return;
        if (showLoading) {
          messagesList.innerHTML = `<div class="list-group-item text-muted">${scheduleText.messagesLoading}</div>`;
        }
        try {
          const subjectId = messagesSubjectFilter && messagesSubjectFilter.value
            ? `?subject_id=${encodeURIComponent(messagesSubjectFilter.value)}`
            : '';
          const selectedKind = messagesTypeFilter && messagesTypeFilter.value
            ? String(messagesTypeFilter.value)
            : '';
          const shouldSyncBadgeFromResponse = !subjectId && !selectedKind;
          const requestToken = ++messageListRequestToken;
          const res = await fetch(`/messages.json${subjectId}`, {
            cache: 'no-store',
            headers: {
              Accept: 'application/json',
            },
          });
          if (!res.ok) throw new Error('bad');
          const data = await res.json();
          if (requestToken !== messageListRequestToken) return;
          const messages = Array.isArray(data.messages) ? data.messages : [];
          const filteredMessages = selectedKind
            ? messages.filter((message) => String(message.message_kind || '') === selectedKind)
            : messages;
          if (!filteredMessages.length) {
            messagesList.innerHTML = `<div class="list-group-item text-muted">${selectedKind ? scheduleText.messagesNoFiltered : scheduleText.messagesEmpty}</div>`;
            if (shouldSyncBadgeFromResponse) {
              updateUnreadBadges(Number(data.unread_count) || 0);
            } else {
              refreshUnreadBadges();
            }
            return;
          }
          const escapeHtml = (value) => String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
          const messageKinds = ['broadcast', 'group', 'subject', 'direct'];
          const kindLabelMap = {
            broadcast: scheduleText.messagesKindBroadcast,
            group: scheduleText.messagesKindGroup,
            subject: scheduleText.messagesKindSubject,
            direct: scheduleText.messagesKindDirect,
          };
          const renderMessageCard = (m) => {
            const kindLabel = kindLabelMap[m.message_kind] || scheduleText.messagesKindAnnouncement;
            const meta = m.message_scope_line
              ? m.message_scope_line
              : [
                m.target_all ? scheduleText.messagesAllStudents : (m.subject_name || scheduleText.messagesSubjectFallback),
                Number(m.group_number || 0) > 0 ? `${scheduleText.groupSingle} ${m.group_number}` : '',
              ].filter(Boolean).join(' · ');
            const createdLabel = new Date(m.published_at || m.created_at).toLocaleString(scheduleLocale);
            const footerMeta = [
              meta,
              m.message_scope_line ? '' : (m.created_by || scheduleText.messagesAdminFallback),
              createdLabel,
            ].filter(Boolean).join(' · ');
            const unreadClass = m.read_id ? '' : 'fw-semibold';
            const reactions = m.reactions || {};
            const reacted = m.reacted || {};
            const makeBtn = (emoji) => {
              const count = reactions[emoji] || 0;
              const active = reacted[emoji] ? 'active' : '';
              return `<button class="btn btn-sm btn-outline-secondary react-btn ${active}" data-message-id="${m.id}" data-emoji="${emoji}">
                <span>${emoji}</span><span class="react-count">${count}</span>
              </button>`;
            };
            const ratingCard = m.rating_snapshot_card || null;
            const ratingPreview = ratingCard && Array.isArray(ratingCard.ranking_preview) && ratingCard.ranking_preview.length
              ? `
                <div class="small text-muted mt-2">
                  ${ratingCard.ranking_preview.map((row) => `${scheduleText.messagesTopPrefix} ${Number(row.rank || 0)}: ${escapeHtml(row.full_name || '')} (${escapeHtml(row.score_label || row.final_score || '')})`).join('<br />')}
                </div>
              `
              : '';
            const titleHtml = m.message_title
              ? `<div class="${unreadClass} mb-1">${escapeHtml(m.message_title)}</div>`
              : `<div class="${unreadClass} mb-1">${escapeHtml(m.body || '')}</div>`;
            const bodyHtml = m.message_title && (m.body_preview || m.body)
              ? `<div class="small mb-1">${escapeHtml(m.body_preview || m.body || '')}</div>`
              : '';
            return `
              <li class="list-group-item">
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle">${escapeHtml(kindLabel)}</span>
                  ${m.read_id ? '' : `<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">${scheduleText.messagesUnreadBadge}</span>`}
                  ${m.is_rating_publication ? `<span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">${scheduleText.messagesPublishedRating}</span>` : ''}
                </div>
                ${titleHtml}
                ${bodyHtml}
                ${ratingPreview}
                <div class="text-muted small">${escapeHtml(footerMeta)}</div>
                <div class="d-flex gap-2 mt-2 msg-reactions">
                  ${makeBtn('🔥')}
                  ${makeBtn('👍')}
                </div>
              </li>
            `;
          };
          const groupedHtml = messageKinds
            .map((kind) => ({
              kind,
              items: filteredMessages.filter((message) => String(message.message_kind || '') === kind),
            }))
            .filter((group) => group.items.length)
            .map((group) => `
              <section class="d-grid gap-2">
                <div class="d-flex align-items-center justify-content-between">
                  <strong>${escapeHtml(kindLabelMap[group.kind] || scheduleText.messagesKindAnnouncement)}</strong>
                  <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">${group.items.length}</span>
                </div>
                <ul class="list-group">
                  ${group.items.map((message) => renderMessageCard(message)).join('')}
                </ul>
              </section>
            `)
            .join('');
          messagesList.innerHTML = groupedHtml || `<div class="list-group-item text-muted">${selectedKind ? scheduleText.messagesNoFiltered : scheduleText.messagesEmpty}</div>`;
          if (shouldSyncBadgeFromResponse) {
            updateUnreadBadges(Number(data.unread_count) || 0);
          }
          if (markAsRead) {
            const unreadIds = filteredMessages
              .filter((m) => !m.read_id)
              .map((m) => Number(m.id))
              .filter((id) => Number.isFinite(id));
            if (unreadIds.length) {
              try {
                await fetch('/messages/read', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ message_ids: unreadIds }),
                });
              } catch (err) {
                // ignore and keep current unread marker
              }
              refreshUnreadBadges();
            } else if (!shouldSyncBadgeFromResponse) {
              refreshUnreadBadges();
            }
          } else if (!shouldSyncBadgeFromResponse) {
            refreshUnreadBadges();
          }
          const reactionButtons = messagesList.querySelectorAll('.msg-reactions .react-btn');
          reactionButtons.forEach((btn) => {
            btn.addEventListener('click', async () => {
              const messageId = Number(btn.dataset.messageId);
              const emoji = btn.dataset.emoji;
              if (Number.isNaN(messageId) || !emoji) return;
              try {
                const res = await fetch('/messages/react', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ message_id: messageId, emoji }),
                });
                if (!res.ok) return;
                const data = await res.json();
                const container = btn.closest('.msg-reactions');
                if (!container) return;
                updateReactionButtons(container, data.reactions, data.reacted);
              } catch (err) {
                console.error(err);
              }
            });
          });
        } catch (err) {
          messagesList.innerHTML = `<div class="list-group-item text-muted">${scheduleText.messagesLoadError}</div>`;
        }
      }

      if (messagesModalEl) {
        messagesModalEl.addEventListener('shown.bs.modal', () => {
          loadMessages({ markAsRead: true, showLoading: true });
        });
      }

      if (messagesBtn) {
        messagesBtn.addEventListener('click', () => {
          setDrawerOpen(false);
          if (!messagesModalEl) return;
          const modal = bootstrap.Modal.getOrCreateInstance(messagesModalEl);
          modal.show();
        });
      }
      if (messagesSubjectFilter) {
        messagesSubjectFilter.addEventListener('change', () => {
          loadMessages({ markAsRead: true, showLoading: true });
        });
      }
      if (messagesTypeFilter) {
        messagesTypeFilter.addEventListener('change', () => {
          loadMessages({ markAsRead: true, showLoading: true });
        });
      }

      window.addEventListener('studerria:messages-updated', () => {
        refreshUnreadBadges();
        if (messagesModalEl && messagesModalEl.classList.contains('show')) {
          loadMessages({ markAsRead: true, showLoading: false });
        }
      });

      const authLiteChangelogModal = document.querySelector('[data-auth-changelog]');
      if (authLiteChangelogModal) {
        const authLiteSheet = authLiteChangelogModal.querySelector('.td-lite-sheet');
        let authLiteLastFocus = null;

        const openAuthLiteChangelog = () => {
          authLiteLastFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
          authLiteChangelogModal.hidden = false;
          document.body.classList.add('studerria-changelog-open');
          window.requestAnimationFrame(() => {
            authLiteChangelogModal.classList.add('is-open');
            if (authLiteSheet) authLiteSheet.focus({ preventScroll: true });
          });
        };

        const closeAuthLiteChangelog = () => {
          authLiteChangelogModal.classList.remove('is-open');
          document.body.classList.remove('studerria-changelog-open');
          window.setTimeout(() => {
            authLiteChangelogModal.hidden = true;
            if (authLiteLastFocus) authLiteLastFocus.focus({ preventScroll: true });
          }, 180);
        };

        document.addEventListener('click', (event) => {
          const open = event.target && event.target.closest ? event.target.closest('[data-auth-changelog-open]') : null;
          if (open) {
            event.preventDefault();
            openAuthLiteChangelog();
            return;
          }
          const close = event.target && event.target.closest ? event.target.closest('[data-auth-changelog-close]') : null;
          if (close && !authLiteChangelogModal.hidden) {
            event.preventDefault();
            closeAuthLiteChangelog();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !authLiteChangelogModal.hidden) {
            closeAuthLiteChangelog();
          }
        });
      }

      refreshUnreadBadges();
      setInterval(refreshUnreadBadges, 60000);
      if (messagesModalEl) {
        const params = new URLSearchParams(window.location.search);
        if (params.get('panel') === 'messages') {
          const modal = bootstrap.Modal.getOrCreateInstance(messagesModalEl);
          modal.show();
        }
      }

      const phrases = Array.isArray(scheduleViewText.dailyPhrases) && scheduleViewText.dailyPhrases.length
        ? scheduleViewText.dailyPhrases
        : [scheduleViewText.heroPhrase];

      const specialPhrasesByDate = scheduleViewText.specialPhrasesByDate || {};

      function getKyivDateParts() {
        const now = new Date();
        const dateString = now.toLocaleDateString('en-CA', { timeZone: 'Europe/Kyiv' });
        const [year, month, day] = dateString.split('-').map(Number);
        return { year, month, day };
      }

      function getKyivDayOfYear() {
        const { year, month, day } = getKyivDateParts();
        const start = Date.UTC(year, 0, 1);
        const current = Date.UTC(year, month - 1, day);
        return Math.floor((current - start) / 86400000);
      }

      function updateDailyPhrase() {
        const el = document.getElementById('daily-phrase');
        if (!el) return;
        const { month, day } = getKyivDateParts();
        const dateKey = `${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        const dayOfYear = getKyivDayOfYear();
        const phrase = specialPhrasesByDate[dateKey] || phrases[dayOfYear % phrases.length];
        if (el.textContent === phrase) return;
        el.classList.add('fade-out');
        setTimeout(() => {
          el.textContent = phrase;
          el.classList.remove('fade-out');
        }, 240);
      }

      function scheduleNextMidnight() {
        const now = new Date();
        const kyivNow = new Date(
          now.toLocaleString('en-US', { timeZone: 'Europe/Kyiv' })
        );
        const nextMidnight = new Date(kyivNow);
        nextMidnight.setHours(24, 0, 0, 0);
        const ms = nextMidnight.getTime() - kyivNow.getTime();
        setTimeout(() => {
          updateDailyPhrase();
          syncWeekAtKyivMidnight();
          scheduleNextMidnight();
        }, Math.max(0, ms));
      }

      updateDailyPhrase();
      scheduleNextMidnight();

      document.querySelectorAll('.file-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.fileTarget;
          const input = target ? document.getElementById(target) : null;
          if (input) input.click();
        });
      });
      document.querySelectorAll('.file-input').forEach((input) => {
        input.addEventListener('change', () => {
          const label = document.querySelector(`[data-file-name="${input.id}"]`);
          if (!label) return;
          const name = input.files && input.files.length ? input.files[0].name : scheduleText.fileNotSelected;
          label.textContent = name;
        });
      });

      window.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        const openModal = document.querySelector('.modal.show');
        if (!openModal) return;
        const instance = bootstrap.Modal.getInstance(openModal);
        if (instance) instance.hide();
      });

      function initLiquidScheduleStatus() {
        const dayLinks = Array.from(document.querySelectorAll('[data-schedule-day-link]'));
        const weekGridRoot = document.getElementById('scheduleWeekGrid');
        const chip = document.querySelector('[data-next-class]');
        const kind = chip ? chip.querySelector('[data-next-kind]') : null;
        const label = chip ? chip.querySelector('[data-next-label]') : null;
        const selectedHeading = document.getElementById('scheduleSelectedDayHeading');
        const selectedMeta = document.getElementById('scheduleSelectedDayMeta');
        const overviewClasses = document.getElementById('scheduleOverviewClasses');
        const overviewRooms = document.getElementById('scheduleOverviewRooms');
        const overviewDeadlines = document.getElementById('scheduleOverviewDeadlines');
        const overviewNextTitle = document.getElementById('scheduleOverviewNextTitle');
        const overviewNextLabel = document.getElementById('scheduleOverviewNextLabel');
        const homeworkMeta = document.getElementById('scheduleHomeworkMeta');
        const homeworkTitle = document.getElementById('scheduleHomeworkTitle');
        const homeworkLine = document.getElementById('scheduleHomeworkLine');
        const todayIso = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Kyiv' });
        const now = new Date();
        const today = now.toLocaleDateString('en-CA', { timeZone: 'Europe/Kyiv' });
        const nowMinutes = Number(now.toLocaleTimeString('en-GB', {
          timeZone: 'Europe/Kyiv',
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
        }).replace(':', ''));
        const storageKey = `schedule-selected-day:<%= selectedCourseId || 'all' %>:<%= userId || 'guest' %>:${currentWeek}`;
        const copy = {
          freeKind: <%- JSON.stringify(lang === 'en' ? 'Free' : 'Вільно') %>,
          freeLabel: <%- JSON.stringify(lang === 'en' ? 'No classes today' : 'Немає пар сьогодні') %>,
          doneKind: <%- JSON.stringify(lang === 'en' ? 'Done' : 'Готово') %>,
          doneLabel: <%- JSON.stringify(lang === 'en' ? 'Done for today' : 'На сьогодні все') %>,
          nextKind: <%- JSON.stringify(lang === 'en' ? 'Next' : 'Далі') %>,
          nowKind: <%- JSON.stringify(lang === 'en' ? 'Now' : 'Зараз') %>,
          selectedOverview: <%- JSON.stringify(lang === 'en' ? 'Selected day overview' : 'Огляд вибраного дня') %>,
          selectedMeta: <%- JSON.stringify(lang === 'en' ? 'Summary of the selected day' : 'Короткий стан вибраного дня') %>,
          classSingle: <%- JSON.stringify(lang === 'en' ? 'class' : 'пара') %>,
          classPlural: <%- JSON.stringify(lang === 'en' ? 'classes' : 'пари') %>,
          noDeadlinesTitle: <%- JSON.stringify(lang === 'en' ? 'No deadlines yet' : 'Поки без дедлайнів') %>,
          noDeadlinesLine: <%- JSON.stringify(lang === 'en' ? 'No assignments attached to this day.' : 'Для цього дня поки немає привʼязаних завдань.') %>,
          noDeadlinesMeta: <%- JSON.stringify(lang === 'en' ? 'For the selected day' : 'Для вибраного дня') %>,
          firstClass: <%- JSON.stringify(lang === 'en' ? 'First class' : 'Перша пара') %>,
          nextClass: <%- JSON.stringify(lang === 'en' ? 'Next class' : 'Наступна пара') %>,
          currentClass: <%- JSON.stringify(lang === 'en' ? 'Current class' : 'Поточна пара') %>,
          quietDay: <%- JSON.stringify(lang === 'en' ? 'Free day' : 'Вільний день') %>,
          quietDayLine: <%- JSON.stringify(lang === 'en' ? 'No classes scheduled.' : 'Пари не заплановані.') %>,
        };

        const parseTime = (timeValue) => {
          const match = String(timeValue || '').match(/(\d{1,2}):(\d{2})\s*-\s*(\d{1,2}):(\d{2})/);
          if (!match) return null;
          return {
            start: Number(`${match[1].padStart(2, '0')}${match[2]}`),
            end: Number(`${match[3].padStart(2, '0')}${match[4]}`),
            startLabel: `${match[1].padStart(2, '0')}:${match[2]}`,
            endLabel: `${match[3].padStart(2, '0')}:${match[4]}`,
          };
        };

        const buildSelection = (scopeCards, scopeDate) => {
          const datedCards = scopeCards
            .filter((card) => String(card.dataset.date || '') === String(scopeDate || ''))
            .map((card) => ({ card, time: parseTime(card.dataset.timeBase || card.dataset.time || '') }))
            .filter((item) => item.time)
            .sort((a, b) => a.time.start - b.time.start);

          const isTodaySelection = String(scopeDate || '') === today;
          const active = isTodaySelection ? datedCards.find((item) => nowMinutes >= item.time.start && nowMinutes <= item.time.end) : null;
          const next = isTodaySelection ? datedCards.find((item) => nowMinutes < item.time.start) : null;
          const first = datedCards[0] || null;
          return { datedCards, isTodaySelection, active, next, first, selected: active || next || first };
        };

        const applyFloatingChip = () => {
          if (!chip) return;
          const cards = Array.from(document.querySelectorAll('.schedule-card[data-date][data-time-base]'));
          const todayState = buildSelection(cards, today);

          cards.forEach((card) => card.classList.remove('is-now', 'is-next'));
          if (todayState.active) todayState.active.card.classList.add('is-now');
          if (!todayState.active && todayState.next) todayState.next.card.classList.add('is-next');

          if (!todayState.datedCards.length) {
            if (kind) kind.textContent = copy.freeKind;
            if (label) label.textContent = copy.freeLabel;
            return;
          }
          if (!todayState.selected) {
            if (kind) kind.textContent = copy.doneKind;
            if (label) label.textContent = copy.doneLabel;
            return;
          }

          const subject = todayState.selected.card.dataset.subject || todayState.selected.card.dataset.class || scheduleViewText.classLabel;
          const room = todayState.selected.card.dataset.roomLabel ? ` · ауд. ${todayState.selected.card.dataset.roomLabel}` : '';
          if (todayState.active) {
            if (kind) kind.textContent = copy.nowKind;
            if (label) label.textContent = `${copy.nowKind}: ${subject} · до ${todayState.selected.time.endLabel}${room}`;
          } else {
            if (kind) kind.textContent = copy.nextKind;
            if (label) label.textContent = `${copy.nextKind}: ${subject} · ${todayState.selected.time.startLabel}${room}`;
          }
        };

        const updateOverview = (dayCard) => {
          if (!(dayCard instanceof HTMLElement)) return;
          const date = String(dayCard.dataset.dayDate || '');
          const dayName = dayCard.querySelector('.day-name') ? dayCard.querySelector('.day-name').textContent.trim() : scheduleViewText.dayFallback;
          const dayDate = dayCard.querySelector('.day-date') ? dayCard.querySelector('.day-date').textContent.trim() : '';
          const classCards = Array.from(dayCard.querySelectorAll('.schedule-card[data-date][data-time-base]'));
          const deadlines = Array.from(dayCard.querySelectorAll('.deadline-item'));
          const rooms = new Set(classCards.map((card) => String(card.dataset.roomLabel || '').trim()).filter(Boolean));
          const state = buildSelection(classCards, date);

          if (selectedHeading) selectedHeading.textContent = `${copy.selectedOverview} · ${dayName}`;
          if (selectedMeta) {
            const classCount = classCards.length;
            const classText = `${classCount} ${classCount === 1 ? copy.classSingle : copy.classPlural}`;
            selectedMeta.textContent = dayDate ? `${dayDate} · ${classText}` : classText;
          }
          if (overviewClasses) overviewClasses.textContent = String(classCards.length);
          if (overviewRooms) overviewRooms.textContent = String(rooms.size);
          if (overviewDeadlines) overviewDeadlines.textContent = String(deadlines.length);

          if (!classCards.length) {
            if (overviewNextTitle) overviewNextTitle.textContent = copy.quietDay;
            if (overviewNextLabel) overviewNextLabel.textContent = copy.quietDayLine;
          } else if (state.active) {
            const subject = state.active.card.dataset.subject || scheduleViewText.classLabel;
            const room = state.active.card.dataset.roomLabel ? ` · ауд. ${state.active.card.dataset.roomLabel}` : '';
            if (overviewNextTitle) overviewNextTitle.textContent = copy.currentClass;
            if (overviewNextLabel) overviewNextLabel.textContent = `${subject} · до ${state.active.time.endLabel}${room}`;
          } else if (state.next) {
            const subject = state.next.card.dataset.subject || scheduleViewText.classLabel;
            const room = state.next.card.dataset.roomLabel ? ` · ауд. ${state.next.card.dataset.roomLabel}` : '';
            if (overviewNextTitle) overviewNextTitle.textContent = copy.nextClass;
            if (overviewNextLabel) overviewNextLabel.textContent = `${subject} · ${state.next.time.startLabel}${room}`;
          } else if (state.first) {
            const subject = state.first.card.dataset.subject || scheduleViewText.classLabel;
            const room = state.first.card.dataset.roomLabel ? ` · ауд. ${state.first.card.dataset.roomLabel}` : '';
            if (overviewNextTitle) overviewNextTitle.textContent = copy.firstClass;
            if (overviewNextLabel) overviewNextLabel.textContent = `${subject} · ${state.first.time.startLabel}${room}`;
          }

          const firstDeadline = deadlines[0];
          if (!firstDeadline) {
            if (homeworkMeta) homeworkMeta.textContent = copy.noDeadlinesMeta;
            if (homeworkTitle) homeworkTitle.textContent = copy.noDeadlinesTitle;
            if (homeworkLine) homeworkLine.textContent = copy.noDeadlinesLine;
            return;
          }

          const deadlineStrong = firstDeadline.querySelector('.deadline-subtitle, .fw-semibold');
          const deadlineMeta = firstDeadline.querySelector('.deadline-meta');
          const deadlineSubject = firstDeadline.querySelector('.fw-semibold');
          if (homeworkMeta) {
            homeworkMeta.textContent = deadlineSubject ? deadlineSubject.textContent.trim() : copy.noDeadlinesMeta;
          }
          if (homeworkTitle) {
            homeworkTitle.textContent = deadlineStrong ? deadlineStrong.textContent.trim() : copy.noDeadlinesTitle;
          }
          if (homeworkLine) {
            homeworkLine.textContent = deadlineMeta ? deadlineMeta.textContent.trim() : copy.noDeadlinesLine;
          }
        };

        const resolveInitialDay = () => {
          const hashDay = String(window.location.hash || '').replace(/^#day-/, '');
          let storedDay = '';
          try {
            storedDay = localStorage.getItem(storageKey) || '';
          } catch (_error) {}
          const preferred = [hashDay, storedDay].find(Boolean);
          if (preferred && document.getElementById(`day-${preferred}`)) {
            return preferred;
          }
          const todayMatch = dayLinks.find((link) => {
            const card = document.getElementById(`day-${link.dataset.scheduleDayLink || ''}`);
            return card && String(card.dataset.dayDate || '') === todayIso;
          });
          if (todayMatch) return todayMatch.dataset.scheduleDayLink || '';
          const classMatch = dayLinks.find((link) => {
            const card = document.getElementById(`day-${link.dataset.scheduleDayLink || ''}`);
            return card && card.querySelector('.schedule-card');
          });
          return (classMatch && classMatch.dataset.scheduleDayLink) || (dayLinks[0] && dayLinks[0].dataset.scheduleDayLink) || '';
        };

        const setActiveDay = (day, persist) => {
          if (!day) return;
          const targetCard = document.getElementById(`day-${day}`);
          if (!(targetCard instanceof HTMLElement)) return;

          dayLinks.forEach((link) => {
            const linkDay = link.dataset.scheduleDayLink || '';
            const card = document.getElementById(`day-${linkDay}`);
            const isTodayLink = card && String(card.dataset.dayDate || '') === todayIso;
            const isActive = linkDay === day;
            link.classList.toggle('is-active', isActive);
            link.classList.toggle('is-today', Boolean(isTodayLink));
            if (isActive) {
              link.setAttribute('aria-current', isTodayLink ? 'date' : 'page');
            } else {
              link.removeAttribute('aria-current');
            }
            if (card instanceof HTMLElement) {
              card.hidden = !isActive;
              card.setAttribute('aria-hidden', isActive ? 'false' : 'true');
            }
          });

          updateOverview(targetCard);
          if (persist) {
            try {
              localStorage.setItem(storageKey, day);
            } catch (_error) {}
          }
        };

        if (weekGridRoot) {
          Array.from(weekGridRoot.children).forEach((card) => {
            if (card instanceof HTMLElement && card.classList.contains('day-card')) {
              card.hidden = true;
              card.setAttribute('aria-hidden', 'true');
            }
          });
        }

        dayLinks.forEach((link) => {
          link.onclick = (event) => {
            event.preventDefault();
            const day = link.dataset.scheduleDayLink || '';
            setActiveDay(day, true);
          };
        });

        applyFloatingChip();
        setActiveDay(resolveInitialDay(), false);
      }

      initLiquidScheduleStatus();
    </script>
      <script src="/js/design-system.js" defer></script>
    <script src="/js/studerria-background.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
