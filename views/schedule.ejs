      function renderTeamworkDeadline(item) {
        if (!item) return;
        if (teamworkDeadlineSubject) {
          teamworkDeadlineSubject.textContent = item.subject_name || '';
        }
        if (teamworkDeadlineDue) {
          const dueLabel = item.due_date ? new Date(item.due_date).toLocaleDateString(scheduleLocale) : '';
          teamworkDeadlineDue.textContent = dueLabel ? `${scheduleText.customDeadlinesDuePrefix}: ${dueLabel}` : '';
        }
        if (teamworkDeadlineTitle) {
          teamworkDeadlineTitle.textContent = item.title || '';
