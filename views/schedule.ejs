        }
        if (teamworkDeadlineTeams) {
          teamworkDeadlineTeams.replaceChildren();
          const teamGroups = Array.isArray(item.team_groups) ? item.team_groups : [];
          if (!teamGroups.length) {
            const empty = document.createElement('li');
            empty.className = 'list-group-item text-muted';
            empty.textContent = scheduleViewText.teamworkNoGroups;
            teamworkDeadlineTeams.appendChild(empty);
          } else {
            teamGroups.forEach((groupItem) => {
              const listItem = document.createElement('li');
              listItem.className = 'list-group-item';
              const groupName = String(groupItem && groupItem.name ? groupItem.name : '').trim() || scheduleViewText.teamworkBadge;
              const membersCount = Math.max(0, Number(groupItem && groupItem.members_count || 0));
              const maxMembersValue = Number(groupItem && groupItem.max_members || 0);
              const maxMembers = Number.isInteger(maxMembersValue) && maxMembersValue > 0
                ? maxMembersValue
                : null;
              const seminarGroup = Number(groupItem && groupItem.seminar_group_number || 0);
              const metaParts = [`${membersCount}${maxMembers ? `/${maxMembers}` : ''}`];
              if (seminarGroup > 0) {
                metaParts.push(`${scheduleText.groupSingle} ${seminarGroup}`);
              }
              const nameEl = document.createElement('div');
              nameEl.className = 'fw-semibold';
              nameEl.textContent = groupName;
              const metaEl = document.createElement('div');
              metaEl.className = 'small text-muted';
              metaEl.textContent = metaParts.join(' · ');
              listItem.appendChild(nameEl);
              listItem.appendChild(metaEl);
              teamworkDeadlineTeams.appendChild(listItem);
            });
          }
        }
      }

