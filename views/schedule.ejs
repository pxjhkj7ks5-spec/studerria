          const title = document.createElement('div');
          title.className = 'fw-semibold';
          title.textContent = item.name;
          container.appendChild(title);

          const members = document.createElement('div');
          members.className = 'small text-muted';
          if (item.members.includes(currentUser)) {
            members.textContent = `${scheduleText.subgroupMembersPrefix}: ${item.members.join(', ')} ${scheduleText.subgroupYouSuffix}`;
            container.classList.add('border', 'border-primary');
          } else {
            members.textContent = item.members.length ? item.members.join(', ') : scheduleText.subgroupNoMembers;
          }
