        .filter((row) => Number.isInteger(row.student_id) && row.student_id > 0);
      const markCurrentAttendanceStatus = (statusKey) => {
        if (!attendanceQuickStatusKeys.includes(String(statusKey || ''))) return;
        const row = currentAttendanceRows[currentAttendanceIndex];
        if (!row) return;
        row.status = String(statusKey);
        if (statusKey !== 'excused') {
          row.reason = '';
        }
        row.marked_at = '';
        setAttendanceFeedback('');
        if (currentAttendanceIndex < currentAttendanceRows.length - 1) {
          currentAttendanceIndex += 1;
        }
        renderAttendanceQuickCard();
      };
      const resetAttendancePanel = () => {
        currentAttendanceSlot = null;
        currentAttendanceContext = null;
        currentAttendanceRows = [];
        currentAttendanceIndex = 0;
        attendanceContextLoaded = false;
        if (attendanceMetaEl) attendanceMetaEl.textContent = scheduleText.attendanceMeta;
        if (attendanceToggleBtn) {
          attendanceToggleBtn.classList.toggle('d-none', !canManageAttendance);
          attendanceToggleBtn.disabled = !canManageAttendance;
          attendanceToggleBtn.textContent = String(attendanceToggleBtn.dataset.openLabel || scheduleText.attendanceSaveAction);
        }
        setAttendanceFeedback('');
        if (attendanceSummaryEl) attendanceSummaryEl.textContent = '';
        if (attendancePrevBtn) attendancePrevBtn.disabled = true;
        if (attendanceSaveBtn) {
          attendanceSaveBtn.disabled = true;
          attendanceSaveBtn.textContent = scheduleText.attendanceSaveAction;
        }
        attendanceChoiceButtons.forEach((button) => {
          button.classList.remove('is-active');
          button.disabled = true;
        });
        renderAttendanceQuickCard();
        if (attendanceSubjectIdInput) attendanceSubjectIdInput.value = '';
        if (attendanceCourseIdInput) attendanceCourseIdInput.value = '';
        if (attendanceDateInput) attendanceDateInput.value = '';
        if (attendanceClassNumberInput) attendanceClassNumberInput.value = '';
        if (attendanceGroupNumberInput) attendanceGroupNumberInput.value = '';
        if (attendanceLessonTypeInput) attendanceLessonTypeInput.value = '';
        if (attendanceIsGeneralInput) attendanceIsGeneralInput.value = '0';
        if (attendanceTargetGroupsInput) attendanceTargetGroupsInput.value = '';
      };
      const applyAttendanceContextToEditor = (payload = {}) => {
        currentAttendanceContext = payload;
        attendanceContextLoaded = true;
        currentAttendanceRows = cloneAttendanceRows(payload.rows || []);
        currentAttendanceIndex = getAttendanceInitialIndex(currentAttendanceRows);
        renderAttendanceQuickCard();
        setAttendanceFeedback('');
      };
      const loadAttendanceContext = async () => {
        if (!currentAttendanceSlot) return null;
        const params = new URLSearchParams({
          subject_id: String(currentAttendanceSlot.subjectId || ''),
          course_id: String(currentAttendanceSlot.courseId || ''),
          class_date: String(currentAttendanceSlot.classDate || ''),
          class_number: String(currentAttendanceSlot.classNumber || ''),
          group_number: String(currentAttendanceSlot.groupNumber || ''),
          lesson_type: String(currentAttendanceSlot.lessonType || ''),
          is_general: currentAttendanceSlot.isGeneral ? '1' : '0',
          target_groups: String(currentAttendanceSlot.targetGroups || ''),
        });
        if (attendanceToggleBtn) attendanceToggleBtn.disabled = true;
        if (attendancePrevBtn) attendancePrevBtn.disabled = true;
        if (attendanceSaveBtn) attendanceSaveBtn.disabled = true;
        attendanceChoiceButtons.forEach((button) => {
          button.disabled = true;
        });
        if (attendanceEmptyStateEl) attendanceEmptyStateEl.classList.add('d-none');
        if (attendanceQuickShellEl) attendanceQuickShellEl.classList.add('d-none');
        setAttendanceFeedback(scheduleText.attendanceLoading);
        try {
          const response = await fetch(`/schedule/attendance/context?${params.toString()}`, {
            credentials: 'same-origin',
          });
          const payload = await response.json().catch(() => ({ ok: false, message: scheduleText.attendanceLoadError }));
          if (!response.ok || !payload.ok) {
            throw new Error(payload && payload.message ? payload.message : scheduleText.attendanceLoadError);
          }
          if (attendanceSubjectIdInput) attendanceSubjectIdInput.value = String(payload.subject_id || '');
          if (attendanceCourseIdInput) attendanceCourseIdInput.value = String(payload.course_id || '');
          if (attendanceDateInput) attendanceDateInput.value = String(payload.class_date || '');
          if (attendanceClassNumberInput) attendanceClassNumberInput.value = String(payload.class_number || '');
          if (attendanceGroupNumberInput) attendanceGroupNumberInput.value = String(currentAttendanceSlot.groupNumber || '');
          if (attendanceLessonTypeInput) attendanceLessonTypeInput.value = String(currentAttendanceSlot.lessonType || '');
          if (attendanceIsGeneralInput) attendanceIsGeneralInput.value = currentAttendanceSlot.isGeneral ? '1' : '0';
          if (attendanceTargetGroupsInput) attendanceTargetGroupsInput.value = String(currentAttendanceSlot.targetGroups || '');
          applyAttendanceContextToEditor(payload);
          return payload;
        } finally {
          if (attendanceToggleBtn) attendanceToggleBtn.disabled = false;
        }
      };
      const saveAttendanceContext = async () => {
        if (!attendanceFormEl || !currentAttendanceSlot) return;
        if (!isAttendanceReadyToSave()) {
          setAttendanceFeedback(scheduleText.attendanceCompleteRequired, 'error');
          return;
        }
        const payload = new URLSearchParams();
        payload.set('subject_id', String(attendanceSubjectIdInput ? attendanceSubjectIdInput.value : currentAttendanceSlot.subjectId || ''));
        payload.set('course_id', String(attendanceCourseIdInput ? attendanceCourseIdInput.value : currentAttendanceSlot.courseId || ''));
        payload.set('attendance_date', String(attendanceDateInput ? attendanceDateInput.value : currentAttendanceSlot.classDate || ''));
        payload.set('attendance_class_number', String(attendanceClassNumberInput ? attendanceClassNumberInput.value : currentAttendanceSlot.classNumber || ''));
        payload.set('group_number', String(attendanceGroupNumberInput ? attendanceGroupNumberInput.value : currentAttendanceSlot.groupNumber || ''));
        payload.set('lesson_type', String(attendanceLessonTypeInput ? attendanceLessonTypeInput.value : currentAttendanceSlot.lessonType || ''));
        payload.set('is_general', String(attendanceIsGeneralInput ? attendanceIsGeneralInput.value : (currentAttendanceSlot.isGeneral ? '1' : '0')));
        payload.set('target_groups', String(attendanceTargetGroupsInput ? attendanceTargetGroupsInput.value : currentAttendanceSlot.targetGroups || ''));
        payload.set('rows_json', JSON.stringify(collectAttendanceRows()));
        if (attendanceSaveBtn) {
          attendanceSaveBtn.disabled = true;
          attendanceSaveBtn.textContent = scheduleText.attendanceSaving;
        }
        if (attendancePrevBtn) attendancePrevBtn.disabled = true;
        attendanceChoiceButtons.forEach((button) => {
          button.disabled = true;
        });
        setAttendanceFeedback(scheduleText.attendanceSaving);
        try {
          const response = await fetch('/schedule/attendance/save', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            },
            body: payload.toString(),
            credentials: 'same-origin',
          });
          const nextState = await response.json().catch(() => ({ ok: false, message: scheduleText.attendanceLoadError }));
          if (!response.ok || !nextState.ok) {
            throw new Error(nextState && nextState.message ? nextState.message : scheduleText.attendanceLoadError);
          }
          applyAttendanceContextToEditor(nextState);
          setAttendanceFeedback(scheduleText.attendanceSaved, 'success');
        } catch (error) {
          setAttendanceFeedback(String(error && error.message ? error.message : scheduleText.attendanceLoadError), 'error');
        } finally {
          renderAttendanceQuickCard();
        }
      };
      resetAttendancePanel();

      function deriveTemplateTitle(rawValue) {
        const normalized = String(rawValue || '').replace(/\s+/g, ' ').trim();
        if (!normalized) return '';
        return normalized.slice(0, 160);
      }

      function bindTemplateCaptureToggle(toggle, titleWrap, titleInput, descriptionInput) {
        if (!toggle) return;
        const sync = () => {
          const enabled = Boolean(toggle.checked);
          if (titleWrap) {
            titleWrap.classList.toggle('d-none', !enabled);
          }
          if (!enabled && titleInput) {
            titleInput.value = '';
          } else if (enabled && titleInput && !titleInput.value.trim() && descriptionInput) {
            titleInput.value = deriveTemplateTitle(descriptionInput.value);
          }
        };
        toggle.addEventListener('change', sync);
        if (descriptionInput && titleInput) {
          descriptionInput.addEventListener('input', () => {
            if (toggle.checked && !titleInput.value.trim()) {
              titleInput.value = deriveTemplateTitle(descriptionInput.value);
            }
          });
        }
        sync();
      }

      bindTemplateCaptureToggle(
        hwSaveAsTemplateToggle,
        hwTemplateTitleWrap,
        hwTemplateTitleInput,
        hwTextInput
      );
      bindTemplateCaptureToggle(
        customSaveAsTemplateToggle,
        customTemplateTitleWrap,
        customTemplateTitleInput,
        customHwDescription
      );
      const customDeadlineCreateModalEl = document.getElementById('customDeadlineModal');
      if (customDeadlineCreateModalEl) {
        customDeadlineCreateModalEl.addEventListener('hidden.bs.modal', () => {
          if (customSaveAsTemplateToggle) {
            customSaveAsTemplateToggle.checked = false;
          }
          if (customTemplateTitleInput) {
            customTemplateTitleInput.value = '';
          }
          if (customTemplateTitleWrap) {
            customTemplateTitleWrap.classList.add('d-none');
          }
        });
      }

      function updateReactionButtons(container, reactions, reacted) {
        const buttons = container.querySelectorAll('.react-btn');
        buttons.forEach((btn) => {
          const emoji = btn.dataset.emoji;
          const count = reactions && reactions[emoji] ? reactions[emoji] : 0;
          const countEl = btn.querySelector('.react-count');
          if (countEl) countEl.textContent = count;
          if (reacted && reacted[emoji]) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      }

      async function toggleHomeworkReaction(homeworkId, emoji, container) {
        if (!currentUserId) return;
        try {
          const res = await fetch('/homework/react', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ homework_id: homeworkId, emoji }),
          });
          if (!res.ok) return;
          const data = await res.json();
          updateReactionButtons(container, data.reactions, data.reacted);
        } catch (err) {
          console.error(err);
        }
      }

      function resolveSafeClientHref(rawValue, { uploadsOnly = false } = {}) {
        const value = String(rawValue || '').trim();
        if (!value) return '';
        try {
          const parsed = new URL(value, window.location.origin);
          const isSameOrigin = parsed.origin === window.location.origin;
          if (isSameOrigin) {
            if (uploadsOnly && !parsed.pathname.startsWith('/uploads/')) {
              return '';
            }
            return `${parsed.pathname}${parsed.search}${parsed.hash}`;
          }
          if (uploadsOnly) {
            return '';
          }
          if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
            return '';
          }
          return parsed.toString();
        } catch (_err) {
          return '';
        }
      }

      function buildSafeAnchor({ href = '', label = '', className = '', target = '' } = {}, { uploadsOnly = false } = {}) {
        const safeHref = resolveSafeClientHref(href, { uploadsOnly });
        const safeLabel = String(label || '').trim();
        if (!safeHref || !safeLabel) {
          return null;
        }
        const link = document.createElement('a');
        link.href = safeHref;
        link.textContent = safeLabel;
        if (className) {
          link.className = className;
        }
        if (target) {
          link.target = target;
          link.rel = 'noopener noreferrer';
        }
        return link;
      }

      function renderHomework(items) {
        listEl.innerHTML = '';
        if (!items.length) {
          const empty = document.createElement('li');
          empty.className = 'list-group-item text-muted';
          empty.textContent = scheduleText.homeworkEmpty;
          listEl.appendChild(empty);
          return;
        }

        items.forEach((item) => {
          const li = document.createElement('li');
          li.className = 'list-group-item';

          const tooltipParts = [];
          if (item.custom_due_date || item.class_date) {
            const dueDate = item.custom_due_date || item.class_date;
            const dueLabel = new Date(dueDate).toLocaleDateString(scheduleLocale);
            tooltipParts.push(`${scheduleText.homeworkDuePrefix}: ${dueLabel}`);
          }
          if (item.tags && item.tags.length) {
            tooltipParts.push(`${scheduleText.homeworkTagsPrefix}: ${item.tags.join(', ')}`);
          }
          if (item.link_url) tooltipParts.push(scheduleText.homeworkLinkAvailable);
          if (item.meeting_url) tooltipParts.push(scheduleText.homeworkMeetingAvailable);
          if (item.file_path) tooltipParts.push(scheduleText.homeworkFileAvailable);
          if (item.room_label) tooltipParts.push(`${scheduleUiText.roomLabel}: ${item.room_label}`);
          if (item.assets && item.assets.length) tooltipParts.push(`${scheduleUiText.assetsLabel}: ${item.assets.length}`);
          if (tooltipParts.length) {
            li.setAttribute('data-bs-toggle', 'tooltip');
            li.setAttribute('data-bs-placement', 'top');
            li.setAttribute('data-bs-title', tooltipParts.join(' • '));
          }

          const title = document.createElement('div');
          title.className = 'fw-semibold mb-1';
          title.textContent = item.description;
          li.appendChild(title);

          const meta = document.createElement('div');
          meta.className = 'text-muted small mb-2';
          const created = new Date(item.created_at).toLocaleString(scheduleLocale);
          meta.textContent = `${scheduleText.homeworkAddedByPrefix}: ${item.created_by || '—'} • ${created}`;
          if (isTeacherView) {
            const groups = Array.isArray(item.group_numbers)
              ? item.group_numbers.map((value) => Number(value)).filter((value) => Number.isInteger(value) && value > 0)
              : [];
            if (groups.length > 1) {
              meta.textContent += ` • ${scheduleText.groupPlural} ${groups.join(', ')}`;
            } else if (groups.length === 1) {
              meta.textContent += ` • ${scheduleText.groupSingle} ${groups[0]}`;
            } else if (item.group_number) {
              meta.textContent += ` • ${scheduleText.groupSingle} ${item.group_number}`;
            }
          }
          li.appendChild(meta);

          if (item.room_label) {
            const roomMeta = document.createElement('div');
            roomMeta.className = 'text-muted small mb-2';
            roomMeta.textContent = `${scheduleUiText.roomLabel}: ${item.room_label}`;
            li.appendChild(roomMeta);
          }

          const dueDate = item.custom_due_date || item.class_date;
          const hasSubmitted = canSubmitHomework && Boolean(item.submitted_at);
          const submittedAt = hasSubmitted ? new Date(item.submitted_at) : null;
          let isUrgent = false;
          if (dueDate) {
            const due = new Date(dueDate);
            const now = new Date();
            const diffDays = Math.ceil((due - now) / (1000 * 60 * 60 * 24));
            isUrgent = diffDays >= 0 && diffDays <= 2;
          }
          const priorityWrap = document.createElement('div');
          priorityWrap.className = 'd-flex flex-wrap gap-2 mb-2';
          const sessionType = String(item.session_type || '').toLowerCase();
          if (sessionType) {
            const sessionChip = document.createElement('span');
            sessionChip.className = 'priority-chip priority-control';
            if (sessionType === 'exam') {
              sessionChip.textContent = scheduleText.homeworkSessionExam;
            } else if (sessionType === 'credit') {
              sessionChip.textContent = scheduleText.homeworkSessionCredit;
            } else if (sessionType === 'consultation') {
              sessionChip.textContent = scheduleText.homeworkSessionConsultation;
            } else {
              sessionChip.textContent = scheduleText.homeworkSessionGeneric;
            }
            priorityWrap.appendChild(sessionChip);
          }
          if (item.is_control) {
            const control = document.createElement('span');
            control.className = 'priority-chip priority-control';
            control.textContent = scheduleText.homeworkControl;
            priorityWrap.appendChild(control);
          } else if (isUrgent) {
            const urgent = document.createElement('span');
            urgent.className = 'priority-chip priority-urgent';
            urgent.textContent = scheduleText.homeworkUrgent;
            priorityWrap.appendChild(urgent);
          } else {
            const normal = document.createElement('span');
            normal.className = 'priority-chip priority-normal';
            normal.textContent = scheduleText.homeworkNormal;
            priorityWrap.appendChild(normal);
          }
          if (item.is_credit) {
            const credit = document.createElement('span');
            credit.className = 'priority-chip priority-control';
            credit.textContent = scheduleText.homeworkCredit;
            priorityWrap.appendChild(credit);
          }
          if (item.is_teacher_homework) {
            const teacherHw = document.createElement('span');
            teacherHw.className = 'priority-chip priority-urgent';
            teacherHw.textContent = scheduleText.homeworkTeacherHomework;
            priorityWrap.appendChild(teacherHw);
          }
          if (dueDate) {
            const dueLabel = new Date(dueDate).toLocaleDateString(scheduleLocale);
            const due = document.createElement('span');
            due.className = 'priority-chip priority-normal';
            due.textContent = `${scheduleText.homeworkDuePrefix}: ${dueLabel}`;
            priorityWrap.appendChild(due);
          }
          if (hasSubmitted && submittedAt && !Number.isNaN(submittedAt.getTime())) {
            const submittedChip = document.createElement('span');
            submittedChip.className = 'priority-chip priority-submitted';
            submittedChip.textContent = scheduleText.homeworkSubmitted;
            priorityWrap.appendChild(submittedChip);
          }
          li.appendChild(priorityWrap);

          if (hasSubmitted && submittedAt && !Number.isNaN(submittedAt.getTime())) {
            const submittedMeta = document.createElement('div');
            submittedMeta.className = 'text-muted small mb-2';
            submittedMeta.textContent = `${scheduleText.homeworkSubmittedAtPrefix}: ${submittedAt.toLocaleString(scheduleLocale)}`;
            li.appendChild(submittedMeta);
          }

          if (item.link_url) {
            const link = buildSafeAnchor({
              href: item.link_url,
              label: scheduleText.homeworkLinkLabel,
              className: 'me-3',
              target: '_blank',
            });
            if (link) {
              li.appendChild(link);
            }
          }
          if (item.meeting_url) {
            const meet = buildSafeAnchor({
              href: item.meeting_url,
              label: scheduleText.homeworkMeetingLabel,
              className: 'me-3',
              target: '_blank',
            });
            if (meet) {
              li.appendChild(meet);
            }
          }

          if (item.file_path) {
            const fileLink = buildSafeAnchor({
              href: item.file_path,
              label: item.file_name || scheduleText.customDeadlinesFileFallback,
              className: 'd-inline-block',
            }, { uploadsOnly: true });
            if (fileLink) {
              li.appendChild(fileLink);
            }
          }
          if (item.assets && item.assets.length) {
            const assetWrap = document.createElement('div');
            assetWrap.className = 'mt-2 d-flex flex-column gap-1';
            const assetLabel = document.createElement('div');
            assetLabel.className = 'text-muted small';
            assetLabel.textContent = `${scheduleUiText.assetsLabel}:`;
            assetWrap.appendChild(assetLabel);
            item.assets.forEach((asset) => {
              const assetLink = buildSafeAnchor({
                href: asset.file_path,
                label: asset.name || asset.original_name || scheduleText.customDeadlinesFileFallback,
                className: 'small',
              }, { uploadsOnly: true });
              if (assetLink) {
                assetWrap.appendChild(assetLink);
              }
            });
            li.appendChild(assetWrap);
          }

          if (canSubmitHomework && homeworkSubmitModal && item.id) {
            const submitWrap = document.createElement('div');
            submitWrap.className = 'mt-2';
            const submitBtn = document.createElement('button');
            submitBtn.type = 'button';
            submitBtn.className = 'btn btn-sm btn-outline-primary';
            submitBtn.textContent = hasSubmitted ? scheduleText.homeworkUpdateSubmit : scheduleText.homeworkSubmit;
            submitBtn.addEventListener('click', () => {
              if (!homeworkSubmitForm) return;
              homeworkSubmitForm.action = `/homework/${encodeURIComponent(item.id)}/submit`;
              if (homeworkSubmitMeta) {
                const dueDate = item.custom_due_date || item.class_date;
                const dueLabel = dueDate ? new Date(dueDate).toLocaleDateString(scheduleLocale) : scheduleText.homeworkNoDeadline;
                const submittedHint = hasSubmitted ? ` • ${scheduleText.homeworkSubmittedHint}` : '';
                homeworkSubmitMeta.textContent = `${item.subject || ''} • ${scheduleText.homeworkMetaDueLabel}: ${dueLabel}${submittedHint}`;
              }
              if (homeworkSubmitId) homeworkSubmitId.value = String(item.id);
              if (homeworkSubmitText) homeworkSubmitText.value = '';
              if (homeworkSubmitLink) homeworkSubmitLink.value = '';
              if (homeworkSubmitFile) homeworkSubmitFile.value = '';
              if (homeworkSubmitFileName) homeworkSubmitFileName.textContent = scheduleText.fileNotSelected;
              homeworkSubmitModal.show();
            });
            submitWrap.appendChild(submitBtn);
            li.appendChild(submitWrap);
          }

          const reactWrap = document.createElement('div');
          reactWrap.className = 'd-flex gap-2 mt-2';
          ['🔥', '👍'].forEach((emoji) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn btn-sm btn-outline-secondary react-btn';
            btn.dataset.emoji = emoji;
            btn.dataset.homeworkId = item.id;
            const count = item.reactions && item.reactions[emoji] ? item.reactions[emoji] : 0;
            btn.innerHTML = `<span>${emoji}</span><span class="react-count">${count}</span>`;
            if (item.reacted && item.reacted[emoji]) {
              btn.classList.add('active');
            }
            btn.addEventListener('click', () => toggleHomeworkReaction(item.id, emoji, reactWrap));
            reactWrap.appendChild(btn);
          });
          li.appendChild(reactWrap);

          listEl.appendChild(li);

          if (tooltipParts.length) {
            new bootstrap.Tooltip(li);
          }
        });
      }

      function renderSubgroups(items) {
        subgroupList.innerHTML = '';
        joinSubgroupId.innerHTML = `<option value="" disabled selected>${scheduleText.subgroupSelect}</option>`;

        if (!items.length) {
          subgroupSection.classList.add('d-none');
          return;
        }

        subgroupSection.classList.remove('d-none');

        items.forEach((item) => {
          const container = document.createElement('div');
