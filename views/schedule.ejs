      const weekGrid = document.getElementById('scheduleWeekGrid');
      const scheduleModes = ['week'];
      const scheduleModeTabs = document.getElementById('scheduleModeTabs');
      const scheduleModeIndicator = document.getElementById('scheduleModeIndicator');
      const scheduleModeButtons = scheduleModeTabs ? Array.from(scheduleModeTabs.querySelectorAll('.glass-tab[data-mode]')) : [];
      const monthSummary = document.getElementById('scheduleMonthSummary');
      let currentScheduleMode = 'week';

      function getPreferredDayCard(dayCards) {
        const today = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Kyiv' });
        return dayCards.find((card) => card.dataset.dayDate === today) || dayCards.find((card) => card.querySelector('.schedule-card')) || dayCards[0] || null;
      }

      function buildMonthSummary() {
        if (!monthSummary || !weekGrid) return;
        const rows = Array.from(weekGrid.querySelectorAll('.day-card')).map((dayCard) => {
          const dayName = dayCard.querySelector('.day-name') ? dayCard.querySelector('.day-name').textContent.trim() : scheduleViewText.dayFallback;
          const dayDate = dayCard.querySelector('.day-date') ? dayCard.querySelector('.day-date').textContent.trim() : '';
          const classesCount = dayCard.querySelectorAll('.schedule-card').length;
          const hwCount = dayCard.querySelectorAll('.hw-chip, .badge--hw').length;
          return { dayName, dayDate, classesCount, hwCount };
        }).filter((row) => row.classesCount || row.hwCount);

        if (!rows.length) {
          monthSummary.innerHTML = `<div class="month-summary-empty">${scheduleViewText.monthSummaryEmpty}</div>`;
          return;
        }

        monthSummary.innerHTML = `
          <div class="month-summary-head">
            <h2 class="month-summary-title">${scheduleViewText.monthSummaryTitle}</h2>
            <p class="month-summary-sub">${scheduleViewText.monthSummarySub}</p>
          </div>
          <div class="month-summary-grid">
            ${rows.map((row) => `
              <article class="month-summary-item">
                <div class="month-summary-day">${row.dayName}</div>
                <div class="month-summary-date">${row.dayDate || '—'}</div>
                <div class="month-summary-metrics">
                  <span>${row.classesCount} ${scheduleViewText.monthSummaryClasses}</span>
                  <span>${row.hwCount} ${scheduleViewText.monthSummaryHomework}</span>
                </div>
              </article>
            `).join('')}
          </div>
        `;
      }

      function updateScheduleModeIndicator(mode, bounce) {
        if (!scheduleModeTabs || !scheduleModeIndicator) return;
        const activeButton = scheduleModeButtons.find((button) => button.dataset.mode === mode);
        if (!activeButton) return;
        scheduleModeIndicator.style.width = `${activeButton.offsetWidth}px`;
        scheduleModeIndicator.style.transform = `translateX(${activeButton.offsetLeft}px)`;
        if (bounce) {
          scheduleModeIndicator.classList.remove('is-bounce');
          requestAnimationFrame(() => scheduleModeIndicator.classList.add('is-bounce'));
          setTimeout(() => scheduleModeIndicator.classList.remove('is-bounce'), 340);
        }
      }

      function applyScheduleMode(mode, options = {}) {
        const { persist = true, bounce = false } = options;
        if (!scheduleModes.includes(mode) || !weekGrid) return;
        currentScheduleMode = mode;
        document.body.setAttribute('data-schedule-mode', mode);
        document.body.classList.toggle('schedule-mode-day', mode === 'day');
        document.body.classList.toggle('schedule-mode-week', mode === 'week');
        document.body.classList.toggle('schedule-mode-month', mode === 'month');

        scheduleModeButtons.forEach((button) => {
          const active = button.dataset.mode === mode;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        updateScheduleModeIndicator(mode, bounce);

        const dayCards = Array.from(weekGrid.querySelectorAll('.day-card'));
        dayCards.forEach((card) => card.classList.remove('d-none'));

        if (mode === 'month') {
          weekGrid.classList.add('d-none');
          if (monthSummary) {
            buildMonthSummary();
            monthSummary.classList.remove('d-none');
          }
        } else {
          weekGrid.classList.remove('d-none');
          if (monthSummary) {
            monthSummary.classList.add('d-none');
          }
          if (mode === 'day') {
            const activeCard = getPreferredDayCard(dayCards);
            dayCards.forEach((card) => card.classList.toggle('d-none', card !== activeCard));
          }
        }

        if (persist) {
          localStorage.setItem('schedule-view-mode', 'week');
        }
      }

      if (scheduleModeTabs && scheduleModeButtons.length) {
        scheduleModeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const mode = button.dataset.mode;
            applyScheduleMode(mode, { persist: true, bounce: true });
          });
        });

        let tabsTouchStartX = 0;
        let tabsTouchStartY = 0;
        scheduleModeTabs.addEventListener('touchstart', (event) => {
          const touch = event.touches[0];
          tabsTouchStartX = touch.clientX;
          tabsTouchStartY = touch.clientY;
        }, { passive: true });
        scheduleModeTabs.addEventListener('touchend', (event) => {
          const touch = event.changedTouches[0];
          const dx = touch.clientX - tabsTouchStartX;
          const dy = touch.clientY - tabsTouchStartY;
          if (Math.abs(dx) < 44 || Math.abs(dx) < Math.abs(dy)) return;
          const index = scheduleModes.indexOf(currentScheduleMode);
          const nextIndex = dx < 0 ? Math.min(scheduleModes.length - 1, index + 1) : Math.max(0, index - 1);
          if (nextIndex !== index) {
            applyScheduleMode(scheduleModes[nextIndex], { persist: true, bounce: true });
          }
        }, { passive: true });
      }

      window.addEventListener('resize', () => updateScheduleModeIndicator(currentScheduleMode, false));
      applyScheduleMode(currentScheduleMode, { persist: false, bounce: false });

      function updateUnreadBadges(count) {
        const targets = [messagesBadge, mobileMenuBadge].filter(Boolean);
        window.dispatchEvent(new CustomEvent('studerria:messages-unread', {
          detail: { count: Number(count) || 0 },
        }));
        if (!targets.length) return;
        if (count > 0) {
          const value = count > 99 ? '99+' : String(count);
          targets.forEach((badge) => {
            badge.textContent = value;
            badge.classList.remove('d-none');
          });
        } else {
          targets.forEach((badge) => badge.classList.add('d-none'));
        }
      }

      const scheduleContent = document.querySelector('.schedule-content');
      if (scheduleContent) {
        let touchStartX = 0;
        let touchStartY = 0;
        scheduleContent.addEventListener('touchstart', (event) => {
          if (document.body.classList.contains('modal-open')) return;
          const t = event.touches[0];
          touchStartX = t.clientX;
          touchStartY = t.clientY;
        }, { passive: true });
        scheduleContent.addEventListener('touchend', (event) => {
          if (document.body.classList.contains('modal-open')) return;
          const t = event.changedTouches[0];
          const dx = t.clientX - touchStartX;
          const dy = t.clientY - touchStartY;
          if (Math.abs(dx) < 50 || Math.abs(dx) < Math.abs(dy)) return;
