                              <span class="hw-chip chip badge--hw">Meet</span>
                            <% } %>
                          <% } %>
                          <% if (hwMeta) { %>
                            <span class="hw-chip chip badge--hw"><%= scheduleViewText.homeworkShort %> <%= hwMeta.count %></span>
