      function filterHomeworkTemplates(subjectId, courseId) {
        const normalizedSubjectId = Number(subjectId);
        const normalizedCourseId = Number(courseId);
        return (teacherHomeworkTemplates || []).filter((template) => {
          const templateSubjectId = Number(template.subject_id);
          const templateCourseId = Number(template.course_id);
          const subjectMatch = Number.isNaN(templateSubjectId) || templateSubjectId < 1 || templateSubjectId === normalizedSubjectId;
          const courseMatch = Number.isNaN(templateCourseId) || templateCourseId < 1 || templateCourseId === normalizedCourseId;
          return subjectMatch && courseMatch;
        });
      }

      function renderHomeworkTemplateOptions(subjectId, courseId) {
        if (!hwTemplateSelect) return;
        templateCache.clear();
        hwTemplateSelect.innerHTML = '';
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = scheduleText.templateSelect;
        hwTemplateSelect.appendChild(placeholder);
        const filtered = filterHomeworkTemplates(subjectId, courseId);
        filtered.forEach((template) => {
          const templateId = Number(template.id);
          if (!Number.isInteger(templateId) || templateId < 1) return;
          templateCache.set(templateId, template);
          const option = document.createElement('option');
          option.value = String(templateId);
          const parts = [String(template.title || '').trim()].filter(Boolean);
          if (template.subject_name) parts.push(String(template.subject_name));
          if (template.course_name) parts.push(String(template.course_name));
          option.textContent = parts.join(' · ');
          hwTemplateSelect.appendChild(option);
        });
        hwTemplateSelect.disabled = filtered.length === 0;
        if (hwTemplateApplyBtn) {
          hwTemplateApplyBtn.disabled = filtered.length === 0;
        }
      }

      function applySelectedHomeworkTemplate() {
        if (!hwTemplateSelect) return;
        const templateId = Number(hwTemplateSelect.value);
        if (!Number.isInteger(templateId) || templateId < 1) return;
        const template = templateCache.get(templateId);
        if (!template) return;
        if (hwTextInput) {
          hwTextInput.value = String(template.description || '');
        }
        if (hwLinkInput) {
          hwLinkInput.value = String(template.link_url || '');
        }
        if (hwMeetingInput) {
          hwMeetingInput.value = String(template.meeting_url || '');
        }
        if (hwTagsInput) {
          hwTagsInput.value = String(template.tags || '');
        }
        if (hwControlToggle) {
          hwControlToggle.checked = Number(template.is_control || 0) === 1;
        }
        if (hwTemplateSourceField) {
          hwTemplateSourceField.value = String(templateId);
