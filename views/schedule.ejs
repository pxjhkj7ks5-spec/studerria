        if (teamworkDeadlineAudience) {
          const lessonLabel = item.lesson_scope === 'seminar'
            ? scheduleViewText.lessonTypeSeminar
            : scheduleViewText.lessonTypeLecture;
          const groups = Array.isArray(item.group_numbers)
            ? item.group_numbers.map((value) => Number(value)).filter((value) => Number.isInteger(value) && value > 0)
            : [];
          let groupLabel = '';
          if (groups.length > 1) {
            groupLabel = `${scheduleText.groupPlural} ${groups.join(', ')}`;
