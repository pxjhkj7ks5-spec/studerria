                    </div>
                    <div class="schedule-debug-meta">
                      visible subjects: <%= Array.isArray(debugCatalog.all_visible_subjects) ? debugCatalog.all_visible_subjects.length : 0 %> ·
                      selected subjects: <%= Array.isArray(debugCatalog.selected_subjects) ? debugCatalog.selected_subjects.length : 0 %><br />
                      unmapped subjects: <%= Array.isArray(debugCatalog.unmapped_subjects) ? debugCatalog.unmapped_subjects.length : 0 %>
                    </div>
