          <section class="td-day-switcher schedule-day-switcher" aria-label="Дні тижня">
          <% daysOfWeek.forEach(function(day) { %>
            <% const dayEntries = scheduleByDay[day] || []; %>
            <% const dayDateValue = dayDates && dayDates[day] ? dayDates[day] : ''; %>
            <% const dayNumber = dayDateValue ? new Date(dayDateValue).toLocaleDateString(localeCode, { day: '2-digit', timeZone: 'Europe/Kyiv' }) : ''; %>
            <% const dayShort = dayDateValue ? new Date(dayDateValue).toLocaleDateString(localeCode, { weekday: 'short', timeZone: 'Europe/Kyiv' }).replace('.', '').toUpperCase() : String(day || '').slice(0, 3).toUpperCase(); %>
            <% const dayCountLabel = dayEntries.length
              ? `${dayEntries.length} ${(lang === 'en' ? (dayEntries.length === 1 ? 'class' : 'classes') : (dayEntries.length === 1 ? 'пара' : 'пари'))}`
              : (lang === 'en' ? 'free' : 'вільно'); %>
            <a
              class="td-day-pill schedule-day-pill <%= dayEntries.length ? 'has-classes' : 'is-quiet' %>"
              href="#day-<%= day %>"
              data-schedule-day-link="<%= day %>"
            >
              <span><%= dayShort %></span>
              <strong><%= dayNumber || day %></strong>
              <small><%= dayCountLabel %></small>
            </a>
          <% }); %>
          </section>
        </section>

        <section class="td-schedule-layout schedule-selected-layout">
        <div id="scheduleWeekGrid" class="schedule-day-panels">
        <% daysOfWeek.forEach(function(day) { %>
          <% const dateLabel = dayDates && dayDates[day] ? new Date(dayDates[day]).toLocaleDateString(localeCode, { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'Europe/Kyiv' }) : ''; %>
          <% const dayEntries = scheduleByDay[day] || []; %>
          <% let maxStreak = 0; let currentStreak = 0; let hasOverlap = false; const seenSlots = {}; %>
          <% for (let i = 0; i < dayEntries.length; i++) { %>
            <% const slotKey = String(dayEntries[i].class_number || ''); %>
            <% seenSlots[slotKey] = (seenSlots[slotKey] || 0) + 1; %>
            <% if (seenSlots[slotKey] > 1) { hasOverlap = true; } %>
            <% if (i === 0 || dayEntries[i].class_number === dayEntries[i - 1].class_number + 1) { %>
              <% currentStreak += 1; %>
            <% } else { %>
              <% currentStreak = 1; %>
            <% } %>
            <% if (currentStreak > maxStreak) { maxStreak = currentStreak; } %>
          <% } %>
          <% const isDenseDay = maxStreak >= 3; %>
          <div id="day-<%= day %>" class="card mb-3 glass day-card liquid-card" data-day-date="<%= dayDates && dayDates[day] ? dayDates[day] : '' %>">
            <div class="day-header">
              <div class="day-title">
                <span class="day-name dayTitle"><%= day %></span>
                <% if (dateLabel) { %>
                  <span class="day-date dayDate"><%= dateLabel %></span>
                <% } %>
              </div>
              <div class="day-indicators">
                <% if (isDenseDay) { %>
                  <span class="day-chip day-chip--primary chip"><%= scheduleViewText.denseDay %></span>
                <% } %>
                <% if (hasOverlap) { %>
                  <button
                    class="day-secondary-signal"
                    type="button"
                    data-bs-toggle="tooltip"
                    data-bs-placement="top"
                      data-bs-title="<%= scheduleViewText.overlapDetected %>"
                      aria-label="<%= scheduleViewText.overlapDetected %>"
                  >
                    i
                  </button>
                <% } %>
              </div>
            </div>
            <div class="list-group list-group-flush">
              <% if (!dayEntries || dayEntries.length === 0) { %>
                <div class="list-group-item empty-state"><%= scheduleViewText.noClasses %></div>
              <% } else { %>
                <% dayEntries.forEach(function(cls, idx) { %>
                  <% const slot = bellSchedule[cls.class_number]; %>
                  <% const timeLabel = slot ? `${slot.start} - ${slot.end}` : ''; %>
                  <% const subjectName = cls.subject_name || ''; %>
                  <% const subjectNameLower = subjectName.toLowerCase(); %>
                  <% const inlineType = /(лекц|семін|лаб|практ|lecture|seminar|lab|practice)/.test(subjectNameLower); %>
                  <% const typeLabel = cls.lesson_type === 'lecture' ? scheduleViewText.lessonTypeLecture : cls.lesson_type === 'seminar' ? scheduleViewText.lessonTypeSeminar : cls.lesson_type === 'lab' ? scheduleViewText.lessonTypeLab : cls.lesson_type === 'practice' ? scheduleViewText.lessonTypePractice : ''; %>
                  <% const showTypeBadge = cls.lesson_type && !inlineType && typeLabel; %>
                  <% const compatHomeworkEnabled = cls.compat_homework_enabled !== false
                    && Number(cls.legacy_subject_id || cls.subject_id || 0) > 0
                    && Number(cls.course_id || cls.owner_course_id || 0) > 0; %>
                  <% const legacyKey = compatHomeworkEnabled ? `${cls.subject_id}|${cls.group_number}|${cls.day_of_week}|${cls.class_number}` : null; %>
                  <% const datedKey = compatHomeworkEnabled && cls.class_date ? `${legacyKey}|${cls.class_date}` : null; %>
                  <% const baseKey = compatHomeworkEnabled
                    ? (cls.class_date ? `${cls.subject_id}|${cls.day_of_week}|${cls.class_number}|${cls.class_date}` : `${cls.subject_id}|${cls.day_of_week}|${cls.class_number}`)
                    : null; %>
                  <% const generalFallbackKey = compatHomeworkEnabled ? `${cls.subject_id}|${cls.day_of_week}|${cls.class_number}` : null; %>
                  <% const hwMetaGeneral = compatHomeworkEnabled && cls.is_general && homeworkMetaAll ? (homeworkMetaAll[baseKey] || homeworkMetaAll[generalFallbackKey]) : null; %>
                  <% const hwMetaGroup = compatHomeworkEnabled && homeworkMeta ? ((datedKey ? homeworkMeta[datedKey] : null) || homeworkMeta[legacyKey]) : null; %>
                  <% const hwMetaAnyGroup = (compatHomeworkEnabled && !cls.is_general && ((role === 'admin' || viewAs === 'student') || cls.lesson_type === 'lecture') && homeworkMetaAll)
                    ? (homeworkMetaAll[baseKey] || homeworkMetaAll[generalFallbackKey])
                    : null; %>
                  <% const hwMeta = compatHomeworkEnabled ? (hwMetaGeneral || hwMetaGroup || hwMetaAnyGroup) : null; %>
                  <% const sessionKindRaw = cls && cls.session_overlay_kind
                    ? String(cls.session_overlay_kind)
                    : (hwMeta && hwMeta.session_kind ? String(hwMeta.session_kind) : '');
                  %>
                  <% const sessionKind = ['exam', 'credit', 'consultation', 'mixed', 'session'].includes(sessionKindRaw) ? sessionKindRaw : ''; %>
                  <% const sessionChipText = sessionKind === 'exam'
                    ? scheduleViewText.sessionExam
                    : sessionKind === 'credit'
                      ? scheduleViewText.sessionCredit
                      : sessionKind === 'consultation'
                        ? scheduleViewText.sessionConsultation
                        : sessionKind
                          ? scheduleViewText.sessionGeneric
                          : ''; %>
                  <% const sessionCardClass = sessionKind ? `has-session session-${sessionKind}` : ''; %>
                  <% const groupLabel = cls.group_label ? cls.group_label : `${t('schedule.group.single')} ${cls.group_number}`; %>
                    <% const attendanceStorageSubjectId = Number(cls.legacy_subject_id || cls.subject_id || 0); %>
                    <% const attendanceCourseId = Number(cls.course_id || cls.owner_course_id || 0); %>
                    <% const attendanceSlotKey = (attendanceStorageSubjectId > 0 && attendanceCourseId > 0 && cls.class_date && Number(cls.class_number || 0) > 0)
                      ? `${attendanceStorageSubjectId}|${attendanceCourseId}|${cls.class_date}|${Number(cls.class_number || 0)}`
                      : ''; %>
                    <% const attendanceMarker = attendanceSlotKey ? scheduleAttendanceCardMap[attendanceSlotKey] : null; %>
                    <% const attendanceMarkerStatus = attendanceMarker && attendanceMarker.status ? String(attendanceMarker.status) : ''; %>
                    <% const prev = idx > 0 ? dayEntries[idx - 1] : null; %>
                    <% const next = idx < dayEntries.length - 1 ? dayEntries[idx + 1] : null; %>
                    <% const chainPrev = prev && prev.subject_id === cls.subject_id && cls.class_number === prev.class_number + 1; %>
                    <% const chainNext = next && next.subject_id === cls.subject_id && next.class_number === cls.class_number + 1; %>
                    <% const tooltipParts = [subjectName, groupLabel, `${scheduleViewText.classLabel} ${cls.class_number}`, timeLabel]; %>
                    <% if (sessionChipText) { tooltipParts.push(sessionChipText); } %>
                    <% if (showTypeBadge) { tooltipParts.push(typeLabel); } %>
                    <div
