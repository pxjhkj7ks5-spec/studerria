      const totalWeeks = <%= totalWeeks || 15 %>;
      const semesterStartDate = <%- JSON.stringify(semester && semester.start_date ? semester.start_date : null).replace(/</g, '\\u003c') %>;
      const kyivWeekFormatter = new Intl.DateTimeFormat(scheduleLocale, {
        day: 'numeric',
        month: 'short',
        timeZone: 'Europe/Kyiv',
      });
      let currentWeek = <%= currentWeek %>;
      const weekLabelText = <%- JSON.stringify(t('schedule.week')).replace(/</g, '\\u003c') %>;
      function setDrawerOpen(open) {
        if (!scheduleDrawer) return;
        document.body.classList.toggle('schedule-drawer-open', open);
        scheduleDrawer.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (scheduleDrawerToggle) {
