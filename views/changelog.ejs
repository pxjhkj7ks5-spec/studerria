<!doctype html>
<html lang="<%= lang %>" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Studerria · <%= t('changelog.title') %></title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/modal-enhanced.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--login td-page--legal" data-theme="light">
    <main class="td-legal-main">
      <section class="td-login-brand" aria-label="Studerria">
        <span class="td-login-logo" aria-hidden="true">
          <%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %>
        </span>
      </section>

      <section class="td-legal-card td-glass-panel" aria-label="Changelog">
        <header class="td-login-card-head">
          <p class="td-lite-kicker"><%= t('changelog.releaseNotes') %></p>
          <h1><%= t('changelog.title') %></h1>
          <p><%= t('changelog.subtitle') %></p>
        </header>

        <div class="td-lite-release-list td-lite-release-list--full">
          <% if (changelog && changelog.length) { %>
            <% changelog.forEach(function(entry) { %>
              <article class="td-lite-release">
                <div class="td-lite-release-head">
                  <strong>v<%= entry.version %></strong>
                  <% if (entry.date) { %>
                    <span><%= entry.date %></span>
                  <% } %>
                </div>
                <ul>
                  <% (entry.items || []).forEach(function(item) { %>
                    <li><%= item %></li>
                  <% }); %>
                </ul>
              </article>
            <% }); %>
          <% } else { %>
            <p class="td-lite-empty"><%= t('changelog.noUpdates') %></p>
          <% } %>
        </div>
      </section>
    </main>

    <%- include('partials/app-footer') %>
    <script src="/js/studerria-background.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
    <script src="/js/login-auth.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
