<!doctype html>
<html lang="uk" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Studerria · Changelog</title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--login td-page--legal" data-theme="light">
    <main class="td-legal-main">
      <section class="td-login-brand" aria-label="Studerria">
        <span class="td-login-logo" aria-hidden="true">
          <%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %>
        </span>
      </section>

      <section class="td-legal-card td-glass-panel" aria-label="Changelog">
        <header class="td-login-card-head">
          <p class="td-lite-kicker">Studerria updates</p>
          <h1>Changelog</h1>
          <p>Всі публічні зміни Studerria в одному місці.</p>
        </header>

        <div class="td-lite-release-list td-lite-release-list--full">
          <% if (changelog && changelog.length) { %>
            <% changelog.forEach(function(entry) { %>
              <article class="td-lite-release">
                <div class="td-lite-release-head">
                  <strong>v<%= entry.version %></strong>
                  <% if (entry.date) { %>
                    <span><%= entry.date %></span>
                  <% } %>
                </div>
                <ul>
                  <% (entry.items || []).forEach(function(item) { %>
                    <li><%= item %></li>
                  <% }); %>
                </ul>
              </article>
            <% }); %>
          <% } else { %>
            <p class="td-lite-empty">Оновлень поки немає.</p>
          <% } %>
        </div>
      </section>
    </main>

    <footer class="td-login-footer">
      <button
        type="button"
        class="td-language-pill"
        data-lang-toggle
        data-current-lang="<%= lang === 'en' ? 'en' : 'uk' %>"
        aria-label="<%= lang === 'en' ? 'Switch language to Ukrainian' : 'Перемкнути мову на English' %>"
      ><%= lang === 'en' ? 'EN' : 'UA' %> <%- include('partials/test-icon', { name: 'chevronDown', className: 'td-mini-chevron' }) %></button>
      <button type="button" class="td-language-pill td-theme-toggle" data-theme-toggle aria-label="Увімкнути темну тему" aria-pressed="false">
        <%- include('partials/test-icon', { name: 'moon', className: 'td-mini-chevron td-theme-moon' }) %>
        <%- include('partials/test-icon', { name: 'sun', className: 'td-mini-chevron td-theme-sun' }) %>
        <span data-theme-label>Dark</span>
      </button>
      <a href="/login">Вхід</a>
      <a href="/terms">Умови використання</a>
      <a href="/privacy">Політика конфіденційності</a>
      <span>© Studerria 2026</span>
    </footer>
    <script src="/js/studerria-background.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
    <script src="/js/login-auth.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
