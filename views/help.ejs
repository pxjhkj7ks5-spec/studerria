<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studerria · <%= t('help.pageTitle') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/navbar-enhanced.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/pages/help.css" />
    <link rel="stylesheet" href="/css/modal-enhanced.css" />
  </head>
  <body class="studerria-theme theme-dark page-help page-local-topbar">
    <%- include('partials/topbar', { role, username, t, activePage: 'help', pageTitle: t('help.pageTitle') }) %>

    <%
      const localeCode = lang === 'uk' ? 'uk-UA' : 'en-US';
      const formatStamp = (value) => {
        if (!value) return '—';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return value;
        return date.toLocaleString(localeCode, {
          dateStyle: 'medium',
          timeStyle: 'short',
        });
      };
      const historyList = Array.isArray(supportRequests) ? supportRequests : [];
      const requestChipClass = (status) => (
        status === 'resolved'
          ? 'status-chip status-chip--active'
          : (status === 'in_progress'
            ? 'status-chip status-chip--info'
            : 'status-chip status-chip--pending')
      );
      const supportSummary = supportStats || {};
      const threadRoleLabel = (roleName) => (
        roleName === 'admin'
          ? (lang === 'uk' ? 'Підтримка' : 'Support')
          : (lang === 'uk' ? 'Ви' : 'You')
      );
    %>

    <section class="studerria-help-shell" aria-labelledby="studerria-help-title">
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger glass-panel mb-0" role="alert"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success glass-panel mb-0" role="status"><%= messages.success %></div>
      <% } %>

      <article class="glass-panel studerria-help-hero">
        <div class="studerria-help-badges" aria-hidden="true">
          <span class="status-chip status-chip--info"><%= helpPage.hero.kicker %></span>
          <span class="status-chip status-chip--neutral"><%= t('help.pageTitle') %></span>
        </div>
        <div class="studerria-help-hero-grid">
          <div class="studerria-help-copy">
            <p class="studerria-help-overline">Studerria</p>
            <h1 class="studerria-help-title" id="studerria-help-title"><%= helpPage.hero.title %></h1>
            <p class="studerria-help-subtitle"><%= helpPage.hero.subtitle %></p>
            <p class="studerria-help-lead"><%= helpPage.hero.lead %></p>
            <p class="studerria-help-note"><%= helpPage.hero.note %></p>
          </div>
        </div>
      </article>

      <section class="studerria-help-grid">
        <article class="glass-panel studerria-help-faq" id="faq-grid" aria-labelledby="studerria-help-faq-title">
          <div class="studerria-help-section-head">
            <div>
              <p class="studerria-help-section-kicker"><%= t('help.pageTitle') %></p>
              <h2 class="studerria-help-section-title" id="studerria-help-faq-title"><%= helpPage.faqTitle %></h2>
            </div>
            <p class="studerria-help-section-copy"><%= helpPage.faqSubtitle %></p>
          </div>
          <div class="studerria-help-faq-groups">
            <% (helpPage.faqGroups || []).forEach(function(group, groupIndex) { %>
              <section class="studerria-help-faq-group" aria-label="<%= group.title %>">
                <div class="studerria-help-faq-head">
                  <span class="status-chip status-chip--neutral"><%= group.kicker %></span>
                  <h3 class="studerria-help-faq-group-title"><%= group.title %></h3>
                </div>
                <div class="studerria-help-faq-list">
                  <% (group.items || []).forEach(function(item, itemIndex) { %>
                    <details class="studerria-help-faq-item" <%= groupIndex === 0 && itemIndex === 0 ? 'open' : '' %>>
                      <summary><span><%= item.question %></span></summary>
                      <p><%= item.answer %></p>
                    </details>
                  <% }); %>
                </div>
              </section>
            <% }); %>
          </div>
        </article>

        <div class="studerria-help-side">
          <article class="glass-panel studerria-help-form-card" id="support-form">
            <div class="studerria-help-section-head">
              <div>
                <p class="studerria-help-section-kicker"><%= t('help.pageTitle') %></p>
                <h2 class="studerria-help-section-title"><%= t('help.formTitle') %></h2>
              </div>
              <p class="studerria-help-section-copy"><%= t('help.formSubtitle') %></p>
            </div>

            <form method="POST" action="/help/support" class="studerria-help-form">
              <div>
                <label class="form-label" for="helpTopic"><%= t('help.formTopic') %></label>
                <select class="form-select" id="helpTopic" name="topic" required>
                  <% (supportCategoryOptions || []).forEach(function(option) { %>
                    <option value="<%= option %>"><%= t(`help.topic.${option}`) %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label class="form-label" for="helpSubject"><%= t('help.formSubject') %></label>
                <input
                  class="form-control"
                  id="helpSubject"
                  name="subject"
                  maxlength="120"
                  minlength="4"
                  placeholder="<%= t('help.formSubjectPlaceholder') %>"
                  required
                />
              </div>
              <div>
                <label class="form-label" for="helpBody"><%= t('help.formMessage') %></label>
                <textarea
                  class="form-control"
                  id="helpBody"
                  name="body"
                  rows="6"
                  maxlength="2000"
                  minlength="12"
                  placeholder="<%= t('help.formMessagePlaceholder') %>"
                  required
                ></textarea>
              </div>
              <p class="studerria-help-form-note"><%= t('help.formPrivacy') %></p>
              <button class="btn btn-primary" type="submit"><%= t('help.formSubmit') %></button>
            </form>
          </article>

          <article class="glass-panel studerria-help-steps">
            <div class="studerria-help-section-head">
              <div>
                <p class="studerria-help-section-kicker"><%= t('help.pageTitle') %></p>
                <h2 class="studerria-help-section-title"><%= helpPage.stepsTitle %></h2>
              </div>
              <p class="studerria-help-section-copy"><%= helpPage.stepsSubtitle %></p>
            </div>
            <div class="studerria-help-step-list">
              <% (helpPage.steps || []).forEach(function(step) { %>
                <article class="studerria-help-step">
                  <h3><%= step.title %></h3>
                  <p><%= step.body %></p>
                </article>
              <% }); %>
            </div>
          </article>
        </div>
      </section>

      <article class="glass-panel studerria-help-history" aria-labelledby="studerria-help-history-title">
        <div class="studerria-help-section-head">
          <div>
            <p class="studerria-help-section-kicker"><%= t('help.pageTitle') %></p>
            <h2 class="studerria-help-section-title" id="studerria-help-history-title"><%= t('help.historyTitle') %></h2>
          </div>
          <p class="studerria-help-section-copy"><%= t('help.historySubtitle') %></p>
        </div>

        <div class="studerria-help-history-summary">
          <span class="status-chip status-chip--info"><%= lang === 'uk' ? 'Активні' : 'Open' %>: <%= Number(supportSummary.open || 0) %></span>
          <span class="status-chip status-chip--active"><%= lang === 'uk' ? 'Закриті' : 'Resolved' %>: <%= Number(supportSummary.resolved || 0) %></span>
          <span class="status-chip status-chip--neutral"><%= lang === 'uk' ? 'Всього' : 'Total' %>: <%= Number(supportSummary.total || historyList.length || 0) %></span>
          <% if (supportSummary.response) { %>
            <span class="status-chip status-chip--muted"><%= lang === 'uk' ? 'SLA' : 'SLA' %>: <%= supportSummary.response %></span>
          <% } %>
        </div>

        <% if (historyList.length) { %>
          <div class="studerria-help-history-list">
            <% historyList.forEach(function(request) { %>
              <article class="studerria-help-history-card">
                <div class="studerria-help-history-top">
                  <div>
                    <div class="studerria-help-history-meta">
                      <span class="<%= requestChipClass(request.status) %>"><%= t(`help.status.${request.status === 'in_progress' ? 'inProgress' : request.status}`) %></span>
                      <span class="status-chip status-chip--muted"><%= t(`help.topic.${request.category}`) %></span>
                    </div>
                    <h3 class="studerria-help-history-title"><%= request.subject %></h3>
                  </div>
                  <div class="studerria-help-history-dates">
                    <span><%= t('help.historyCreated') %>: <%= formatStamp(request.created_at) %></span>
                    <span><%= t('help.historyUpdated') %>: <%= formatStamp(request.updated_at || request.created_at) %></span>
                  </div>
                </div>
                <div class="studerria-help-thread">
                  <% (request.messages || []).forEach(function(message) { %>
                    <div class="studerria-help-thread-message <%= message.author_role === 'admin' ? 'is-admin' : 'is-user' %>">
                      <div class="studerria-help-thread-head">
                        <strong><%= threadRoleLabel(message.author_role) %></strong>
                        <span><%= formatStamp(message.created_at) %></span>
                      </div>
                      <p class="studerria-help-history-body"><%= message.body %></p>
                    </div>
                  <% }) %>
                </div>
                <% if (request.last_message_preview) { %>
                  <div class="studerria-help-history-note">
                    <span><%= lang === 'uk' ? 'Останнє оновлення' : 'Latest update' %></span>
                    <p><%= request.last_message_preview %></p>
                  </div>
                <% } %>
                <% if (request.needs_reply) { %>
                  <div class="studerria-help-thread-toolbar">
                    <p class="studerria-help-thread-toolbar-copy"><%= t('help.closePrompt') %></p>
                    <form
                      method="POST"
                      action="/help/support/<%= request.id %>/close"
                      class="studerria-help-close-form"
                      data-confirm="<%= t('help.closeConfirm') %>"
                      onsubmit="return confirm(this.dataset.confirm || '')"
                    >
                      <button class="btn btn-outline-secondary glass btn-sm studerria-help-close-button" type="submit">
                        <%= t('help.closeAction') %>
                      </button>
                    </form>
                  </div>
                  <form method="POST" action="/help/support/<%= request.id %>/reply" class="studerria-help-reply-form">
                    <label class="form-label" for="supportReply<%= request.id %>"><%= lang === 'uk' ? 'Уточнити контекст' : 'Add reply' %></label>
                    <textarea
                      class="form-control"
                      id="supportReply<%= request.id %>"
                      name="body"
                      rows="3"
                      maxlength="2000"
                      minlength="2"
                      placeholder="<%= lang === 'uk' ? 'Наприклад: проблема відтворюється і після зміни групи...' : 'For example: the issue still reproduces after the group change...' %>"
                      required
                    ></textarea>
                    <div class="studerria-help-reply-actions">
                      <button class="btn btn-primary btn-sm" type="submit"><%= lang === 'uk' ? 'Відправити відповідь' : 'Send reply' %></button>
                    </div>
                  </form>
                <% } %>
              </article>
            <% }); %>
          </div>
        <% } else { %>
          <p class="studerria-help-empty"><%= t('help.historyEmpty') %></p>
        <% } %>
      </article>

      <%- include('partials/app-footer') %>
    </section>

    <%- include('partials/changelog-modal') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/js/navbar.js" defer></script>
    <script src="/js/design-system.js" defer></script>
  </body>
</html>
