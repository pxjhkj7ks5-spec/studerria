<!doctype html>
<html lang="uk" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title><%= t('login.title') %></title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--login" data-theme="light">
    <main class="td-login-main">
      <section class="td-login-brand" aria-label="Studerria">
        <span class="td-login-logo" aria-hidden="true">
          <%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %>
        </span>
      </section>

      <section class="td-login-card td-glass-panel" aria-label="<%= t('login.title') %>">
        <header class="td-login-card-head">
          <h1>Вхід</h1>
          <p>Раді бачити тебе знову! 👋</p>
        </header>

        <% if (error) { %>
          <div class="td-login-alert" role="alert">
            <%= loginErrorText || t('login.error') %>
          </div>
        <% } %>

        <form id="loginForm" class="td-form" method="POST" action="/login">
          <label class="td-field" for="full_name">
            <span>Email або логін</span>
            <span class="td-input-wrap">
              <%- include('partials/test-icon', { name: 'mail', className: 'td-input-icon' }) %>
              <input
                id="full_name"
                name="full_name"
                type="text"
                placeholder="Введіть email або логін"
                autocomplete="username"
                required
              />
            </span>
          </label>

          <label class="td-field" for="password">
            <span><%= t('login.password') %></span>
            <span class="td-input-wrap td-input-wrap--password" data-password-field>
              <%- include('partials/test-icon', { name: 'lock', className: 'td-input-icon' }) %>
              <input
                id="password"
                name="password"
                type="password"
                placeholder="<%= t('login.passwordPlaceholder') %>"
                autocomplete="current-password"
                required
                data-password-input
              />
              <button class="td-password-reveal" type="button" aria-label="Показати пароль" data-password-reveal hidden>
                <%- include('partials/test-icon', { name: 'eye', className: 'td-password-eye td-password-eye--show' }) %>
                <%- include('partials/test-icon', { name: 'eyeOff', className: 'td-password-eye td-password-eye--hide' }) %>
              </button>
            </span>
          </label>

          <div class="td-form-row">
            <label class="td-checkbox">
              <input type="checkbox" name="remember" />
              <span>Запамʼятати мене</span>
            </label>
            <a href="/help">Забули пароль?</a>
          </div>

          <button class="td-primary-button" type="submit">Увійти</button>
        </form>

        <p class="td-login-bottom">Ще немає акаунту? <a href="/register">Зареєструватися</a></p>
      </section>
    </main>

    <footer class="td-login-footer">
      <button type="button" class="td-language-pill">UA <%- include('partials/test-icon', { name: 'chevronDown', className: 'td-mini-chevron' }) %></button>
      <button type="button" class="td-language-pill td-theme-toggle" data-theme-toggle aria-label="Увімкнути темну тему" aria-pressed="false">
        <%- include('partials/test-icon', { name: 'moon', className: 'td-mini-chevron td-theme-moon' }) %>
        <%- include('partials/test-icon', { name: 'sun', className: 'td-mini-chevron td-theme-sun' }) %>
        <span data-theme-label>Dark</span>
      </button>
      <a href="/help">Підтримка</a>
      <a href="/terms">Умови використання</a>
      <a href="/privacy">Політика конфіденційності</a>
      <button type="button" class="td-footer-link" data-auth-changelog-open>Changelog</button>
      <span>© Studerria 2026</span>
    </footer>
    <%- include('partials/auth-lite-changelog') %>
    <script src="/js/login-auth.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
