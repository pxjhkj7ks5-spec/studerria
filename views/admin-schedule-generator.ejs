        cancel: 'Cancel',
      }
    : {
        pageTitle: 'Генератор розкладу',
        backToAdmin: 'Назад в адмінку',
        sessionGenerator: 'Генератор сесій',
        heroTitle: 'Генератор розкладу',
        heroLead: 'Обери семестр, задай кількість пар і збережи чистий план без зайвого.',
        runLabel: 'Запуск',
        statusPublished: 'Опубліковано',
        statusDraft: 'Чернетка',
        location: 'Кампус',
        locationKyiv: 'Київ',
        locationMunich: 'Мюнхен',
        course: 'Курс',
        semester: 'Терм',
        applyScope: 'Застосувати',
        scopeHint: 'Терм обирається глобально для сторінки і може бути неактивним.',
        noCourses: 'Немає курсів для цього кампусу.',
        noSemesters: 'Для курсу немає семестрів.',
        matrixTitle: 'Матриця предметів семестру',
        matrixLead: 'Кожен предмет дубльовано як Лекція і Семінар. Вкажи кількість пар, опційно викладача, і синхронізуй.',
        subject: 'Предмет',
        type: 'Тип',
        lecture: 'Лекція',
        seminar: 'Семінар',
        pairs: 'К-сть пар',
        teacher: 'Викладач',
        teacherAuto: 'Авто (з призначень)',
        additional: 'Додаткове',
        additionalEmpty: 'Не задано',
        additionalEdit: 'День/слот',
        syncRows: 'Синхронізувати таблицю',
        noRows: 'Для цього семестру предметів не знайдено.',
        extraItemsHint: (count) => `У цьому scope є приховані legacy-записи: ${count}. Вони зникнуть після синхронізації цього scope.`,
        teacherSettingsMoved: 'Налаштування робочих днів викладачів винесено зі сторінки генератора.',
        openAcademicSetup: 'Відкрити Academic Setup',
        runTitle: 'Згенерувати превʼю',
        runHint: 'Генерація запускається тільки по вибраному курсу + терму.',
        generatePreview: 'Згенерувати превʼю',
        openPreview: 'Відкрити превʼю',
        settingsTitle: 'Налаштування генерації',
        settingsHint: 'Лишили тільки параметри, що реально впливають на якість генерації.',
        blockedWeeks: 'Спец-тижні навчання',
        blockedWeeksPlaceholder: 'Наприклад: 2,5,9-10',
        specialWeeksMode: 'Режим спец-тижнів',
        specialWeeksBlock: 'Не генерувати на цих тижнях',
        specialWeeksOverlay: 'Ігнорувати список (звичайна генерація)',
        maxDailyPairs: 'Макс пар/день',
        targetDailyPairs: 'Ціль пар/день',
        distribution: 'Розподіл лекцій по тижнях',
        seminarDistribution: 'Розподіл семінарів по тижнях',
        distStart: 'Початок',
        distEven: 'Рівномірно',
        distEnd: 'Кінець',
        strictNoEvening: 'Строго без 6-7 пар',
        preferCompactness: 'Компактніше розклад по днях',
        autoSubjectDays: 'Авто-баланс днів для предметів',
        subjectSingleDay: 'Один предмет в один день тижня',
        lectureSeminarSameDay: 'Лекція + семінар в один день',
        lectureBeforeSeminar: 'Лекція перед семінаром',
        mirrorGroups: 'Увімкнути дзеркальні групи (A/B)',
        saveSettings: 'Зберегти налаштування',
        advancedTitle: 'Додаткові параметри',
        fixedDay: 'Фіксований день',
        fixedSlot: 'Фіксований слот',
        any: 'Будь-який',
        save: 'Зберегти',
        cancel: 'Скасувати',
      };

  const safeDayOptions = Array.isArray(dayOptions) && dayOptions.length
    ? dayOptions
    : ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
  const safeDayLabels = Array.isArray(dayLabels) && dayLabels.length
    ? dayLabels
    : ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Нд'];
  const safeClassOptions = Array.isArray(classOptions) && classOptions.length
    ? classOptions
    : [1, 2, 3, 4, 5, 6, 7];

  const activeLocationCourses = (coursesByLocation && coursesByLocation[activeLocation]) || [];
  const scopedCourseId = Number(selectedGlobalCourseId || (selectedGlobalCourse && selectedGlobalCourse.id) || 0) || null;
  const scopedSemesterId = Number(selectedGlobalSemesterId || (selectedGlobalSemester && selectedGlobalSemester.id) || 0) || null;
  const scopedSemesters = Array.isArray(selectedGlobalSemesters) ? selectedGlobalSemesters : [];
  const matrixRows = Array.isArray(selectedGlobalMatrixRows) ? selectedGlobalMatrixRows : [];
  const teacherOptionsBySubject = selectedGlobalTeacherOptionsBySubject && typeof selectedGlobalTeacherOptionsBySubject === 'object'
    ? selectedGlobalTeacherOptionsBySubject
    : {};
  const fallbackTeachers = Array.isArray(teachers) ? teachers : [];
  const extraItemsCount = Number(selectedGlobalExtraItemsCount || 0) || 0;
  const generatorConfig = config && typeof config === 'object' ? config : {};
  const configDistribution = String(generatorConfig.distribution || 'even').toLowerCase();
  const configSeminarDistribution = String(generatorConfig.seminar_distribution || 'even').toLowerCase();
  const configSpecialWeeksMode = String(generatorConfig.special_weeks_mode || 'block').toLowerCase() === 'overlay'
    ? 'overlay'
    : 'block';
  const configMaxDailyPairs = Number(generatorConfig.max_daily_pairs || 7);
  const configTargetDailyPairs = Number(generatorConfig.target_daily_pairs || 4);

  const formatLocationLabel = (value) => String(value || '').toLowerCase() === 'munich'
    ? schedulePageText.locationMunich
    : schedulePageText.locationKyiv;

  const formatAdvancedLabel = (day, slot) => {
    const dayText = String(day || '').trim();
    const slotNumber = Number(slot || 0);
    if (!dayText && !slotNumber) return schedulePageText.additionalEmpty;
    if (dayText && slotNumber) return `${dayText} · #${slotNumber}`;
    if (dayText) return dayText;
    return `#${slotNumber}`;
  };
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title><%= schedulePageText.pageTitle %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/pages/admin-schedule-generator.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <style>
      .generator-min-shell .card {
        border: 1px solid color-mix(in srgb, var(--glass-border, rgba(255,255,255,.2)) 85%, transparent);
      }
      .generator-min-shell .matrix-table th,
      .generator-min-shell .matrix-table td {
        vertical-align: middle;
      }
      .generator-min-shell .matrix-type-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .22rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.2);
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .04em;
      }
      .generator-min-shell .matrix-type-badge.is-lecture {
        background: rgba(83, 162, 255, .14);
      }
      .generator-min-shell .matrix-type-badge.is-seminar {
        background: rgba(100, 224, 170, .14);
      }
      .generator-min-shell .matrix-additional-chip {
        display: inline-flex;
        align-items: center;
        padding: .2rem .55rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.2);
        font-size: .75rem;
        color: var(--text-muted, rgba(255,255,255,.72));
      }
    </style>
  </head>
  <body class="studerria-theme theme-dark schedule-generator-page generator-min-shell">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>

    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand"><%= schedulePageText.pageTitle %></span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted"><%= t('role.admin') %>: <%= username %></span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="<%= t('theme.toggle') %>"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-primary btn-sm me-2" href="/admin"><%= schedulePageText.backToAdmin %></a>
          <a class="btn btn-outline-secondary btn-sm me-2" href="/admin/session-generator"><%= schedulePageText.sessionGenerator %></a>
          <form method="POST" action="/admin/schedule-generator/new" class="me-2">
            <button class="btn btn-outline-secondary btn-sm" type="submit">New run</button>
          </form>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>

      <div class="generator-hero glass mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <h1 class="h3 mb-2"><%= schedulePageText.heroTitle %></h1>
            <div class="text-muted"><%= schedulePageText.heroLead %></div>
          </div>
          <div class="generator-status">
            <span class="generator-chip"><%= schedulePageText.runLabel %> #<%= run.id %></span>
            <span class="badge bg-<%= run.status === 'published' ? 'success' : 'secondary' %>">
              <%= run.status === 'published' ? schedulePageText.statusPublished : schedulePageText.statusDraft %>
            </span>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12 col-xl-4">
          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2"><%= schedulePageText.scopeHint %></div>
              <form method="GET" action="/admin/schedule-generator" class="row g-3" id="scheduleGeneratorScopeForm">
                <input type="hidden" name="run" value="<%= run.id %>" />
                <div class="col-12">
                  <label class="form-label"><%= schedulePageText.location %></label>
                  <select class="form-select" name="location" id="scopeLocationSelect">
                    <option value="kyiv" <%= activeLocation === 'kyiv' ? 'selected' : '' %>><%= schedulePageText.locationKyiv %></option>
                    <option value="munich" <%= activeLocation === 'munich' ? 'selected' : '' %>><%= schedulePageText.locationMunich %></option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label"><%= schedulePageText.course %></label>
                  <select class="form-select" name="course_id" id="scopeCourseSelect" <%= activeLocationCourses.length ? '' : 'disabled' %>>
                    <% if (!activeLocationCourses.length) { %>
                      <option value=""><%= schedulePageText.noCourses %></option>
                    <% } else { %>
                      <% activeLocationCourses.forEach(function(course) { %>
                        <option value="<%= course.id %>" <%= Number(course.id) === Number(scopedCourseId || 0) ? 'selected' : '' %>><%= course.name %></option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label"><%= schedulePageText.semester %></label>
                  <select class="form-select" name="semester_id" id="scopeSemesterSelect" <%= scopedSemesters.length ? '' : 'disabled' %>>
                    <% if (!scopedSemesters.length) { %>
                      <option value=""><%= schedulePageText.noSemesters %></option>
                    <% } else { %>
                      <% scopedSemesters.forEach(function(semester) { %>
                        <option value="<%= semester.id %>" <%= Number(semester.id) === Number(scopedSemesterId || 0) ? 'selected' : '' %>>
                          <%= semester.display_title || semester.title || ('Semester ' + semester.id) %> · <%= semester.weeks_count || '—' %>
                        </option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
              </form>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2"><%= schedulePageText.teacherSettingsMoved %></div>
              <a class="btn btn-outline-secondary btn-sm" href="/admin/pathways"><%= schedulePageText.openAcademicSetup %></a>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2"><%= schedulePageText.settingsTitle %></div>
              <div class="small text-muted mb-3"><%= schedulePageText.settingsHint %></div>
              <form method="POST" action="/admin/schedule-generator/config" class="row g-3">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <input type="hidden" name="active_location" value="<%= activeLocation %>" />
                <input type="hidden" name="location" value="<%= activeLocation %>" />
                <input type="hidden" name="course_id" value="<%= scopedCourseId || '' %>" />
                <input type="hidden" name="semester_id" value="<%= scopedSemesterId || '' %>" />
                <% if (scopedCourseId && scopedSemesterId) { %>
                  <input type="hidden" name="course_semesters[<%= scopedCourseId %>]" value="<%= scopedSemesterId %>" />
                <% } %>
                <div class="col-12">
                  <label class="form-label"><%= schedulePageText.blockedWeeks %></label>
                  <input
                    class="form-control"
                    type="text"
                    name="blocked_weeks"
                    placeholder="<%= schedulePageText.blockedWeeksPlaceholder %>"
                    value="<%= String(generatorConfig.blocked_weeks || '') %>"
                  />
                </div>
                <div class="col-12">
                  <label class="form-label"><%= schedulePageText.specialWeeksMode %></label>
                  <select class="form-select" name="special_weeks_mode">
                    <option value="block" <%= configSpecialWeeksMode === 'block' ? 'selected' : '' %>><%= schedulePageText.specialWeeksBlock %></option>
                    <option value="overlay" <%= configSpecialWeeksMode === 'overlay' ? 'selected' : '' %>><%= schedulePageText.specialWeeksOverlay %></option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label"><%= schedulePageText.maxDailyPairs %></label>
                  <input class="form-control" type="number" min="1" max="7" name="max_daily_pairs" value="<%= Number.isFinite(configMaxDailyPairs) ? configMaxDailyPairs : 7 %>" />
                </div>
                <div class="col-6">
                  <label class="form-label"><%= schedulePageText.targetDailyPairs %></label>
                  <input class="form-control" type="number" min="1" max="7" name="target_daily_pairs" value="<%= Number.isFinite(configTargetDailyPairs) ? configTargetDailyPairs : 4 %>" />
                </div>
                <div class="col-6">
                  <label class="form-label"><%= schedulePageText.distribution %></label>
                  <select class="form-select" name="distribution">
                    <option value="start" <%= configDistribution === 'start' ? 'selected' : '' %>><%= schedulePageText.distStart %></option>
                    <option value="even" <%= configDistribution === 'even' ? 'selected' : '' %>><%= schedulePageText.distEven %></option>
                    <option value="end" <%= configDistribution === 'end' ? 'selected' : '' %>><%= schedulePageText.distEnd %></option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label"><%= schedulePageText.seminarDistribution %></label>
                  <select class="form-select" name="seminar_distribution">
                    <option value="start" <%= configSeminarDistribution === 'start' ? 'selected' : '' %>><%= schedulePageText.distStart %></option>
                    <option value="even" <%= configSeminarDistribution === 'even' ? 'selected' : '' %>><%= schedulePageText.distEven %></option>
                    <option value="end" <%= configSeminarDistribution === 'end' ? 'selected' : '' %>><%= schedulePageText.distEnd %></option>
                  </select>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="strict_no_evening" id="cfgStrictNoEvening" <%= generatorConfig.strict_no_evening ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgStrictNoEvening"><%= schedulePageText.strictNoEvening %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="prefer_compactness" id="cfgPreferCompactness" <%= generatorConfig.prefer_compactness ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgPreferCompactness"><%= schedulePageText.preferCompactness %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="auto_subject_days" id="cfgAutoSubjectDays" <%= generatorConfig.auto_subject_days !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgAutoSubjectDays"><%= schedulePageText.autoSubjectDays %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="subject_single_day" id="cfgSubjectSingleDay" <%= generatorConfig.subject_single_day !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgSubjectSingleDay"><%= schedulePageText.subjectSingleDay %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="lecture_seminar_same_day" id="cfgLectureSeminarSameDay" <%= generatorConfig.lecture_seminar_same_day !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgLectureSeminarSameDay"><%= schedulePageText.lectureSeminarSameDay %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="lecture_before_seminar" id="cfgLectureBeforeSeminar" <%= generatorConfig.lecture_before_seminar !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgLectureBeforeSeminar"><%= schedulePageText.lectureBeforeSeminar %></label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mirror_groups" id="cfgMirrorGroups" <%= generatorConfig.mirror_groups ? 'checked' : '' %> />
                    <label class="form-check-label" for="cfgMirrorGroups"><%= schedulePageText.mirrorGroups %></label>
                  </div>
                </div>
                <div class="col-12 d-grid">
                  <button class="btn btn-outline-primary" type="submit"><%= schedulePageText.saveSettings %></button>
                </div>
              </form>
            </div>
          </div>

          <div class="card glass-panel">
            <div class="card-body">
              <div class="generator-section-title mb-2"><%= schedulePageText.runTitle %></div>
              <div class="small text-muted mb-3"><%= schedulePageText.runHint %></div>
              <form method="POST" action="/admin/schedule-generator/run" class="d-grid gap-2">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <input type="hidden" name="active_location" value="<%= activeLocation %>" />
                <input type="hidden" name="course_id" value="<%= scopedCourseId || '' %>" />
                <input type="hidden" name="scope_semester_id" value="<%= scopedSemesterId || '' %>" />
                <button class="btn btn-primary" type="submit" <%= scopedCourseId && scopedSemesterId ? '' : 'disabled' %>><%= schedulePageText.generatePreview %></button>
              </form>
              <% if (scopedCourseId) { %>
                <a
                  class="btn btn-outline-primary btn-sm mt-2"
                  href="/admin/schedule-generator/<%= run.id %>/preview?course=<%= scopedCourseId %>&week=1&location=<%= encodeURIComponent(String(activeLocation || 'kyiv')) %>&semester_id=<%= scopedSemesterId || '' %>"
                >
                  <%= schedulePageText.openPreview %>
                </a>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-8">
          <div class="card glass-panel">
            <div class="card-body">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                <div class="generator-section-title"><%= schedulePageText.matrixTitle %></div>
                <div class="small text-muted">
                  <%= scopedCourseId ? (selectedGlobalCourse && selectedGlobalCourse.name) : '—' %>
                  <% if (scopedSemesterId) { %>
                    · <%= selectedGlobalSemester && (selectedGlobalSemester.title || ('Semester ' + selectedGlobalSemester.id)) %>
                  <% } %>
                </div>
              </div>
              <div class="small text-muted mb-3"><%= schedulePageText.matrixLead %></div>

              <% if (extraItemsCount > 0) { %>
                <div class="alert alert-warning py-2"><%= schedulePageText.extraItemsHint(extraItemsCount) %></div>
              <% } %>

              <form method="POST" action="/admin/schedule-generator/items/bulk-sync" id="bulkScheduleSyncForm">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <input type="hidden" name="active_location" value="<%= activeLocation %>" />
                <input type="hidden" name="course_id" value="<%= scopedCourseId || '' %>" />
                <input type="hidden" name="semester_id" value="<%= scopedSemesterId || '' %>" />

                <% if (!matrixRows.length) { %>
                  <div class="generator-empty"><%= schedulePageText.noRows %></div>
                <% } else { %>
                  <div class="table-responsive">
                    <table class="table matrix-table align-middle">
                      <thead>
                        <tr>
                          <th><%= schedulePageText.subject %></th>
                          <th><%= schedulePageText.type %></th>
                          <th style="width: 120px;"><%= schedulePageText.pairs %></th>
                          <th style="width: 220px;"><%= schedulePageText.teacher %></th>
                          <th style="width: 190px;"><%= schedulePageText.additional %></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% matrixRows.forEach(function(row, idx) { %>
                          <% const rowId = idx + 1; %>
                          <% const subjectTeacherOptions = teacherOptionsBySubject[String(row.subject_id)] || []; %>
                          <tr>
                            <td>
                              <div class="fw-semibold"><%= row.subject_name %></div>
                              <input type="hidden" name="row_subject_id" value="<%= row.subject_id %>" />
                              <input type="hidden" name="row_lesson_type" value="<%= row.lesson_type %>" />
                            </td>
                            <td>
                              <span class="matrix-type-badge <%= row.lesson_type === 'seminar' ? 'is-seminar' : 'is-lecture' %>">
                                <%= row.lesson_type === 'seminar' ? schedulePageText.seminar : schedulePageText.lecture %>
                              </span>
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="number" min="0" max="120" name="row_pairs_count" value="<%= Number(row.pairs_count || 0) %>" />
                            </td>
                            <td>
                              <select class="form-select form-select-sm" name="row_teacher_id">
                                <option value=""><%= schedulePageText.teacherAuto %></option>
                                <% if (subjectTeacherOptions.length) { %>
                                  <% subjectTeacherOptions.forEach(function(teacher) { %>
                                    <option value="<%= teacher.id %>" <%= Number(row.teacher_id || 0) === Number(teacher.id || 0) ? 'selected' : '' %>><%= teacher.name %></option>
                                  <% }); %>
                                <% } else { %>
                                  <% fallbackTeachers.forEach(function(teacher) { %>
                                    <option value="<%= teacher.id %>" <%= Number(row.teacher_id || 0) === Number(teacher.id || 0) ? 'selected' : '' %>><%= teacher.full_name %></option>
                                  <% }); %>
                                <% } %>
                              </select>
                            </td>
                            <td>
                              <input type="hidden" name="row_fixed_day" id="row-fixed-day-<%= rowId %>" value="<%= row.fixed_day || '' %>" />
                              <input type="hidden" name="row_fixed_class_number" id="row-fixed-slot-<%= rowId %>" value="<%= row.fixed_class_number || '' %>" />
                              <div class="d-flex align-items-center gap-2">
                                <span class="matrix-additional-chip" id="row-advanced-label-<%= rowId %>"><%= formatAdvancedLabel(row.fixed_day, row.fixed_class_number) %></span>
                                <button
                                  class="btn btn-outline-secondary btn-sm"
                                  type="button"
                                  data-open-advanced
                                  data-row-id="<%= rowId %>"
                                >
                                  <%= schedulePageText.additionalEdit %>
                                </button>
                              </div>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                  <div class="d-grid d-md-flex justify-content-md-end mt-3">
                    <button class="btn btn-primary" type="submit" <%= scopedCourseId && scopedSemesterId ? '' : 'disabled' %>><%= schedulePageText.syncRows %></button>
                  </div>
                <% } %>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/app-footer') %>
    <%- include('partials/changelog-modal') %>

    <div class="modal fade" id="matrixAdvancedModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content glass-panel">
          <div class="modal-header">
            <h5 class="modal-title"><%= schedulePageText.advancedTitle %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label"><%= schedulePageText.fixedDay %></label>
              <select class="form-select" id="matrixAdvancedDaySelect">
                <option value=""><%= schedulePageText.any %></option>
                <% safeDayOptions.forEach(function(day, idx) { %>
                  <option value="<%= day %>"><%= safeDayLabels[idx] || day %> · <%= day %></option>
                <% }); %>
              </select>
            </div>
            <div class="mb-1">
              <label class="form-label"><%= schedulePageText.fixedSlot %></label>
              <select class="form-select" id="matrixAdvancedSlotSelect">
                <option value=""><%= schedulePageText.any %></option>
                <% safeClassOptions.forEach(function(slot) { %>
                  <option value="<%= slot %>">#<%= slot %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= schedulePageText.cancel %></button>
            <button type="button" class="btn btn-primary" id="matrixAdvancedSaveBtn"><%= schedulePageText.save %></button>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        const applyTheme = (theme) => {
          document.body.classList.toggle('theme-light', theme === 'light');
          document.body.classList.toggle('theme-dark', theme === 'dark');
          document.body.setAttribute('data-theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
          themeToggle.textContent = theme === 'light'
            ? (themeToggle.dataset.darkLabel || '☀️')
            : (themeToggle.dataset.lightLabel || '🌙');
        };
        const storedTheme = localStorage.getItem('ui-theme');
        const normalizedTheme = storedTheme === 'theme-light' || storedTheme === 'light' ? 'light' : 'dark';
        localStorage.setItem('ui-theme', normalizedTheme === 'dark' ? 'theme-dark' : 'theme-light');
        applyTheme(normalizedTheme);
        themeToggle.addEventListener('click', () => {
          const next = document.body.classList.contains('theme-dark') ? 'light' : 'dark';
          localStorage.setItem('ui-theme', next === 'dark' ? 'theme-dark' : 'theme-light');
          applyTheme(next);
        });
      }

      const advancedModalElement = document.getElementById('matrixAdvancedModal');
      const bootstrapModalCtor = window.bootstrap && typeof window.bootstrap.Modal === 'function'
        ? window.bootstrap.Modal
        : null;
      const advancedModal = advancedModalElement && bootstrapModalCtor
        ? new bootstrapModalCtor(advancedModalElement)
        : null;
      const advancedDaySelect = document.getElementById('matrixAdvancedDaySelect');
      const advancedSlotSelect = document.getElementById('matrixAdvancedSlotSelect');
      const advancedSaveBtn = document.getElementById('matrixAdvancedSaveBtn');
      let activeRowId = null;
      const scopeForm = document.getElementById('scheduleGeneratorScopeForm');
      const scopeSelects = [
        document.getElementById('scopeLocationSelect'),
        document.getElementById('scopeCourseSelect'),
        document.getElementById('scopeSemesterSelect'),
      ].filter(Boolean);

      if (scopeForm && scopeSelects.length) {
        const submitScopeForm = () => {
          if (scopeForm.dataset.submitting === '1') return;
          scopeForm.dataset.submitting = '1';
          if (typeof scopeForm.requestSubmit === 'function') {
            scopeForm.requestSubmit();
            return;
          }
          scopeForm.submit();
        };
        scopeSelects.forEach((select) => {
          select.addEventListener('change', submitScopeForm);
        });
      }

      const getAdvancedLabel = (dayValue, slotValue) => {
        const day = String(dayValue || '').trim();
        const slot = Number(slotValue || 0);
        if (!day && !slot) return <%- JSON.stringify(schedulePageText.additionalEmpty) %>;
        if (day && slot) return `${day} · #${slot}`;
        if (day) return day;
        return `#${slot}`;
      };

      const openAdvancedModalForRow = (rowId) => {
        const dayInput = document.getElementById(`row-fixed-day-${rowId}`);
        const slotInput = document.getElementById(`row-fixed-slot-${rowId}`);
        if (!dayInput || !slotInput || !advancedModal) return;
        activeRowId = String(rowId);
        if (advancedDaySelect) advancedDaySelect.value = dayInput.value || '';
        if (advancedSlotSelect) advancedSlotSelect.value = slotInput.value || '';
        advancedModal.show();
      };

      document.querySelectorAll('[data-open-advanced]').forEach((button) => {
        button.addEventListener('click', () => {
          openAdvancedModalForRow(button.dataset.rowId);
        });
      });

      if (advancedSaveBtn) {
        advancedSaveBtn.addEventListener('click', () => {
          if (!activeRowId) return;
          const dayInput = document.getElementById(`row-fixed-day-${activeRowId}`);
          const slotInput = document.getElementById(`row-fixed-slot-${activeRowId}`);
          const label = document.getElementById(`row-advanced-label-${activeRowId}`);
          if (!dayInput || !slotInput || !label) return;
          dayInput.value = advancedDaySelect ? advancedDaySelect.value : '';
          slotInput.value = advancedSlotSelect ? advancedSlotSelect.value : '';
          label.textContent = getAdvancedLabel(dayInput.value, slotInput.value);
          if (advancedModal) advancedModal.hide();
        });
      }
    </script>
  </body>
</html>
