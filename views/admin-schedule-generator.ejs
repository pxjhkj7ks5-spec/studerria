<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Генератор розкладу</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/pages/admin-schedule-generator.css" />
      <link rel="stylesheet" href="/css/design-system.css" />
      <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="theme-light schedule-generator-page">
    <%- include('partials/dynamic-bg') %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand">Генератор розкладу</span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted"><%= t('role.admin') %>: <%= username %></span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="Toggle theme"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-primary btn-sm me-2" href="/admin">Назад в адмінку</a>
          <a class="btn btn-outline-secondary btn-sm me-2" href="/admin/session-generator">Генератор сесій</a>
          <form method="POST" action="/admin/schedule-generator/new" class="me-2">
            <button class="btn btn-outline-secondary btn-sm" type="submit">Новий план</button>
          </form>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>

      <% const disableRunKyiv = validationByLocation && validationByLocation.kyiv ? validationByLocation.kyiv.hasCritical : false; %>
      <% const disableRunMunich = validationByLocation && validationByLocation.munich ? validationByLocation.munich.hasCritical : false; %>

      <div class="generator-hero glass mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <h1 class="h3 mb-2">Генератор розкладу</h1>
            <div class="text-muted">
              Формуємо повний розклад по вибраній локації: фіксовані слоти, дзеркальні тижні, обмеження викладачів.
            </div>
          </div>
          <div class="generator-status">
            <span class="generator-chip">Run #<%= run.id %></span>
            <span class="badge bg-<%= run.status === 'published' ? 'success' : 'secondary' %>">
              <%= run.status === 'published' ? 'Опубліковано' : 'Чернетка' %>
            </span>
          </div>
        </div>
        <div class="generator-actions mt-3">
          <form method="POST" action="/admin/schedule-generator/run" class="generator-run-form" data-scope-target>
            <input type="hidden" name="run_id" value="<%= run.id %>" />
            <input type="hidden" name="active_location" id="runLocationInput" value="<%= activeLocation %>" />
            <button
              class="btn btn-primary"
              type="submit"
              id="generatePreviewBtn"
              data-disable-kyiv="<%= disableRunKyiv ? 'true' : 'false' %>"
              data-disable-munich="<%= disableRunMunich ? 'true' : 'false' %>"
              <%= (activeLocation === 'kyiv' ? disableRunKyiv : disableRunMunich) ? 'disabled' : '' %>
            >
              Згенерувати превʼю
            </button>
          </form>
          <% const activeCourseList = (courseSemestersByLocation && courseSemestersByLocation[activeLocation]) || []; %>
          <% const firstCourseId = activeCourseList.length ? activeCourseList[0].course.id : null; %>
          <% if (firstCourseId) { %>
            <a class="btn btn-outline-primary" href="/admin/schedule-generator/<%= run.id %>/preview?course=<%= firstCourseId %>&week=1">Відкрити превʼю</a>
          <% } %>
          <a class="btn btn-outline-secondary" href="/admin/session-generator?location=<%= activeLocation %>">Генератор сесій</a>
        </div>
        <div class="generator-actions mt-2">
          <% ['kyiv', 'munich'].forEach(function(location) { %>
            <% const locationCourses = (courseSemestersByLocation && courseSemestersByLocation[location]) || []; %>
            <% if (locationCourses.length) { %>
              <form method="POST" action="/admin/schedule-generator/run" class="d-flex flex-wrap align-items-center gap-2 generator-run-form" data-scope-target data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <input type="hidden" name="active_location" value="<%= location %>" />
                <input type="hidden" name="scope" value="course" />
                <select name="course_id" class="form-select form-select-sm w-auto">
                  <% locationCourses.forEach(function(row) { %>
                    <option value="<%= row.course.id %>"><%= row.course.name %></option>
                  <% }); %>
                </select>
                <button
                  class="btn btn-outline-primary btn-sm"
                  type="submit"
                  data-disable-kyiv="<%= disableRunKyiv ? 'true' : 'false' %>"
                  data-disable-munich="<%= disableRunMunich ? 'true' : 'false' %>"
                  <%= (location === 'kyiv' ? disableRunKyiv : disableRunMunich) ? 'disabled' : '' %>
                >
                  Перегенерувати курс
                </button>
              </form>
            <% } %>
          <% }); %>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12 col-xl-4">
          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="generator-section-title">Курси</div>
                <div class="btn-group btn-group-sm">
                  <button class="btn btn-outline-primary location-toggle <%= activeLocation === 'kyiv' ? 'active' : '' %>" type="button" data-location="kyiv">Kyiv</button>
                  <button class="btn btn-outline-primary location-toggle <%= activeLocation === 'munich' ? 'active' : '' %>" type="button" data-location="munich">Munich</button>
                </div>
              </div>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const courseList = courseSemestersByLocation[location] || []; %>
                <div class="d-grid gap-2" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (courseList.length) { %>
                    <% courseList.forEach(function(row) { %>
                      <div class="glass-inset p-3">
                        <div class="fw-semibold"><%= row.course.name %></div>
                        <div class="small text-muted">
                          <%= row.semester ? row.semester.title : 'Немає активного семестру' %>
                          <% if (row.semester) { %> · <%= row.semester.weeks_count %> тижнів <% } %>
                        </div>
                        <div class="small text-muted">
                          Активні дні: <%= (courseDaysByLocation[location][row.course.id] || []).join(', ') %>
                        </div>
                      </div>
                    <% }); %>
                  <% } else { %>
                    <div class="generator-empty">Немає курсів для <%= location === 'kyiv' ? 'Kyiv' : 'Munich' %>.</div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Аналітика генератора</div>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const insight = generationInsightsByLocation && generationInsightsByLocation[location]; %>
                <div class="generator-insights" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (!insight) { %>
                    <div class="generator-empty">Аналітика недоступна.</div>
                  <% } else { %>
                    <div class="insight-header mb-2">
                      <span class="insight-health <%= insight.healthState === 'good' ? 'is-good' : insight.healthState === 'warn' ? 'is-warn' : 'is-critical' %>">
                        <%= insight.healthState === 'good' ? 'Стабільно' : insight.healthState === 'warn' ? 'Потрібна увага' : 'Ризиковано' %>
                      </span>
                      <span class="small text-muted">Індекс якості: <%= insight.healthScore %>/100</span>
                    </div>
                    <div class="insight-metrics mb-2">
                      <div class="insight-metric"><span>Блокери</span><strong><%= insight.blockers %></strong></div>
                      <div class="insight-metric"><span>Попередження</span><strong><%= insight.warnings %></strong></div>
                      <div class="insight-metric"><span>Частково заплан.</span><strong><%= insight.partialCount %></strong></div>
                      <div class="insight-metric"><span>Без слота</span><strong><%= insight.noSlotCount %></strong></div>
                      <div class="insight-metric"><span>Немає дозвол. слотів</span><strong><%= insight.noAllowedClassesCount || 0 %></strong></div>
                      <div class="insight-metric"><span>Вечірні пари</span><strong><%= Math.round((insight.lateShare || 0) * 100) %>%</strong></div>
                      <div class="insight-metric"><span>Перекіс по днях</span><strong><%= Math.round((insight.dayImbalance || 0) * 100) %>%</strong></div>
                    </div>
                    <div class="small text-muted mb-2">
                      <% const peakDay = insight.peakDay && insight.peakDay.day ? insight.peakDay.day : null; %>
                      <% const peakDayIdx = peakDay ? dayOptions.indexOf(peakDay) : -1; %>
                      <% const peakDayLabel = peakDayIdx >= 0 ? (dayLabels[peakDayIdx] || peakDay) : (peakDay || '—'); %>
                      Пік: <%= peakDayLabel %> (<%= insight.peakDay ? insight.peakDay.total : 0 %>) · Пара #<%= insight.peakSlot ? insight.peakSlot.slot : '—' %> (<%= insight.peakSlot ? insight.peakSlot.count : 0 %>)
                    </div>
                    <% if (insight.conflictTop && insight.conflictTop.length) { %>
                      <div class="insight-top mb-2">
                        <% insight.conflictTop.forEach(function(top) { %>
                          <span class="insight-top-chip"><%= top.label %>: <%= top.count %></span>
                        <% }); %>
                      </div>
                    <% } %>
                    <div class="insight-tips">
                      <% (insight.tips || []).forEach(function(tip) { %>
                        <div class="insight-tip"><span class="insight-tip-dot"></span><span><%= tip %></span></div>
                      <% }); %>
                    </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="d-flex align-items-center justify-content-between mb-2 gap-2">
                <div class="generator-section-title m-0">Налаштування генерації</div>
                <form method="POST" action="/admin/schedule-generator/config/autotune" class="m-0">
                  <input type="hidden" name="run_id" value="<%= run.id %>" />
                  <input type="hidden" name="active_location" id="autoTuneLocationInput" value="<%= activeLocation %>" />
                  <button class="btn btn-outline-primary btn-sm" type="submit">Safe auto-tune</button>
                </form>
              </div>
              <form method="POST" action="/admin/schedule-generator/config" class="row g-3">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <input type="hidden" name="active_location" id="activeLocationInput" value="<%= activeLocation %>" />
                <div class="col-12">
                  <label class="form-label">Розподіл пар</label>
                  <select class="form-select" name="distribution">
                    <option value="start" <%= config.distribution === 'start' ? 'selected' : '' %>>Концентрація на початку</option>
                    <option value="even" <%= config.distribution === 'even' ? 'selected' : '' %>>Рівномірно</option>
                    <option value="end" <%= config.distribution === 'end' ? 'selected' : '' %>>Концентрація в кінці</option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label">Семінари</label>
                  <select class="form-select" name="seminar_distribution">
                    <option value="start" <%= config.seminar_distribution === 'start' ? 'selected' : '' %>>На початку</option>
                    <option value="even" <%= config.seminar_distribution === 'even' ? 'selected' : '' %>>Рівномірно</option>
                    <option value="end" <%= config.seminar_distribution === 'end' ? 'selected' : '' %>>В кінці</option>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label">Max пар/день</label>
                  <input class="form-control" type="number" name="max_daily_pairs" min="1" max="7" value="<%= config.max_daily_pairs || 7 %>" />
                </div>
                <div class="col-6">
                  <label class="form-label">Ціль пар/день</label>
                  <input class="form-control" type="number" name="target_daily_pairs" min="1" max="7" value="<%= config.target_daily_pairs || 4 %>" />
                </div>
                <div class="col-12">
                  <% const evennessValue = Number.isFinite(Number(config.evenness_bias)) ? Number(config.evenness_bias) : 50; %>
                  <label class="form-label d-flex justify-content-between align-items-center">
                    <span>Баланс рівномірності</span>
                    <span class="badge bg-secondary" id="evennessBiasValue"><%= evennessValue %>%</span>
                  </label>
                  <input
                    class="form-range"
                    type="range"
                    name="evenness_bias"
                    id="evennessBiasRange"
                    min="0"
                    max="100"
                    value="<%= evennessValue %>"
                  />
                  <div class="small text-muted">0 — компактніше, 100 — максимально рівномірно.</div>
                </div>
                <div class="col-12">
                  <% const lateSlotValue = Number.isFinite(Number(config.late_slot_weight)) ? Number(config.late_slot_weight) : 60; %>
                  <label class="form-label d-flex justify-content-between align-items-center">
                    <span>Уникати вечірніх слотів</span>
                    <span class="badge bg-secondary" id="lateSlotWeightValue"><%= lateSlotValue %>%</span>
                  </label>
                  <input
                    class="form-range"
                    type="range"
                    name="late_slot_weight"
                    id="lateSlotWeightRange"
                    min="0"
                    max="100"
                    value="<%= lateSlotValue %>"
                  />
                  <div class="small text-muted">0 — не враховувати, 100 — максимально уникати 5–7 пар.</div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="strict_no_evening" id="strictNoEvening" <%= config.strict_no_evening ? 'checked' : '' %> />
                    <label class="form-check-label" for="strictNoEvening">Strict no-evening (заборонити 6-7 пари)</label>
                  </div>
                  <div class="small text-muted">Жорстка заборона вечірніх слотів. Якщо не вистачає місця — генератор покаже конфлікти.</div>
                </div>
                <div class="col-12">
                  <label class="form-label">Особливі тижні (1-3,8)</label>
                  <input class="form-control" name="blocked_weeks" value="<%= config.blocked_weeks || '' %>" placeholder="1-2,6,9" />
                </div>
                <div class="col-12">
                  <label class="form-label">Режим особливих тижнів</label>
                  <select class="form-select" name="special_weeks_mode">
                    <option value="block" <%= config.special_weeks_mode !== 'overlay' ? 'selected' : '' %>>Блокувати заняття</option>
                    <option value="overlay" <%= config.special_weeks_mode === 'overlay' ? 'selected' : '' %>>Накладати поверх</option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label">Семестри курсів</label>
                  <% ['kyiv', 'munich'].forEach(function(location) { %>
                    <div class="d-grid gap-2" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                      <% (courseSemestersByLocation[location] || []).forEach(function(row) { %>
                        <% const semList = semestersByCourse[row.course.id] || []; %>
                        <% const selectedSemId = (selectedSemestersByLocation[location] && selectedSemestersByLocation[location][row.course.id]) || (row.semester ? row.semester.id : null); %>
                        <div class="glass-inset p-3">
                          <div class="fw-semibold"><%= row.course.name %></div>
                          <select class="form-select form-select-sm mt-2" name="course_semesters[<%= row.course.id %>]">
                            <% semList.forEach(function(sem) { %>
                              <option value="<%= sem.id %>" <%= Number(sem.id) === Number(selectedSemId) ? 'selected' : '' %>>
                                <%= sem.title %> · <%= sem.weeks_count %> тижнів
                              </option>
                            <% }); %>
                          </select>
                        </div>
                      <% }); %>
                    </div>
                  <% }); %>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="auto_subject_days" id="autoSubjectDays" <%= config.auto_subject_days ? 'checked' : '' %> />
                    <label class="form-check-label" for="autoSubjectDays">Авто-розклад днів для предметів</label>
                  </div>
                  <div class="small text-muted">Автоматично закріплюємо предмет за одним днем, щоб пари не розповзались.</div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="subject_single_day" id="subjectSingleDay" <%= config.subject_single_day !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="subjectSingleDay">Один день на предмет (окрім різних викладачів)</label>
                  </div>
                  <div class="small text-muted">Для мов та предметів з різними викладачами дозволяємо розбиття на кілька днів.</div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="lecture_seminar_same_day" id="lectureSeminarSameDay" <%= config.lecture_seminar_same_day !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="lectureSeminarSameDay">Лекція + семінар в один день</label>
                  </div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="lecture_before_seminar" id="lectureBeforeSeminar" <%= config.lecture_before_seminar !== false ? 'checked' : '' %> />
                    <label class="form-check-label" for="lectureBeforeSeminar">Пріоритет: лекція перед семінаром</label>
                  </div>
                  <div class="small text-muted">Для предметів, де є і лекція, і семінар: семінар ставимо тільки після лекції в межах тижня.</div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="prefer_compactness" id="preferCompactness" <%= config.prefer_compactness ? 'checked' : '' %> />
                    <label class="form-check-label" for="preferCompactness">Менше вікон між парами</label>
                  </div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="mirror_groups" id="mirrorGroups" <%= config.mirror_groups ? 'checked' : '' %> />
                    <label class="form-check-label" for="mirrorGroups">Швидке дзеркало груп (A/B)</label>
                  </div>
                  <div class="small text-muted">Парно зʼєднуємо групи 1/2 з однаковим ключем дзеркала та чергуємо по тижнях.</div>
                </div>
                <div class="col-12 d-grid">
                  <button class="btn btn-outline-primary" type="submit">Зберегти налаштування</button>
                </div>
              </form>
            </div>
          </div>

          <div class="card glass-panel mb-4" id="generatorScopeCard">
            <div class="card-body">
              <div class="generator-section-title mb-2">Scope controls</div>
              <div class="small text-muted mb-3">Застосовується до Preview/Publish. Якщо порожньо — генеруємо весь семестр.</div>
              <% const lastScope = lastStats && lastStats.scope ? lastStats.scope : {}; %>
              <% const scopeWeeks = Array.isArray(lastScope.weeks) ? lastScope.weeks : []; %>
              <% const scopeGroups = Array.isArray(lastScope.groups) ? lastScope.groups : []; %>
              <% const scopeDays = Array.isArray(lastScope.days) ? lastScope.days : []; %>
              <% const scopeFrom = scopeWeeks.length ? Math.min(...scopeWeeks) : ''; %>
              <% const scopeTo = scopeWeeks.length ? Math.max(...scopeWeeks) : ''; %>
              <div class="row g-3">
                <div class="col-12">
                  <label class="form-label">Semester (optional)</label>
                  <select class="form-select" name="scope_semester_id" data-scope-field>
                    <option value="">Усі семестри</option>
                    <% const seenScopeSem = new Set(); %>
                    <% Object.values(semestersByCourse || {}).forEach(function(list) { %>
                      <% (list || []).forEach(function(sem) { %>
                        <% if (!seenScopeSem.has(sem.id)) { seenScopeSem.add(sem.id); %>
                          <option value="<%= sem.id %>" <%= lastScope.semester_id && Number(lastScope.semester_id) === Number(sem.id) ? 'selected' : '' %>>
                            <%= sem.title %> · <%= sem.weeks_count %> тижнів
                          </option>
                        <% } %>
                      <% }); %>
                    <% }); %>
                  </select>
                </div>
                <div class="col-6">
                  <label class="form-label">Week from</label>
                  <input class="form-control" type="number" min="1" max="20" name="scope_week_from" value="<%= scopeFrom %>" data-scope-field />
                </div>
                <div class="col-6">
                  <label class="form-label">Week to</label>
                  <input class="form-control" type="number" min="1" max="20" name="scope_week_to" value="<%= scopeTo %>" data-scope-field />
                </div>
                <div class="col-12">
                  <label class="form-label">Groups</label>
                  <div class="d-flex flex-wrap gap-2">
                    <% [1,2,3].forEach(function(group) { %>
                      <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="scope_groups" value="<%= group %>" data-scope-field <%= scopeGroups.includes(group) ? 'checked' : '' %> />
                        <span class="form-check-label"><%= group %></span>
                      </label>
                    <% }); %>
                  </div>
                </div>
                <div class="col-12">
                  <label class="form-label">Days</label>
                  <div class="d-flex flex-wrap gap-2">
                    <% (dayOptions || []).forEach(function(day, idx) { %>
                      <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="scope_days" value="<%= day %>" data-scope-field <%= scopeDays.includes(day) ? 'checked' : '' %> />
                        <span class="form-check-label"><%= (dayLabels && dayLabels[idx]) || day %></span>
                      </label>
                    <% }); %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Перед запуском</div>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const validation = validationByLocation && validationByLocation[location]; %>
                <div data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (!validation || !validation.issues.length) { %>
                    <div class="validation-empty">Все готово до генерації.</div>
                  <% } else { %>
                    <div class="validation-summary mb-2">
                      <span class="validation-chip <%= validation.hasCritical ? 'is-error' : 'is-warn' %>">
                        <%= validation.hasCritical ? 'Критично' : 'Увага' %>
                      </span>
                      <span class="small text-muted"><%= validation.issues.length %> перевірок</span>
                    </div>
                    <div class="d-grid gap-2">
                      <% validation.issues.slice(0, 6).forEach(function(issue) { %>
                        <div class="validation-issue <%= issue.level === 'error' ? 'is-error' : 'is-warn' %>">
                          <span class="validation-dot"></span>
                          <div>
                            <div class="small fw-semibold"><%= issue.message %></div>
                            <div class="small text-muted"><%= issue.level === 'error' ? 'Блокує генерацію' : 'Попередження' %></div>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                    <% if (validation.issues.length > 6) { %>
                      <div class="small text-muted mt-2">Ще <%= validation.issues.length - 6 %> пунктів.</div>
                    <% } %>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Dry-run злиття предметів</div>
              <div class="small text-muted mb-3">
                Показує, які предмети будуть злиті перед міграцією. Дані лише для перегляду — базу не змінює.
              </div>
              <div class="d-flex flex-wrap align-items-center gap-2">
                <select class="form-select form-select-sm w-auto" id="mergePreviewCourse">
                  <option value="">Усі курси</option>
                  <% ['kyiv', 'munich'].forEach(function(location) { %>
                    <% const courseList = courseSemestersByLocation[location] || []; %>
                    <% courseList.forEach(function(row) { %>
                      <option value="<%= row.course.id %>" data-location="<%= location %>"><%= row.course.name %></option>
                    <% }); %>
                  <% }); %>
                </select>
                <button class="btn btn-outline-primary btn-sm" type="button" id="mergePreviewBtn">Показати dry-run</button>
              </div>
              <div id="mergePreviewMeta" class="small text-muted mt-2"></div>
              <div id="mergePreviewList" class="merge-preview-list mt-3 d-grid gap-2"></div>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Остання генерація</div>
              <% if (lastStats) { %>
                <div class="d-grid gap-2 mb-3">
                  <div class="glass-inset p-3">
                    <div class="small text-muted">Записів</div>
                    <div class="fw-semibold"><%= lastStats.entries %> пар</div>
                  </div>
                  <div class="glass-inset p-3">
                    <div class="small text-muted">Конфліктів</div>
                    <div class="fw-semibold"><%= lastStats.conflicts %></div>
                  </div>
                  <% if (lastStats.diff) { %>
                    <div class="glass-inset p-3">
                      <div class="small text-muted">Diff (Preview)</div>
                      <div class="fw-semibold">+<%= lastStats.diff.added %> · ~<%= lastStats.diff.updated %> · −<%= lastStats.diff.removed %></div>
                      <div class="small text-muted">Overwrite slots: <%= lastStats.diff.overwrite %></div>
                      <div class="small text-muted">Manual overwrite: TODO (needs `is_manual`)</div>
                    </div>
                  <% } %>
                  <div class="small text-muted">Оновлено: <%= lastStats.generated_at ? new Date(lastStats.generated_at).toLocaleString('uk-UA') : '' %></div>
                  <div class="small text-muted">Operation: <%= lastStats.operation_id || '—' %></div>
                  <% if (lastStats.scope) { %>
                    <div class="small text-muted">
                      <% if (lastStats.scope.type === 'course') { %>
                        Курс: <%= courseById[lastStats.scope.course_id] || 'Невідомий' %>
                      <% } else { %>
                        Локація: <%= lastStats.scope.location === 'munich' ? 'Munich' : 'Kyiv' %>
                      <% } %>
                    </div>
                  <% } %>
                </div>
              <% } else { %>
                <div class="generator-empty mb-3">Ще не запускали генерацію.</div>
              <% } %>
              <% if (lastConflicts && lastConflicts.length) { %>
                <div class="small text-muted mb-2">Проблеми:</div>
                <div class="d-grid gap-2">
                  <% lastConflicts.slice(0, 5).forEach(function(conflict) { %>
                    <div class="glass-inset p-2">
                      <div class="fw-semibold"><%= conflict.subject || 'Без предмета' %></div>
                      <div class="small text-muted"><%= conflict.reason %></div>
                    </div>
                  <% }); %>
                </div>
              <% } %>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-1">Карта завантаження (день × пара)</div>
              <div class="small text-muted mb-2">Чим темніша клітинка, тим більше занять у цьому слоті. Цифра в клітинці — кількість занять.</div>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const heatmap = heatmapByLocation && heatmapByLocation[location]; %>
                <% const insight = generationInsightsByLocation && generationInsightsByLocation[location]; %>
                <div class="heatmap" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (!heatmap || !heatmap.max) { %>
                    <div class="generator-empty">Немає даних для теплової карти.</div>
                  <% } else { %>
                    <% const latePercent = insight ? Math.round((insight.lateShare || 0) * 100) : 0; %>
                    <% const imbalancePercent = insight ? Math.round((insight.dayImbalance || 0) * 100) : 0; %>
                    <% const lateLevel = latePercent >= 30 ? 'високе навантаження' : latePercent >= 18 ? 'помірне' : 'низьке'; %>
                    <% const balanceLevel = imbalancePercent >= 45 ? 'сильний перекіс' : imbalancePercent >= 25 ? 'помірний перекіс' : 'рівномірно'; %>
                    <% const peakDay = insight && insight.peakDay && insight.peakDay.day ? insight.peakDay.day : null; %>
                    <% const peakDayIdx = peakDay ? dayOptions.indexOf(peakDay) : -1; %>
                    <% const peakDayLabel = peakDayIdx >= 0 ? (dayLabels[peakDayIdx] || peakDay) : (peakDay || '—'); %>
                    <div class="heatmap-summary mb-2">
                      <span class="heatmap-summary-chip">Вечірні пари: <strong><%= latePercent %>%</strong> (<%= lateLevel %>)</span>
                      <span class="heatmap-summary-chip">Рівномірність по днях: <strong><%= balanceLevel %></strong></span>
                      <span class="heatmap-summary-chip">Найбільше навантаження: <strong><%= peakDayLabel %></strong></span>
                    </div>
                    <div class="heatmap-legend mb-2">
                      <span class="heatmap-legend-label">Інтенсивність:</span>
                      <span class="heatmap-legend-chip is-low">Низька</span>
                      <span class="heatmap-legend-chip is-mid">Середня</span>
                      <span class="heatmap-legend-chip is-high">Висока</span>
                    </div>
                    <div class="heatmap-grid">
                      <div class="heatmap-row heatmap-head">
                        <span class="heatmap-label"></span>
                        <% classOptions.forEach(function(slot) { %>
                          <span class="heatmap-head-cell">#<%= slot %></span>
                        <% }); %>
                      </div>
                      <% dayOptions.forEach(function(day) { %>
                        <% const dayLabel = dayLabels[dayOptions.indexOf(day)] || day.slice(0, 2); %>
                        <div class="heatmap-row">
                          <span class="heatmap-label"><%= dayLabel %></span>
                          <% classOptions.forEach(function(slot) { %>
                            <% const count = heatmap.counts && heatmap.counts[day] ? heatmap.counts[day][slot] : 0; %>
                            <% const intensity = heatmap.max ? (count / heatmap.max) : 0; %>
                            <span
                              class="heatmap-cell"
                              style="--heat:<%= intensity.toFixed(2) %>;"
                              title="<%= dayLabel %>, пара <%= slot %>: <%= count %> занять"
                            >
                              <%= count ? count : '' %>
                            </span>
                          <% }); %>
                        </div>
                      <% }); %>
                    </div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel">
            <div class="card-body">
              <div class="generator-section-title mb-2">Викладачі</div>
              <% if (teachers && teachers.length) { %>
                <div class="d-grid gap-3">
                  <% teachers.forEach(function(teacher) { %>
                    <% const limit = limitsByTeacher[teacher.id] || {}; %>
                    <form method="POST" action="/admin/schedule-generator/teachers/save" class="glass-inset p-3">
                      <input type="hidden" name="run_id" value="<%= run.id %>" />
                      <input type="hidden" name="teacher_id" value="<%= teacher.id %>" />
                      <div class="fw-semibold mb-2"><%= teacher.full_name %></div>
                      <div class="teacher-days mb-2">
                        <% dayOptions.forEach(function(day, idx) { %>
                          <% const label = dayLabels[idx] || day.slice(0, 2); %>
                          <label class="teacher-day-pill">
                            <input
                              class="form-check-input"
                              type="checkbox"
                              name="allowed_days"
                              value="<%= day %>"
                              <%= (limit.allowed_weekdays || []).includes(day) ? 'checked' : '' %>
                            />
                            <span><%= label %></span>
                          </label>
                        <% }); %>
                      </div>
                      <div class="d-flex align-items-center gap-2">
                        <div class="flex-grow-1">
                          <label class="form-label small">Max пар/тиждень</label>
                          <input
                            class="form-control form-control-sm"
                            type="number"
                            name="max_pairs_per_week"
                            min="1"
                            placeholder="Без ліміту"
                            value="<%= limit.max_pairs_per_week || '' %>"
                          />
                        </div>
                        <button class="btn btn-outline-primary btn-sm" type="submit">Зберегти</button>
                      </div>
                    </form>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="generator-empty">Немає викладачів.</div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-8">
          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Додати предмет</div>
              <form method="POST" action="/admin/schedule-generator/items/add" class="row g-3">
                <input type="hidden" name="run_id" value="<%= run.id %>" />
                <div class="col-12 col-md-4">
                  <label class="form-label">Курс</label>
                  <select class="form-select" name="course_id" id="genCourseSelect" required>
                    <% Object.values(coursesByLocation).flat().forEach(function(course) { %>
                      <option value="<%= course.id %>" data-location="<%= course.location || 'kyiv' %>"><%= course.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label">Предмет</label>
                  <select class="form-select" name="subject_id" id="genSubjectSelect" required>
                    <% Object.values(coursesByLocation).flat().forEach(function(course) { %>
                      <optgroup label="<%= course.name %>" data-location="<%= course.location || 'kyiv' %>">
                        <% (subjectsByCourse[course.id] || []).forEach(function(subject) { %>
                          <option value="<%= subject.id %>" data-course="<%= course.id %>" data-group-count="<%= subject.group_count %>">
                            <%= subject.name %>
                          </option>
                        <% }); %>
                      </optgroup>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label">Тип заняття</label>
                  <select class="form-select" name="lesson_type">
                    <option value="lecture">Лекція</option>
                    <option value="seminar">Семінар</option>
                    <option value="lab">Лаб</option>
                    <option value="practice">Практика</option>
                  </select>
                </div>
                <div class="col-6 col-md-3">
                  <label class="form-label">Група</label>
                  <select class="form-select" name="group_number" id="genGroupSelect">
                    <option value="all">Усі групи</option>
                    <option value="1" data-group="1">1</option>
                    <option value="2" data-group="2">2</option>
                    <option value="3" data-group="3">3</option>
                  </select>
                </div>
                <div class="col-6 col-md-3">
                  <label class="form-label">К-сть пар</label>
                  <input class="form-control" type="number" name="pairs_count" min="1" value="1" required />
                </div>
                <div class="col-12 col-md-3">
                  <label class="form-label">Викладач</label>
                  <select class="form-select" name="teacher_id">
                    <option value="">Без викладача</option>
                    <% teachers.forEach(function(teacher) { %>
                      <option value="<%= teacher.id %>"><%= teacher.full_name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12 col-md-3">
                  <label class="form-label">Ключ дзеркала</label>
                  <input class="form-control" name="mirror_key" id="mirrorKeyInput" placeholder="A1" />
                  <div class="mirror-key-actions mt-2">
                    <button class="btn btn-outline-secondary btn-sm" type="button" id="mirrorKeyGenerate">Згенерувати</button>
                    <button class="btn btn-outline-secondary btn-sm" type="button" id="mirrorKeyCopy">Копіювати</button>
                  </div>
                  <div class="form-text text-muted">Однаковий ключ для груп 1/2.</div>
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label">Тижні (необовʼязково)</label>
                  <input class="form-control" name="weeks_set" placeholder="1-2,5,7" />
                </div>
                <div class="col-6 col-md-4">
                  <label class="form-label">Фіксований день</label>
                  <select class="form-select" name="fixed_day">
                    <option value="">Будь-який</option>
                    <% dayOptions.forEach(function(day) { %>
                      <option value="<%= day %>"><%= day %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-6 col-md-4">
                  <label class="form-label">Фіксований слот</label>
                  <select class="form-select" name="fixed_class_number">
                    <option value="">Будь-який</option>
                    <% classOptions.forEach(function(n) { %>
                      <option value="<%= n %>"><%= n %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12 col-md-6 d-grid">
                  <button class="btn btn-primary" type="submit">Додати до генератора</button>
                </div>
              </form>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="generator-section-title">Дзеркальні ключі</div>
                <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#mirrorAutoModal">
                  Авто-пари A/B
                </button>
              </div>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const mirrorSummary = mirrorSummaryByLocation && mirrorSummaryByLocation[location]; %>
                <div class="d-grid gap-2" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (!mirrorSummary || !mirrorSummary.length) { %>
                    <div class="generator-empty">Немає дзеркальних ключів.</div>
                  <% } else { %>
                    <% mirrorSummary.forEach(function(group) { %>
                      <div class="glass-inset p-3 mirror-row <%= group.status === 'ok' ? '' : 'mirror-warn' %>">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                          <div class="fw-semibold"><%= group.key %></div>
                          <span class="badge <%= group.status === 'ok' ? 'bg-success' : group.status === 'warn' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                            <%= group.status === 'ok' ? 'OK' : group.status === 'warn' ? 'Проблема' : 'Немає пари' %>
                          </span>
                        </div>
                        <div class="small text-muted">
                          Група 1: <%= group.group1 %> · Група 2: <%= group.group2 %>
                        </div>
                        <% if (group.subjects && group.subjects.length) { %>
                          <div class="small text-muted">Предмети: <%= group.subjects.join(', ') %></div>
                        <% } %>
                        <% if (group.courses && group.courses.length) { %>
                          <div class="small text-muted">Курси: <%= group.courses.join(', ') %></div>
                        <% } %>
                      </div>
                    <% }); %>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel mb-4">
            <div class="card-body">
              <div class="generator-section-title mb-2">Конфлікти після генерації</div>
              <% const conflictLabels = { missing_course_context: 'Немає активного семестру', missing_weeks_count: 'Не задано кількість тижнів', no_available_weeks: 'Немає доступних тижнів', no_allowed_days: 'Немає доступних днів', no_allowed_classes: 'Немає дозволених слотів', no_slot_found: 'Немає слота', partial_schedule: 'Часткова генерація', subject_day_mismatch: 'Предмет має різні дні', unknown: 'Невідома причина' }; %>
              <% const rejectionLabels = { course_slot_busy: 'Слот зайнятий лекцією/курсом', lecture_slot_busy: 'Слот блокує лекція', subject_slot_busy: 'Предмет уже стоїть у цей слот', lecture_must_be_first: 'Семінар має бути після лекції', teacher_slot_busy: 'Викладач зайнятий', group_slot_busy: 'Група зайнята', group_day_limit: 'Ліміт пар/день у групи', teacher_week_limit: 'Ліміт викладача на тиждень', unknown: 'Інше' }; %>
              <% ['kyiv', 'munich'].forEach(function(location) { %>
                <% const conflicts = conflictDetails && conflictDetails[location]; %>
                <div class="d-grid gap-2" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                  <% if (!conflicts || !conflicts.length) { %>
                    <div class="generator-empty">Конфліктів немає.</div>
                  <% } else { %>
                    <% conflicts.slice(0, 6).forEach(function(conflict) { %>
                      <div class="glass-inset p-3 conflict-row">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                          <div class="fw-semibold"><%= conflict.subject || 'Без предмета' %></div>
                          <span class="badge bg-danger">Проблема</span>
                        </div>
                        <div class="small text-muted">
                          <%= conflictLabels[conflict.reason] || conflict.reason || conflictLabels.unknown %>
                          <% if (conflict.scheduled) { %> · <%= conflict.scheduled %><% } %>
                          <% if (conflict.target) { %> / <%= conflict.target %><% } %>
                        </div>
                        <% if (conflict.items && conflict.items.length) { %>
                          <div class="small text-muted mt-1">
                            <% conflict.items.forEach(function(item, idx) { %>
                              <span><%= item.course %> · <%= item.group %> · <%= item.teacher || 'Без викладача' %></span><%= idx < conflict.items.length - 1 ? ' · ' : '' %>
                            <% }); %>
                          </div>
                        <% } %>
                        <% if (conflict.diagnostics && conflict.diagnostics.top_rejections && conflict.diagnostics.top_rejections.length) { %>
                          <div class="small text-muted mt-1">
                            Причини відсіву слотів:
                            <% conflict.diagnostics.top_rejections.forEach(function(reason, idx) { %>
                              <span><%= rejectionLabels[reason.reason] || reason.reason %> (<%= reason.count %>)</span><%= idx < conflict.diagnostics.top_rejections.length - 1 ? ' · ' : '' %>
                            <% }); %>
                          </div>
                        <% } %>
                      </div>
                    <% }); %>
                    <% if (conflicts.length > 6) { %>
                      <div class="small text-muted">Ще <%= conflicts.length - 6 %> конфліктів.</div>
                    <% } %>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="card glass-panel">
            <div class="card-body">
              <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="generator-section-title">План занять</div>
                <% ['kyiv', 'munich'].forEach(function(location) { %>
                  <% const problemCount = problemItemLookupByLocation && problemItemLookupByLocation[location] ? Object.keys(problemItemLookupByLocation[location]).length : 0; %>
                  <div class="form-check form-switch m-0 problem-toggle" data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                    <input class="form-check-input" type="checkbox" id="problemToggle-<%= location %>" <%= problemCount ? '' : 'disabled' %> />
                    <label class="form-check-label small" for="problemToggle-<%= location %>">
                      Показати проблемні (<%= problemCount %>)
                    </label>
                  </div>
                <% }); %>
              </div>
              <% if (items && items.length) { %>
                <div class="table-responsive">
                  <table class="table generator-table align-middle">
                    <thead>
                      <tr>
                        <th>Курс</th>
                        <th>Предмет</th>
                        <th>Тип</th>
                        <th>Група</th>
                        <th>Викладач</th>
                        <th>Пар</th>
                        <th>Тижні</th>
                        <th>Дзеркало</th>
                        <th>Фікс. день</th>
                        <th>Фікс. слот</th>
                        <th>Дії</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% items.forEach(function(item) { %>
                        <% const rowLocation = courseLocationMap[item.course_id] || 'kyiv'; %>
                        <% const problemLevel = problemItemLookupByLocation && problemItemLookupByLocation[rowLocation] ? problemItemLookupByLocation[rowLocation][item.id] : null; %>
                        <% const hasConflict = conflictItemIds && conflictItemIds[rowLocation] ? conflictItemIds[rowLocation].has(item.id) : false; %>
                        <% const isFixed = item.fixed_day || item.fixed_class_number; %>
                        <tr
                          data-location-row
                          data-location="<%= rowLocation %>"
                          data-item-id="<%= item.id %>"
                          data-problem="<%= problemLevel ? 'true' : 'false' %>"
                          data-problem-level="<%= problemLevel || '' %>"
                          data-conflict="<%= hasConflict ? 'true' : 'false' %>"
                          data-fixed="<%= isFixed ? 'true' : 'false' %>"
                          class="<%= problemLevel ? 'problem-row' : '' %>"
                        >
                          <td>
                            <select class="form-select form-select-sm" name="course_id" form="gen-item-<%= item.id %>">
                              <% Object.values(coursesByLocation).flat().forEach(function(course) { %>
                                <option value="<%= course.id %>" <%= Number(item.course_id) === Number(course.id) ? 'selected' : '' %>><%= course.name %></option>
                              <% }); %>
                            </select>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="subject_id" form="gen-item-<%= item.id %>">
                              <% Object.values(coursesByLocation).flat().forEach(function(course) { %>
                                <optgroup label="<%= course.name %>">
                                  <% (subjectsByCourse[course.id] || []).forEach(function(subject) { %>
                                    <option value="<%= subject.id %>" <%= Number(item.subject_id) === Number(subject.id) ? 'selected' : '' %>>
                                      <%= subject.name %>
                                    </option>
                                  <% }); %>
                                </optgroup>
                              <% }); %>
                            </select>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="lesson_type" form="gen-item-<%= item.id %>">
                              <option value="lecture" <%= item.lesson_type === 'lecture' ? 'selected' : '' %>>Лекція</option>
                              <option value="seminar" <%= item.lesson_type === 'seminar' ? 'selected' : '' %>>Семінар</option>
                              <option value="lab" <%= item.lesson_type === 'lab' ? 'selected' : '' %>>Лаб</option>
                              <option value="practice" <%= item.lesson_type === 'practice' ? 'selected' : '' %>>Практика</option>
                            </select>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="group_number" form="gen-item-<%= item.id %>">
                              <option value="all" <%= item.group_number === null || typeof item.group_number === 'undefined' ? 'selected' : '' %>>Усі</option>
                              <option value="1" <%= Number(item.group_number) === 1 ? 'selected' : '' %>>1</option>
                              <option value="2" <%= Number(item.group_number) === 2 ? 'selected' : '' %>>2</option>
                              <option value="3" <%= Number(item.group_number) === 3 ? 'selected' : '' %>>3</option>
                            </select>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="teacher_id" form="gen-item-<%= item.id %>">
                              <option value="">—</option>
                              <% teachers.forEach(function(teacher) { %>
                                <option value="<%= teacher.id %>" <%= Number(item.teacher_id) === Number(teacher.id) ? 'selected' : '' %>>
                                  <%= teacher.full_name %>
                                </option>
                              <% }); %>
                            </select>
                          </td>
                          <td>
                            <input class="form-control form-control-sm" type="number" name="pairs_count" min="1" form="gen-item-<%= item.id %>" value="<%= item.pairs_count %>" />
                          </td>
                          <td>
                            <input class="form-control form-control-sm" name="weeks_set" form="gen-item-<%= item.id %>" value="<%= item.weeks_set || '' %>" />
                          </td>
                          <td>
                            <div class="mirror-key-field">
                              <input
                                class="form-control form-control-sm"
                                name="mirror_key"
                                id="mirror-key-<%= item.id %>"
                                form="gen-item-<%= item.id %>"
                                value="<%= item.mirror_key || '' %>"
                              />
                              <button
                                class="btn btn-outline-secondary btn-sm mirror-key-copy"
                                type="button"
                                data-target="mirror-key-<%= item.id %>"
                              >
                                Копіювати
                              </button>
                            </div>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="fixed_day" form="gen-item-<%= item.id %>">
                              <option value="">—</option>
                              <% dayOptions.forEach(function(day) { %>
                                <option value="<%= day %>" <%= item.fixed_day === day ? 'selected' : '' %>><%= day %></option>
                              <% }); %>
                            </select>
                          </td>
                          <td>
                            <select class="form-select form-select-sm" name="fixed_class_number" form="gen-item-<%= item.id %>">
                              <option value="">—</option>
                              <% classOptions.forEach(function(n) { %>
                                <option value="<%= n %>" <%= Number(item.fixed_class_number) === Number(n) ? 'selected' : '' %>><%= n %></option>
                              <% }); %>
                            </select>
                          </td>
                          <td class="d-flex flex-wrap gap-2">
                            <form id="gen-item-<%= item.id %>" method="POST" action="/admin/schedule-generator/items/edit/<%= item.id %>">
                              <input type="hidden" name="run_id" value="<%= run.id %>" />
                            </form>
                            <button class="btn btn-sm btn-outline-primary" type="submit" form="gen-item-<%= item.id %>">Save</button>
                            <% if (isFixed) { %>
                              <form method="POST" action="/admin/schedule-generator/items/unfreeze/<%= item.id %>">
                                <input type="hidden" name="run_id" value="<%= run.id %>" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Unlock</button>
                              </form>
                            <% } else { %>
                              <form method="POST" action="/admin/schedule-generator/items/freeze/<%= item.id %>">
                                <input type="hidden" name="run_id" value="<%= run.id %>" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Lock</button>
                              </form>
                            <% } %>
                            <form method="POST" action="/admin/schedule-generator/items/delete/<%= item.id %>">
                              <input type="hidden" name="run_id" value="<%= run.id %>" />
                              <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('Видалити запис?');">Delete</button>
                            </form>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="generator-empty">Додайте предмети, щоб створити план.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/app-footer') %>

      <%- include('partials/changelog-modal') %>

      <div class="modal fade" id="mirrorAutoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content glass-panel">
            <div class="modal-header">
              <h5 class="modal-title">Авто-пари для дзеркала</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="POST" action="/admin/schedule-generator/mirror-auto">
              <input type="hidden" name="run_id" value="<%= run.id %>" />
              <div class="modal-body">
                <div class="text-muted small mb-3">
                  Ми підберемо пари для груп 1/2 з однаковою кількістю пар і без фіксованих тижнів/слотів.
                  Загальні предмети та предмети з уже заданими дзеркалами не включаємо.
                </div>
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <button class="btn btn-outline-secondary btn-sm" type="button" data-mirror-select="all">Вибрати всі</button>
                  <button class="btn btn-outline-secondary btn-sm" type="button" data-mirror-select="none">Зняти всі</button>
                </div>
                <% ['kyiv', 'munich'].forEach(function(location) { %>
                  <% const candidates = autoMirrorCandidatesByLocation && autoMirrorCandidatesByLocation[location]; %>
                  <div data-location-section="<%= location %>" style="<%= activeLocation === location ? '' : 'display: none;' %>">
                    <% if (!candidates || !candidates.length) { %>
                      <div class="validation-empty">Немає кандидатів для автопар у цій локації.</div>
                    <% } else { %>
                      <div class="list-group mirror-auto-list">
                        <% candidates.forEach(function(pair) { %>
                          <label class="list-group-item d-flex gap-3 align-items-start">
                            <input
                              class="form-check-input mt-1"
                              type="checkbox"
                              name="mirror_pairs[]"
                              value="<%= pair.a.id %>:<%= pair.b.id %>"
                              data-location="<%= location %>"
                              <%= activeLocation === location ? '' : 'disabled' %>
                              checked
                            />
                            <div>
                              <div class="fw-semibold">
                                Група 1: <%= pair.a.subject_name %> → Група 2: <%= pair.b.subject_name %>
                              </div>
                              <div class="small text-muted">
                                <%= pair.course_name %> · <%= pair.lesson_type === 'seminar' ? 'Семінар' : pair.lesson_type %> · <%= pair.pairs_count %> пар
                              </div>
                            </div>
                          </label>
                        <% }); %>
                      </div>
                    <% } %>
                    <% const exclusions = autoMirrorExclusionsByLocation && autoMirrorExclusionsByLocation[location]; %>
                    <% if (exclusions && exclusions.length) { %>
                      <% const shown = exclusions.slice(0, 60); %>
                      <details class="mirror-auto-exclusions mt-3">
                        <summary>Чому не попало в авто‑пари (<%= exclusions.length %>)</summary>
                        <div class="list-group mirror-exclusion-list mt-2">
                          <% shown.forEach(function(item) { %>
                            <div class="list-group-item">
                              <div class="fw-semibold">
                                <%= item.subject_name %>
                                <span class="small text-muted">· Група <%= item.group_number || '—' %></span>
                              </div>
                              <div class="small text-muted">
                                <%= item.course_name %> · <%= item.lesson_type === 'seminar' ? 'Семінар' : item.lesson_type %> · <%= item.pairs_count %> пар
                              </div>
                              <div class="d-flex flex-wrap gap-2 mt-2">
                                <% item.reasons.forEach(function(reason) { %>
                                  <span class="mirror-reason-chip"><%= reason %></span>
                                <% }); %>
                              </div>
                            </div>
                          <% }); %>
                          <% if (exclusions.length > shown.length) { %>
                            <div class="small text-muted">
                              Ще <%= exclusions.length - shown.length %> записів.
                            </div>
                          <% } %>
                        </div>
                      </details>
                    <% } %>
                  </div>
                <% }); %>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Скасувати</button>
                <button type="submit" class="btn btn-primary">Застосувати пари</button>
              </div>
            </form>
          </div>
        </div>
      </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        const applyTheme = (theme) => {
          document.body.classList.toggle('theme-light', theme === 'light');
          document.body.classList.toggle('theme-dark', theme === 'dark');
          themeToggle.textContent = theme === 'light' ? themeToggle.dataset.darkLabel : themeToggle.dataset.lightLabel;
        };
        const stored = localStorage.getItem('theme') || 'light';
        applyTheme(stored);
        themeToggle.addEventListener('click', () => {
          const next = document.body.classList.contains('theme-light') ? 'dark' : 'light';
          localStorage.setItem('theme', next);
          applyTheme(next);
        });
      }

      const locationButtons = document.querySelectorAll('.location-toggle');
      const locationInput = document.getElementById('activeLocationInput');
      const runLocationInput = document.getElementById('runLocationInput');
      const autoTuneLocationInput = document.getElementById('autoTuneLocationInput');
      const locationSections = document.querySelectorAll('[data-location-section]');
      const locationRows = document.querySelectorAll('[data-location-row]');

      const courseSelect = document.getElementById('genCourseSelect');
      const subjectSelect = document.getElementById('genSubjectSelect');
      const groupSelect = document.getElementById('genGroupSelect');
      const courseOptions = courseSelect ? Array.from(courseSelect.options) : [];
      const subjectGroups = subjectSelect ? Array.from(subjectSelect.querySelectorAll('optgroup')) : [];
      const runButtons = document.querySelectorAll('[data-disable-kyiv]');
      const mirrorAutoModal = document.getElementById('mirrorAutoModal');
      const mirrorAutoInputs = mirrorAutoModal
        ? Array.from(mirrorAutoModal.querySelectorAll('input[name="mirror_pairs[]"]'))
        : [];
      const mergePreviewBtn = document.getElementById('mergePreviewBtn');
      const mergePreviewCourse = document.getElementById('mergePreviewCourse');
      const mergePreviewList = document.getElementById('mergePreviewList');
      const mergePreviewMeta = document.getElementById('mergePreviewMeta');
      const mergePreviewOptions = mergePreviewCourse ? Array.from(mergePreviewCourse.options) : [];
      const scopeCard = document.getElementById('generatorScopeCard');
      const scopeFields = scopeCard ? Array.from(scopeCard.querySelectorAll('[data-scope-field]')) : [];
      const runForms = document.querySelectorAll('.generator-run-form');

      const evennessRange = document.getElementById('evennessBiasRange');
      const evennessValue = document.getElementById('evennessBiasValue');
      if (evennessRange && evennessValue) {
        const syncEvenness = () => {
          evennessValue.textContent = `${evennessRange.value}%`;
        };
        syncEvenness();
        evennessRange.addEventListener('input', syncEvenness);
      }

      const lateSlotRange = document.getElementById('lateSlotWeightRange');
      const lateSlotValue = document.getElementById('lateSlotWeightValue');
      if (lateSlotRange && lateSlotValue) {
        const syncLateSlots = () => {
          lateSlotValue.textContent = `${lateSlotRange.value}%`;
        };
        syncLateSlots();
        lateSlotRange.addEventListener('input', syncLateSlots);
      }

      const mirrorKeyInput = document.getElementById('mirrorKeyInput');
      const mirrorKeyGenerate = document.getElementById('mirrorKeyGenerate');
      const mirrorKeyCopy = document.getElementById('mirrorKeyCopy');

      const collectScopeValues = () => {
        const values = {};
        scopeFields.forEach((field) => {
          if (field.type === 'checkbox') {
            if (!values[field.name]) values[field.name] = [];
            if (field.checked) values[field.name].push(field.value);
            return;
          }
          values[field.name] = field.value;
        });
        return values;
      };

      const syncScopeToForm = (form) => {
        if (!form) return;
        form.querySelectorAll('[data-scope-hidden]').forEach((el) => el.remove());
        const values = collectScopeValues();
        Object.keys(values).forEach((name) => {
          const value = values[name];
          if (Array.isArray(value)) {
            value.forEach((val) => {
              if (!val) return;
              const input = document.createElement('input');
              input.type = 'hidden';
              input.name = name;
              input.value = val;
              input.dataset.scopeHidden = '1';
              form.appendChild(input);
            });
            return;
          }
          if (!value) return;
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = name;
          input.value = value;
          input.dataset.scopeHidden = '1';
          form.appendChild(input);
        });
      };

      const generateMirrorKey = () => {
        const seed = Math.random().toString(36).slice(2, 5).toUpperCase();
        const time = Date.now().toString(36).slice(-3).toUpperCase();
        return `M-${time}${seed}`;
      };

      const copyText = async (text) => {
        if (!text) return;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      };

      if (mirrorKeyGenerate && mirrorKeyInput) {
        mirrorKeyGenerate.addEventListener('click', () => {
          mirrorKeyInput.value = generateMirrorKey();
          mirrorKeyInput.focus();
        });
      }
      if (mirrorKeyCopy && mirrorKeyInput) {
        mirrorKeyCopy.addEventListener('click', () => copyText(mirrorKeyInput.value));
      }
      document.querySelectorAll('.mirror-key-copy').forEach((btn) => {
        btn.addEventListener('click', () => {
          const targetId = btn.dataset.target;
          const input = targetId ? document.getElementById(targetId) : null;
          if (input) copyText(input.value);
        });
      });

      const problemToggles = {
        kyiv: document.getElementById('problemToggle-kyiv'),
        munich: document.getElementById('problemToggle-munich'),
      };

      const applyProblemFilter = (location) => {
        const toggle = problemToggles[location];
        const onlyProblem = toggle && toggle.checked;
        locationRows.forEach((row) => {
          if (row.dataset.location !== location) return;
          if (!onlyProblem) {
            row.style.display = '';
            return;
          }
          row.style.display = row.dataset.problem === 'true' ? '' : 'none';
        });
      };

      Object.entries(problemToggles).forEach(([location, toggle]) => {
        if (!toggle) return;
        toggle.addEventListener('change', () => applyProblemFilter(location));
      });

      const updateRunButtons = (location) => {
        runButtons.forEach((btn) => {
          const disable = location === 'munich' ? btn.dataset.disableMunich === 'true' : btn.dataset.disableKyiv === 'true';
          btn.disabled = disable;
        });
      };

      const setMergePreviewMeta = (text) => {
        if (mergePreviewMeta) {
          mergePreviewMeta.textContent = text || '';
        }
      };

      const clearMergePreview = () => {
        if (mergePreviewList) mergePreviewList.innerHTML = '';
      };

      const renderMergePreview = (payload) => {
        clearMergePreview();
        const total = Number(payload?.total || 0);
        setMergePreviewMeta(total ? `Знайдено ${total} злиттів` : 'Немає предметів для злиття.');
        if (!total || !mergePreviewList) return;
        (payload.merges || []).forEach((item) => {
          const card = document.createElement('div');
          card.className = 'glass-inset p-3 merge-preview-item';

          const title = document.createElement('div');
          title.className = 'fw-semibold';
          title.textContent = item.base_name || item.canonical_name || 'Без назви';

          const meta = document.createElement('div');
          meta.className = 'small text-muted';
          const courseLabel = item.course_name ? `${item.course_name} • ` : '';
          const lectureName = item.lecture?.name || '-';
          const seminarName = item.seminar?.name || '-';
          meta.textContent = `${courseLabel}Лекція: ${lectureName} • Семінар: ${seminarName}`;

          const canonical = document.createElement('div');
          canonical.className = 'small';
          const sourceLabel = item.canonical_source || 'base';
          canonical.textContent = `Канонічний: ${item.canonical_name || ''} (${sourceLabel})`;

          card.append(title, meta, canonical);

          if (item.rename && item.rename.from && item.rename.to) {
            const rename = document.createElement('div');
            rename.className = 'small text-muted';
            rename.textContent = `Перейменування: ${item.rename.from} → ${item.rename.to}`;
            card.append(rename);
          }
          if (item.rename_conflict) {
            const warn = document.createElement('div');
            warn.className = 'small text-warning';
            warn.textContent = 'Конфлікт перейменування: назва вже існує.';
            card.append(warn);
          }

          mergePreviewList.appendChild(card);
        });
      };

      if (mergePreviewBtn) {
        mergePreviewBtn.addEventListener('click', async () => {
          const originalText = mergePreviewBtn.textContent;
          mergePreviewBtn.disabled = true;
          mergePreviewBtn.textContent = 'Завантаження...';
          setMergePreviewMeta('Завантажуємо список...');
          clearMergePreview();
          try {
            const params = new URLSearchParams();
            const selectedCourse = mergePreviewCourse ? String(mergePreviewCourse.value || '') : '';
            if (selectedCourse) params.set('course_id', selectedCourse);
            const url = `/admin/schedule-generator/merge-preview${params.toString() ? `?${params.toString()}` : ''}`;
            const response = await fetch(url, { headers: { Accept: 'application/json' } });
            if (!response.ok) {
              throw new Error('Request failed');
            }
            const data = await response.json();
            renderMergePreview(data);
          } catch (err) {
            setMergePreviewMeta('Не вдалося отримати dry-run. Спробуйте ще раз.');
          } finally {
            mergePreviewBtn.disabled = false;
            mergePreviewBtn.textContent = originalText;
          }
        });
      }

      if (runForms.length && scopeFields.length) {
        runForms.forEach((form) => {
          form.addEventListener('submit', () => {
            syncScopeToForm(form);
          });
        });
      }

      function syncSubjects() {
        if (!courseSelect || !subjectSelect) return;
        const courseId = courseSelect.value;
        const options = Array.from(subjectSelect.querySelectorAll('option'));
        options.forEach((opt) => {
          const optCourse = opt.dataset.course;
          const show = !optCourse || optCourse === courseId;
          opt.hidden = !show;
        });
        const visible = options.find((opt) => !opt.hidden);
        if (visible) {
          subjectSelect.value = visible.value;
        }
        syncGroupOptions();
      }

      function syncGroupOptions() {
        if (!subjectSelect || !groupSelect) return;
        const selected = subjectSelect.options[subjectSelect.selectedIndex];
        const groupCount = Number(selected?.dataset?.groupCount || 1);
        Array.from(groupSelect.querySelectorAll('option[data-group]')).forEach((opt) => {
          const num = Number(opt.dataset.group);
          opt.disabled = num > groupCount;
        });
      }

      function applyLocation(location) {
        const safe = location === 'munich' ? 'munich' : 'kyiv';
        if (locationInput) locationInput.value = safe;
        if (runLocationInput) runLocationInput.value = safe;
        if (autoTuneLocationInput) autoTuneLocationInput.value = safe;
        updateRunButtons(safe);
        locationButtons.forEach((btn) => {
          btn.classList.toggle('active', btn.dataset.location === safe);
        });
        locationSections.forEach((section) => {
          const isActive = section.dataset.locationSection === safe;
          if (isActive) {
            section.style.removeProperty('display');
          } else {
            section.style.setProperty('display', 'none', 'important');
          }
          section.querySelectorAll('select[name^="course_semesters["]').forEach((select) => {
            select.disabled = !isActive;
          });
        });
        locationRows.forEach((row) => {
          row.style.display = row.dataset.location === safe ? '' : 'none';
        });
        applyProblemFilter(safe);
        if (courseOptions.length) {
          courseOptions.forEach((opt) => {
            const optLocation = opt.dataset.location || 'kyiv';
            opt.hidden = optLocation !== safe;
          });
          const firstVisible = courseOptions.find((opt) => !opt.hidden);
          if (firstVisible) {
            courseSelect.value = firstVisible.value;
          }
        }
        if (subjectGroups.length) {
          subjectGroups.forEach((group) => {
            const groupLocation = group.dataset.location || 'kyiv';
            const show = groupLocation === safe;
            group.hidden = !show;
            group.disabled = !show;
          });
        }
        syncSubjects();
        if (mirrorAutoInputs.length) {
          mirrorAutoInputs.forEach((input) => {
            const targetLocation = input.dataset.location || 'kyiv';
            input.disabled = targetLocation !== safe;
          });
        }
        if (mergePreviewOptions.length) {
          mergePreviewOptions.forEach((opt) => {
            if (!opt.value) {
              opt.hidden = false;
              return;
            }
            const optLocation = opt.dataset.location || 'kyiv';
            opt.hidden = optLocation !== safe;
          });
          if (mergePreviewCourse && mergePreviewCourse.selectedOptions.length) {
            const selected = mergePreviewCourse.selectedOptions[0];
            if (selected && selected.hidden) {
              mergePreviewCourse.value = '';
            }
          }
        }
      }

      if (courseSelect) {
        courseSelect.addEventListener('change', syncSubjects);
      }
      if (subjectSelect) {
        subjectSelect.addEventListener('change', syncGroupOptions);
      }
      if (locationButtons.length) {
        locationButtons.forEach((btn) => {
          btn.addEventListener('click', () => applyLocation(btn.dataset.location));
        });
      }

      if (mirrorAutoModal) {
        mirrorAutoModal.querySelectorAll('[data-mirror-select]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const mode = btn.dataset.mirrorSelect;
            const safe = locationInput ? locationInput.value : 'kyiv';
            mirrorAutoInputs.forEach((input) => {
              if (input.dataset.location !== safe || input.disabled) return;
              input.checked = mode === 'all';
            });
          });
        });
      }

      applyLocation(locationInput ? locationInput.value : 'kyiv');
    </script>
      <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
</html>
