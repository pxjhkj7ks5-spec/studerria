        additionalEdit: 'Day/slot',
        syncRows: 'Sync Rows',
        noRows: 'No subjects found for this semester.',
        extraItemsHint: (count) => `Hidden legacy rows in this scope: ${count}. They remain untouched until next sync for this scope.`,
        teacherSettingsMoved: 'Teacher day constraints are moved out of this page.',
        openAcademicSetup: 'Open Academic Setup',
        runTitle: 'Generate Preview',
        runHint: 'Generation runs for the selected course + semester scope.',
        generatePreview: 'Generate preview',
        openPreview: 'Open preview',
        settingsTitle: 'Generation Settings',
        settingsHint: 'Use only the controls that directly affect generation quality.',
        blockedWeeks: 'Special Study Weeks',
        blockedWeeksPlaceholder: 'For example: 2,5,9-10',
        specialWeeksMode: 'Special weeks behavior',
        specialWeeksBlock: 'Do not generate on these weeks',
        specialWeeksOverlay: 'Ignore list (normal generation)',
        maxDailyPairs: 'Max pairs/day',
        targetDailyPairs: 'Target pairs/day',
        distribution: 'Lecture week distribution',
        seminarDistribution: 'Seminar week distribution',
        distStart: 'Start',
        distEven: 'Even',
        distEnd: 'End',
        strictNoEvening: 'Strict: avoid 6-7 slots',
        preferCompactness: 'Prefer compact day layout',
        autoSubjectDays: 'Auto-balance subject weekdays',
        subjectSingleDay: 'Keep one subject on one weekday',
        lectureSeminarSameDay: 'Prefer lecture + seminar same day',
        lectureBeforeSeminar: 'Lecture before seminar',
        mirrorGroups: 'Enable mirror groups (A/B)',
        saveSettings: 'Save settings',
