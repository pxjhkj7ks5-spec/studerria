                                    </div>
                                  </div>
                                  <div class="academic-v2-actions">
                                    <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-subject" data-editor-payload='<%- toAttr(stageSubject) %>'>Edit</button>
                                    <form method="post" action="/admin/pathways/v2/stage-subjects/<%= stageSubject.id %>/delete">
                                      <%- renderFocusFields() %>
                                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                  </div>
                                </div>
                              </div>
                            <% }); %>
                          </div>
                        <% } else { %>
                          <div class="academic-v2-empty">No stage subjects yet.</div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </details>
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Activities</strong>
                    <span class="academic-v2-chip"><%= scopedStageSubjectActivitiesList.length %> templates</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
