  const workspaceScopeSummary = [
    { label: 'Програма', value: selectedProgram ? selectedProgram.name : 'Не вибрано' },
    { label: 'Когорта', value: selectedCohort ? `${selectedCohort.label} · ${selectedCohort.admission_year}` : 'Не вибрано' },
    { label: 'Курс', value: selectedGroup ? selectedGroup.label : 'Не вибрано' },
    { label: 'Етап', value: selectedGroup ? `Stage ${selectedGroup.stage_number}` : `Template ${activeTemplateStage}` },
    { label: 'Кампус', value: selectedGroup ? (campusLabelByKey.get(selectedGroup.campus_key) || selectedGroup.campus_key) : 'Не вибрано' },
    { label: 'Терм', value: selectedTerm ? selectedTerm.title : 'Усі терми' },
  ];
  const selectedGroupUsersList = (selectedGroupUsers || []).map((user) => ({
    ...user,
    current_group_label: user.group_label || (selectedGroup ? selectedGroup.label : ''),
    status_label: user.group_id ? 'Призначено' : 'Без курсу',
  }));
  const currentSubjectTemplateLinks = subjectCards.reduce((map, subject) => {
    const templateId = Number(subject.subject_template_id || 0);
    if (!templateId) {
      return map;
    }
    map.set(templateId, Number(map.get(templateId) || 0) + 1);
    return map;
  }, new Map());
  const workspaceDefaultMode = selectedGroup ? 'operate' : 'structure';
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Academic Setup v2</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/pages/admin-academic-v2.css" />
  </head>
  <body>
    <%- include('partials/theme-bootstrap-body') %>

    <main class="academic-v2-page">
      <form method="get" action="/admin/pathways" class="academic-v2-context-bar">
        <span class="academic-v2-context-bar-title">Academic Setup v2</span>
        <div class="academic-v2-context-bar-selectors">
          <select name="program_id" title="Програма">
            <% (programs || []).forEach((program) => { %>
              <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
            <% }); %>
          </select>
          <select name="cohort_id" title="Когорта">
            <% (scopedCohorts || []).forEach((cohort) => { %>
              <option value="<%= cohort.id %>" <%= Number(cohort.id) === activeCohortId ? 'selected' : '' %>><%= cohort.label %> · <%= cohort.admission_year %></option>
            <% }); %>
          </select>
          <select name="group_id" title="Курс">
            <% (scopedGroups || []).forEach((group) => { %>
              <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %> · s<%= group.stage_number %> · <%= campusLabelByKey.get(group.campus_key) || group.campus_key %></option>
            <% }); %>
          </select>
          <select name="term_id" title="Терм">
            <option value="">Усі терми</option>
            <% scopedTermsList.forEach((term) => { %>
              <option value="<%= term.id %>" <%= Number(term.id) === activeTermId ? 'selected' : '' %>><%= term.title %></option>
            <% }); %>
          </select>
          <input type="hidden" name="template_stage" value="<%= activeTemplateStage || 1 %>" />
          <input type="hidden" name="bachelor_catalog_source" value="<%= String(activeBachelorCatalogSourceKey || '').replace(/"/g, '&quot;') %>" />
          <button type="submit" class="btn btn-sm btn-primary">Apply</button>
        </div>
        <div class="academic-v2-context-bar-stats">
          <span><strong><%= Number(summary && summary.programs_total || 0) %></strong> prog</span>
          <span><strong><%= Number(summary && summary.groups_total || 0) %></strong> courses</span>
          <span><strong><%= Number(summary && summary.group_subjects_total || 0) %></strong> subj</span>
          <span><strong><%= Number(summary && summary.schedule_entries_total || 0) %></strong> slots</span>
        </div>
      </form>

      <div class="academic-v2-shell">

        <div class="academic-v2-layout">
          <aside class="academic-v2-sidebar">
            <div class="academic-v2-sidebar-title">Workspace</div>
            <div class="academic-v2-mode-toggle academic-v2-mode-toggle--triple">
              <button type="button" class="academic-v2-mode-button" data-mode-button="operate">Operate</button>
              <button type="button" class="academic-v2-mode-button" data-mode-button="structure">Structure</button>
              <button type="button" class="academic-v2-mode-button" data-mode-button="diagnostics">Diagnostics</button>
            </div>
            <div class="academic-v2-sidebar-group">
              <div class="academic-v2-sidebar-group-title">Status</div>
              <div class="academic-v2-sidebar-chip-stack">
                <span class="academic-v2-chip <%= selectedGroup ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= selectedGroup ? 'Scope ready' : 'Need course' %></span>
                <span class="academic-v2-chip"><%= subjectCards.length %> subj</span>
                <span class="academic-v2-chip"><%= termCards.length %> terms</span>
                <span class="academic-v2-chip <%= workspaceReadiness.scheduleConflictCount ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= workspaceReadiness.scheduleConflictCount %> warnings</span>
              </div>
            </div>
            <div class="academic-v2-sidebar-note" title="Запис іде тільки в academic_v2_* таблиці. Legacy-таблиці — лише проєкція для суміснісності.">
              <span aria-hidden="true">ℹ</span>
              <span>Source: <span class="academic-v2-code">academic_v2_*</span></span>
            </div>
            <div class="academic-v2-sidebar-group academic-v2-sidebar-group--utility">
              <nav class="academic-v2-sidebar-nav">
                <a class="academic-v2-nav-link" href="/admin/pathways?legacy=1"><span>Legacy</span><span class="academic-v2-code">↗</span></a>
                <a class="academic-v2-nav-link" href="/admin"><span>Admin</span><span class="academic-v2-code">←</span></a>
              </nav>
            </div>
          </aside>

          <div class="academic-v2-main">
            <% if (success) { %>
              <div class="academic-v2-alert academic-v2-alert--success"><strong>Збережено.</strong> <%= success %></div>
            <% } %>
            <% if (error) { %>
              <div class="academic-v2-alert academic-v2-alert--error"><strong>Помилка дії.</strong> <%= error %></div>
            <% } %>
            <% if (warning) { %>
              <div class="academic-v2-alert academic-v2-alert--warning"><strong>Збережено з попередженням.</strong> <%= warning %></div>
            <% } %>

            <div class="academic-v2-scope-strip">
              <div class="academic-v2-scope-strip-items">
                <% workspaceScopeSummary.forEach((item) => { %>
                  <span class="academic-v2-scope-pill" title="<%= item.label %>"><strong><%= item.value %></strong></span>
                <% }); %>
              </div>
              <div class="academic-v2-scope-strip-actions">
                <button type="button" class="btn btn-outline-secondary" data-mode-button="operate" data-workspace-tab-target="subjects">Предмети</button>
                <button type="button" class="btn btn-outline-secondary" data-mode-button="operate" data-workspace-tab-target="terms">Терми</button>
                <button type="button" class="btn btn-outline-secondary" data-mode-button="operate" data-workspace-tab-target="schedule">Розклад</button>
              </div>
            </div>

            <section class="academic-v2-card academic-v2-workspace-header-card">
              <div class="academic-v2-mode-toolbar" data-mode-panel="operate">
                <div class="academic-v2-mode-toolbar-head">
                  <div>
                    <h2 class="academic-v2-section-title">Workspace</h2>
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip"><%= subjectCards.length %> subjects</span>
                    <span class="academic-v2-chip"><%= activeTermCount %> active terms</span>
                    <span class="academic-v2-chip"><%= scheduleEntriesForViews.length %> slots</span>
                  </div>
                </div>
                <div class="academic-v2-workspace-tabs">
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="overview">Огляд</button>
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="subjects">Предмети</button>
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="terms">Терми</button>
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="schedule">Розклад</button>
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="teachers">Викладачі</button>
                  <button type="button" class="academic-v2-workspace-tab" data-workspace-tab-target="students">Студенти</button>
                </div>
              </div>
              <div class="academic-v2-mode-toolbar" data-mode-panel="structure">
                <div class="academic-v2-mode-toolbar-head">
                  <div>
                    <h2 class="academic-v2-section-title">Structure</h2>
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip"><%= Number(summary && summary.programs_total || 0) %> programs</span>
                    <span class="academic-v2-chip"><%= Number(summary && summary.groups_total || 0) %> courses</span>
                    <span class="academic-v2-chip"><%= scopedStageSubjectTemplatesList.length %> stage subjects</span>
                  </div>
                </div>
                <div class="academic-v2-workspace-tabs academic-v2-workspace-tabs--structure">
                  <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="programs">Programs</button>
                  <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="cohorts">Cohorts</button>
                  <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="courses">Courses</button>
                  <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="stage-templates">Stage Templates</button>
                  <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="subject-templates">Subject Templates</button>
                  <% if (isBachelorProgramSelected) { %>
                    <button type="button" class="academic-v2-workspace-tab" data-structure-tab-target="bachelor-catalog">Bachelor Catalog</button>
                  <% } %>
                </div>
              </div>
              <div class="academic-v2-mode-toolbar" data-mode-panel="diagnostics">
                <div class="academic-v2-mode-toolbar-head">
                  <div>
                    <h2 class="academic-v2-section-title">Diagnostics</h2>
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip <%= Number(projectionHealthTotals.groups_with_issues || 0) ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= Number(projectionHealthTotals.groups_with_issues || 0) %> projection issues</span>
                    <span class="academic-v2-chip <%= Number(activityIntegritySummary.group_subjects_without_activities || 0) ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= Number(activityIntegritySummary.group_subjects_without_activities || 0) %> missing activities</span>
                    <span class="academic-v2-chip <%= Number(cleanupAudit.total_findings || 0) ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= Number(cleanupAudit.total_findings || 0) %> cleanup findings</span>
                  </div>
                </div>
                <div class="academic-v2-workspace-tabs academic-v2-workspace-tabs--structure">
                  <button type="button" class="academic-v2-workspace-tab" data-diagnostics-tab-target="projection">Projection</button>
                  <button type="button" class="academic-v2-workspace-tab" data-diagnostics-tab-target="integrity">Integrity</button>
                  <button type="button" class="academic-v2-workspace-tab" data-diagnostics-tab-target="cleanup">Cleanup</button>
                </div>
              </div>
            </section>

            <div class="academic-v2-mode-panel" data-mode-panel="diagnostics">
              <section class="academic-v2-card" id="diagnostics-projection" data-diagnostics-panel="projection">
                <div class="academic-v2-section-head">
                  <div>
                    <h2 class="academic-v2-section-title">Projection health</h2>
                  </div>
                  <form method="post" action="/admin/pathways/v2/groups/resync-all">
                    <%- renderFocusFields() %>
                    <button type="submit" class="btn btn-outline-secondary">Resync projections</button>
                  </form>
                </div>
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Live projection summary</strong>
                    <span class="academic-v2-chip academic-v2-chip--ok"><%= Number(projectionHealthTotals.groups_healthy || 0) %> healthy</span>
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= Number(projectionHealthTotals.groups_with_issues || 0) %> review</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <div class="academic-v2-chip-row mt-2">
                      <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_missing_legacy_course || 0) %> missing legacy</span>
                      <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_without_active_term || 0) %> no active term</span>
                      <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_with_user_sync_gaps || 0) %> sync gaps</span>
                      <span class="academic-v2-chip"><%= Number(projectionHealthTotals.subjects_without_teachers || 0) %> no teacher</span>
                    </div>
                    <div class="academic-v2-table-wrap mt-2">
                      <table class="table academic-v2-table">
                        <thead>
                          <tr>
                            <th>Course</th>
                            <th>Health</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% projectionHealthList.forEach((item) => { %>
                            <tr>
                              <td>
                                <div class="academic-v2-kv">
                                  <strong><%= item.group_label %></strong>
                                  <span class="academic-v2-muted"><%= item.program_name %> · <%= item.admission_year %> · stage <%= item.stage_number %> · <%= item.campus_key %></span>
                                </div>
                              </td>
                              <td>
                                <div class="academic-v2-chip-row">
                                  <span class="academic-v2-chip <%= item.is_healthy ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= item.is_healthy ? 'ok' : 'review' %></span>
                                  <% (item.issues || []).slice(0, 4).forEach((issue) => { %>
                                    <span class="academic-v2-chip"><%= issue %></span>
                                  <% }); %>
                                  <% if ((item.issues || []).length > 4) { %>
                                    <span class="academic-v2-chip">+<%= item.issues.length - 4 %></span>
                                  <% } %>
                                </div>
                              </td>
                              <td class="text-end">
                                <div class="academic-v2-actions justify-content-end">
                                  <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: item.program_id, cohort_id: item.cohort_id, group_id: item.group_id, term_id: '' }) %>">Фокус</a>
                                  <form method="post" action="/admin/pathways/v2/groups/<%= item.group_id %>/resync">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Resync</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </details>
              </section>

              <section class="academic-v2-card" id="diagnostics-integrity" data-diagnostics-panel="integrity">
                <div class="academic-v2-section-head">
                  <div>
                    <h2 class="academic-v2-section-title">Activity integrity</h2>
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip <%= Number(activityIntegritySummary.stage_subject_templates_without_activities || 0) === 0 ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= Number(activityIntegritySummary.stage_subject_templates_without_activities || 0) %> stage gaps</span>
                    <span class="academic-v2-chip <%= Number(activityIntegritySummary.group_subjects_without_activities || 0) === 0 ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= Number(activityIntegritySummary.group_subjects_without_activities || 0) %> course gaps</span>
                  </div>
                </div>
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Stage scope</strong>
                    <span class="academic-v2-chip"><%= Number(activityIntegritySummary.scoped_stage_subject_templates_without_activities || 0) %> missing</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <% if (scopedStageSubjectsWithoutActivities.length) { %>
                      <div class="academic-v2-stack mt-2">
                        <% scopedStageSubjectsWithoutActivities.forEach((item) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center">
                              <span class="academic-v2-chip academic-v2-chip--warm"><%= item.subject_title %></span>
                              <div class="academic-v2-actions">
                                <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: item.program_id, cohort_id: '', group_id: '', term_id: '', template_stage: item.stage_number }) %>">Фокус</a>
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-subject" data-editor-payload='<%- toAttr(item) %>'>Edit</button>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty mt-2">У вибраному stage scope все ок.</div>
                    <% } %>
                  </div>
                </details>
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Course scope</strong>
                    <span class="academic-v2-chip"><%= Number(activityIntegritySummary.scoped_group_subjects_without_activities || 0) %> missing</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <% if (scopedGroupSubjectsWithoutActivities.length) { %>
                      <div class="academic-v2-stack mt-2">
                        <% scopedGroupSubjectsWithoutActivities.forEach((item) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center">
                              <span class="academic-v2-chip academic-v2-chip--warm"><%= item.subject_title %></span>
                              <div class="academic-v2-actions">
                                <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: '', cohort_id: '', group_id: item.group_id, term_id: '' }) %>">Фокус</a>
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="group-subject" data-editor-payload='<%- toAttr(item) %>'>Edit</button>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty mt-2">У вибраному course scope все ок.</div>
                    <% } %>
                  </div>
                </details>
              </section>

              <section class="academic-v2-card" id="diagnostics-cleanup" data-diagnostics-panel="cleanup">
                <div class="academic-v2-section-head">
                  <div>
                    <h2 class="academic-v2-section-title">Cleanup dry-run</h2>
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= Number(cleanupAudit.total_findings || 0) %> findings</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.users_without_group_id || 0) %> no course</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.users_with_course_projection_mismatch || 0) %> mismatch</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.group_subjects_without_teacher_assignment || 0) %> no teacher</span>
                  </div>
                </div>
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Cleanup audit</strong>
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= Number(cleanupAudit.total_findings || 0) %> findings</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <div class="academic-v2-table-wrap mt-2">
                      <table class="table academic-v2-table">
                        <tbody>
                          <tr><th>Courses without active term</th><td><%= Number(cleanupAudit.groups_without_active_term || 0) %></td></tr>
                          <tr><th>Stale legacy course mappings</th><td><%= Number(cleanupAudit.stale_legacy_course_rows || 0) %></td></tr>
                          <tr><th>Stale legacy subject rows</th><td><%= Number(cleanupAudit.stale_legacy_subject_rows || 0) %></td></tr>
                          <tr><th>Stale legacy semester rows</th><td><%= Number(cleanupAudit.stale_legacy_semester_rows || 0) %></td></tr>
                          <tr><th>Stale legacy schedule rows</th><td><%= Number(cleanupAudit.stale_legacy_schedule_rows || 0) %></td></tr>
                          <tr><th>Legacy study contexts without v2 owner</th><td><%= Number(cleanupAudit.stale_legacy_study_context_rows || 0) %></td></tr>
                          <tr><th>Stale legacy preset rows</th><td><%= Number(cleanupAudit.legacy_preset_rows || 0) %></td></tr>
                          <tr><th>Legacy offerings without v2 owner</th><td><%= Number(cleanupAudit.stale_legacy_offering_rows || 0) %></td></tr>
                        </tbody>
                      </table>
                    </div>
                    <details class="mt-2 academic-v2-help-details">
                      <summary class="academic-v2-muted">CLI cleanup commands</summary>
                      <div class="academic-v2-muted mt-1">
                        <span class="academic-v2-code">node scripts/academic-v2-cleanup.js --normalize-users</span><br />
                        <span class="academic-v2-code">node scripts/academic-v2-cleanup.js --archive-legacy-config</span><br />
                        <span class="academic-v2-code">node scripts/academic-v2-cleanup.js --activity-integrity --write-snapshot</span><br />
                        Then repeat with <span class="academic-v2-code">--apply</span>.
                      </div>
                    </details>
                  </div>
                </details>
              </section>
            </div>

            <div class="academic-v2-mode-panel" data-mode-panel="structure">
            <section class="academic-v2-card" id="programs" data-structure-panel="programs">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Програми</h2>
                  <!-- Track-level canonical program list -->
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/programs/save" class="academic-v2-subcard" data-editor-form="program">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="program_id" value="" data-editor-input="program.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="programTrack">Track</label>
                      <select id="programTrack" class="form-select" name="track_key" data-editor-input="program.track_key">
                        <% trackOptions.forEach((track) => { %>
                          <option value="<%= track.value %>"><%= track.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="programCode">Code</label>
                      <input id="programCode" class="form-control academic-v2-code" type="text" name="code" data-editor-input="program.code" placeholder="BSC-ENG" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="programName">Name</label>
                      <input id="programName" class="form-control" type="text" name="name" data-editor-input="program.name" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="programSort">Sort order</label>
                      <input id="programSort" class="form-control" type="number" name="sort_order" data-editor-input="program.sort_order" value="100" />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="programActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="program.is_active" checked />
                    <label class="form-check-label" for="programActive">Active program</label>
                  </div>
                  <div class="academic-v2-actions mt-2">
                    <button type="submit" class="btn btn-primary">Зберегти програму</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="program">Скинути</button>
                  </div>
                </form>
                <div class="academic-v2-subcard">
                  <div class="academic-v2-table-wrap">
                    <table class="table academic-v2-table">
                      <thead>
                        <tr>
                          <th>Program</th>
                          <th>Stats</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% (programs || []).forEach((program) => { %>
                          <tr>
                            <td>
                              <div class="academic-v2-kv">
                                <strong><%= program.name %></strong>
                                <span class="academic-v2-muted"><%= program.track_key %> - <span class="academic-v2-code"><%= program.code || 'no-code' %></span></span>
                              </div>
                            </td>
                            <td><span class="academic-v2-chip"><%= program.cohort_count %> cohorts</span> <span class="academic-v2-chip"><%= program.group_count %> courses</span></td>
                            <td class="text-end">
                              <div class="academic-v2-actions justify-content-end">
                                <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: program.id, cohort_id: '', group_id: '', term_id: '' }) %>">Фокус</a>
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="program" data-editor-payload='<%- toAttr(program) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/programs/<%= program.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="cohorts" data-structure-panel="cohorts">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Когорти</h2>
                  <!-- Cohorts: admission year + stage promotion -->
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/cohorts/save" class="academic-v2-subcard" data-editor-form="cohort">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="cohort_id" value="" data-editor-input="cohort.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="cohortProgram">Program</label>
                      <select id="cohortProgram" class="form-select" name="program_id" data-editor-input="cohort.program_id">
                        <% (programs || []).forEach((program) => { %>
                          <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="cohortYear">Admission year</label>
                      <input id="cohortYear" class="form-control" type="number" name="admission_year" data-editor-input="cohort.admission_year" value="<%= new Date().getFullYear() %>" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="cohortLabel">Label</label>
                      <input id="cohortLabel" class="form-control" type="text" name="label" data-editor-input="cohort.label" placeholder="2026 Intake" required />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="cohortActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="cohort.is_active" checked />
                    <label class="form-check-label" for="cohortActive">Active cohort</label>
                  </div>
                  <div class="academic-v2-actions mt-2">
                    <button type="submit" class="btn btn-primary">Зберегти когорту</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="cohort">Скинути</button>
                  </div>
                </form>
                <div class="academic-v2-stack">
                  <div class="academic-v2-subcard">
                    <div class="academic-v2-table-wrap">
                      <table class="table academic-v2-table">
                        <thead>
                          <tr>
                            <th>Cohort</th>
                            <th>Stats</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% (cohorts || []).forEach((cohort) => { %>
                            <tr>
                              <td>
                                <div class="academic-v2-kv">
                                  <strong><%= cohort.label %></strong>
                                  <span class="academic-v2-muted"><%= cohort.program_name %> - <%= cohort.admission_year %> - current stage <%= cohort.current_stage_number %></span>
                                </div>
                              </td>
                              <td>
                                <span class="academic-v2-chip"><%= cohort.group_count %> courses</span>
                                <span class="academic-v2-chip"><%= cohort.current_stage_number %> live stage</span>
                                <span class="academic-v2-chip academic-v2-chip--ok"><%= cohort.enrolled_users %> users</span>
                              </td>
                              <td class="text-end">
                                <div class="academic-v2-actions justify-content-end">
                                  <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: cohort.program_id, cohort_id: cohort.id, group_id: '', term_id: '' }) %>">Фокус</a>
                                  <button type="button" class="btn btn-sm btn-primary" data-editor-target="cohort" data-editor-payload='<%- toAttr(cohort) %>'>Edit</button>
                                  <form method="post" action="/admin/pathways/v2/cohorts/<%= cohort.id %>/delete">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                  <div class="academic-v2-subcard">
                    <h3 class="h6 mb-1">Promote cohort</h3>
                    <% if (selectedCohort) { %>
                      <!-- Promotion: replaces live subjects/terms for the new stage -->
                      <form method="get" action="/admin/pathways" class="academic-v2-form-grid academic-v2-form-grid--compact">
                        <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" />
                        <input type="hidden" name="cohort_id" value="<%= activeCohortId || '' %>" />
                        <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" />
                        <input type="hidden" name="term_id" value="<%= activeTermId || '' %>" />
                        <input type="hidden" name="template_stage" value="<%= activeTemplateStage || 1 %>" />
                        <input type="hidden" name="preview_cohort_id" value="<%= selectedCohort.id %>" />
                        <div class="academic-v2-field">
                          <label for="previewTargetStage">Target stage</label>
                          <select id="previewTargetStage" class="form-select" name="preview_target_stage">
                            <% stageOptions.forEach((stageNumber) => { %>
                              <option value="<%= stageNumber %>" <%= Number((promotionPreview && promotionPreview.target_stage_number) || selectedCohort.current_stage_number + 1) === stageNumber ? 'selected' : '' %>>Stage <%= stageNumber %></option>
                            <% }); %>
                          </select>
                        </div>
                        <div class="academic-v2-actions">
                          <button type="submit" class="btn btn-outline-secondary">Preview promotion</button>
                        </div>
                      </form>
                      <% if (promotionPreview && Number(promotionPreview.cohort_id || 0) === Number(selectedCohort.id || 0)) { %>
                        <div class="academic-v2-stack mt-3">
                          <div class="academic-v2-chip-row">
                            <span class="academic-v2-chip">Stage <%= promotionPreview.current_stage_number %> -> <%= promotionPreview.target_stage_number %></span>
                            <span class="academic-v2-chip"><%= promotionPreview.template_term_count %> template terms</span>
                            <span class="academic-v2-chip"><%= promotionPreview.template_subject_count %> template subjects</span>
                            <span class="academic-v2-chip"><%= promotionPreview.subjects_without_teacher_defaults %> subjects without teacher defaults</span>
                          </div>
                          <% if ((promotionPreview.issues || []).length) { %>
                            <div class="academic-v2-alert academic-v2-alert--warning">
                              <strong>Preview blocked.</strong>
                              <%= promotionPreview.issues.join(' ') %>
                            </div>
                          <% } %>
                          <% if ((promotionPreview.course_plans || []).length) { %>
                            <div class="academic-v2-table-wrap">
                              <table class="table academic-v2-table">
                                <thead>
                                  <tr>
                                    <th>Campus</th>
                                    <th>Поточний курс</th>
                                    <th>Target course</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% promotionPreview.course_plans.forEach((plan) => { %>
                                    <tr>
                                      <td><%= plan.campus_key %></td>
                                      <td>
                                        <div class="academic-v2-kv">
                                          <strong><%= plan.source_course_label %></strong>
                                          <span class="academic-v2-muted"><%= plan.source_user_count %> users, <%= plan.source_term_count %> terms, <%= plan.source_subject_count %> subjects</span>
                                        </div>
                                      </td>
                                      <td>
                                        <span class="academic-v2-chip"><%= plan.target_course_exists ? 'existing target course' : 'new target course' %></span>
                                        <% if (plan.target_course_label) { %><span class="academic-v2-chip"><%= plan.target_course_label %></span><% } %>
                                      </td>
                                    </tr>
                                  <% }); %>
                                </tbody>
                              </table>
                            </div>
                          <% } %>
                          <% if (promotionPreview.can_apply) { %>
                            <form method="post" action="/admin/pathways/v2/cohorts/<%= selectedCohort.id %>/promote" class="academic-v2-actions">
                              <%- renderFocusFields() %>
                              <input type="hidden" name="target_stage_number" value="<%= promotionPreview.target_stage_number %>" />
                              <button type="submit" class="btn btn-primary">Apply promotion</button>
                            </form>
                          <% } %>
                        </div>
                      <% } %>
                    <% } else { %>
                      <div class="academic-v2-empty">Спершу вибери когорту, щоб переглянути і застосувати промоцію етапу.</div>
                    <% } %>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="stage-templates" data-structure-panel="stage-templates">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Stage templates</h2>
                  <!-- Templates: stage-level term/subject definitions, applied on promotion -->
                </div>
                <% if (scopedStageSubjectsWithoutActivities.length) { %>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= scopedStageSubjectsWithoutActivities.length %> stage subjects missing activity</span>
                  </div>
                <% } %>
              </div>
              <div class="academic-v2-subcard mb-4">
                <form method="get" action="/admin/pathways" class="academic-v2-focus-grid">
                  <input type="hidden" name="cohort_id" value="<%= activeCohortId || '' %>" />
                  <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" />
                  <input type="hidden" name="term_id" value="<%= activeTermId || '' %>" />
                  <div class="academic-v2-field">
                    <label for="templateProgramId">Program</label>
                    <select id="templateProgramId" class="form-select" name="program_id">
                      <% (programs || []).forEach((program) => { %>
                        <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-field">
                    <label for="templateStageNumber">Template stage</label>
                    <select id="templateStageNumber" class="form-select" name="template_stage">
                      <% stageOptions.forEach((stageNumber) => { %>
                        <option value="<%= stageNumber %>" <%= stageNumber === activeTemplateStage ? 'selected' : '' %>>Stage <%= stageNumber %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-actions">
                    <button type="submit" class="btn btn-outline-secondary">Load stage template</button>
                  </div>
                </form>
                <div class="academic-v2-chip-row mt-1">
                  <% (templateStageCards || []).forEach((card) => { %>
                    <span class="academic-v2-chip <%= card.is_current ? 'academic-v2-chip--ok' : '' %>">Stage <%= card.stage_number %>: <%= card.term_count %> terms, <%= card.subject_count %> subjects</span>
                  <% }); %>
                </div>
              </div>
              <div class="academic-v2-stack">
                <details class="academic-v2-subcard academic-v2-disclosure">
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Terms</strong>
                    <span class="academic-v2-chip"><%= (scopedStageTermTemplates || []).length %> templates</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <div class="academic-v2-grid-2">
                      <form method="post" action="/admin/pathways/v2/stage-terms/save" class="academic-v2-subcard" data-editor-form="stage-term">
                        <%- renderFocusFields() %>
                        <input type="hidden" name="stage_term_template_id" value="" data-editor-input="stage-term.id" />
                        <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" data-preserve-reset="1" />
                        <input type="hidden" name="stage_number" value="<%= activeTemplateStage || 1 %>" data-preserve-reset="1" />
                        <h3 class="h6 mb-1">Stage terms</h3>
                        <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                          <div class="academic-v2-field">
                            <label for="stageTermNumber">Term number</label>
                            <select id="stageTermNumber" class="form-select" name="term_number" data-editor-input="stage-term.term_number">
                              <% termOptions.forEach((term) => { %>
                                <option value="<%= term.value %>"><%= term.label %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageTermTitle">Title</label>
                            <input id="stageTermTitle" class="form-control" type="text" name="title" data-editor-input="stage-term.title" placeholder="Term 1" required />
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageTermStartDate">Start date</label>
                            <input id="stageTermStartDate" class="form-control" type="date" name="start_date" data-editor-input="stage-term.start_date" />
                          </div>
                          <div class="academic-v2-field">
                            <label>Weeks</label>
                            <div class="academic-v2-muted">Fixed presets: T1 = 15, T2 = 15, T3 = 7.</div>
                          </div>
                        </div>
                        <input type="hidden" name="is_active_default" value="0" />
                        <div class="form-check mt-3">
                          <input id="stageTermActiveDefault" class="form-check-input" type="checkbox" name="is_active_default" value="1" data-editor-input="stage-term.is_active_default" />
                          <label class="form-check-label" for="stageTermActiveDefault">Default active term</label>
                        </div>
                        <div class="academic-v2-actions mt-2">
                          <button type="submit" class="btn btn-primary">Зберегти stage term</button>
                          <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-term">Скинути</button>
                        </div>
                      </form>
                      <div class="academic-v2-subcard">
                        <h3 class="h6 mb-1">Поточні stage term templates</h3>
                        <% if ((scopedStageTermTemplates || []).length) { %>
                          <div class="academic-v2-stack">
                            <% (scopedStageTermTemplates || []).forEach((stageTerm) => { %>
                              <div class="academic-v2-subcard">
                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                  <div>
                                    <strong><%= stageTerm.title %></strong>
                                    <div class="academic-v2-muted">Term <%= stageTerm.term_number %> - <%= stageTerm.weeks_count %> weeks<%= stageTerm.start_date ? ` - ${stageTerm.start_date}` : '' %></div>
                                  </div>
                                  <div class="academic-v2-actions">
                                    <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-term" data-editor-payload='<%- toAttr(stageTerm) %>'>Edit</button>
                                  </div>
                                </div>
                              </div>
                            <% }); %>
                          </div>
                        <% } else { %>
                          <div class="academic-v2-empty">No stage terms yet.</div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </details>
                <details class="academic-v2-subcard academic-v2-disclosure" open>
                  <summary class="academic-v2-disclosure-summary">
                    <strong>Stage subjects</strong>
                    <span class="academic-v2-chip"><%= scopedStageSubjectTemplatesList.length %> templates</span>
                  </summary>
                  <div class="academic-v2-disclosure-body">
                    <div class="academic-v2-grid-2">
                      <form method="post" action="/admin/pathways/v2/stage-subjects/save" class="academic-v2-subcard" data-editor-form="stage-subject">
                        <%- renderFocusFields() %>
                        <input type="hidden" name="stage_subject_template_id" value="" data-editor-input="stage-subject.id" />
                        <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" data-preserve-reset="1" />
                        <input type="hidden" name="stage_number" value="<%= activeTemplateStage || 1 %>" data-preserve-reset="1" />
                        <h3 class="h6 mb-1">Stage subjects</h3>
                        <div class="academic-v2-form-grid">
                          <div class="academic-v2-field">
                            <label for="stageSubjectTemplate">Subject template</label>
                            <select id="stageSubjectTemplate" class="form-select" name="subject_template_id" data-editor-input="stage-subject.subject_template_id">
                              <% (subjectTemplates || []).forEach((template) => { %>
                                <option value="<%= template.id %>"><%= template.name %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field" style="grid-column: 1 / -1;">
                            <label for="stageSubjectTitle">Live title override</label>
                            <input id="stageSubjectTitle" class="form-control" type="text" name="title" data-editor-input="stage-subject.title" placeholder="Leave empty to use the template name" />
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageSubjectGroups">Group count</label>
                            <input id="stageSubjectGroups" class="form-control" type="number" name="group_count" data-editor-input="stage-subject.group_count" value="1" />
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageSubjectDefaultGroup">Default group</label>
                            <input id="stageSubjectDefaultGroup" class="form-control" type="number" name="default_group" data-editor-input="stage-subject.default_group" value="1" />
                          </div>
                          <div class="academic-v2-field" style="grid-column: 1 / -1;">
                            <span class="academic-v2-muted">Sorted alphabetically.</span>
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageSubjectTerms">Stage terms</label>
                            <select id="stageSubjectTerms" class="form-select" name="stage_term_template_ids" multiple size="4" data-editor-input="stage-subject.stage_term_template_ids">
                              <% (scopedStageTermTemplates || []).forEach((stageTerm) => { %>
                                <option value="<%= stageTerm.id %>"><%= stageTerm.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field" style="grid-column: 1 / -1;">
                            <label for="stageSubjectTeachers">Default teachers</label>
                            <select id="stageSubjectTeachers" class="form-select" name="teacher_ids" multiple size="5" data-editor-input="stage-subject.teacher_ids">
                              <% (teachers || []).forEach((teacher) => { %>
                                <option value="<%= teacher.id %>"><%= teacher.full_name %></option>
                              <% }); %>
                            </select>
                          </div>
                        </div>
                        <div class="academic-v2-checkboxes mt-3">
                          <input type="hidden" name="is_visible" value="0" />
                          <div class="form-check"><input id="stageSubjectVisible" class="form-check-input" type="checkbox" name="is_visible" value="1" data-editor-input="stage-subject.is_visible" checked /><label class="form-check-label" for="stageSubjectVisible">Visible</label></div>
                          <input type="hidden" name="is_required" value="0" />
                          <div class="form-check"><input id="stageSubjectRequired" class="form-check-input" type="checkbox" name="is_required" value="1" data-editor-input="stage-subject.is_required" checked /><label class="form-check-label" for="stageSubjectRequired">Required</label></div>
                          <input type="hidden" name="is_general" value="0" />
                          <div class="form-check"><input id="stageSubjectGeneral" class="form-check-input" type="checkbox" name="is_general" value="1" data-editor-input="stage-subject.is_general" checked /><label class="form-check-label" for="stageSubjectGeneral">General</label></div>
                          <input type="hidden" name="show_in_teamwork" value="0" />
                          <div class="form-check"><input id="stageSubjectTeamwork" class="form-check-input" type="checkbox" name="show_in_teamwork" value="1" data-editor-input="stage-subject.show_in_teamwork" checked /><label class="form-check-label" for="stageSubjectTeamwork">Show in teamwork</label></div>
                        </div>
                        <div class="academic-v2-actions mt-2">
                          <button type="submit" class="btn btn-primary">Зберегти stage subject</button>
                          <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-subject">Скинути</button>
                        </div>
                      </form>
                      <div class="academic-v2-subcard">
                        <h3 class="h6 mb-1">Поточні stage subject templates</h3>
                        <% if (scopedStageSubjectTemplatesList.length) { %>
                          <div class="academic-v2-stack">
                            <% scopedStageSubjectTemplatesList.forEach((stageSubject) => { %>
                              <div class="academic-v2-subcard">
                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                  <div>
                                    <strong><%= stageSubject.title %></strong>
                                    <div class="academic-v2-muted"><%= stageSubject.subject_template_name %></div>
                                    <div class="academic-v2-chip-row mt-2">
                                      <span class="academic-v2-chip"><%= stageSubject.stage_term_titles.length ? stageSubject.stage_term_titles.join(', ') : 'All stage terms' %></span>
                                      <span class="academic-v2-chip"><%= stageSubject.teacher_names.length ? stageSubject.teacher_names.join(', ') : 'No teacher defaults' %></span>
