                              <td>
                                <span class="academic-v2-chip"><%= group.term_count %> terms</span>
                                <span class="academic-v2-chip"><%= group.group_subject_count %> subjects</span>
                                <span class="academic-v2-chip academic-v2-chip--ok"><%= group.enrolled_users %> users</span>
                                <% if (group.track_key === 'teacher' && group.is_teacher_registration_default) { %>
                                  <span class="academic-v2-chip academic-v2-chip--ok">teacher default</span>
                                <% } %>
                                <% if (health) { %>
                                  <span class="academic-v2-chip <%= health.is_healthy ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= health.is_healthy ? 'projection ok' : 'needs review' %></span>
                                  <% (health.issues || []).slice(0, 2).forEach((issue) => { %>
                                    <span class="academic-v2-chip"><%= issue %></span>
                                  <% }); %>
                                <% } %>
                              </td>
                              <td class="text-end">
                                <div class="academic-v2-actions justify-content-end">
                                  <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: group.program_id, cohort_id: group.cohort_id, group_id: group.id, term_id: '' }) %>">Фокус</a>
                                  <button type="button" class="btn btn-sm btn-primary" data-editor-target="group" data-editor-payload='<%- toAttr(group) %>'>Edit</button>
                                  <form method="post" action="/admin/pathways/v2/groups/<%= group.id %>/delete">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                  <div class="academic-v2-subcard">
                    <h3 class="h6 mb-1">Операційний перехід у курс</h3>
                    <!-- Workspace contains subjects, terms, schedule, students -->
                    <div class="academic-v2-actions">
                      <button type="button" class="btn btn-outline-secondary" data-mode-button="operate" data-workspace-tab-target="overview">Відкрити workspace</button>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            </div>

            <div class="academic-v2-mode-panel" data-mode-panel="operate">
              <section class="academic-v2-card" id="overview" data-workspace-panel="overview">
                <div class="academic-v2-section-head">
                  <div>
                    <h2 class="academic-v2-section-title">Огляд</h2>
                    <!-- Overview: readiness snapshot -->
                  </div>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip <%= workspaceReadiness.hasActiveTerm ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>">
                      <%= workspaceReadiness.hasActiveTerm ? 'Є активний терм' : 'Активний терм відсутній' %>
                    </span>
                    <span class="academic-v2-chip"><%= subjectCards.length %> предметів</span>
                    <span class="academic-v2-chip"><%= termCards.length %> термів</span>
                    <span class="academic-v2-chip"><%= scheduleEntriesForViews.length %> слотів</span>
                  </div>
                </div>
                <% if (selectedGroup) { %>
                  <div class="academic-v2-grid-3 academic-v2-grid-3--overview">
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-subcard-topline">Готовність предметів</div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip"><%= workspaceReadiness.subjectBoundCount %> привʼязані до термів</span>
                        <span class="academic-v2-chip"><%= workspaceReadiness.activityReadyCount %> з активностями</span>
                        <span class="academic-v2-chip"><%= workspaceReadiness.teacherReadyCount %> з викладачами</span>
                        <span class="academic-v2-chip academic-v2-chip--warm"><%= workspaceReadiness.missingTeacherCount %> без викладача</span>
                      </div>
                    </div>
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-subcard-topline">Розклад і терми</div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip <%= activeTermCount ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= activeTermCount %> активних термів</span>
                        <span class="academic-v2-chip"><%= archivedTermCount %> архівних</span>
                        <span class="academic-v2-chip"><%= selectedWorkspaceTermId ? (selectedTermRecord ? selectedTermRecord.title : 'Поточний терм') : 'Усі терми' %></span>
                        <span class="academic-v2-chip <%= workspaceReadiness.scheduleConflictCount ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= workspaceReadiness.scheduleConflictCount %> попереджень у розкладі</span>
                      </div>
                    </div>
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-subcard-topline">Швидкі дії</div>
                      <div class="academic-v2-actions mt-2">
                        <button type="button" class="btn btn-outline-secondary" data-workspace-tab-target="subjects">Предмети</button>
                        <button type="button" class="btn btn-outline-secondary" data-workspace-tab-target="terms">Терми</button>
                        <button type="button" class="btn btn-outline-secondary" data-workspace-tab-target="schedule">Розклад</button>
                        <button type="button" class="btn btn-outline-secondary" data-workspace-tab-target="students">Студенти</button>
                      </div>
                    </div>
                  </div>
                <% } else { %>
                  <div class="academic-v2-empty">Оберіть курс у блоці контексту, щоб побачити готовність і перейти до операційних панелей.</div>
                <% } %>
              </section>

            <section class="academic-v2-card" id="subjects" data-workspace-panel="subjects">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Предмети курсу</h2>
                  <!-- Live course subjects + right-side editor -->
                </div>
                <div class="academic-v2-chip-row">
                  <span class="academic-v2-chip"><%= subjectCards.length %> живих предметів</span>
                  <span class="academic-v2-chip"><%= workspaceReadiness.teacherReadyCount %> з викладачами</span>
                  <span class="academic-v2-chip academic-v2-chip--warm"><%= scopedGroupSubjectsWithoutActivities.length %> без активності</span>
                </div>
              </div>

              <div class="academic-v2-grid-2 academic-v2-grid-2--subjects">
                <div class="academic-v2-stack">
                  <div class="academic-v2-subcard">
                    <div class="academic-v2-section-head academic-v2-section-head--tight">
                      <div>
                        <div class="academic-v2-subcard-topline">Живі предмети курсу</div>
                        <h3 class="h6 mb-1">Операційний список предметів</h3>
                        <!-- Live course subjects with readiness state -->
                      </div>
                      <div class="academic-v2-actions">
                        <button type="button" class="btn btn-outline-secondary" data-subject-create>Додати предмет до курсу</button>
                      </div>
                    </div>
                    <% if (subjectCards.length) { %>
                      <div class="academic-v2-stack">
                        <% subjectCards.forEach((subject) => { %>
                          <% const subjectSharedMeta = sharedSubjectMetaById[numberOrZero(subject.id)] || { mode: 'standalone', outbound_links: [], inbound_link: null }; %>
                          <% const subjectHasLinkedCopies = subjectSharedMeta.mode === 'source' && Array.isArray(subjectSharedMeta.outbound_links) && subjectSharedMeta.outbound_links.length > 0; %>
                          <div class="academic-v2-course-subject-card" data-subject-card data-subject-id="<%= subject.id %>" data-subject-card-payload='<%- toAttr(subject) %>'>
                            <div class="academic-v2-course-subject-card-head">
                              <div>
                                <strong><%= subject.title %></strong>
                                <div class="academic-v2-muted"><%= subject.template_name %></div>
                              </div>
                              <span class="academic-v2-chip <%= subject.readiness.tone === 'ok' ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= subject.readiness.label %></span>
                            </div>
                            <div class="academic-v2-chip-row mt-1">
                              <span class="academic-v2-chip"><%= subject.group_count %> підгруп</span>
                              <span class="academic-v2-chip">default G<%= subject.default_group %></span>
                              <span class="academic-v2-chip"><%= subject.teacher_count %> викладачів</span>
                              <span class="academic-v2-chip"><%= subject.term_count %> термів</span>
                              <span class="academic-v2-chip"><%= subject.activity_count %> активностей</span>
                              <% if (subjectSharedMeta.mode === 'source') { %><span class="academic-v2-chip academic-v2-chip--ok">Shared-джерело</span><% } %>
                              <% if (subjectSharedMeta.mode === 'linked') { %><span class="academic-v2-chip academic-v2-chip--warm">Linked-копія</span><% } %>
                              <% if (subject.is_visible) { %><span class="academic-v2-chip academic-v2-chip--ok">Видимий</span><% } %>
                              <% if (subject.is_required) { %><span class="academic-v2-chip">Обовʼязковий</span><% } %>
                              <% if (subject.is_general) { %><span class="academic-v2-chip">General</span><% } %>
                              <% if (subject.show_in_teamwork) { %><span class="academic-v2-chip">Teamwork</span><% } %>
                            </div>
                            <% if (subject.readiness_labels.length) { %>
                              <div class="academic-v2-chip-row mt-2">
                                <% subject.readiness_labels.forEach((label) => { %>
                                  <span class="academic-v2-chip academic-v2-chip--warm"><%= label %></span>
                                <% }); %>
                              </div>
                            <% } %>
                            <div class="academic-v2-actions mt-2">
                              <button type="button" class="btn btn-sm btn-primary" data-editor-target="group-subject" data-editor-payload='<%- toAttr(subject) %>' data-subject-focus-id="<%= subject.id %>">Редагувати</button>
                              <button type="button" class="btn btn-sm btn-outline-secondary" data-editor-target="group-subject" data-editor-payload='<%- toAttr(subject) %>' data-subject-focus-id="<%= subject.id %>" data-subject-focus-section="teachers">Викладачі</button>
                              <button type="button" class="btn btn-sm btn-outline-secondary" data-editor-target="group-subject" data-editor-payload='<%- toAttr(subject) %>' data-subject-focus-id="<%= subject.id %>" data-subject-focus-section="activities">Активності</button>
                              <form method="post" action="/admin/pathways/v2/group-subjects/<%= subject.id %>/delete">
                                <%- renderFocusFields() %>
                                <button type="submit" class="btn btn-sm btn-outline-danger" <%= subjectHasLinkedCopies ? 'disabled' : '' %> title="<%= subjectHasLinkedCopies ? 'Спочатку прибери linked-копії або перенеси їх на інше джерело.' : '' %>">Вилучити</button>
                              </form>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty"><%= activeGroupId ? 'У вибраному курсі ще немає предметів.' : 'Спершу вибери курс, щоб перейти до живих предметів.' %></div>
                    <% } %>
                  </div>
                </div>

                <div class="academic-v2-detail-shell">
                  <div class="academic-v2-subcard academic-v2-detail-summary" id="subject-detail-summary">
                    <div class="academic-v2-subcard-topline">Редактор</div>
                    <h3 class="h6 mb-1" data-subject-detail-title><%= initialSubjectCard ? initialSubjectCard.title : 'Новий предмет курсу' %></h3>
                    <p class="academic-v2-muted" style="font-size:0.74rem;" data-subject-detail-copy>
                      <%= initialSubjectCard ? initialSubjectCard.title : 'Вибери предмет зліва' %>
                    </p>
                    <div class="academic-v2-chip-row mt-1">
                      <span class="academic-v2-chip" data-subject-detail-groups><%= initialSubjectCard ? `${initialSubjectCard.group_count} підгруп` : '1 підгрупа' %></span>
                      <span class="academic-v2-chip" data-subject-detail-terms><%= initialSubjectCard ? `${initialSubjectCard.term_count} термів` : '0 термів' %></span>
                      <span class="academic-v2-chip" data-subject-detail-teachers><%= initialSubjectCard ? `${initialSubjectCard.teacher_count} викладачів` : '0 викладачів' %></span>
                      <span class="academic-v2-chip" data-subject-detail-activities><%= initialSubjectCard ? `${initialSubjectCard.activity_count} активностей` : '0 активностей' %></span>
                      <span class="academic-v2-chip <%= initialSubjectCard && initialSubjectCard.readiness.tone === 'ok' ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>" data-subject-detail-readiness><%= initialSubjectCard ? initialSubjectCard.readiness.label : 'Потребує налаштування' %></span>
                    </div>
                  </div>

                  <form method="post" action="/admin/pathways/v2/group-subjects/save" class="academic-v2-subcard" data-editor-form="group-subject" id="subject-detail-form">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="group_subject_id" value="" data-editor-input="group-subject.id" />
                    <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" data-editor-input="group-subject.group_id" data-preserve-reset="1" />
                    <div class="academic-v2-subcard-topline">Основне</div>
                    <div class="academic-v2-form-grid">
                      <div class="academic-v2-field">
                        <label for="groupSubjectTemplate">Шаблон предмета</label>
                        <input type="hidden" name="subject_template_id" value="" data-group-subject-template-hidden-lock disabled />
                        <select id="groupSubjectTemplate" class="form-select" name="subject_template_id" data-editor-input="group-subject.subject_template_id">
                          <% (subjectTemplates || []).forEach((template) => { %>
                            <option value="<%= template.id %>"><%= template.name %></option>
                          <% }); %>
                        </select>
                        <div class="academic-v2-muted mt-2" data-group-subject-template-lock></div>
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;">
                        <label for="groupSubjectTitle">Жива назва</label>
                        <input id="groupSubjectTitle" class="form-control" type="text" name="title" data-editor-input="group-subject.title" placeholder="За замовчуванням буде назва шаблону" />
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;">
                        <span class="academic-v2-muted">Предмети курсу впорядковуються за назвою автоматично.</span>
                      </div>
                      <div class="academic-v2-field">
                        <label for="groupSubjectGroups">Кількість підгруп</label>
                        <input id="groupSubjectGroups" class="form-control" type="number" name="group_count" data-editor-input="group-subject.group_count" value="1" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="groupSubjectDefaultGroup">Базова підгрупа</label>
                        <input id="groupSubjectDefaultGroup" class="form-control" type="number" name="default_group" data-editor-input="group-subject.default_group" value="1" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="groupSubjectTerms">Терми</label>
                        <select id="groupSubjectTerms" class="form-select" name="term_ids" multiple size="5" data-editor-input="group-subject.term_ids">
                          <% scopedTermsList.forEach((term) => { %>
                            <option value="<%= term.id %>"><%= term.title %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;" id="subject-detail-teachers">
                        <label for="groupSubjectTeachers">Викладачі</label>
                        <select id="groupSubjectTeachers" class="form-select" name="teacher_ids" multiple size="5" data-editor-input="group-subject.teacher_ids">
                          <% (teachers || []).forEach((teacher) => { %>
                            <option value="<%= teacher.id %>"><%= teacher.full_name %></option>
                          <% }); %>
                        </select>
                      </div>
                    </div>
                    <div class="academic-v2-checkboxes mt-3">
                      <input type="hidden" name="is_visible" value="0" />
                      <div class="form-check"><input id="groupSubjectVisible" class="form-check-input" type="checkbox" name="is_visible" value="1" data-editor-input="group-subject.is_visible" checked /><label class="form-check-label" for="groupSubjectVisible">Видимий у каталогах</label></div>
                      <input type="hidden" name="is_required" value="0" />
                      <div class="form-check"><input id="groupSubjectRequired" class="form-check-input" type="checkbox" name="is_required" value="1" data-editor-input="group-subject.is_required" checked /><label class="form-check-label" for="groupSubjectRequired">Обовʼязковий</label></div>
                      <input type="hidden" name="is_general" value="0" />
                      <div class="form-check"><input id="groupSubjectGeneral" class="form-check-input" type="checkbox" name="is_general" value="1" data-editor-input="group-subject.is_general" checked /><label class="form-check-label" for="groupSubjectGeneral">Загальний</label></div>
                      <input type="hidden" name="show_in_teamwork" value="0" />
                      <div class="form-check"><input id="groupSubjectTeamwork" class="form-check-input" type="checkbox" name="show_in_teamwork" value="1" data-editor-input="group-subject.show_in_teamwork" checked /><label class="form-check-label" for="groupSubjectTeamwork">Показувати в teamwork</label></div>
                    </div>
                    <div class="academic-v2-actions mt-2">
                      <button type="submit" class="btn btn-primary">Зберегти предмет</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="group-subject">Скинути</button>
                    </div>
                  </form>

                  <div class="academic-v2-subcard" id="subject-shared-card">
                    <div class="academic-v2-section-head academic-v2-section-head--tight">
                      <div>
                        <div class="academic-v2-subcard-topline">Спільний предмет</div>
                        <h3 class="h6 mb-1">Shared-копії між курсами</h3>
                        <p class="academic-v2-muted" style="font-size:0.74rem;" data-group-subject-shared-copy>
                          <% if (initialSubjectSharedMeta.mode === 'linked' && initialSubjectSharedMeta.inbound_link) { %>
                            Linked-копія з «<%= initialSubjectSharedMeta.inbound_link.source_group_label %>»
                          <% } else if (initialSubjectSharedMeta.mode === 'source') { %>
                            Shared-джерело для <%= initialSubjectSharedMeta.outbound_links.length %> курсів
                          <% } else { %>
                            Standalone. Можна перетворити на shared-джерело.
                          <% } %>
                        </p>
                      </div>
                    </div>

                    <form method="post" action="/admin/pathways/v2/group-subjects/share" id="subject-share-form">
                      <%- renderFocusFields() %>
                      <input type="hidden" name="source_group_subject_id" value="<%= initialSubjectCard ? initialSubjectCard.id : '' %>" data-group-subject-share-source />
                      <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                        <div class="academic-v2-field">
                          <label for="groupSubjectShareTarget">Цільовий курс для shared-копії</label>
                          <select id="groupSubjectShareTarget" class="form-select" name="target_group_id" data-group-subject-share-target>
                            <option value="">Оберіть курс…</option>
                            <% assignableCourseOptions.forEach((group) => { %>
                              <option value="<%= group.id %>"><%= group.option_label %></option>
                            <% }); %>
                          </select>
                        </div>
                        <div class="academic-v2-field">
                          <label>Як це працює</label>
                          <div class="academic-v2-muted" data-group-subject-shared-summary>
                            <% if (initialSubjectSharedMeta.mode === 'linked' && initialSubjectSharedMeta.inbound_link) { %>
                              Linked-копія не може створювати власні shared-гілки. Відкрий базовий предмет, щоб керувати shared-звʼязками.
                            <% } else { %>
                              Буде створено linked-копію або підʼєднано наявний предмет з тим самим шаблоном у вибраному курсі. Далі його можна оновлювати з цього джерела вручну.
                            <% } %>
                          </div>
                        </div>
                      </div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip">Setup синхронізується вручну</span>
                        <span class="academic-v2-chip">Терми мапляться за номером</span>
                        <span class="academic-v2-chip">Викладачі й активності копіюються</span>
                        <span class="academic-v2-chip academic-v2-chip--warm">Розклад лишається локальним</span>
                      </div>
                      <div class="academic-v2-checkboxes mt-3">
                        <input type="hidden" name="open_target_course" value="0" />
                        <div class="form-check">
                          <input id="groupSubjectShareOpenTarget" class="form-check-input" type="checkbox" name="open_target_course" value="1" checked />
                          <label class="form-check-label" for="groupSubjectShareOpenTarget">Після створення відкрити цільовий курс і linked-копію</label>
                        </div>
                      </div>
                      <p class="academic-v2-muted mt-2 mb-0" style="font-size:0.74rem;" data-group-subject-shared-feedback>
                        <% if (initialSubjectSharedMeta.mode === 'linked' && initialSubjectSharedMeta.inbound_link) { %>
                          Заблоковано: керується з іншого курсу.
                        <% } else { %>
                          Вибери курс-ціль для shared-копії.
                        <% } %>
                      </p>
                      <div class="academic-v2-actions mt-2">
                        <button type="submit" class="btn btn-primary" data-group-subject-share-submit disabled>Створити shared-копію</button>
                        <button
                          type="button"
                          class="btn btn-outline-secondary <%= initialSubjectSharedMeta.inbound_link ? '' : 'd-none' %>"
                          data-group-subject-shared-open-source
                          data-shared-open-href="<%= initialSubjectSharedMeta.inbound_link ? initialSubjectSharedMeta.inbound_link.workspace_href : '' %>"
                        >
                          Відкрити базовий предмет
                        </button>
                      </div>
                    </form>

                    <form method="post" action="/admin/pathways/v2/group-subjects/shared-sync" class="mt-3" id="subject-shared-sync-form">
                      <%- renderFocusFields() %>
                      <input type="hidden" name="source_group_subject_id" value="<%= initialSubjectCard ? initialSubjectCard.id : '' %>" data-group-subject-shared-sync-source />
                      <div class="academic-v2-actions">
                        <button type="submit" class="btn btn-outline-secondary" data-group-subject-shared-sync-submit <%= initialSubjectSharedMeta.mode === 'source' && initialSubjectSharedMeta.outbound_links.length ? '' : 'disabled' %>>Синхронізувати linked-копії</button>
                      </div>
                    </form>

                    <div class="academic-v2-stack mt-3" data-group-subject-shared-links>
                      <% if (initialSubjectSharedMeta.mode === 'source' && initialSubjectSharedMeta.outbound_links.length) { %>
                        <% initialSubjectSharedMeta.outbound_links.forEach((link) => { %>
                          <div class="academic-v2-course-subject-card academic-v2-course-subject-card--compact">
                            <div class="academic-v2-course-subject-card-head">
                              <div>
                                <strong><%= link.linked_group_label %></strong>
                                <div class="academic-v2-muted"><%= link.linked_subject_title %></div>
                              </div>
                              <span class="academic-v2-chip">Linked-копія</span>
                            </div>
                            <div class="academic-v2-actions mt-2">
                              <a class="btn btn-sm btn-outline-secondary" href="<%= link.workspace_href %>">Відкрити</a>
                            </div>
                          </div>
                        <% }); %>
                      <% } else if (initialSubjectSharedMeta.mode === 'linked' && initialSubjectSharedMeta.inbound_link) { %>
                        <div class="academic-v2-course-subject-card academic-v2-course-subject-card--compact">
                          <div class="academic-v2-course-subject-card-head">
                            <div>
                              <strong><%= initialSubjectSharedMeta.inbound_link.source_group_label %></strong>
                              <div class="academic-v2-muted"><%= initialSubjectSharedMeta.inbound_link.source_subject_title %></div>
                            </div>
                            <span class="academic-v2-chip academic-v2-chip--ok">Базове джерело</span>
                          </div>
                          <div class="academic-v2-actions mt-2">
                            <a class="btn btn-sm btn-outline-secondary" href="<%= initialSubjectSharedMeta.inbound_link.workspace_href %>">Відкрити джерело</a>
                          </div>
                        </div>
                      <% } else { %>
                        <div class="academic-v2-empty">Поки що немає linked-копій. Створи shared-копію для іншого курсу або працюй з одноразовим призначенням нижче.</div>
                      <% } %>
                    </div>
                  </div>

                  <form method="post" action="/admin/pathways/v2/group-subjects/assign" class="academic-v2-subcard" id="subject-assign-form">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="source_group_subject_id" value="" data-group-subject-assign-source />
                    <div class="academic-v2-section-head academic-v2-section-head--tight">
                      <div>
                        <div class="academic-v2-subcard-topline">Повторне використання предмета</div>
                        <h3 class="h6 mb-1">Призначити в інший курс</h3>
                        <p class="academic-v2-muted" style="font-size:0.74rem;">Копіює предмет без shared-звʼязку. Розклад не переноситься.</p>
                      </div>
                    </div>
                    <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                      <div class="academic-v2-field">
                        <label for="groupSubjectAssignTarget">Цільовий курс</label>
                        <select id="groupSubjectAssignTarget" class="form-select" name="target_group_id" data-group-subject-assign-target required>
                          <option value="">Оберіть курс…</option>
                          <% assignableCourseOptions.forEach((group) => { %>
                            <option value="<%= group.id %>"><%= group.option_label %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field">
                        <label>Що буде перенесено</label>
                        <div class="academic-v2-muted" data-group-subject-assign-summary>Вибери живий предмет зліва, щоб підготувати копію в інший курс.</div>
                      </div>
                    </div>
                    <div class="academic-v2-chip-row mt-1">
                      <span class="academic-v2-chip">Назва і прапорці</span>
                      <span class="academic-v2-chip">Терми за номером</span>
                      <span class="academic-v2-chip">Викладачі</span>
                      <span class="academic-v2-chip">Активності</span>
                      <span class="academic-v2-chip academic-v2-chip--warm">Розклад не копіюється</span>
                    </div>
                    <div class="academic-v2-checkboxes mt-3">
                      <input type="hidden" name="open_target_course" value="0" />
                      <div class="form-check">
                        <input id="groupSubjectAssignOpenTarget" class="form-check-input" type="checkbox" name="open_target_course" value="1" checked />
                        <label class="form-check-label" for="groupSubjectAssignOpenTarget">Після призначення відкрити цільовий курс і новий предмет</label>
                      </div>
                    </div>
                    <p class="academic-v2-muted mt-2 mb-0" style="font-size:0.74rem;" data-group-subject-assign-feedback>Вибери предмет і курс-ціль.</p>
                    <div class="academic-v2-actions mt-2">
                      <button type="submit" class="btn btn-primary" data-group-subject-assign-submit disabled>Призначити в інший курс</button>
                    </div>
                  </form>

                  <form method="post" action="/admin/pathways/v2/group-subject-activities/save" class="academic-v2-subcard" data-editor-form="group-subject-activity" id="subject-detail-activities">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="group_subject_activity_id" value="" data-editor-input="group-subject-activity.id" />
                    <div class="academic-v2-section-head academic-v2-section-head--tight">
                      <div>
                        <div class="academic-v2-subcard-topline">Активності предмета</div>
                        <h3 class="h6 mb-1">Керування лекціями, семінарами та практиками</h3>
                        <!-- Activities: child-layer of the current subject -->
                      </div>
                    </div>
                    <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                      <div class="academic-v2-field">
                        <label for="groupSubjectActivitySubject">Предмет курсу</label>
                        <select id="groupSubjectActivitySubject" class="form-select" name="group_subject_id" data-editor-input="group-subject-activity.group_subject_id">
                          <% subjectCards.forEach((subject) => { %>
                            <option value="<%= subject.id %>"><%= subject.title %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field">
                        <label for="groupSubjectActivityType">Тип активності</label>
                        <select id="groupSubjectActivityType" class="form-select" name="activity_type" data-editor-input="group-subject-activity.activity_type">
                          <% activityTypeOptions.forEach((activityType) => { %>
                            <option value="<%= activityType.value %>"><%= activityType.label %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field">
                        <label for="groupSubjectActivitySortOrder">Порядок</label>
                        <input id="groupSubjectActivitySortOrder" class="form-control" type="number" name="sort_order" data-editor-input="group-subject-activity.sort_order" value="0" />
                      </div>
                    </div>
                    <div class="academic-v2-chip-row mt-1">
                      <span class="academic-v2-chip">Lecture = для всіх підгруп</span>
                      <span class="academic-v2-chip">Seminar / Practice / Lab = по підгрупах</span>
                    </div>
                    <div class="academic-v2-actions mt-2">
                      <button type="submit" class="btn btn-primary">Зберегти активність</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="group-subject-activity">Скинути</button>
                    </div>
                    <div class="academic-v2-chip-row mt-1">
                      <% activityPresetOptions.forEach((preset) => { %>
                        <button
                          type="submit"
                          class="btn btn-sm btn-outline-secondary"
                          formaction="/admin/pathways/v2/group-subject-activities/preset"
                          formmethod="post"
                          name="preset_key"
                          value="<%= preset.value %>"
                        ><%= preset.label %></button>
                      <% }); %>
                    </div>
                  </form>

                  <div class="academic-v2-subcard">
                    <div class="academic-v2-subcard-topline">Поточний набір активностей</div>
                    <% if (scopedGroupSubjectActivitiesList.length) { %>
                      <div class="academic-v2-stack">
                        <% scopedGroupSubjectActivitiesList.forEach((activity) => { %>
                          <div class="academic-v2-activity-row" data-subject-activity-row data-subject-id="<%= activity.group_subject_id %>">
                            <div>
                              <strong><%= activity.subject_title %></strong>
                              <div class="academic-v2-muted"><%= activity.activity_label || activity.activity_type %> · порядок <%= Number(activity.sort_order || 0) %></div>
                            </div>
                            <div class="academic-v2-actions">
                              <button type="button" class="btn btn-sm btn-primary" data-editor-target="group-subject-activity" data-editor-payload='<%- toAttr(activity) %>' data-subject-focus-id="<%= activity.group_subject_id %>" data-subject-focus-section="activities">Редагувати</button>
                              <form method="post" action="/admin/pathways/v2/group-subject-activities/<%= activity.id %>/delete">
                                <%- renderFocusFields() %>
                                <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                              </form>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty">Для поточного курсу ще немає жодної активності.</div>
                    <% } %>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="terms" data-workspace-panel="terms">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Терми</h2>
                  <!-- Terms: lifecycle, archive, week count, schedule readiness -->
                </div>
                <div class="academic-v2-chip-row">
                  <span class="academic-v2-chip <%= activeTermCount ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= activeTermCount %> активних</span>
                  <span class="academic-v2-chip"><%= termCards.length %> всього</span>
                  <span class="academic-v2-chip"><%= archivedTermCount %> в архіві</span>
                  <span class="academic-v2-chip <%= workspaceReadiness.scheduleConflictCount ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>"><%= workspaceReadiness.scheduleConflictCount %> попереджень</span>
                </div>
              </div>
              <% if (selectedGroup) { %>
                <div class="academic-v2-grid-2 academic-v2-grid-2--terms">
                  <div class="academic-v2-stack">
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-subcard-topline">Готовність</div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip <%= workspaceReadiness.hasActiveTerm ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= workspaceReadiness.hasActiveTerm ? 'Активний терм вибрано' : 'Активний терм відсутній' %></span>
                        <span class="academic-v2-chip"><%= workspaceReadiness.subjectBoundCount %> предметів привʼязані до термів</span>
                        <span class="academic-v2-chip"><%= workspaceReadiness.activityReadyCount %> предметів готові до розкладу</span>
                        <span class="academic-v2-chip academic-v2-chip--warm"><%= workspaceReadiness.missingTeacherCount %> предметів без викладача</span>
                      </div>
                    </div>
                    <div class="academic-v2-stack">
                      <% termCards.forEach((term) => { %>
                        <div class="academic-v2-term-card">
                          <div class="academic-v2-course-subject-card-head">
                            <div>
                              <strong><%= term.title %></strong>
                              <div class="academic-v2-muted">Терм <%= term.term_number %> · <%= term.start_date || 'дата не задана' %> · <%= term.weeks_count %> тижнів</div>
                            </div>
                            <span class="academic-v2-chip <%= term.is_live ? 'academic-v2-chip--ok' : (term.is_archived ? 'academic-v2-chip--warm' : '') %>">
                              <%= term.is_live ? 'Активний' : (term.is_archived ? 'Архів' : 'Неактивний') %>
                            </span>
                          </div>
                          <div class="academic-v2-chip-row mt-1">
                            <span class="academic-v2-chip"><%= term.schedule_entry_count %> слотів</span>
                            <span class="academic-v2-chip"><%= term.is_archived ? 'Архівний' : 'Живий' %></span>
                          </div>
                          <div class="academic-v2-actions mt-2">
                            <button type="button" class="btn btn-sm btn-primary" data-editor-target="term" data-editor-payload='<%- toAttr(term) %>'>Редагувати</button>
                            <form method="post" action="/admin/pathways/v2/terms/save">
                              <%- renderFocusFields() %>
                              <input type="hidden" name="term_id" value="<%= term.id %>" />
                              <input type="hidden" name="group_id" value="<%= term.group_id %>" />
                              <input type="hidden" name="term_number" value="<%= term.term_number %>" />
                              <input type="hidden" name="title" value="<%= term.title %>" />
                              <input type="hidden" name="start_date" value="<%= term.start_date || '' %>" />
                              <input type="hidden" name="weeks_count" value="<%= term.weeks_count %>" />
                              <input type="hidden" name="is_active" value="1" />
                              <input type="hidden" name="is_archived" value="0" />
                              <button type="submit" class="btn btn-sm btn-outline-secondary">Зробити активним</button>
                            </form>
                            <form method="post" action="/admin/pathways/v2/terms/save">
                              <%- renderFocusFields() %>
                              <input type="hidden" name="term_id" value="<%= term.id %>" />
                              <input type="hidden" name="group_id" value="<%= term.group_id %>" />
                              <input type="hidden" name="term_number" value="<%= term.term_number %>" />
                              <input type="hidden" name="title" value="<%= term.title %>" />
                              <input type="hidden" name="start_date" value="<%= term.start_date || '' %>" />
                              <input type="hidden" name="weeks_count" value="<%= term.weeks_count %>" />
                              <input type="hidden" name="is_active" value="<%= term.is_archived ? 0 : (term.is_active ? 1 : 0) %>" />
                              <input type="hidden" name="is_archived" value="<%= term.is_archived ? 0 : 1 %>" />
                              <button type="submit" class="btn btn-sm btn-outline-secondary"><%= term.is_archived ? 'Повернути з архіву' : 'В архів' %></button>
                            </form>
                            <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ term_id: term.id }) %>">Відкрити розклад</a>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  </div>
                  <form method="post" action="/admin/pathways/v2/terms/save" class="academic-v2-subcard" data-editor-form="term">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="term_id" value="" data-editor-input="term.id" />
                    <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" data-editor-input="term.group_id" data-preserve-reset="1" />
                    <div class="academic-v2-subcard-topline">Редактор терму</div>
                    <div class="academic-v2-form-grid">
                      <div class="academic-v2-field">
                        <label for="termNumber">Номер терму</label>
                        <select id="termNumber" class="form-select" name="term_number" data-editor-input="term.term_number">
                          <% termOptions.forEach((term) => { %>
                            <option value="<%= term.value %>"><%= term.label %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;">
                        <label for="termTitle">Назва</label>
                        <input id="termTitle" class="form-control" type="text" name="title" data-editor-input="term.title" placeholder="Term 1" required />
                      </div>
                      <div class="academic-v2-field">
                        <label for="termStartDate">Дата старту</label>
                        <input id="termStartDate" class="form-control" type="date" name="start_date" data-editor-input="term.start_date" />
                      </div>
                      <div class="academic-v2-field">
                        <label>Кількість тижнів</label>
                        <div class="academic-v2-muted">Фіксовано: T1 = 15, T2 = 15, T3 = 7.</div>
                      </div>
                    </div>
                    <div class="academic-v2-checkboxes mt-3">
                      <input type="hidden" name="is_active" value="0" />
                      <div class="form-check"><input id="termActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="term.is_active" /><label class="form-check-label" for="termActive">Активний терм</label></div>
                      <input type="hidden" name="is_archived" value="0" />
                      <div class="form-check"><input id="termArchived" class="form-check-input" type="checkbox" name="is_archived" value="1" data-editor-input="term.is_archived" /><label class="form-check-label" for="termArchived">Архівний</label></div>
                    </div>
                    <div class="academic-v2-actions mt-2">
                      <button type="submit" class="btn btn-primary">Зберегти терм</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="term">Скинути</button>
                    </div>
                  </form>
                </div>
              <% } else { %>
                <div class="academic-v2-empty">Оберіть курс, щоб керувати термами.</div>
              <% } %>
            </section>

            <section class="academic-v2-card" id="schedule" data-workspace-panel="schedule">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Розклад</h2>
                  <!-- Schedule: grid-first editor, advanced row editor as fallback -->
                </div>
                <div class="academic-v2-chip-row">
                  <span class="academic-v2-chip"><%= selectedTermRecord ? selectedTermRecord.title : 'Терм не вибрано' %></span>
                  <span class="academic-v2-chip"><%= scheduleEntriesForViews.length %> слотів у вибраному термі</span>
                  <a class="academic-v2-chip <%= workspaceReadiness.scheduleConflictCount ? 'academic-v2-chip--warm' : 'academic-v2-chip--ok' %>" href="<%= buildScheduleListHref({ warning_only: workspaceReadiness.scheduleConflictCount ? 1 : '' }) %>#warning-report">
                    <%= workspaceReadiness.scheduleConflictCount ? `${workspaceReadiness.scheduleConflictCount} слотів із попередженнями` : 'Без попереджень' %>
                  </a>
                  <a class="academic-v2-chip" href="<%= buildScheduleListHref() %>">Усі слоти окремо</a>
                </div>
              </div>
              <% if (selectedGroup) { %>
                <div class="academic-v2-grid-2 academic-v2-grid-2--schedule-summary">
                  <div class="academic-v2-subcard" id="schedule-warning-preview">
                    <div class="academic-v2-subcard-topline">Попередження розкладу</div>
                    <% if (scheduleWarningEntries.length) { %>
                      <h3 class="h6 mb-1">Що саме означає <%= workspaceReadiness.scheduleConflictCount %> попереджень</h3>
                      <div class="academic-v2-muted">
                        Лічильник показує кількість слотів, у яких є хоча б одна проблема. Нижче є розбивка по причинах і кілька перших прикладів.
                      </div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip academic-v2-chip--warm"><%= scheduleWarningEntries.length %> слотів з проблемами</span>
                        <span class="academic-v2-chip"><%= scheduleWarningReasonTotal %> окремих причин</span>
                        <% scheduleWarningReasonBreakdown.slice(0, 4).forEach((item) => { %>
                          <span class="academic-v2-chip"><%= item.label %> · <%= item.count %></span>
                        <% }); %>
                      </div>
                      <div class="academic-v2-stack mt-3">
                        <% scheduleWarningPreview.forEach((entry) => { %>
                          <div class="academic-v2-warning-row">
                            <div class="academic-v2-warning-row-head">
                              <strong><%= entry.subject_title %></strong>
                              <span class="academic-v2-chip academic-v2-chip--warm"><%= entry.warning_labels.length %> причин</span>
                            </div>
                            <div class="academic-v2-muted">
                              <%= entry.day_of_week %> · пара <%= entry.class_number %> · тиждень <%= entry.week_number %> · <%= entry.activity_label || entry.activity_type %> · <%= entry.target_group_label %>
                            </div>
                            <div class="academic-v2-chip-row mt-2">
                              <% entry.warning_labels.forEach((label) => { %>
                                <span class="academic-v2-schedule-warning"><%= label %></span>
                              <% }); %>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                      <% if (scheduleWarningHiddenCount > 0) { %>
                        <div class="academic-v2-muted mt-3">Ще <%= scheduleWarningHiddenCount %> слотів із попередженнями винесені в детальний список.</div>
                      <% } %>
                      <div class="academic-v2-actions mt-2">
                        <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref({ warning_only: 1 }) %>#warning-report">Відкрити детальний розбір</a>
                        <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref() %>">Усі слоти окремою сторінкою</a>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-alert academic-v2-alert--success mb-0">
                        У вибраному термі зараз немає слотів із конфліктами, браком викладача або term-binding помилками.
                      </div>
                    <% } %>
                  </div>
                  <div class="academic-v2-subcard">
                    <div class="academic-v2-subcard-topline">Окремий список слотів</div>
                    <h3 class="h6 mb-1">Повний перелік пар більше не вантажиться в цьому workspace цілком</h3>
                    <div class="academic-v2-muted">
                      Основний робочий екран лишається grid-first. Повний список усіх слотів і детальний warning-report відкриваються окремо, щоб вкладка `Розклад` не гальмувала.
                    </div>
                    <div class="academic-v2-chip-row mt-1">
                      <span class="academic-v2-chip"><%= scheduleEntriesForViews.length %> слотів</span>
                      <span class="academic-v2-chip"><%= schedulePreviewEntries.length %> слотів у швидкому preview</span>
                      <span class="academic-v2-chip"><%= scheduleBySubject.length %> предметів із розкладом</span>
                    </div>
                    <div class="academic-v2-actions mt-2">
                      <a class="btn btn-primary" href="<%= buildScheduleListHref() %>">Відкрити повний список слотів</a>
                      <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref({ warning_only: 1 }) %>#warning-report">Тільки проблемні слоти</a>
                    </div>
                  </div>
                </div>
                <div class="academic-v2-grid-2 academic-v2-grid-2--schedule">
                  <div class="academic-v2-stack">
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-section-head academic-v2-section-head--tight">
                        <div>
                          <div class="academic-v2-subcard-topline">Вигляд</div>
                          <h3 class="h6 mb-1">Перемикання подань</h3>
                        </div>
                        <div class="academic-v2-actions">
                          <button type="button" class="btn btn-outline-secondary" data-schedule-view-target="calendar">Календар</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-view-target="subject">За предметом</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-view-target="teacher">За викладачем</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-view-target="group">За підгрупою</button>
