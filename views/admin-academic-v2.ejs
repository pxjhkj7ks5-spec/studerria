                          <div class="academic-v2-field academic-v2-field--compact">
                            <label for="schedulePlacementWeek">Тижні</label>
                            <input id="schedulePlacementWeek" class="form-control" type="text" value="<%= scheduleWeekOptions[0] || 1 %>" placeholder="1 або 1, 3, 5" />
