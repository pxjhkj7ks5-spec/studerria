                                    <span><%= entry.subject_title %> · <%= entry.activity_label || entry.activity_type %></span>
                                  </button>
                                <% }); %>
                              </div>
                              <% if (groupView.hidden_entry_count > 0) { %>
                                <div class="academic-v2-muted mt-2">Ще <%= groupView.hidden_entry_count %> слотів цієї підгрупи є в окремому списку.</div>
                              <% } %>
                            <% } else { %>
                              <div class="academic-v2-muted mt-2">На цю підгрупу поки нічого не поставлено.</div>
                            <% } %>
                          </div>
                        <% }); %>
                      </div>
                      <div class="academic-v2-actions mt-2">
                        <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref() %>">Повний список по підгрупах</a>
                      </div>
                    </div>
                  </div>

                  <div class="academic-v2-stack">
                    <details class="academic-v2-advanced-block" open>
                      <summary>Advanced editor</summary>
                      <form method="post" action="/admin/pathways/v2/schedule/save" class="academic-v2-subcard mt-3" data-editor-form="schedule">
                        <%- renderFocusFields() %>
                        <input type="hidden" name="schedule_entry_id" value="" data-editor-input="schedule.id" />
                        <input id="scheduleActivity" type="hidden" name="group_subject_activity_id" value="" data-editor-input="schedule.group_subject_activity_id" />
                        <div class="academic-v2-form-grid academic-v2-form-grid--compact academic-v2-form-grid--schedule-advanced">
                          <div class="academic-v2-field">
                            <label for="scheduleTerm">Терм</label>
                            <select id="scheduleTerm" class="form-select" name="term_id" data-editor-input="schedule.term_id">
                              <% termCards.forEach((term) => { %>
                                <option value="<%= term.id %>" <%= Number(term.id) === activeTermId ? 'selected' : '' %>><%= term.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field academic-v2-field--wide">
                            <label for="scheduleSubject">Предмет</label>
                            <select id="scheduleSubject" class="form-select">
                              <% schedulableSubjects.forEach((subject) => { %>
                                <option value="<%= subject.id %>"><%= subject.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="scheduleDay">День</label>
                            <select id="scheduleDay" class="form-select" name="day_of_week" data-editor-input="schedule.day_of_week">
                              <% dayOptions.forEach((day) => { %>
                                <option value="<%= day %>"><%= day %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="scheduleActivityType">Режим активності</label>
                            <select id="scheduleActivityType" class="form-select"></select>
                          </div>
                          <div class="academic-v2-field academic-v2-field--compact">
                            <label for="scheduleClassNumber">Пара</label>
                            <input id="scheduleClassNumber" class="form-control" type="number" name="class_number" data-editor-input="schedule.class_number" value="1" />
                          </div>
                          <div class="academic-v2-field academic-v2-field--wide">
                            <label for="scheduleWeekNumber">Тижні</label>
                            <input id="scheduleWeekNumber" class="form-control" type="text" name="week_number" data-editor-input="schedule.week_number" value="1" placeholder="1 або 1, 3, 5" />
                            <div class="academic-v2-muted mt-1">Список тижнів замінює поточний набір для цього слота.</div>
                          </div>
                          <div class="academic-v2-field academic-v2-field--full academic-v2-field--schedule-groups">
                            <label for="scheduleTargetGroups">Підгрупи</label>
                            <select id="scheduleTargetGroups" class="form-select" name="target_group_numbers" multiple size="4" data-editor-input="schedule.target_group_numbers"></select>
                            <div id="scheduleTargetGroupsHint" class="academic-v2-muted mt-2">Спершу вибери предмет і режим активності. Лекції використовують усі підгрупи автоматично.</div>
                          </div>
                        </div>
                        <div class="academic-v2-actions mt-2">
                          <button type="submit" class="btn btn-primary">Зберегти слот</button>
                          <button type="button" class="btn btn-outline-secondary" data-editor-reset="schedule">Скинути</button>
                        </div>
                      </form>
                    </details>

                    <div class="academic-v2-subcard" data-schedule-view-panel="advanced">
                      <div class="academic-v2-subcard-topline">Швидкий список слотів</div>
                      <% if (schedulePreviewEntries.length) { %>
                        <div class="academic-v2-stack">
                          <% schedulePreviewEntries.forEach((entry) => { %>
                            <div class="academic-v2-schedule-list-card">
                              <div class="d-flex flex-wrap justify-content-between gap-2">
                                <div>
                                  <strong><%= entry.subject_title %></strong>
                                  <div class="academic-v2-muted"><%= entry.day_of_week %> · пара <%= entry.class_number %> · тиждень <%= entry.week_number %> · <%= entry.activity_label || entry.activity_type %> · <%= entry.target_group_label %></div>
                                </div>
                                <div class="academic-v2-actions">
                                  <button type="button" class="btn btn-sm btn-primary" data-editor-target="schedule" data-editor-payload='<%- toAttr(entry) %>'>Редагувати</button>
                                  <form method="post" action="/admin/pathways/v2/schedule/<%= entry.id %>/delete">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                                  </form>
                                </div>
                              </div>
                            </div>
                          <% }); %>
                        </div>
                        <% if (schedulePreviewHiddenCount > 0) { %>
                          <div class="academic-v2-muted mt-3">Ще <%= schedulePreviewHiddenCount %> слотів винесено на окрему сторінку, щоб ця вкладка відкривалась швидше.</div>
                        <% } %>
                        <div class="academic-v2-actions mt-2">
                          <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref() %>">Відкрити повний список слотів</a>
                          <a class="btn btn-outline-secondary" href="<%= buildScheduleListHref({ warning_only: 1 }) %>#warning-report">Проблемні слоти</a>
                        </div>
                      <% } else { %>
                        <div class="academic-v2-empty">У цьому термі ще немає manual rows.</div>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% } else { %>
                <div class="academic-v2-empty">Оберіть курс, щоб перейти до розкладу.</div>
              <% } %>
            </section>

            <section class="academic-v2-card" id="teachers" data-workspace-panel="teachers">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Викладачі</h2>
                  <!-- Teacher coverage for current course -->
                </div>
              </div>
              <% if (teacherCoverageCards.length) { %>
                <div class="academic-v2-grid-2 academic-v2-grid-2--teachers">
                  <% teacherCoverageCards.forEach((teacher) => { %>
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-course-subject-card-head">
                        <div>
                          <strong><%= teacher.teacher_name %></strong>
                          <div class="academic-v2-muted"><%= teacher.subject_titles.length %> предметів · <%= teacher.entries.length %> слотів</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-workspace-tab-target="schedule">Розклад</button>
                      </div>
                      <div class="academic-v2-chip-row mt-1">
                        <% teacher.subject_titles.forEach((title) => { %>
                          <span class="academic-v2-chip"><%= title %></span>
                        <% }); %>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="academic-v2-empty">У поточному курсі ще немає призначених викладачів.</div>
              <% } %>
            </section>

            <section class="academic-v2-card" id="students" data-workspace-panel="students">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Студенти та перепризначення</h2>
                  <!-- Bulk enrollment with preview and confirmation -->
                </div>
                <div class="academic-v2-chip-row">
                  <span class="academic-v2-chip"><%= selectedGroupUsersList.length %> вже в курсі</span>
                  <span class="academic-v2-chip"><%= (users || []).length %> доступно для призначення</span>
                </div>
              </div>
              <% if (selectedGroup) { %>
                <form method="post" action="/admin/pathways/v2/enrollments/bulk" class="academic-v2-stack" id="studentBulkForm">
                  <%- renderFocusFields() %>
                  <div class="academic-v2-grid-2 academic-v2-grid-2--students">
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-subcard-topline">Ціль перепризначення</div>
                      <div class="academic-v2-field mt-3">
                        <label for="bulkGroupId">Курс призначення</label>
                        <select id="bulkGroupId" class="form-select" name="group_id">
                          <% (scopedGroups || groups || []).forEach((group) => { %>
                            <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip" id="studentSelectionCount">0 вибрано</span>
                        <span class="academic-v2-chip"><%= selectedGroup.label %></span>
                        <span class="academic-v2-chip"><%= selectedGroupUsersList.length %> зараз у курсі</span>
                      </div>
                      <div class="academic-v2-alert academic-v2-alert--warning mt-3" id="studentBulkConfirmText">
                        Перед застосуванням перевір підсумок: скільки людей вибрано і в який курс вони підуть.
                      </div>
                      <div class="academic-v2-actions mt-2">
                        <button type="submit" class="btn btn-primary">Застосувати перепризначення</button>
                      </div>
                    </div>
                    <div class="academic-v2-subcard">
                      <div class="academic-v2-student-table-wrap">
                        <table class="table academic-v2-table">
                          <thead>
                            <tr>
                              <th></th>
                              <th>Студент</th>
                              <th>Роль</th>
                              <th>Поточний курс</th>
                              <th>Статус</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% (users || []).forEach((user) => { %>
                              <tr>
                                <td><input class="form-check-input" type="checkbox" name="user_ids" value="<%= user.id %>" data-student-checkbox /></td>
                                <td>
                                  <div class="academic-v2-kv">
                                    <strong><%= user.full_name %></strong>
                                    <span class="academic-v2-muted"><%= user.legacy_course_name || 'legacy не задано' %></span>
                                  </div>
                                </td>
                                <td><span class="academic-v2-chip"><%= user.role %></span></td>
                                <td><%= user.group_label || 'Не призначено' %></td>
                                <td><span class="academic-v2-chip <%= Number(user.group_id || 0) === Number(activeGroupId || 0) ? 'academic-v2-chip--ok' : '' %>"><%= Number(user.group_id || 0) === Number(activeGroupId || 0) ? 'У цьому курсі' : 'Можна перенести' %></span></td>
                              </tr>
                            <% }); %>
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </form>
              <% } else { %>
                <div class="academic-v2-empty">Оберіть курс, щоб управляти студентським складом.</div>
              <% } %>
            </section>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/app-footer') %>
    <%- include('partials/changelog-modal') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
      defer
    ></script>
    <script>
      (function academicV2Editors() {
        const workspaceDefaultMode = <%- JSON.stringify(workspaceDefaultMode) %>;
        const subjectCardsData = <%- JSON.stringify(subjectCards || []) %>;
        const scopedGroupSubjectsData = <%- JSON.stringify(subjectCards || []) %>;
        const scopedGroupSubjectActivitiesData = <%- JSON.stringify(scopedGroupSubjectActivitiesList || []) %>;
        const sharedSubjectMetaData = <%- JSON.stringify(sharedSubjectMetaById || {}) %>;
        const subjectTemplateIdsByGroupData = <%- JSON.stringify(subjectTemplateIdsByGroup || {}) %>;
        const requestedSubjectId = Number(<%- JSON.stringify(numberOrZero(requestedSubjectId)) %> || 0);
        const requestedWorkspaceTab = <%- JSON.stringify(String(requestedWorkspaceTab || '').trim()) %>;
        const normalizedRequestedWorkspaceTab = ['overview', 'subjects', 'terms', 'schedule', 'teachers', 'students'].includes(requestedWorkspaceTab)
          ? requestedWorkspaceTab
          : '';
        const scheduleEntriesData = <%- JSON.stringify(scheduleEntriesForViews || []) %>;
        const requestedScheduleEntryId = Number(<%- JSON.stringify(numberOrZero(requestedScheduleEntryId)) %> || 0);
        const forms = new Map();
        document.querySelectorAll('[data-editor-form]').forEach((form) => {
