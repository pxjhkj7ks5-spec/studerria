                          <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-subject-activity">Скинути</button>
                        </div>
                        <div class="academic-v2-chip-row mt-1">
                          <% activityPresetOptions.forEach((preset) => { %>
                            <button
                              type="submit"
                              class="btn btn-sm btn-outline-secondary"
                              formaction="/admin/pathways/v2/stage-subject-activities/preset"
                              formmethod="post"
                              name="preset_key"
                              value="<%= preset.value %>"
                            ><%= preset.label %></button>
                          <% }); %>
