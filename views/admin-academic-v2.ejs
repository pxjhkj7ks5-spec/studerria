                              <div class="academic-v2-stack mt-3">
                                <% groupView.preview_entries.forEach((entry) => { %>
                                  <button type="button" class="academic-v2-inline-card-button" data-editor-target="schedule" data-editor-payload='<%- toAttr(entry) %>'>
