                          <% teacherCoverageCards.forEach((teacher) => { %>
                            <div class="academic-v2-schedule-list-card">
                              <strong><%= teacher.teacher_name %></strong>
                              <div class="academic-v2-chip-row mt-2">
                                <span class="academic-v2-chip"><%= teacher.subject_titles.length %> предметів</span>
                                <span class="academic-v2-chip"><%= teacher.entries.length %> слотів</span>
