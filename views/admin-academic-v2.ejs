<%
  const numberOrZero = (value) => {
    const normalized = Number(value || 0);
    return Number.isInteger(normalized) && normalized > 0 ? normalized : 0;
  };
  const focusState = focus && typeof focus === 'object' ? focus : {};
  const activeProgramId = numberOrZero(focusState.programId);
  const activeCohortId = numberOrZero(focusState.cohortId);
  const activeGroupId = numberOrZero(focusState.groupId);
  const activeTermId = numberOrZero(focusState.termId);
  const activeTemplateStage = numberOrZero(focusState.templateStageNumber) || 1;
  const projectionHealthList = Array.isArray(projectionHealth) ? projectionHealth : [];
  const projectionHealthByGroup = new Map(projectionHealthList.map((item) => [Number(item.group_id || 0), item]));
  const projectionHealthTotals = projectionHealthSummary && typeof projectionHealthSummary === 'object' ? projectionHealthSummary : {};
  const activityIntegrityState = activityIntegrity && typeof activityIntegrity === 'object' ? activityIntegrity : {};
  const activityIntegritySummary = activityIntegrityState.summary && typeof activityIntegrityState.summary === 'object'
    ? activityIntegrityState.summary
    : {};
  const scopedStageSubjectsWithoutActivities = Array.isArray(activityIntegrityState.scopedStageSubjectTemplatesWithoutActivities)
    ? activityIntegrityState.scopedStageSubjectTemplatesWithoutActivities
    : [];
  const scopedGroupSubjectsWithoutActivities = Array.isArray(activityIntegrityState.scopedGroupSubjectsWithoutActivities)
    ? activityIntegrityState.scopedGroupSubjectsWithoutActivities
    : [];
  const cleanupAudit = auditSummary && typeof auditSummary === 'object' ? auditSummary : {};
  const stageOptions = [1, 2, 3, 4];
  const trackOptions = [
    { value: 'bachelor', label: 'Bachelor' },
    { value: 'master', label: 'Master' },
    { value: 'teacher', label: 'Teacher' },
  ];
  const campusOptions = [
    { value: 'kyiv', label: 'Kyiv' },
    { value: 'munich', label: 'Munich' },
  ];
  const dayOptions = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
  const activityTypeOptions = [
    { value: 'lecture', label: 'Lecture' },
    { value: 'seminar', label: 'Seminar' },
    { value: 'practice', label: 'Practice' },
    { value: 'lab', label: 'Lab' },
  ];
  const activityPresetOptions = [
    { value: 'lecture_seminar', label: 'Lecture + seminar' },
    { value: 'lecture_practice', label: 'Lecture + practice' },
    { value: 'lecture_seminar_lab', label: 'Lecture + seminar + lab' },
  ];
  const selectedGroupUsers = (users || []).filter((item) => Number(item.group_id || 0) === activeGroupId);
  const scopedGroupSubjectsList = Array.isArray(scopedGroupSubjects) ? scopedGroupSubjects : [];
  const scopedGroupSubjectActivitiesList = Array.isArray(scopedGroupSubjectActivities) ? scopedGroupSubjectActivities : [];
  const scopedStageSubjectTemplatesList = Array.isArray(scopedStageSubjectTemplates) ? scopedStageSubjectTemplates : [];
  const scopedStageSubjectActivitiesList = Array.isArray(scopedStageSubjectActivities) ? scopedStageSubjectActivities : [];
  const buildFocusHref = (overrides = {}) => {
    const merged = Object.assign({}, {
      program_id: activeProgramId,
      cohort_id: activeCohortId,
      group_id: activeGroupId,
      term_id: activeTermId,
      template_stage: activeTemplateStage,
    }, overrides || {});
    const params = new URLSearchParams();
    Object.entries(merged).forEach(([key, rawValue]) => {
      const value = numberOrZero(rawValue);
      if (value > 0) {
        params.set(key, String(value));
      }
    });
    const query = params.toString();
    return query ? `/admin/pathways?${query}` : '/admin/pathways';
  };
  const renderFocusFields = () => `
    <input type="hidden" name="focus_program_id" value="${activeProgramId || ''}" />
    <input type="hidden" name="focus_cohort_id" value="${activeCohortId || ''}" />
    <input type="hidden" name="focus_group_id" value="${activeGroupId || ''}" />
    <input type="hidden" name="focus_term_id" value="${activeTermId || ''}" />
    <input type="hidden" name="focus_template_stage" value="${activeTemplateStage || 1}" />
  `;
  const toAttr = (value) => JSON.stringify(value || {}).replace(/'/g, '&#39;');
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Academic Setup v2</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/pages/admin-academic-v2.css" />
  </head>
  <body>
    <%- include('partials/theme-bootstrap-body') %>

    <main class="academic-v2-page">
      <div class="academic-v2-shell">
        <section class="academic-v2-hero">
          <div class="academic-v2-hero-grid">
            <div>
              <span class="academic-v2-kicker">Academic Core v2</span>
              <h1 class="academic-v2-title">One model for programs, cohorts, courses, terms, and live subjects.</h1>
              <p class="academic-v2-subtitle">
                This replaces the old daily Academic Setup flow with a single source of truth:
                <strong>Program -> Cohort -> Course -> Term -> CourseSubject</strong>.
                Legacy courses, subjects, semesters, registration pathways, and schedule rows are now compatibility projections only.
              </p>
              <div class="academic-v2-hero-actions">
                <a class="btn btn-primary btn-lg" href="#scope">Open control surface</a>
                <a class="btn btn-outline-secondary btn-lg" href="/admin/pathways?legacy=1">Legacy read-only view</a>
                <a class="btn btn-outline-secondary btn-lg" href="/admin">Back to admin</a>
              </div>
            </div>
            <div class="academic-v2-summary-grid">
              <div class="academic-v2-stat">
                <span class="academic-v2-stat-label">Programs</span>
                <span class="academic-v2-stat-value"><%= Number(summary && summary.programs_total ? summary.programs_total : 0) %></span>
              </div>
              <div class="academic-v2-stat">
                <span class="academic-v2-stat-label">Courses</span>
                <span class="academic-v2-stat-value"><%= Number(summary && summary.groups_total ? summary.groups_total : 0) %></span>
              </div>
              <div class="academic-v2-stat">
                <span class="academic-v2-stat-label">Course subjects</span>
                <span class="academic-v2-stat-value"><%= Number(summary && summary.group_subjects_total ? summary.group_subjects_total : 0) %></span>
              </div>
              <div class="academic-v2-stat">
                <span class="academic-v2-stat-label">Schedule entries</span>
                <span class="academic-v2-stat-value"><%= Number(summary && summary.schedule_entries_total ? summary.schedule_entries_total : 0) %></span>
              </div>
            </div>
          </div>
        </section>

        <div class="academic-v2-layout">
          <aside class="academic-v2-sidebar">
            <div class="academic-v2-sidebar-title">Sections</div>
            <nav class="academic-v2-sidebar-nav">
              <a class="academic-v2-nav-link" href="#scope"><span>Focus</span><span class="academic-v2-code">01</span></a>
              <a class="academic-v2-nav-link" href="#health"><span>Projection Health</span><span class="academic-v2-code">02</span></a>
              <a class="academic-v2-nav-link" href="#programs"><span>Programs</span><span class="academic-v2-code">03</span></a>
              <a class="academic-v2-nav-link" href="#cohorts"><span>Cohorts</span><span class="academic-v2-code">04</span></a>
              <a class="academic-v2-nav-link" href="#stage-templates"><span>Stage Templates</span><span class="academic-v2-code">05</span></a>
              <a class="academic-v2-nav-link" href="#groups"><span>Courses</span><span class="academic-v2-code">06</span></a>
              <a class="academic-v2-nav-link" href="#subjects"><span>Subjects & Teachers</span><span class="academic-v2-code">07</span></a>
              <a class="academic-v2-nav-link" href="#terms"><span>Terms & Schedule</span><span class="academic-v2-code">08</span></a>
            </nav>
            <div class="academic-v2-sidebar-note">
              Default admin writes go only into <span class="academic-v2-code">academic_v2_*</span>.
              Legacy tables stay alive as a one-way projection for registration and old user-facing pages.
            </div>
          </aside>

          <div class="academic-v2-main">
            <% if (success) { %>
              <div class="academic-v2-alert academic-v2-alert--success"><strong>Saved.</strong> <%= success %></div>
            <% } %>
            <% if (error) { %>
              <div class="academic-v2-alert academic-v2-alert--error"><strong>Action failed.</strong> <%= error %></div>
            <% } %>
            <% if (warning) { %>
              <div class="academic-v2-alert academic-v2-alert--warning"><strong>Saved with warning.</strong> <%= warning %></div>
            <% } %>

            <section class="academic-v2-card" id="scope">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Focus</h2>
                  <p class="academic-v2-section-copy">
                    Pick the working scope first. Every create/update action below keeps this focus state so you can operate inside one cohort and one course without constantly rebuilding context.
                  </p>
                </div>
                <div class="academic-v2-chip-row">
                  <% if (selectedProgram) { %><span class="academic-v2-chip"><%= selectedProgram.name %></span><% } %>
                  <% if (selectedCohort) { %><span class="academic-v2-chip"><%= selectedCohort.label %></span><% } %>
                  <% if (selectedGroup) { %><span class="academic-v2-chip"><%= selectedGroup.label %></span><% } %>
                  <% if (selectedTerm) { %><span class="academic-v2-chip academic-v2-chip--warm"><%= selectedTerm.title %></span><% } %>
                </div>
              </div>
              <form method="get" action="/admin/pathways" class="academic-v2-subcard">
                <div class="academic-v2-focus-grid">
                  <div class="academic-v2-field">
                    <label for="focusProgramId">Program</label>
                    <select id="focusProgramId" class="form-select" name="program_id">
                      <% (programs || []).forEach((program) => { %>
                        <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-field">
                    <label for="focusCohortId">Cohort</label>
                    <select id="focusCohortId" class="form-select" name="cohort_id">
                      <% (scopedCohorts || []).forEach((cohort) => { %>
                        <option value="<%= cohort.id %>" <%= Number(cohort.id) === activeCohortId ? 'selected' : '' %>><%= cohort.label %> - <%= cohort.admission_year %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-field">
                    <label for="focusGroupId">Course</label>
                    <select id="focusGroupId" class="form-select" name="group_id">
                      <% (scopedGroups || []).forEach((group) => { %>
                        <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %> - stage <%= group.stage_number %> - <%= group.campus_key %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-field">
                    <label for="focusTermId">Term</label>
                    <select id="focusTermId" class="form-select" name="term_id">
                      <option value="">All terms</option>
                      <% (scopedTerms || []).forEach((term) => { %>
                        <option value="<%= term.id %>" <%= Number(term.id) === activeTermId ? 'selected' : '' %>><%= term.title %></option>
                      <% }); %>
                    </select>
                  </div>
                </div>
                <div class="academic-v2-actions mt-3">
                  <button type="submit" class="btn btn-primary">Apply focus</button>
                </div>
              </form>
            </section>

            <section class="academic-v2-card" id="health">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Projection Health</h2>
                  <p class="academic-v2-section-copy">
                    <span class="academic-v2-code">academic_v2_*</span> is the only write source now. This section is a dry-run audit surface for projection drift, user normalization gaps, and legacy cleanup candidates before any destructive cleanup script runs.
                  </p>
                </div>
                <form method="post" action="/admin/pathways/v2/groups/resync-all">
                  <%- renderFocusFields() %>
                    <button type="submit" class="btn btn-outline-secondary">Resync all course projections</button>
                </form>
              </div>
              <div class="academic-v2-grid-2">
                <div class="academic-v2-subcard">
                  <h3 class="h5 mb-3">Live projection summary</h3>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--ok"><%= Number(projectionHealthTotals.groups_healthy || 0) %> healthy courses</span>
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= Number(projectionHealthTotals.groups_with_issues || 0) %> courses with issues</span>
                    <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_missing_legacy_course || 0) %> missing legacy course</span>
                    <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_without_active_term || 0) %> missing active term</span>
                    <span class="academic-v2-chip"><%= Number(projectionHealthTotals.groups_with_user_sync_gaps || 0) %> user sync gaps</span>
                    <span class="academic-v2-chip"><%= Number(projectionHealthTotals.subjects_without_teachers || 0) %> subjects without teachers</span>
                  </div>
                  <div class="academic-v2-table-wrap mt-3">
                    <table class="table academic-v2-table">
                      <thead>
                        <tr>
                          <th>Course</th>
                          <th>Health</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% projectionHealthList.forEach((item) => { %>
                          <tr>
                            <td>
                              <div class="academic-v2-kv">
                                <strong><%= item.group_label %></strong>
                                <span class="academic-v2-muted"><%= item.program_name %> - <%= item.admission_year %> - stage <%= item.stage_number %> - <%= item.campus_key %></span>
                              </div>
                            </td>
                            <td>
                              <div class="academic-v2-chip-row">
                                <span class="academic-v2-chip <%= item.is_healthy ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= item.is_healthy ? 'projection ok' : 'needs review' %></span>
                                <% (item.issues || []).slice(0, 4).forEach((issue) => { %>
                                  <span class="academic-v2-chip"><%= issue %></span>
                                <% }); %>
                                <% if ((item.issues || []).length > 4) { %>
                                  <span class="academic-v2-chip">+<%= item.issues.length - 4 %> more</span>
                                <% } %>
                              </div>
                            </td>
                            <td class="text-end">
                              <div class="academic-v2-actions justify-content-end">
                                <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: item.program_id, cohort_id: item.cohort_id, group_id: item.group_id, term_id: '' }) %>">Focus</a>
                                <form method="post" action="/admin/pathways/v2/groups/<%= item.group_id %>/resync">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-secondary">Resync</button>
                                </form>
                              </div>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </div>
                <div class="academic-v2-subcard">
                  <h3 class="h5 mb-3">Cleanup dry-run</h3>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= Number(cleanupAudit.total_findings || 0) %> total findings</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.users_without_group_id || 0) %> users without v2 course</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.users_with_course_projection_mismatch || 0) %> user projection mismatches</span>
                    <span class="academic-v2-chip"><%= Number(cleanupAudit.group_subjects_without_teacher_assignment || 0) %> subjects missing teacher</span>
                  </div>
                  <div class="academic-v2-table-wrap mt-3">
                    <table class="table academic-v2-table">
                      <tbody>
                        <tr><th>Courses without active term</th><td><%= Number(cleanupAudit.groups_without_active_term || 0) %></td></tr>
                        <tr><th>Stale legacy course mappings</th><td><%= Number(cleanupAudit.stale_legacy_course_rows || 0) %></td></tr>
                        <tr><th>Stale legacy subject rows</th><td><%= Number(cleanupAudit.stale_legacy_subject_rows || 0) %></td></tr>
                        <tr><th>Stale legacy semester rows</th><td><%= Number(cleanupAudit.stale_legacy_semester_rows || 0) %></td></tr>
                        <tr><th>Stale legacy schedule rows</th><td><%= Number(cleanupAudit.stale_legacy_schedule_rows || 0) %></td></tr>
                        <tr><th>Legacy study contexts without v2 owner</th><td><%= Number(cleanupAudit.stale_legacy_study_context_rows || 0) %></td></tr>
                        <tr><th>Stale legacy preset rows</th><td><%= Number(cleanupAudit.legacy_preset_rows || 0) %></td></tr>
                        <tr><th>Legacy offerings without v2 owner</th><td><%= Number(cleanupAudit.stale_legacy_offering_rows || 0) %></td></tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="academic-v2-muted mt-3">
                    Cleanup runs only from CLI:
                    <span class="academic-v2-code">node scripts/academic-v2-cleanup.js --normalize-users</span>,
                    <span class="academic-v2-code">node scripts/academic-v2-cleanup.js --archive-legacy-config</span>,
                    then repeat with <span class="academic-v2-code">--apply</span> after reviewing the dry-run snapshot.
                  </div>
                </div>
                <div class="academic-v2-subcard">
                  <h3 class="h5 mb-3">Activity integrity</h3>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip <%= Number(activityIntegritySummary.stage_subject_templates_without_activities || 0) === 0 ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>">
                      <%= Number(activityIntegritySummary.stage_subject_templates_without_activities || 0) %> stage subjects missing activity
                    </span>
                    <span class="academic-v2-chip <%= Number(activityIntegritySummary.group_subjects_without_activities || 0) === 0 ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>">
                      <%= Number(activityIntegritySummary.group_subjects_without_activities || 0) %> course subjects missing activity
                    </span>
                    <span class="academic-v2-chip">
                      <%= Number(activityIntegritySummary.scoped_stage_subject_templates_without_activities || 0) %> missing in selected stage scope
                    </span>
                    <span class="academic-v2-chip">
                      <%= Number(activityIntegritySummary.scoped_group_subjects_without_activities || 0) %> missing in selected course scope
                    </span>
                  </div>
                  <div class="academic-v2-table-wrap mt-3">
                    <table class="table academic-v2-table">
                      <tbody>
                        <tr>
                          <th>Selected stage template scope</th>
                          <td>
                            <% if (scopedStageSubjectsWithoutActivities.length) { %>
                              <div class="academic-v2-chip-row">
                                <% scopedStageSubjectsWithoutActivities.forEach((item) => { %>
                                  <span class="academic-v2-chip academic-v2-chip--warm"><%= item.subject_title %></span>
                                <% }); %>
                              </div>
                            <% } else { %>
                              <span class="academic-v2-muted">No missing activities in the selected stage template scope.</span>
                            <% } %>
                          </td>
                        </tr>
                        <tr>
                          <th>Selected course scope</th>
                          <td>
                            <% if (scopedGroupSubjectsWithoutActivities.length) { %>
                              <div class="academic-v2-chip-row">
                                <% scopedGroupSubjectsWithoutActivities.forEach((item) => { %>
                                  <span class="academic-v2-chip academic-v2-chip--warm"><%= item.subject_title %></span>
                                <% }); %>
                              </div>
                            <% } else { %>
                              <span class="academic-v2-muted">No missing activities in the selected course scope.</span>
                            <% } %>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <div class="academic-v2-muted mt-3">
                    Every stage subject template and live course subject should keep at least one activity so the activity-based schedule editor always has a valid target.
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="programs">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Programs</h2>
                  <p class="academic-v2-section-copy">Track-level configuration. No admissions, pathways, presets, or contexts here. Just the canonical program list.</p>
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/programs/save" class="academic-v2-subcard" data-editor-form="program">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="program_id" value="" data-editor-input="program.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="programTrack">Track</label>
                      <select id="programTrack" class="form-select" name="track_key" data-editor-input="program.track_key">
                        <% trackOptions.forEach((track) => { %>
                          <option value="<%= track.value %>"><%= track.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="programCode">Code</label>
                      <input id="programCode" class="form-control academic-v2-code" type="text" name="code" data-editor-input="program.code" placeholder="BSC-ENG" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="programName">Name</label>
                      <input id="programName" class="form-control" type="text" name="name" data-editor-input="program.name" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="programSort">Sort order</label>
                      <input id="programSort" class="form-control" type="number" name="sort_order" data-editor-input="program.sort_order" value="100" />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="programActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="program.is_active" checked />
                    <label class="form-check-label" for="programActive">Active program</label>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save program</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="program">Reset</button>
                  </div>
                </form>
                <div class="academic-v2-subcard">
                  <div class="academic-v2-table-wrap">
                    <table class="table academic-v2-table">
                      <thead>
                        <tr>
                          <th>Program</th>
                          <th>Stats</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% (programs || []).forEach((program) => { %>
                          <tr>
                            <td>
                              <div class="academic-v2-kv">
                                <strong><%= program.name %></strong>
                                <span class="academic-v2-muted"><%= program.track_key %> - <span class="academic-v2-code"><%= program.code || 'no-code' %></span></span>
                              </div>
                            </td>
                            <td><span class="academic-v2-chip"><%= program.cohort_count %> cohorts</span> <span class="academic-v2-chip"><%= program.group_count %> courses</span></td>
                            <td class="text-end">
                              <div class="academic-v2-actions justify-content-end">
                                <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: program.id, cohort_id: '', group_id: '', term_id: '' }) %>">Focus</a>
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="program" data-editor-payload='<%- toAttr(program) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/programs/<%= program.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="cohorts">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Cohorts</h2>
                  <p class="academic-v2-section-copy">Admission year belongs to the program directly. Cohorts stay empty until you create a course or promote the cohort into a prepared stage template.</p>
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/cohorts/save" class="academic-v2-subcard" data-editor-form="cohort">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="cohort_id" value="" data-editor-input="cohort.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="cohortProgram">Program</label>
                      <select id="cohortProgram" class="form-select" name="program_id" data-editor-input="cohort.program_id">
                        <% (programs || []).forEach((program) => { %>
                          <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="cohortYear">Admission year</label>
                      <input id="cohortYear" class="form-control" type="number" name="admission_year" data-editor-input="cohort.admission_year" value="<%= new Date().getFullYear() %>" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="cohortLabel">Label</label>
                      <input id="cohortLabel" class="form-control" type="text" name="label" data-editor-input="cohort.label" placeholder="2026 Intake" required />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="cohortActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="cohort.is_active" checked />
                    <label class="form-check-label" for="cohortActive">Active cohort</label>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save cohort</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="cohort">Reset</button>
                  </div>
                </form>
                <div class="academic-v2-stack">
                  <div class="academic-v2-subcard">
                    <div class="academic-v2-table-wrap">
                      <table class="table academic-v2-table">
                        <thead>
                          <tr>
                            <th>Cohort</th>
                            <th>Stats</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% (cohorts || []).forEach((cohort) => { %>
                            <tr>
                              <td>
                                <div class="academic-v2-kv">
                                  <strong><%= cohort.label %></strong>
                                  <span class="academic-v2-muted"><%= cohort.program_name %> - <%= cohort.admission_year %> - current stage <%= cohort.current_stage_number %></span>
                                </div>
                              </td>
                              <td>
                                <span class="academic-v2-chip"><%= cohort.group_count %> courses</span>
                                <span class="academic-v2-chip"><%= cohort.current_stage_number %> live stage</span>
                                <span class="academic-v2-chip academic-v2-chip--ok"><%= cohort.enrolled_users %> users</span>
                              </td>
                              <td class="text-end">
                                <div class="academic-v2-actions justify-content-end">
                                  <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: cohort.program_id, cohort_id: cohort.id, group_id: '', term_id: '' }) %>">Focus</a>
                                  <button type="button" class="btn btn-sm btn-primary" data-editor-target="cohort" data-editor-payload='<%- toAttr(cohort) %>'>Edit</button>
                                  <form method="post" action="/admin/pathways/v2/cohorts/<%= cohort.id %>/delete">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                  <div class="academic-v2-subcard">
                    <h3 class="h5 mb-2">Promote cohort</h3>
                    <% if (selectedCohort) { %>
                      <p class="academic-v2-section-copy mb-3">Move the cohort to the next stage with a preview. Promotion replaces the live subject and term set for the new stage, while the previous stage stays as history.</p>
                      <form method="get" action="/admin/pathways" class="academic-v2-form-grid academic-v2-form-grid--compact">
                        <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" />
                        <input type="hidden" name="cohort_id" value="<%= activeCohortId || '' %>" />
                        <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" />
                        <input type="hidden" name="term_id" value="<%= activeTermId || '' %>" />
                        <input type="hidden" name="template_stage" value="<%= activeTemplateStage || 1 %>" />
                        <input type="hidden" name="preview_cohort_id" value="<%= selectedCohort.id %>" />
                        <div class="academic-v2-field">
                          <label for="previewTargetStage">Target stage</label>
                          <select id="previewTargetStage" class="form-select" name="preview_target_stage">
                            <% stageOptions.forEach((stageNumber) => { %>
                              <option value="<%= stageNumber %>" <%= Number((promotionPreview && promotionPreview.target_stage_number) || selectedCohort.current_stage_number + 1) === stageNumber ? 'selected' : '' %>>Stage <%= stageNumber %></option>
                            <% }); %>
                          </select>
                        </div>
                        <div class="academic-v2-actions">
                          <button type="submit" class="btn btn-outline-secondary">Preview promotion</button>
                        </div>
                      </form>
                      <% if (promotionPreview && Number(promotionPreview.cohort_id || 0) === Number(selectedCohort.id || 0)) { %>
                        <div class="academic-v2-stack mt-3">
                          <div class="academic-v2-chip-row">
                            <span class="academic-v2-chip">Stage <%= promotionPreview.current_stage_number %> -> <%= promotionPreview.target_stage_number %></span>
                            <span class="academic-v2-chip"><%= promotionPreview.template_term_count %> template terms</span>
                            <span class="academic-v2-chip"><%= promotionPreview.template_subject_count %> template subjects</span>
                            <span class="academic-v2-chip"><%= promotionPreview.subjects_without_teacher_defaults %> subjects without teacher defaults</span>
                          </div>
                          <% if ((promotionPreview.issues || []).length) { %>
                            <div class="academic-v2-alert academic-v2-alert--warning">
                              <strong>Preview blocked.</strong>
                              <%= promotionPreview.issues.join(' ') %>
                            </div>
                          <% } %>
                          <% if ((promotionPreview.course_plans || []).length) { %>
                            <div class="academic-v2-table-wrap">
                              <table class="table academic-v2-table">
                                <thead>
                                  <tr>
                                    <th>Campus</th>
                                    <th>Current live course</th>
                                    <th>Target course</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% promotionPreview.course_plans.forEach((plan) => { %>
                                    <tr>
                                      <td><%= plan.campus_key %></td>
                                      <td>
                                        <div class="academic-v2-kv">
                                          <strong><%= plan.source_course_label %></strong>
                                          <span class="academic-v2-muted"><%= plan.source_user_count %> users, <%= plan.source_term_count %> terms, <%= plan.source_subject_count %> subjects</span>
                                        </div>
                                      </td>
                                      <td>
                                        <span class="academic-v2-chip"><%= plan.target_course_exists ? 'existing target course' : 'new target course' %></span>
                                        <% if (plan.target_course_label) { %><span class="academic-v2-chip"><%= plan.target_course_label %></span><% } %>
                                      </td>
                                    </tr>
                                  <% }); %>
                                </tbody>
                              </table>
                            </div>
                          <% } %>
                          <% if (promotionPreview.can_apply) { %>
                            <form method="post" action="/admin/pathways/v2/cohorts/<%= selectedCohort.id %>/promote" class="academic-v2-actions">
                              <%- renderFocusFields() %>
                              <input type="hidden" name="target_stage_number" value="<%= promotionPreview.target_stage_number %>" />
                              <button type="submit" class="btn btn-primary">Apply promotion</button>
                            </form>
                          <% } %>
                        </div>
                      <% } %>
                    <% } else { %>
                      <div class="academic-v2-empty">Focus a cohort first to preview and apply stage promotion.</div>
                    <% } %>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="stage-templates">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Stage templates</h2>
                  <p class="academic-v2-section-copy">Templates define which terms and subjects belong to each program stage. They do not create live course data until you explicitly apply them to a course or promote a cohort.</p>
                </div>
                <% if (scopedStageSubjectsWithoutActivities.length) { %>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= scopedStageSubjectsWithoutActivities.length %> stage subjects missing activity</span>
                  </div>
                <% } %>
              </div>
              <div class="academic-v2-subcard mb-4">
                <form method="get" action="/admin/pathways" class="academic-v2-focus-grid">
                  <input type="hidden" name="cohort_id" value="<%= activeCohortId || '' %>" />
                  <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" />
                  <input type="hidden" name="term_id" value="<%= activeTermId || '' %>" />
                  <div class="academic-v2-field">
                    <label for="templateProgramId">Program</label>
                    <select id="templateProgramId" class="form-select" name="program_id">
                      <% (programs || []).forEach((program) => { %>
                        <option value="<%= program.id %>" <%= Number(program.id) === activeProgramId ? 'selected' : '' %>><%= program.name %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-field">
                    <label for="templateStageNumber">Template stage</label>
                    <select id="templateStageNumber" class="form-select" name="template_stage">
                      <% stageOptions.forEach((stageNumber) => { %>
                        <option value="<%= stageNumber %>" <%= stageNumber === activeTemplateStage ? 'selected' : '' %>>Stage <%= stageNumber %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="academic-v2-actions">
                    <button type="submit" class="btn btn-outline-secondary">Load stage template</button>
                  </div>
                </form>
                <div class="academic-v2-chip-row mt-3">
                  <% (templateStageCards || []).forEach((card) => { %>
                    <span class="academic-v2-chip <%= card.is_current ? 'academic-v2-chip--ok' : '' %>">Stage <%= card.stage_number %>: <%= card.term_count %> terms, <%= card.subject_count %> subjects</span>
                  <% }); %>
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <div class="academic-v2-stack">
                  <form method="post" action="/admin/pathways/v2/stage-terms/save" class="academic-v2-subcard" data-editor-form="stage-term">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="stage_term_template_id" value="" data-editor-input="stage-term.id" />
                    <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" data-preserve-reset="1" />
                    <input type="hidden" name="stage_number" value="<%= activeTemplateStage || 1 %>" data-preserve-reset="1" />
                    <h3 class="h5 mb-3">Stage terms</h3>
                    <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                      <div class="academic-v2-field">
                        <label for="stageTermNumber">Term number</label>
                        <input id="stageTermNumber" class="form-control" type="number" name="term_number" data-editor-input="stage-term.term_number" value="1" required />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageTermTitle">Title</label>
                        <input id="stageTermTitle" class="form-control" type="text" name="title" data-editor-input="stage-term.title" placeholder="Semester 1" required />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageTermStartDate">Start date</label>
                        <input id="stageTermStartDate" class="form-control" type="date" name="start_date" data-editor-input="stage-term.start_date" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageTermWeeks">Weeks</label>
                        <input id="stageTermWeeks" class="form-control" type="number" name="weeks_count" data-editor-input="stage-term.weeks_count" value="16" />
                      </div>
                    </div>
                    <input type="hidden" name="is_active_default" value="0" />
                    <div class="form-check mt-3">
                      <input id="stageTermActiveDefault" class="form-check-input" type="checkbox" name="is_active_default" value="1" data-editor-input="stage-term.is_active_default" />
                      <label class="form-check-label" for="stageTermActiveDefault">Make this the default active term when the stage is applied</label>
                    </div>
                    <div class="academic-v2-actions mt-3">
                      <button type="submit" class="btn btn-primary">Save stage term</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-term">Reset</button>
                    </div>
                  </form>
                  <div class="academic-v2-subcard">
                    <h3 class="h5 mb-3">Current stage term templates</h3>
                    <% if ((scopedStageTermTemplates || []).length) { %>
                      <div class="academic-v2-stack">
                        <% (scopedStageTermTemplates || []).forEach((stageTerm) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                              <div>
                                <strong><%= stageTerm.title %></strong>
                                <div class="academic-v2-muted">Term <%= stageTerm.term_number %> - <%= stageTerm.weeks_count %> weeks<%= stageTerm.start_date ? ` - ${stageTerm.start_date}` : '' %></div>
                              </div>
                              <div class="academic-v2-actions">
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-term" data-editor-payload='<%- toAttr(stageTerm) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/stage-terms/<%= stageTerm.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty">No stage terms yet for the selected program and stage.</div>
                    <% } %>
                  </div>
                </div>
                <div class="academic-v2-stack">
                  <form method="post" action="/admin/pathways/v2/stage-subjects/save" class="academic-v2-subcard" data-editor-form="stage-subject">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="stage_subject_template_id" value="" data-editor-input="stage-subject.id" />
                    <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" data-preserve-reset="1" />
                    <input type="hidden" name="stage_number" value="<%= activeTemplateStage || 1 %>" data-preserve-reset="1" />
                    <h3 class="h5 mb-3">Stage subjects</h3>
                    <div class="academic-v2-form-grid">
                      <div class="academic-v2-field">
                        <label for="stageSubjectTemplate">Subject template</label>
                        <select id="stageSubjectTemplate" class="form-select" name="subject_template_id" data-editor-input="stage-subject.subject_template_id">
                          <% (subjectTemplates || []).forEach((template) => { %>
                            <option value="<%= template.id %>"><%= template.name %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;">
                        <label for="stageSubjectTitle">Live title override</label>
                        <input id="stageSubjectTitle" class="form-control" type="text" name="title" data-editor-input="stage-subject.title" placeholder="Leave empty to use the template name" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectGroups">Group count</label>
                        <input id="stageSubjectGroups" class="form-control" type="number" name="group_count" data-editor-input="stage-subject.group_count" value="1" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectDefaultGroup">Default group</label>
                        <input id="stageSubjectDefaultGroup" class="form-control" type="number" name="default_group" data-editor-input="stage-subject.default_group" value="1" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectSortOrder">Sort order</label>
                        <input id="stageSubjectSortOrder" class="form-control" type="number" name="sort_order" data-editor-input="stage-subject.sort_order" value="0" />
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectTerms">Stage terms</label>
                        <select id="stageSubjectTerms" class="form-select" name="stage_term_template_ids" multiple size="4" data-editor-input="stage-subject.stage_term_template_ids">
                          <% (scopedStageTermTemplates || []).forEach((stageTerm) => { %>
                            <option value="<%= stageTerm.id %>"><%= stageTerm.title %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field" style="grid-column: 1 / -1;">
                        <label for="stageSubjectTeachers">Default teachers</label>
                        <select id="stageSubjectTeachers" class="form-select" name="teacher_ids" multiple size="5" data-editor-input="stage-subject.teacher_ids">
                          <% (teachers || []).forEach((teacher) => { %>
                            <option value="<%= teacher.id %>"><%= teacher.full_name %></option>
                          <% }); %>
                        </select>
                      </div>
                    </div>
                    <div class="academic-v2-checkboxes mt-3">
                      <input type="hidden" name="is_visible" value="0" />
                      <div class="form-check"><input id="stageSubjectVisible" class="form-check-input" type="checkbox" name="is_visible" value="1" data-editor-input="stage-subject.is_visible" checked /><label class="form-check-label" for="stageSubjectVisible">Visible</label></div>
                      <input type="hidden" name="is_required" value="0" />
                      <div class="form-check"><input id="stageSubjectRequired" class="form-check-input" type="checkbox" name="is_required" value="1" data-editor-input="stage-subject.is_required" checked /><label class="form-check-label" for="stageSubjectRequired">Required</label></div>
                      <input type="hidden" name="is_general" value="0" />
                      <div class="form-check"><input id="stageSubjectGeneral" class="form-check-input" type="checkbox" name="is_general" value="1" data-editor-input="stage-subject.is_general" checked /><label class="form-check-label" for="stageSubjectGeneral">General</label></div>
                      <input type="hidden" name="show_in_teamwork" value="0" />
                      <div class="form-check"><input id="stageSubjectTeamwork" class="form-check-input" type="checkbox" name="show_in_teamwork" value="1" data-editor-input="stage-subject.show_in_teamwork" checked /><label class="form-check-label" for="stageSubjectTeamwork">Show in teamwork</label></div>
                    </div>
                    <div class="academic-v2-actions mt-3">
                      <button type="submit" class="btn btn-primary">Save stage subject</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-subject">Reset</button>
                    </div>
                  </form>
                  <div class="academic-v2-subcard">
                    <h3 class="h5 mb-3">Current stage subject templates</h3>
                    <% if (scopedStageSubjectTemplatesList.length) { %>
                      <div class="academic-v2-stack">
                        <% scopedStageSubjectTemplatesList.forEach((stageSubject) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                              <div>
                                <strong><%= stageSubject.title %></strong>
                                <div class="academic-v2-muted"><%= stageSubject.subject_template_name %></div>
                                <div class="academic-v2-chip-row mt-2">
                                  <span class="academic-v2-chip"><%= stageSubject.stage_term_titles.length ? stageSubject.stage_term_titles.join(', ') : 'All stage terms' %></span>
                                  <span class="academic-v2-chip"><%= stageSubject.teacher_names.length ? stageSubject.teacher_names.join(', ') : 'No teacher defaults' %></span>
                                  <% (stageSubject.activity_types || []).forEach((activityType) => { %>
                                    <span class="academic-v2-chip"><%= activityType %></span>
                                  <% }); %>
                                </div>
                              </div>
                              <div class="academic-v2-actions">
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-subject" data-editor-payload='<%- toAttr(stageSubject) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/stage-subjects/<%= stageSubject.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty">No stage subjects yet for the selected program and stage.</div>
                    <% } %>
                  </div>
                  <form method="post" action="/admin/pathways/v2/stage-subject-activities/save" class="academic-v2-subcard" data-editor-form="stage-subject-activity">
                    <%- renderFocusFields() %>
                    <input type="hidden" name="stage_subject_activity_id" value="" data-editor-input="stage-subject-activity.id" />
                    <h3 class="h5 mb-3">Stage subject activities</h3>
                    <div class="academic-v2-form-grid">
                      <div class="academic-v2-field">
                        <label for="stageSubjectActivityTemplate">Stage subject</label>
                        <select id="stageSubjectActivityTemplate" class="form-select" name="stage_subject_template_id" data-editor-input="stage-subject-activity.stage_subject_template_id">
                          <% scopedStageSubjectTemplatesList.forEach((stageSubject) => { %>
                            <option value="<%= stageSubject.id %>"><%= stageSubject.title %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectActivityType">Activity type</label>
                        <select id="stageSubjectActivityType" class="form-select" name="activity_type" data-editor-input="stage-subject-activity.activity_type">
                          <% activityTypeOptions.forEach((activityType) => { %>
                            <option value="<%= activityType.value %>"><%= activityType.label %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-field">
                        <label for="stageSubjectActivitySortOrder">Sort order</label>
                        <input id="stageSubjectActivitySortOrder" class="form-control" type="number" name="sort_order" data-editor-input="stage-subject-activity.sort_order" value="0" />
                      </div>
                    </div>
                    <div class="academic-v2-muted mt-3">Lecture activities are shared across all groups. Seminar, practice, and lab activities are scheduled by subgroup.</div>
                    <div class="academic-v2-actions mt-3">
                      <button type="submit" class="btn btn-primary">Save stage activity</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="stage-subject-activity">Reset</button>
                    </div>
