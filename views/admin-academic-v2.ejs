                      <select id="termGroup" class="form-select" name="group_id" data-editor-input="term.group_id">
                        <% (scopedGroups || groups || []).forEach((group) => { %>
                          <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="termNumber">Term number</label>
                      <input id="termNumber" class="form-control" type="number" name="term_number" data-editor-input="term.term_number" value="1" required />
                    </div>
                    <div class="academic-v2-field" style="grid-column: 1 / -1;">
                      <label for="termTitle">Title</label>
                      <input id="termTitle" class="form-control" type="text" name="title" data-editor-input="term.title" placeholder="Fall term" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="termStartDate">Start date</label>
                      <input id="termStartDate" class="form-control" type="date" name="start_date" data-editor-input="term.start_date" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="termWeeks">Weeks count</label>
                      <input id="termWeeks" class="form-control" type="number" name="weeks_count" data-editor-input="term.weeks_count" value="16" />
                    </div>
                  </div>
                  <div class="academic-v2-checkboxes mt-3">
                    <input type="hidden" name="is_active" value="0" />
                    <div class="form-check"><input id="termActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="term.is_active" /><label class="form-check-label" for="termActive">Active term</label></div>
                    <input type="hidden" name="is_archived" value="0" />
                    <div class="form-check"><input id="termArchived" class="form-check-input" type="checkbox" name="is_archived" value="1" data-editor-input="term.is_archived" /><label class="form-check-label" for="termArchived">Archived</label></div>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save term</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="term">Reset</button>
                  </div>
                </form>

                <form method="post" action="/admin/pathways/v2/schedule/save" class="academic-v2-subcard" data-editor-form="schedule">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="schedule_entry_id" value="" data-editor-input="schedule.id" />
                  <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                    <div class="academic-v2-field">
                      <label for="scheduleTerm">Term</label>
                      <select id="scheduleTerm" class="form-select" name="term_id" data-editor-input="schedule.term_id">
                        <% (scopedTerms || []).forEach((term) => { %>
                          <option value="<%= term.id %>" <%= Number(term.id) === activeTermId ? 'selected' : '' %>><%= term.title %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleActivity">Subject activity</label>
                      <select id="scheduleActivity" class="form-select" name="group_subject_activity_id" data-editor-input="schedule.group_subject_activity_id">
                        <% scopedGroupSubjectActivitiesList.forEach((activity) => { %>
                          <option value="<%= activity.id %>"><%= activity.subject_title %> · <%= activity.activity_type %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleDay">Day</label>
                      <select id="scheduleDay" class="form-select" name="day_of_week" data-editor-input="schedule.day_of_week">
                        <% dayOptions.forEach((day) => { %>
                          <option value="<%= day %>"><%= day %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleActivityTypeDisplay">Activity mode</label>
                      <input id="scheduleActivityTypeDisplay" class="form-control" type="text" value="" readonly />
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleClassNumber">Class #</label>
                      <input id="scheduleClassNumber" class="form-control" type="number" name="class_number" data-editor-input="schedule.class_number" value="1" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleWeekNumber">Week #</label>
                      <input id="scheduleWeekNumber" class="form-control" type="number" name="week_number" data-editor-input="schedule.week_number" value="1" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="scheduleTargetGroups">Target groups</label>
                      <select id="scheduleTargetGroups" class="form-select" name="target_group_numbers" multiple size="4" data-editor-input="schedule.target_group_numbers"></select>
                      <div id="scheduleTargetGroupsHint" class="academic-v2-muted mt-2">Lecture activities use all groups automatically.</div>
                    </div>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save schedule entry</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="schedule">Reset</button>
                  </div>
                </form>

                <div class="academic-v2-stack">
                  <div class="academic-v2-subcard">
                    <h3 class="h5 mb-3">Terms in selected course</h3>
                    <% if ((scopedTerms || []).length) { %>
                      <div class="academic-v2-stack">
                        <% (scopedTerms || []).forEach((term) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                              <div>
                                <strong><%= term.title %></strong>
                                <div class="academic-v2-muted">Term <%= term.term_number %> - <%= term.start_date || 'no start date' %> - <%= term.weeks_count %> weeks</div>
                              </div>
                              <div class="academic-v2-actions">
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="term" data-editor-payload='<%- toAttr(term) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/terms/<%= term.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty"><%= activeGroupId ? 'No terms for the current course yet.' : 'Pick or create a course first.' %></div>
                    <% } %>
                  </div>
                  <div class="academic-v2-subcard">
                    <h3 class="h5 mb-3">Manual schedule</h3>
                    <% if ((scopedScheduleEntries || []).length) { %>
                      <div class="academic-v2-stack">
                        <% (scopedScheduleEntries || []).forEach((entry) => { %>
                          <div class="academic-v2-subcard">
                            <div class="d-flex flex-wrap justify-content-between gap-2">
                              <div>
                                <strong><%= entry.subject_title %></strong>
                                <div class="academic-v2-muted"><%= entry.term_title %> - <%= entry.day_of_week %> - class <%= entry.class_number %> - week <%= entry.week_number %> - <%= entry.activity_label || entry.lesson_type %> - <%= entry.target_group_label || ('group ' + entry.group_number) %></div>
                              </div>
                              <div class="academic-v2-actions">
                                <button type="button" class="btn btn-sm btn-primary" data-editor-target="schedule" data-editor-payload='<%- toAttr(entry) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/schedule/<%= entry.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </div>
                          </div>
                        <% }); %>
                      </div>
                    <% } else { %>
                      <div class="academic-v2-empty"><%= activeGroupId ? 'No manual schedule rows for the current course yet.' : 'Pick or create a course first.' %></div>
                    <% } %>
                  </div>
                </div>
              </div>
              <% if (selectedGroupUsers.length) { %>
                <div class="academic-v2-subcard mt-4">
                  <h3 class="h5 mb-3">Students in current course</h3>
                  <div class="academic-v2-chip-row">
                    <% selectedGroupUsers.forEach((user) => { %>
                      <span class="academic-v2-chip"><%= user.full_name %> - <%= user.role %></span>
                    <% }); %>
                  </div>
                </div>
              <% } %>
            </section>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/app-footer') %>
    <%- include('partials/changelog-modal') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
      defer
    ></script>
    <script>
      (function academicV2Editors() {
        const scopedGroupSubjectsData = <%- JSON.stringify(scopedGroupSubjectsList || []) %>;
        const scopedGroupSubjectActivitiesData = <%- JSON.stringify(scopedGroupSubjectActivitiesList || []) %>;
        const forms = new Map();
        document.querySelectorAll('[data-editor-form]').forEach((form) => {
          forms.set(form.getAttribute('data-editor-form'), form);
        });
        const groupCohort = document.getElementById('groupCohort');
        const groupTeacherDefaultField = document.getElementById('groupTeacherDefaultField');
        const groupTeacherDefault = document.getElementById('groupTeacherDefault');
        const scheduleActivity = document.getElementById('scheduleActivity');
        const scheduleActivityTypeDisplay = document.getElementById('scheduleActivityTypeDisplay');
        const scheduleTargetGroups = document.getElementById('scheduleTargetGroups');
        const scheduleTargetGroupsHint = document.getElementById('scheduleTargetGroupsHint');

        const capitalize = (value) => {
          const text = String(value || '').trim();
          return text ? text.charAt(0).toUpperCase() + text.slice(1) : '';
        };

        const getScopedSubjectById = (subjectId) => scopedGroupSubjectsData.find((subject) => Number(subject.id || 0) === Number(subjectId || 0)) || null;
        const getScopedActivityById = (activityId) => scopedGroupSubjectActivitiesData.find((activity) => Number(activity.id || 0) === Number(activityId || 0)) || null;

        const syncGroupTeacherDefaultVisibility = () => {
          if (!groupTeacherDefaultField || !groupTeacherDefault || !groupCohort) {
            return;
          }
          const selectedOption = groupCohort.options[groupCohort.selectedIndex] || null;
          const trackKey = String(selectedOption?.dataset.trackKey || '').trim().toLowerCase();
          const isTeacherTrack = trackKey === 'teacher';
          groupTeacherDefaultField.style.display = isTeacherTrack ? '' : 'none';
          if (!isTeacherTrack) {
            groupTeacherDefault.checked = false;
          }
        };

        const syncScheduleActivityState = (payload = null) => {
          if (!scheduleActivity || !scheduleTargetGroups || !scheduleActivityTypeDisplay || !scheduleTargetGroupsHint) {
            return;
          }
          const selectedActivityId = Number(
            scheduleActivity.value
            || (payload && (payload.group_subject_activity_id || payload.activity_id))
            || 0
          );
          const activity = getScopedActivityById(selectedActivityId);
          const subject = activity ? getScopedSubjectById(activity.group_subject_id) : null;
          const activityType = String(
            (activity && activity.activity_type)
            || (payload && (payload.activity_type || payload.lesson_type))
            || ''
          ).trim().toLowerCase();
          const isLecture = activityType === 'lecture';
          const groupCount = Math.max(1, Number(subject && subject.group_count ? subject.group_count : 1) || 1);
          const defaultGroup = Math.max(1, Number(subject && subject.default_group ? subject.default_group : 1) || 1);
          const requestedGroups = Array.isArray(payload && payload.target_group_numbers)
            ? payload.target_group_numbers.map((value) => String(value))
            : (payload && payload.group_number ? [String(payload.group_number)] : []);

          scheduleTargetGroups.innerHTML = '';
          if (activityType) {
            scheduleActivityTypeDisplay.value = isLecture
              ? `${capitalize(activityType)} · all groups`
              : `${capitalize(activityType)} · by subgroup`;
          } else {
            scheduleActivityTypeDisplay.value = '';
          }

          if (!activity) {
            scheduleTargetGroups.disabled = true;
            scheduleTargetGroupsHint.textContent = 'Select a subject activity first.';
            return;
          }

          if (isLecture) {
            scheduleTargetGroups.disabled = true;
            scheduleTargetGroupsHint.textContent = 'Lecture activities always target all groups.';
            return;
          }

          scheduleTargetGroups.disabled = false;
          scheduleTargetGroupsHint.textContent = 'Pick one or more subgroups for this activity.';
          for (let groupNumber = 1; groupNumber <= groupCount; groupNumber += 1) {
            const option = document.createElement('option');
            option.value = String(groupNumber);
            option.textContent = `Group ${groupNumber}`;
            option.selected = requestedGroups.length
              ? requestedGroups.includes(option.value)
              : groupNumber === defaultGroup;
            scheduleTargetGroups.appendChild(option);
          }
        };

        const applyPayload = (target, payload) => {
          const form = forms.get(target);
          if (!form || !payload || typeof payload !== 'object') {
            return;
          }
          form.querySelectorAll('[data-editor-input]').forEach((field) => {
            const path = field.getAttribute('data-editor-input') || '';
            const expectedPrefix = target + '.';
            if (!path.startsWith(expectedPrefix)) {
              return;
            }
            const payloadKey = path.slice(expectedPrefix.length);
            const value = payload[payloadKey];
            if (field instanceof HTMLInputElement && field.type === 'checkbox') {
              field.checked = value === true || value === 1 || value === '1';
              return;
            }
            if (field instanceof HTMLSelectElement && field.multiple) {
              const selectedValues = Array.isArray(value) ? value.map((item) => String(item)) : [];
              Array.from(field.options).forEach((option) => {
                option.selected = selectedValues.includes(option.value);
              });
              return;
            }
            field.value = value == null ? '' : String(value);
          });
          if (target === 'group') {
            syncGroupTeacherDefaultVisibility();
          }
          if (target === 'schedule') {
            syncScheduleActivityState(payload);
          }
        };

        document.querySelectorAll('[data-editor-target]').forEach((button) => {
          button.addEventListener('click', () => {
            const target = button.getAttribute('data-editor-target');
            const rawPayload = button.getAttribute('data-editor-payload') || '{}';
            try {
              applyPayload(target, JSON.parse(rawPayload));
              const form = forms.get(target);
              if (form) {
                form.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            } catch (_error) {
              // ignore malformed payloads
            }
          });
        });

        document.querySelectorAll('[data-editor-reset]').forEach((button) => {
          button.addEventListener('click', () => {
            const target = button.getAttribute('data-editor-reset');
            const form = forms.get(target);
            if (!form) {
              return;
            }
            form.reset();
            form.querySelectorAll('input[type="hidden"]').forEach((input) => {
              if (String(input.name || '').startsWith('focus_')) {
                return;
              }
              if (input.hasAttribute('data-preserve-reset')) {
                return;
              }
              input.value = '';
            });
            if (target === 'group') {
              syncGroupTeacherDefaultVisibility();
            }
            if (target === 'schedule') {
              syncScheduleActivityState();
            }
          });
        });

        if (groupCohort) {
          groupCohort.addEventListener('change', syncGroupTeacherDefaultVisibility);
        }
        if (scheduleActivity) {
          scheduleActivity.addEventListener('change', () => syncScheduleActivityState());
        }
        syncGroupTeacherDefaultVisibility();
        syncScheduleActivityState();
      })();
    </script>
  </body>
</html>
