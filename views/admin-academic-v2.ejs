                        <%- renderFocusFields() %>
                        <input type="hidden" name="stage_subject_activity_id" value="" data-editor-input="stage-subject-activity.id" />
                        <h3 class="h6 mb-1">Stage subject activities</h3>
                        <div class="academic-v2-form-grid">
                          <div class="academic-v2-field">
                            <label for="stageSubjectActivityTemplate">Stage subject</label>
                            <select id="stageSubjectActivityTemplate" class="form-select" name="stage_subject_template_id" data-editor-input="stage-subject-activity.stage_subject_template_id">
                              <% scopedStageSubjectTemplatesList.forEach((stageSubject) => { %>
                                <option value="<%= stageSubject.id %>"><%= stageSubject.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageSubjectActivityType">Activity type</label>
                            <select id="stageSubjectActivityType" class="form-select" name="activity_type" data-editor-input="stage-subject-activity.activity_type">
                              <% activityTypeOptions.forEach((activityType) => { %>
                                <option value="<%= activityType.value %>"><%= activityType.label %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="stageSubjectActivitySortOrder">Sort order</label>
                            <input id="stageSubjectActivitySortOrder" class="form-control" type="number" name="sort_order" data-editor-input="stage-subject-activity.sort_order" value="0" />
                          </div>
                        </div>
                        <div class="academic-v2-muted mt-3">Lecture shared. Seminar/practice/lab by subgroup.</div>
