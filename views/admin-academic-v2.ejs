                        <div class="academic-v2-subcard">
                          <div class="d-flex flex-wrap justify-content-between gap-2">
                            <div>
                              <strong><%= activity.subject_title %></strong>
                              <div class="academic-v2-muted"><%= activity.activity_type %> · <%= Number(activity.sort_order || 0) %></div>
                            </div>
                            <div class="academic-v2-actions">
                              <button type="button" class="btn btn-sm btn-primary" data-editor-target="group-subject-activity" data-editor-payload='<%- toAttr(activity) %>'>Edit</button>
                              <form method="post" action="/admin/pathways/v2/group-subject-activities/<%= activity.id %>/delete">
                                <%- renderFocusFields() %>
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                              </form>
                            </div>
                          </div>
                        </div>
                      <% }); %>
                    </div>
