                      <select id="groupSubjectTerms" class="form-select" name="term_ids" multiple size="5" data-editor-input="group-subject.term_ids">
                        <% (scopedTerms || []).forEach((term) => { %>
                          <option value="<%= term.id %>"><%= term.title %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field" style="grid-column: 1 / -1;">
                      <label for="groupSubjectTeachers">Teachers</label>
                      <select id="groupSubjectTeachers" class="form-select" name="teacher_ids" multiple size="5" data-editor-input="group-subject.teacher_ids">
