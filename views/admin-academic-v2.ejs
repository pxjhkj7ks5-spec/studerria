                        <% if (scopedStageSubjectActivitiesList.length) { %>
                          <div class="academic-v2-stack">
                            <% scopedStageSubjectActivitiesList.forEach((activity) => { %>
                              <div class="academic-v2-subcard">
                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                  <div>
                                    <strong><%= activity.subject_title %></strong>
                                    <div class="academic-v2-muted"><%= activity.activity_type %> · <%= Number(activity.sort_order || 0) %></div>
                                  </div>
                                  <div class="academic-v2-actions">
                                    <button type="button" class="btn btn-sm btn-primary" data-editor-target="stage-subject-activity" data-editor-payload='<%- toAttr(activity) %>'>Edit</button>
                                    <form method="post" action="/admin/pathways/v2/stage-subject-activities/<%= activity.id %>/delete">
                                      <%- renderFocusFields() %>
                                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                  </div>
                                </div>
                              </div>
                            <% }); %>
                          </div>
                        <% } else { %>
                          <div class="academic-v2-empty">No stage activities yet.</div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </details>
              </div>
            </section>

            <% if (isBachelorProgramSelected) { %>
              <section class="academic-v2-card" id="bachelor-catalog-panel" data-structure-panel="bachelor-catalog">
                  <div class="academic-v2-section-head academic-v2-section-head--tight">
                    <div>
                      <div class="academic-v2-subcard-topline">Каталог бакалавра</div>
                      <h3 class="h6 mb-1">Bulk editor</h3>
                      <!-- Bachelor catalog: edit stage/term/required flags; sync adds missing only -->
                    </div>
                    <div class="academic-v2-chip-row">
                      <span class="academic-v2-chip"><%= bachelorCatalogRowsList.length %> entries</span>
                      <span class="academic-v2-chip academic-v2-chip--ok"><%= bachelorCatalogSummary.seeded %> seeded</span>
                      <span class="academic-v2-chip academic-v2-chip--warm"><%= bachelorCatalogSummary.customized %> customized</span>
                      <span class="academic-v2-chip academic-v2-chip--warm"><%= bachelorCatalogSummary.unassigned %> unassigned</span>
                    </div>
                  </div>
                  <div class="academic-v2-grid-2">
                    <form method="get" action="/admin/pathways" class="academic-v2-subcard">
                      <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" />
                      <input type="hidden" name="cohort_id" value="<%= activeCohortId || '' %>" />
                      <input type="hidden" name="group_id" value="<%= activeGroupId || '' %>" />
                      <input type="hidden" name="term_id" value="<%= activeTermId || '' %>" />
                      <input type="hidden" name="template_stage" value="<%= activeTemplateStage || 1 %>" />
                      <div class="academic-v2-field">
                        <label for="bachelorCatalogSource">Source</label>
                        <select id="bachelorCatalogSource" class="form-select" name="bachelor_catalog_source">
                          <% bachelorCatalogSourcesList.forEach((source) => { %>
                            <option value="<%= source.key %>" <%= String(source.key || '') === String(activeBachelorCatalogSourceKey || '') ? 'selected' : '' %>>
                              <%= source.label %> · <%= source.entry_count %> rows
                            </option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="academic-v2-actions mt-2">
                        <button type="submit" class="btn btn-outline-secondary">Завантажити source</button>
                      </div>
                    </form>
                    <form method="post" action="/admin/pathways/v2/bachelor-catalog/sync" class="academic-v2-subcard">
                      <%- renderFocusFields() %>
                      <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" />
                      <input type="hidden" name="source_key" value="<%= selectedBachelorCatalogSource ? selectedBachelorCatalogSource.key : activeBachelorCatalogSourceKey %>" />
                      <div class="academic-v2-subcard-topline">Sync</div>
                      <div class="academic-v2-muted" style="font-size:0.78rem;">
                        <% if (selectedBachelorCatalogSource) { %>
                          <strong><%= selectedBachelorCatalogSource.title %></strong>
                        <% } else { %>
                          Обери source для sync.
                        <% } %>
                      </div>
                      <div class="academic-v2-chip-row mt-1">
                        <span class="academic-v2-chip">Default preset: L + S</span>
                        <span class="academic-v2-chip">Flags start as required + general</span>
                      </div>
                      <div class="academic-v2-actions mt-2">
                        <button type="submit" class="btn btn-primary" <%= !selectedBachelorCatalogSource ? 'disabled' : '' %>>Sync source → program</button>
                      </div>
                    </form>
                  </div>
                  <div class="academic-v2-field mt-3">
                    <label for="bachelorCatalogSearch">Search</label>
                    <input
                      id="bachelorCatalogSearch"
                      class="form-control"
                      type="search"
                      placeholder="Пошук за назвою, кодом або блоком"
                      data-bachelor-catalog-search
                    />
                  </div>
                  <% if (bachelorCatalogRowsList.length) { %>
                    <div class="table-responsive mt-3">
                      <table class="table align-middle academic-v2-table">
                        <thead>
                          <tr>
                            <th>Source row</th>
                            <th>Suggested</th>
                            <th>Current</th>
                            <th>Flags</th>
                            <th>Status</th>
                            <th>Save</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% bachelorCatalogRowsList.forEach((row) => { %>
                            <% const currentStageNumber = numberOrZero(row.current_stage_number); %>
                            <% const currentTermNumbers = Array.isArray(row.current_term_numbers) ? row.current_term_numbers : []; %>
                            <% const suggestedTermNumbers = Array.isArray(row.suggested_term_numbers) ? row.suggested_term_numbers : []; %>
                            <tr
                              data-bachelor-catalog-row
                              data-bachelor-catalog-searchable="<%= [row.display_title, row.template_name, row.source_code, row.source_section, row.entry_kind].join(' ').toLowerCase() %>"
                            >
                              <td>
                                <strong><%= row.display_title %></strong>
                                <div class="academic-v2-muted"><%= row.source_code %> · <%= row.source_section %></div>
                                <% if (row.template_name !== row.display_title) { %>
                                  <div class="academic-v2-muted">Template: <%= row.template_name %></div>
                                <% } %>
                                <div class="academic-v2-chip-row mt-2">
                                  <span class="academic-v2-chip">Kind: <%= row.entry_kind %></span>
                                  <span class="academic-v2-chip">L + S default</span>
                                </div>
                              </td>
                              <td>
                                <div class="academic-v2-chip-row">
                                  <span class="academic-v2-chip"><%= row.suggested_stage_number ? `Stage ${row.suggested_stage_number}` : 'Stage —' %></span>
                                  <span class="academic-v2-chip"><%= suggestedTermNumbers.length ? `Term ${suggestedTermNumbers.join(', ')}` : 'Terms —' %></span>
                                </div>
                              </td>
                              <td>
                                <div class="academic-v2-chip-row">
                                  <span class="academic-v2-chip <%= currentStageNumber ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= currentStageNumber ? `Stage ${currentStageNumber}` : 'Unassigned' %></span>
                                  <span class="academic-v2-chip"><%= currentTermNumbers.length ? `Term ${currentTermNumbers.join(', ')}` : 'Terms —' %></span>
                                </div>
                              </td>
                              <td>
                                <div class="academic-v2-chip-row">
                                  <span class="academic-v2-chip <%= row.current_is_required ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= row.current_is_required ? 'Required' : 'Optional' %></span>
                                  <span class="academic-v2-chip <%= row.current_is_general ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= row.current_is_general ? 'General' : 'Not general' %></span>
                                </div>
                              </td>
                              <td>
                                <span class="academic-v2-chip <%= row.status && row.status.tone === 'ok' ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>">
                                  <%= row.status && row.status.label ? row.status.label : 'Unknown' %>
                                </span>
                              </td>
                              <td style="min-width: 360px;">
                                <form method="post" action="/admin/pathways/v2/bachelor-catalog/save" class="academic-v2-stack">
                                  <%- renderFocusFields() %>
                                  <input type="hidden" name="program_id" value="<%= activeProgramId || '' %>" />
                                  <input type="hidden" name="source_key" value="<%= row.source_key %>" />
                                  <input type="hidden" name="source_code" value="<%= row.source_code %>" />
                                  <input type="hidden" name="stage_subject_template_id" value="<%= row.current_stage_subject_template_id || '' %>" />
                                  <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                                    <div class="academic-v2-field">
                                      <label>Stage</label>
                                      <select class="form-select form-select-sm" name="stage_number">
                                        <option value="">Unassigned</option>
                                        <% stageOptions.forEach((stageNumber) => { %>
                                          <option value="<%= stageNumber %>" <%= currentStageNumber === stageNumber ? 'selected' : '' %>>Stage <%= stageNumber %></option>
                                        <% }); %>
                                      </select>
                                    </div>
                                    <div class="academic-v2-field">
                                      <label>Terms</label>
                                      <div class="academic-v2-chip-row">
                                        <% termOptions.forEach((term) => { %>
                                          <label class="academic-v2-chip">
                                            <input type="checkbox" name="term_numbers" value="<%= term.value %>" <%= currentTermNumbers.includes(term.value) ? 'checked' : '' %> />
                                            T<%= term.value %>
                                          </label>
                                        <% }); %>
                                      </div>
                                    </div>
                                  </div>
                                  <div class="academic-v2-chip-row">
                                    <label class="academic-v2-chip">
                                      <input type="hidden" name="is_required" value="0" />
                                      <input type="checkbox" name="is_required" value="1" <%= row.current_is_required ? 'checked' : '' %> />
                                      Required
                                    </label>
                                    <label class="academic-v2-chip">
                                      <input type="hidden" name="is_general" value="0" />
                                      <input type="checkbox" name="is_general" value="1" <%= row.current_is_general ? 'checked' : '' %> />
                                      General
                                    </label>
                                  </div>
                                  <div class="academic-v2-actions">
                                    <button type="submit" class="btn btn-sm btn-primary">Save row</button>
                                  </div>
                                </form>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } else { %>
                    <div class="academic-v2-empty mt-3">Source has no rows for this program yet.</div>
                  <% } %>
              </section>
            <% } %>

            <section class="academic-v2-card" id="subject-templates" data-structure-panel="subject-templates">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Subject templates</h2>
                </div>
                <div class="academic-v2-chip-row">
                  <span class="academic-v2-chip"><%= subjectTemplates.length %> templates</span>
                  <span class="academic-v2-chip"><%= subjectCards.length %> linked in selected course</span>
                </div>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/templates/save" class="academic-v2-subcard" data-editor-form="template">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="subject_template_id" value="" data-editor-input="template.id" />
                  <div class="academic-v2-section-head academic-v2-section-head--tight">
                    <div>
                      <div class="academic-v2-subcard-topline">Catalog</div>
                      <h3 class="h6 mb-1">Шаблон предмета</h3>
                    </div>
                  </div>
                  <div class="academic-v2-form-grid academic-v2-form-grid--compact">
                    <div class="academic-v2-field" style="grid-column: 1 / -1;">
                      <label for="templateName">Назва шаблону</label>
                      <input id="templateName" class="form-control" type="text" name="name" data-editor-input="template.name" placeholder="Філософія" required />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-2">
                    <input id="templateActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="template.is_active" checked />
                    <label class="form-check-label" for="templateActive">Активний шаблон</label>
                  </div>
                  <div class="academic-v2-actions mt-2">
                    <button type="submit" class="btn btn-primary">Зберегти шаблон</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="template">Скинути</button>
                  </div>
                </form>
                <div class="academic-v2-subcard">
                  <div class="academic-v2-table-wrap">
                    <table class="table academic-v2-table">
                      <thead>
                        <tr>
                          <th>Template</th>
                          <th>Usage</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% (subjectTemplates || []).forEach((template) => { %>
                          <tr>
                            <td>
                              <div class="academic-v2-kv">
                                <strong><%= template.name %></strong>
                                <span class="academic-v2-muted"><%= template.is_active ? 'Active' : 'Inactive' %></span>
                              </div>
                            </td>
                            <td>
                              <div class="academic-v2-chip-row">
                                <span class="academic-v2-chip"><%= template.group_subject_count %> system</span>
                                <span class="academic-v2-chip"><%= Number(currentSubjectTemplateLinks.get(Number(template.id || 0)) || 0) %> selected course</span>
                              </div>
                            </td>
                            <td class="text-end">
                              <div class="academic-v2-actions justify-content-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-editor-target="template" data-editor-payload='<%- toAttr(template) %>'>Edit</button>
                                <form method="post" action="/admin/pathways/v2/templates/<%= template.id %>/delete">
                                  <%- renderFocusFields() %>
                                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                              </div>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="groups" data-structure-panel="courses">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Courses</h2>
