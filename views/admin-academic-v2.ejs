                </div>
                <% if (selectedGroup) { %>
                  <div class="academic-v2-actions">
                    <form method="post" action="/admin/pathways/v2/groups/<%= selectedGroup.id %>/apply-stage-template">
                      <%- renderFocusFields() %>
                      <button type="submit" class="btn btn-outline-secondary">Apply stage template</button>
