          const requestedGroups = Array.isArray(payload && payload.target_group_numbers)
            ? payload.target_group_numbers.map((value) => String(value))
            : (payload && payload.group_number
              ? [String(payload.group_number)]
              : getRequestedValues(selectElement));

          selectElement.innerHTML = '';
          if (!activity) {
            selectElement.disabled = true;
            if (hintElement) {
              hintElement.textContent = 'Спершу вибери предмет і режим активності.';
            }
            return { activity: null, subject: null, isLecture: false };
          }

          if (isLecture) {
            selectElement.disabled = true;
            if (hintElement) {
              hintElement.textContent = 'Лекція автоматично ставиться на всі підгрупи.';
            }
            return { activity, subject, isLecture };
          }

          selectElement.disabled = false;
          if (hintElement) {
            hintElement.textContent = 'Вибери одну або кілька підгруп для цієї активності.';
          }
          for (let groupNumber = 1; groupNumber <= groupCount; groupNumber += 1) {
            const option = document.createElement('option');
            option.value = String(groupNumber);
            option.textContent = `Підгрупа ${groupNumber}`;
            option.selected = requestedGroups.length
              ? requestedGroups.includes(option.value)
              : groupNumber === defaultGroup;
            selectElement.appendChild(option);
          }
          return { activity, subject, isLecture };
        };

        const syncScheduleActivityState = (payload = null) => {
          renderTargetGroupOptions({
            selectElement: scheduleTargetGroups,
            hintElement: scheduleTargetGroupsHint,
            activityId: scheduleActivity && scheduleActivity.value,
            payload,
          });
        };
        const buildScheduleFormStatePayload = () => {
          const resolvedActivity = getScopedActivityById(Number(scheduleActivity && scheduleActivity.value || 0));
          const normalizedWeekValue = buildWeekNumberValue(
            scheduleWeekNumber ? scheduleWeekNumber.value : activeScheduleWeek,
            activeScheduleWeek || 1
          );
          const normalizedClassNumber = Math.max(1, Number(scheduleClassNumber && scheduleClassNumber.value || 0) || 1);
          const scheduleEntryId = scheduleForm
            ? String((scheduleForm.querySelector('[data-editor-input="schedule.id"]') || {}).value || '')
            : '';
          return {
            id: scheduleEntryId,
            schedule_entry_id: scheduleEntryId,
            term_id: scheduleTerm ? String(scheduleTerm.value || '') : '',
            group_subject_activity_id: scheduleActivity ? String(scheduleActivity.value || '') : '',
            activity_id: scheduleActivity ? String(scheduleActivity.value || '') : '',
            activity_type: resolvedActivity ? String(resolvedActivity.activity_type || '') : '',
            day_of_week: String(scheduleDay && scheduleDay.value || '').trim(),
            class_number: normalizedClassNumber,
            week_number: normalizedWeekValue,
            target_group_numbers: getRequestedValues(scheduleTargetGroups),
          };
        };
        const syncSchedulePlacementFromAdvancedFields = () => {
          const payload = buildScheduleFormStatePayload();
          if (schedulePlacementTerm && payload.term_id) {
            schedulePlacementTerm.value = payload.term_id;
          }
          selectedSlot = {
            dayOfWeek: String(payload.day_of_week || '').trim(),
            classNumber: Math.max(0, Number(payload.class_number || 0) || 0),
          };
          if (payload.week_number) {
            activeScheduleWeek = getPrimaryWeekNumber(payload.week_number, activeScheduleWeek || 1);
          }
          if (selectedScheduleEntryPayload && payload.schedule_entry_id) {
            selectedScheduleEntryPayload = {
              ...selectedScheduleEntryPayload,
              ...payload,
            };
          }
          syncSchedulePlacementState(payload);
          persistWorkspaceState();
        };

        const buildPlacementWarnings = () => {
          const activityId = Number(schedulePlacementActivity && schedulePlacementActivity.value || 0);
          const weekNumber = getPrimaryWeekNumber(schedulePlacementWeek && schedulePlacementWeek.value, activeScheduleWeek || 1);
          const dayOfWeek = String(selectedSlot.dayOfWeek || '').trim();
          const classNumber = Number(selectedSlot.classNumber || 0);
          const termId = Number(schedulePlacementTerm && schedulePlacementTerm.value || 0);
          const activity = getScopedActivityById(activityId);
          const subject = activity ? getScopedSubjectById(activity.group_subject_id) : null;
          const warnings = [];
          if (!activity || !subject) {
            return warnings;
          }
          if (!Array.isArray(subject.teacher_names) || !subject.teacher_names.length) {
            warnings.push('У предмета немає призначеного викладача');
          }
          if (Array.isArray(subject.term_ids) && termId && !subject.term_ids.map((value) => Number(value || 0)).includes(termId)) {
            warnings.push('Предмет не привʼязаний до вибраного терму');
          }
          if (!dayOfWeek || !classNumber) {
            return warnings;
          }
          const requestedGroups = normalizePlacementGroups(activity, getRequestedValues(schedulePlacementTargetGroups)).map((value) => Number(value || 0));
          const teacherNames = Array.isArray(subject.teacher_names) ? subject.teacher_names : [];
          scheduleEntriesData
            .filter((entry) => (
              Number(entry.week_number || 0) === weekNumber
              && Number(entry.class_number || 0) === classNumber
              && String(entry.day_of_week || '') === dayOfWeek
            ))
            .forEach((entry) => {
              const teacherConflict = teacherNames.some((teacherName) => (entry.teacher_names || []).includes(teacherName));
              const groupConflict = requestedGroups.some((groupNumber) => (entry.resolved_group_numbers || []).map((value) => Number(value || 0)).includes(groupNumber));
              if (teacherConflict) {
                warnings.push('У цьому слоті викладач уже зайнятий');
              }
              if (groupConflict) {
                warnings.push('У цьому слоті є перетин підгруп');
              }
            });
          return Array.from(new Set(warnings));
        };

        const syncSchedulePlacementState = (payload = null) => {
          if (payload && schedulePlacementActivity) {
            const nextActivityId = String(payload.group_subject_activity_id || payload.activity_id || '');
            if (nextActivityId) {
              schedulePlacementActivity.value = nextActivityId;
            }
          }
          if (payload && schedulePlacementTerm) {
            const nextTermId = String(payload.term_id || '');
            if (nextTermId) {
              schedulePlacementTerm.value = nextTermId;
            }
          }
          if (payload && schedulePlacementWeek) {
            const nextWeek = buildWeekNumberValue(payload.week_number, activeScheduleWeek || 1);
            if (nextWeek) {
              schedulePlacementWeek.value = nextWeek;
              activeScheduleWeek = getPrimaryWeekNumber(nextWeek, activeScheduleWeek || 1);
            }
          }
          renderTargetGroupOptions({
            selectElement: schedulePlacementTargetGroups,
            hintElement: schedulePlacementWarning,
            activityId: schedulePlacementActivity && schedulePlacementActivity.value,
            payload,
          });

          const activity = getScopedActivityById(Number(schedulePlacementActivity && schedulePlacementActivity.value || 0));
          const activityLabel = activity
            ? `${activity.subject_title} · ${activity.activity_label || activity.activity_type}`
            : 'Предмет або режим не вибрано';
          if (schedulePlacementSummary) {
            schedulePlacementSummary.textContent = selectedSlot.dayOfWeek && selectedSlot.classNumber
              ? `${activityLabel} → ${selectedSlot.dayOfWeek}, пара ${selectedSlot.classNumber}, ${formatWeekNumberLabel(schedulePlacementWeek ? schedulePlacementWeek.value : activeScheduleWeek, activeScheduleWeek)}`
              : `${activityLabel}. Обери слот у таблиці.`;
          }
          if (schedulePlacementWarning) {
            const warnings = buildPlacementWarnings();
            schedulePlacementWarning.textContent = warnings.length
              ? warnings.join(' · ')
              : 'Конфліктів для вибраної комбінації не знайдено.';
          }
          scheduleWeekButtons.forEach((button) => {
            button.classList.toggle('is-active', Number(button.getAttribute('data-schedule-week') || 0) === activeScheduleWeek);
          });
          document.querySelectorAll('[data-schedule-entry-week]').forEach((card) => {
            card.hidden = Number(card.getAttribute('data-schedule-entry-week') || 0) !== activeScheduleWeek;
          });
          scheduleSlots.forEach((slot) => {
            const dayOfWeek = String(slot.getAttribute('data-day-of-week') || '');
            const classNumber = Number(slot.getAttribute('data-class-number') || 0);
            const placeholder = slot.querySelector('.academic-v2-schedule-slot-empty');
            const visibleCards = Array.from(slot.querySelectorAll('[data-schedule-entry-week]')).filter((card) => !card.hidden);
            if (placeholder) {
              placeholder.hidden = visibleCards.length > 0;
            }
            slot.classList.toggle(
              'is-selected',
              String(selectedSlot.dayOfWeek || '') === dayOfWeek && Number(selectedSlot.classNumber || 0) === classNumber
            );
          });
        };

        const renderSharedSubjectLinksHtml = (meta = {}) => {
          const outboundLinks = Array.isArray(meta.outbound_links) ? meta.outbound_links : [];
          if (String(meta.mode || '') === 'source' && outboundLinks.length) {
            return outboundLinks.map((link) => `
              <div class="academic-v2-course-subject-card academic-v2-course-subject-card--compact">
                <div class="academic-v2-course-subject-card-head">
                  <div>
                    <strong>${escapeHtml(link.linked_group_label || '')}</strong>
                    <div class="academic-v2-muted">${escapeHtml(link.linked_subject_title || '')}</div>
                  </div>
                  <span class="academic-v2-chip">Linked-копія</span>
                </div>
                <div class="academic-v2-actions mt-2">
                  <a class="btn btn-sm btn-outline-secondary" href="${escapeHtml(link.workspace_href || '/admin/pathways')}">Відкрити</a>
                </div>
              </div>
            `).join('');
          }
          if (String(meta.mode || '') === 'linked' && meta.inbound_link) {
            return `
              <div class="academic-v2-course-subject-card academic-v2-course-subject-card--compact">
                <div class="academic-v2-course-subject-card-head">
                  <div>
                    <strong>${escapeHtml(meta.inbound_link.source_group_label || '')}</strong>
                    <div class="academic-v2-muted">${escapeHtml(meta.inbound_link.source_subject_title || '')}</div>
                  </div>
                  <span class="academic-v2-chip academic-v2-chip--ok">Базове джерело</span>
                </div>
                <div class="academic-v2-actions mt-2">
                  <a class="btn btn-sm btn-outline-secondary" href="${escapeHtml(meta.inbound_link.workspace_href || '/admin/pathways')}">Відкрити джерело</a>
                </div>
              </div>
            `;
          }
          return '<div class="academic-v2-empty">Поки що немає linked-копій. Створи shared-копію для іншого курсу або працюй з одноразовим призначенням нижче.</div>';
        };

        const syncGroupSubjectSharedState = () => {
          const subject = getSubjectCardById(activeSubjectId);
          const subjectTemplateId = Number(subject && subject.subject_template_id || 0);
          const sharedMeta = getSharedSubjectMetaById(activeSubjectId);
          const outboundLinks = Array.isArray(sharedMeta.outbound_links) ? sharedMeta.outbound_links : [];
          const outboundGroupIds = new Set(outboundLinks.map((link) => Number(link.linked_group_id || 0)).filter((value) => value > 0));
          const isLinkedCopy = String(sharedMeta.mode || '') === 'linked';
          const isSourceSubject = String(sharedMeta.mode || '') === 'source';
          const isSharedParticipant = isLinkedCopy || isSourceSubject;
          if (groupSubjectTemplate && groupSubjectTemplateHiddenLock) {
            groupSubjectTemplate.disabled = Boolean(subject && isSharedParticipant);
            groupSubjectTemplateHiddenLock.disabled = !(subject && isSharedParticipant);
            groupSubjectTemplateHiddenLock.value = subject && isSharedParticipant
              ? String(subjectTemplateId || '')
              : '';
          }
          if (groupSubjectTemplateLock) {
            if (!subject) {
              groupSubjectTemplateLock.textContent = '';
            } else if (isLinkedCopy) {
              groupSubjectTemplateLock.textContent = 'Шаблон зафіксовано, бо цей предмет є linked-копією shared-джерела.';
            } else if (isSourceSubject) {
              groupSubjectTemplateLock.textContent = 'Шаблон зафіксовано, поки цей предмет має linked-копії в інших курсах.';
            } else {
              groupSubjectTemplateLock.textContent = '';
            }
          }
          if (groupSubjectShareSource) {
            groupSubjectShareSource.value = subject ? String(subject.id || '') : '';
          }
          if (groupSubjectSharedSyncSource) {
            groupSubjectSharedSyncSource.value = subject ? String(subject.id || '') : '';
          }
          if (groupSubjectSharedCopy) {
            if (!subject) {
              groupSubjectSharedCopy.textContent = 'Вибери живий предмет, щоб побачити shared-стан і керувати linked-копіями між курсами.';
            } else if (isLinkedCopy && sharedMeta.inbound_link) {
              groupSubjectSharedCopy.textContent = `Цей предмет є linked-копією і керується з курсу «${sharedMeta.inbound_link.source_group_label || ''}».`;
            } else if (isSourceSubject) {
              groupSubjectSharedCopy.textContent = `Цей предмет є базовим shared-джерелом для ${outboundLinks.length} курсів. Можна створювати нові linked-копії та вручну синхронізувати їхні налаштування.`;
            } else {
              groupSubjectSharedCopy.textContent = 'Перетворює поточний предмет на базове shared-джерело для інших курсів, але лишає окремі live rows у кожному курсі. Розклад лишається локальним для кожної копії.';
            }
          }
          if (groupSubjectSharedSummary) {
            if (!subject) {
              groupSubjectSharedSummary.textContent = 'Вибери живий предмет зліва, щоб створити shared-копію або керувати вже звʼязаними курсами.';
            } else if (isLinkedCopy && sharedMeta.inbound_link) {
              groupSubjectSharedSummary.textContent = 'Linked-копія не може створювати власні shared-гілки. Відкрий базовий предмет, щоб керувати shared-звʼязками.';
            } else {
              groupSubjectSharedSummary.textContent = 'Буде створено linked-копію або підʼєднано наявний предмет з тим самим шаблоном у вибраному курсі. Далі його можна оновлювати з цього джерела вручну.';
            }
          }
          if (groupSubjectShareTarget && groupSubjectShareSubmit) {
            let availableTargetCount = 0;
            Array.from(groupSubjectShareTarget.options || []).forEach((option) => {
              if (!option.value) {
                option.disabled = false;
                return;
              }
              if (!option.dataset.baseLabel) {
                option.dataset.baseLabel = option.textContent.trim();
              }
              const targetGroupId = Number(option.value || 0);
              const hasExistingSharedLink = outboundGroupIds.has(targetGroupId);
              const targetTemplateIds = courseSubjectTemplateIdsByGroup.get(targetGroupId) || new Set();
              const hasExistingTargetSubject = Boolean(subjectTemplateId && targetTemplateIds.has(subjectTemplateId));
              const isDisabled = !subject || isLinkedCopy || hasExistingSharedLink;
              option.disabled = isDisabled;
              option.textContent = hasExistingSharedLink
                ? `${option.dataset.baseLabel} · уже звʼязано`
                : hasExistingTargetSubject
                  ? `${option.dataset.baseLabel} · підʼєднає наявний предмет`
                  : `${option.dataset.baseLabel} · створить linked-копію`;
              if (!isDisabled) {
                availableTargetCount += 1;
              }
            });
            if (!subject || isLinkedCopy || (groupSubjectShareTarget.value && groupSubjectShareTarget.selectedOptions[0] && groupSubjectShareTarget.selectedOptions[0].disabled)) {
              groupSubjectShareTarget.value = '';
            }
            groupSubjectShareTarget.disabled = !subject || isLinkedCopy || availableTargetCount < 1;
            const selectedTargetGroupId = Number(groupSubjectShareTarget.value || 0);
            const selectedOption = groupSubjectShareTarget.selectedOptions[0] || null;
            const selectedTargetTemplateIds = courseSubjectTemplateIdsByGroup.get(selectedTargetGroupId) || new Set();
            const willLinkExisting = Boolean(selectedTargetGroupId && subjectTemplateId && selectedTargetTemplateIds.has(subjectTemplateId));
            groupSubjectShareSubmit.disabled = !subject || isLinkedCopy || !selectedTargetGroupId;
            if (groupSubjectSharedFeedback) {
              if (!subject) {
                groupSubjectSharedFeedback.textContent = 'Спочатку вибери живий предмет у поточному курсі.';
              } else if (isLinkedCopy && sharedMeta.inbound_link) {
                groupSubjectSharedFeedback.textContent = `Цей предмет уже звʼязано з «${sharedMeta.inbound_link.source_group_label || ''}». Для нових shared-звʼязків відкрий базовий предмет.`;
              } else if (!availableTargetCount) {
                groupSubjectSharedFeedback.textContent = 'Для цього предмета немає доступного цільового курсу: усі релевантні курси вже linked до цього джерела.';
              } else if (selectedOption && willLinkExisting) {
                groupSubjectSharedFeedback.textContent = `У курсі «${selectedOption.dataset.baseLabel || selectedOption.textContent.trim()}» вже є предмет з тим самим шаблоном. Ми підʼєднаємо його як linked-копію і синхронізуємо налаштування з цього джерела.`;
              } else if (selectedOption) {
                groupSubjectSharedFeedback.textContent = `Буде створено нову linked-копію в курсі «${selectedOption.dataset.baseLabel || selectedOption.textContent.trim()}». Далі її можна буде вручну синхронізувати з цього джерела.`;
              } else {
                groupSubjectSharedFeedback.textContent = 'Вибери курс, у якому треба створити shared-копію або підʼєднати наявний предмет того самого шаблону.';
              }
            }
          }
          if (groupSubjectSharedOpenSource) {
            const sourceHref = sharedMeta.inbound_link && sharedMeta.inbound_link.workspace_href
              ? String(sharedMeta.inbound_link.workspace_href).trim()
              : '';
            groupSubjectSharedOpenSource.classList.toggle('d-none', !sourceHref);
            groupSubjectSharedOpenSource.dataset.sharedOpenHref = sourceHref;
          }
          if (groupSubjectSharedSyncSubmit) {
            groupSubjectSharedSyncSubmit.disabled = !subject || !isSourceSubject || !outboundLinks.length;
          }
          if (groupSubjectSharedLinks) {
            groupSubjectSharedLinks.innerHTML = renderSharedSubjectLinksHtml(sharedMeta);
          }
        };

        const syncGroupSubjectAssignState = () => {
          const subject = getSubjectCardById(activeSubjectId);
          const subjectTemplateId = Number(subject && subject.subject_template_id || 0);
          if (groupSubjectAssignSource) {
            groupSubjectAssignSource.value = subject ? String(subject.id || '') : '';
          }
          if (groupSubjectAssignSummary) {
            groupSubjectAssignSummary.textContent = subject
              ? `Буде створено окремий предмет для «${subject.title}» на базі шаблону «${subject.template_name}».`
              : 'Вибери живий предмет зліва, щоб підготувати копію в інший курс.';
          }
          if (!groupSubjectAssignTarget || !groupSubjectAssignSubmit) {
            return;
          }
          const hasSubject = Boolean(subject && subject.id);
          const baseOptions = Array.from(groupSubjectAssignTarget.options || []);
          let availableTargetCount = 0;
          baseOptions.forEach((option) => {
            if (!option.value) {
              option.disabled = false;
              return;
            }
            if (!option.dataset.baseLabel) {
              option.dataset.baseLabel = option.textContent.trim();
            }
            const targetGroupId = Number(option.value || 0);
            const targetTemplateIds = courseSubjectTemplateIdsByGroup.get(targetGroupId) || new Set();
            const isDuplicate = hasSubject && subjectTemplateId && targetTemplateIds.has(subjectTemplateId);
            option.disabled = !hasSubject || isDuplicate;
            option.textContent = isDuplicate
              ? `${option.dataset.baseLabel} · уже має цей предмет`
              : option.dataset.baseLabel;
            if (!option.disabled) {
              availableTargetCount += 1;
            }
          });
          if (!hasSubject || (groupSubjectAssignTarget.value && groupSubjectAssignTarget.selectedOptions[0] && groupSubjectAssignTarget.selectedOptions[0].disabled)) {
            groupSubjectAssignTarget.value = '';
          }
          groupSubjectAssignTarget.disabled = !hasSubject || availableTargetCount < 1;
          const selectedOption = groupSubjectAssignTarget.selectedOptions[0] || null;
          const selectedTargetGroupId = Number(groupSubjectAssignTarget.value || 0);
          const hasSelectedTarget = selectedTargetGroupId > 0;
          const selectedTargetTemplateIds = courseSubjectTemplateIdsByGroup.get(selectedTargetGroupId) || new Set();
          const selectedTargetBlocked = Boolean(selectedTargetGroupId && subjectTemplateId && selectedTargetTemplateIds.has(subjectTemplateId));
          groupSubjectAssignSubmit.disabled = !hasSubject || !selectedTargetGroupId || selectedTargetBlocked;
          if (groupSubjectAssignFeedback) {
            if (!hasSubject) {
              groupSubjectAssignFeedback.textContent = 'Спочатку вибери живий предмет у поточному курсі. Лише після цього можна призначити його в інший курс.';
            } else if (!availableTargetCount) {
              groupSubjectAssignFeedback.textContent = 'Для цього предмета немає доступного цільового курсу: у всіх інших курсах уже є live subject на базі цього шаблону.';
            } else if (selectedTargetBlocked) {
              groupSubjectAssignFeedback.textContent = `У курсі «${selectedOption ? selectedOption.dataset.baseLabel || selectedOption.textContent.trim() : ''}» уже є предмет на базі шаблону «${subject.template_name}».`;
            } else if (hasSelectedTarget && selectedOption) {
              groupSubjectAssignFeedback.textContent = `Буде створено окремий предмет у курсі «${selectedOption.dataset.baseLabel || selectedOption.textContent.trim()}». Скопіюються терми за номером, викладачі й активності; розклад не переноситься.`;
            } else {
              groupSubjectAssignFeedback.textContent = 'Вибери цільовий курс. Дублікати за шаблоном предмета вже заблоковані в списку.';
            }
          }
        };

        const updateSubjectDetail = (subjectId) => {
          activeSubjectId = Number(subjectId || 0);
          const subject = getSubjectCardById(activeSubjectId);
          subjectCards.forEach((card) => {
            card.classList.toggle('is-active', Number(card.getAttribute('data-subject-id') || 0) === activeSubjectId);
          });
          subjectActivityRows.forEach((row) => {
            if (!activeSubjectId) {
              row.hidden = false;
              return;
            }
            row.hidden = Number(row.getAttribute('data-subject-id') || 0) !== activeSubjectId;
          });
          if (groupSubjectActivitySubject && subject) {
            groupSubjectActivitySubject.value = String(subject.id);
          }
          if (subjectDetailTitle) {
            subjectDetailTitle.textContent = subject ? subject.title : 'Новий предмет курсу';
          }
          if (subjectDetailCopy) {
            subjectDetailCopy.textContent = subject
              ? `Керуй назвою, термами, викладачами та активностями для предмета ${subject.title}.`
              : 'Створи новий предмет або вибери наявний зліва. Усі зміни лишаються в межах поточного курсу.';
          }
          if (subjectDetailGroups) {
            subjectDetailGroups.textContent = subject ? `${subject.group_count} підгруп` : '1 підгрупа';
          }
          if (subjectDetailTerms) {
            subjectDetailTerms.textContent = subject ? `${subject.term_count} термів` : '0 термів';
          }
          if (subjectDetailTeachers) {
            subjectDetailTeachers.textContent = subject ? `${subject.teacher_count} викладачів` : '0 викладачів';
          }
          if (subjectDetailActivities) {
            subjectDetailActivities.textContent = subject ? `${subject.activity_count} активностей` : '0 активностей';
          }
          if (subjectDetailReadiness) {
            subjectDetailReadiness.textContent = subject ? subject.readiness.label : 'Потребує налаштування';
            subjectDetailReadiness.classList.toggle('academic-v2-chip--ok', Boolean(subject && subject.readiness && subject.readiness.tone === 'ok'));
            subjectDetailReadiness.classList.toggle('academic-v2-chip--warm', !subject || !subject.readiness || subject.readiness.tone !== 'ok');
          }
          syncGroupSubjectSharedState();
          syncGroupSubjectAssignState();
          persistWorkspaceState();
        };

        const setMode = (mode) => {
          const normalizedMode = normalizeModeName(mode);
          activeMode = ['operate', 'structure', 'diagnostics'].includes(normalizedMode) ? normalizedMode : 'operate';
          modePanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-mode-panel') !== activeMode;
          });
          modeButtons.forEach((button) => {
            button.classList.toggle(
              'is-active',
              button.classList.contains('academic-v2-mode-button')
              && String(button.getAttribute('data-mode-button') || '') === activeMode
            );
          });
          persistWorkspaceState();
        };

        const setWorkspaceTab = (tab) => {
          activeWorkspaceTab = tab || 'overview';
          workspacePanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-workspace-panel') !== activeWorkspaceTab;
          });
          workspaceTabButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-workspace-tab-target') || '') === activeWorkspaceTab);
          });
          setMode('operate');
          persistWorkspaceState();
        };

        const setStructureTab = (tab) => {
          activeStructureTab = tab || 'programs';
          structurePanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-structure-panel') !== activeStructureTab;
          });
          structureTabButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-structure-tab-target') || '') === activeStructureTab);
          });
          setMode('structure');
          persistWorkspaceState();
        };

        const setDiagnosticsTab = (tab) => {
          activeDiagnosticsTab = tab || 'projection';
          diagnosticsPanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-diagnostics-panel') !== activeDiagnosticsTab;
          });
          diagnosticsTabButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-diagnostics-tab-target') || '') === activeDiagnosticsTab);
          });
          setMode('diagnostics');
          persistWorkspaceState();
        };

        const setScheduleView = (view) => {
          activeScheduleView = view || 'calendar';
          scheduleViewPanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-schedule-view-panel') !== activeScheduleView;
          });
          scheduleViewButtons.forEach((button) => {
            button.classList.toggle('is-active', String(button.getAttribute('data-schedule-view-target') || '') === activeScheduleView);
          });
          if (scheduleAdvancedBlock) {
            scheduleAdvancedBlock.open = activeScheduleView === 'advanced';
          }
          persistWorkspaceState();
        };

        const applyPayload = (target, payload) => {
          const form = forms.get(target);
          if (!form || !payload || typeof payload !== 'object') {
            return;
          }
          form.querySelectorAll('[data-editor-input]').forEach((field) => {
            const path = field.getAttribute('data-editor-input') || '';
            const expectedPrefix = target + '.';
            if (!path.startsWith(expectedPrefix)) {
              return;
            }
            const payloadKey = path.slice(expectedPrefix.length);
            const value = payload[payloadKey];
            if (field instanceof HTMLInputElement && field.type === 'checkbox') {
              field.checked = value === true || value === 1 || value === '1';
              return;
            }
            if (field instanceof HTMLSelectElement && field.multiple) {
              const selectedValues = Array.isArray(value) ? value.map((item) => String(item)) : [];
              Array.from(field.options).forEach((option) => {
                option.selected = selectedValues.includes(option.value);
              });
              return;
            }
            field.value = value == null ? '' : String(value);
          });
          if (target === 'group') {
            syncGroupTeacherDefaultVisibility();
            setStructureTab('courses');
          }
          if (target === 'program') {
            setStructureTab('programs');
          }
          if (target === 'cohort') {
            setStructureTab('cohorts');
          }
          if (target === 'template') {
            setStructureTab('subject-templates');
          }
          if (target === 'stage-term' || target === 'stage-subject' || target === 'stage-subject-activity') {
            setStructureTab('stage-templates');
          }
          if (target === 'group-subject') {
            updateSubjectDetail(payload.id);
            setWorkspaceTab('subjects');
          }
          if (target === 'group-subject-activity') {
            updateSubjectDetail(payload.group_subject_id);
            setWorkspaceTab('subjects');
          }
          if (target === 'term') {
            setWorkspaceTab('terms');
          }
          if (target === 'schedule') {
            selectedScheduleEntryPayload = payload;
            selectedSlot = {
              dayOfWeek: String(payload.day_of_week || ''),
              classNumber: Number(payload.class_number || 0),
            };
            if (schedulePlacementWeek) {
              activeScheduleWeek = getPrimaryWeekNumber(payload.week_number || schedulePlacementWeek.value, activeScheduleWeek || 1);
              schedulePlacementWeek.value = buildWeekNumberValue(payload.week_number, activeScheduleWeek || 1);
            }
            if (scheduleWeekNumber) {
              scheduleWeekNumber.value = buildWeekNumberValue(payload.week_number, activeScheduleWeek || 1);
            }
            syncAllScheduleActivitySelectors({
              activityId: Number(payload.group_subject_activity_id || payload.activity_id || 0),
              activityType: String(payload.activity_type || payload.lesson_type || ''),
            });
            syncScheduleActivityState(payload);
            syncSchedulePlacementState(payload);
            setWorkspaceTab('schedule');
            setScheduleView('advanced');
          }
          persistWorkspaceState();
        };
        const openRequestedScheduleEntry = () => {
          if (!requestedScheduleEntryId) {
            return false;
          }
          const entry = scheduleEntriesData.find((item) => Number(item && item.id ? item.id : 0) === requestedScheduleEntryId);
          if (!entry) {
            return false;
          }
          applyPayload('schedule', entry);
          const form = forms.get('schedule');
          if (form) {
            form.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return true;
        };
        const openRequestedSubject = () => {
          if (!requestedSubjectId || requestedScheduleEntryId) {
            return false;
          }
          const subject = getSubjectCardById(requestedSubjectId);
          if (!subject) {
            return false;
          }
          updateSubjectDetail(requestedSubjectId);
          applyPayload('group-subject', subject);
          setWorkspaceTab(normalizedRequestedWorkspaceTab || 'subjects');
          const form = forms.get('group-subject');
          if (form) {
            form.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return true;
        };

        document.querySelectorAll('[data-editor-target]').forEach((button) => {
          button.addEventListener('click', (event) => {
            event.stopPropagation();
            const target = button.getAttribute('data-editor-target');
            const rawPayload = button.getAttribute('data-editor-payload') || '{}';
            try {
              applyPayload(target, JSON.parse(rawPayload));
              const form = forms.get(target);
              if (form) {
                form.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            } catch (_error) {
              // ignore malformed payloads
            }
          });
        });

        document.querySelectorAll('[data-editor-reset]').forEach((button) => {
          button.addEventListener('click', () => {
            const target = button.getAttribute('data-editor-reset');
            const form = forms.get(target);
            if (!form) {
              return;
            }
            form.reset();
            form.querySelectorAll('input[type="hidden"]').forEach((input) => {
              if (String(input.name || '').startsWith('focus_')) {
                return;
              }
              if (input.hasAttribute('data-preserve-reset')) {
                return;
              }
              input.value = '';
            });
            if (target === 'group') {
              syncGroupTeacherDefaultVisibility();
            }
            if (target === 'group-subject') {
              updateSubjectDetail(0);
            }
            if (target === 'schedule') {
              selectedScheduleEntryPayload = null;
              selectedSlot = { dayOfWeek: '', classNumber: 0 };
              if (schedulePlacementWeek) {
                schedulePlacementWeek.value = buildWeekNumberValue(activeScheduleWeek || 1, activeScheduleWeek || 1);
              }
              if (scheduleWeekNumber) {
                scheduleWeekNumber.value = buildWeekNumberValue(activeScheduleWeek || 1, activeScheduleWeek || 1);
              }
              syncAllScheduleActivitySelectors();
              syncScheduleActivityState();
              syncSchedulePlacementState();
            }
            persistWorkspaceState();
          });
        });

        modeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetMode = button.getAttribute('data-mode-button');
            if (targetMode) {
              if (targetMode === 'structure') {
                setStructureTab(activeStructureTab);
                return;
              }
              if (targetMode === 'diagnostics') {
                setDiagnosticsTab(activeDiagnosticsTab);
                return;
              }
              setMode(targetMode);
            }
          });
        });

        workspaceTabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetTab = button.getAttribute('data-workspace-tab-target');
            if (targetTab) {
              setWorkspaceTab(targetTab);
            }
          });
        });

        structureTabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetTab = button.getAttribute('data-structure-tab-target');
            if (targetTab) {
              setStructureTab(targetTab);
            }
          });
        });

        diagnosticsTabButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetTab = button.getAttribute('data-diagnostics-tab-target');
            if (targetTab) {
              setDiagnosticsTab(targetTab);
            }
          });
        });

        scheduleViewButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const targetView = button.getAttribute('data-schedule-view-target');
            if (targetView) {
              setWorkspaceTab('schedule');
              setScheduleView(targetView);
            }
          });
        });

        scheduleWeekButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const nextWeek = Number(button.getAttribute('data-schedule-week') || 1);
            activeScheduleWeek = nextWeek;
            if (schedulePlacementWeek) {
              schedulePlacementWeek.value = buildWeekNumberValue(nextWeek, nextWeek);
            }
            if (scheduleWeekNumber) {
              scheduleWeekNumber.value = buildWeekNumberValue(nextWeek, nextWeek);
            }
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        });

        subjectCards.forEach((card) => {
          card.addEventListener('click', (event) => {
            if (event.target instanceof HTMLElement && event.target.closest('.academic-v2-actions')) {
              return;
            }
            const subjectId = Number(card.getAttribute('data-subject-id') || 0);
            updateSubjectDetail(subjectId);
            const subject = getSubjectCardById(subjectId);
            if (subject) {
              applyPayload('group-subject', subject);
            }
            setWorkspaceTab('subjects');
            persistWorkspaceState();
          });
        });

        document.querySelectorAll('[data-subject-focus-id]').forEach((button) => {
          button.addEventListener('click', () => {
            const subjectId = Number(button.getAttribute('data-subject-focus-id') || 0);
            const focusSection = String(button.getAttribute('data-subject-focus-section') || '').trim();
            updateSubjectDetail(subjectId);
            setWorkspaceTab('subjects');
            if (focusSection) {
              const target = document.getElementById(focusSection === 'teachers' ? 'subject-detail-teachers' : 'subject-detail-activities');
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            }
          });
        });

        subjectCreateButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const subjectForm = forms.get('group-subject');
            if (subjectForm) {
              subjectForm.reset();
              subjectForm.querySelectorAll('input[type="hidden"]').forEach((input) => {
                if (String(input.name || '').startsWith('focus_') || input.hasAttribute('data-preserve-reset')) {
                  return;
                }
                input.value = '';
              });
            }
            updateSubjectDetail(0);
            setWorkspaceTab('subjects');
            if (subjectForm) {
              subjectForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            persistWorkspaceState();
          });
        });

        if (groupSubjectAssignTarget) {
          groupSubjectAssignTarget.addEventListener('change', () => {
            syncGroupSubjectAssignState();
          });
        }
        if (groupSubjectShareTarget) {
          groupSubjectShareTarget.addEventListener('change', () => {
            syncGroupSubjectSharedState();
          });
        }
        if (groupSubjectSharedOpenSource) {
          groupSubjectSharedOpenSource.addEventListener('click', () => {
            const href = String(groupSubjectSharedOpenSource.dataset.sharedOpenHref || '').trim();
            if (href) {
              window.location.href = href;
            }
          });
        }
        if (groupSubjectShareForm) {
          groupSubjectShareForm.addEventListener('submit', (event) => {
            const subject = getSubjectCardById(activeSubjectId);
            const targetGroupId = Number(groupSubjectShareTarget && groupSubjectShareTarget.value || 0);
            const selectedOption = targetGroupId && groupSubjectShareTarget && groupSubjectShareTarget.selectedOptions[0]
              ? groupSubjectShareTarget.selectedOptions[0]
              : null;
            const targetLabel = selectedOption ? (selectedOption.dataset.baseLabel || selectedOption.textContent.trim()) : '';
            if (!subject || !targetLabel) {
              event.preventDefault();
              return;
            }
            const targetTemplateIds = courseSubjectTemplateIdsByGroup.get(targetGroupId) || new Set();
            const willLinkExisting = Boolean(subject.subject_template_id && targetTemplateIds.has(Number(subject.subject_template_id || 0)));
            const confirmationText = willLinkExisting
              ? `Підʼєднати наявний предмет «${subject.title}» у курсі «${targetLabel}» як linked-копію і синхронізувати його налаштування?`
              : `Створити linked-копію предмета «${subject.title}» у курсі «${targetLabel}»? Розклад не буде скопійовано.`;
            if (!window.confirm(confirmationText)) {
              event.preventDefault();
            }
          });
        }
        if (groupSubjectSharedSyncForm) {
          groupSubjectSharedSyncForm.addEventListener('submit', (event) => {
            const subject = getSubjectCardById(activeSubjectId);
            const sharedMeta = getSharedSubjectMetaById(activeSubjectId);
            const linkedCount = Array.isArray(sharedMeta.outbound_links) ? sharedMeta.outbound_links.length : 0;
            if (!subject || !linkedCount) {
              event.preventDefault();
              return;
            }
            if (!window.confirm(`Синхронізувати налаштування предмета «${subject.title}» у ${linkedCount} linked-копіях? Локальний розклад у цих курсах не переноситься, але зайві activity можуть бути очищені.`)) {
              event.preventDefault();
            }
          });
        }
        if (groupSubjectAssignForm) {
          groupSubjectAssignForm.addEventListener('submit', (event) => {
            const subject = getSubjectCardById(activeSubjectId);
            const targetGroupId = Number(groupSubjectAssignTarget && groupSubjectAssignTarget.value || 0);
            const targetLabel = targetGroupId && groupSubjectAssignTarget && groupSubjectAssignTarget.selectedOptions[0]
              ? (groupSubjectAssignTarget.selectedOptions[0].dataset.baseLabel || groupSubjectAssignTarget.selectedOptions[0].textContent.trim())
              : '';
            if (!subject || !targetLabel) {
              event.preventDefault();
              return;
            }
            if (!window.confirm(`Створити окремий предмет «${subject.title}» у курсі «${targetLabel}»? Розклад не буде скопійовано.`)) {
              event.preventDefault();
            }
          });
        }

        scheduleSlots.forEach((slot) => {
          slot.addEventListener('click', (event) => {
            if (event.target instanceof HTMLElement && event.target.closest('[data-editor-target="schedule"]')) {
              return;
            }
            selectedSlot = {
              dayOfWeek: String(slot.getAttribute('data-day-of-week') || ''),
              classNumber: Number(slot.getAttribute('data-class-number') || 0),
            };
            if (scheduleDay) {
              scheduleDay.value = selectedSlot.dayOfWeek;
            }
            if (scheduleClassNumber) {
              scheduleClassNumber.value = String(selectedSlot.classNumber);
            }
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        });

        if (schedulePlacementSubject) {
          schedulePlacementSubject.addEventListener('change', () => {
            syncAllScheduleActivitySelectors({
              subjectId: Number(schedulePlacementSubject.value || 0),
              activityType: schedulePlacementActivityType ? schedulePlacementActivityType.value : '',
            });
            syncScheduleActivityState();
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        }
        if (schedulePlacementActivityType) {
          schedulePlacementActivityType.addEventListener('change', () => {
            syncAllScheduleActivitySelectors({
              subjectId: Number(schedulePlacementSubject && schedulePlacementSubject.value || 0),
              activityType: schedulePlacementActivityType.value,
            });
            syncScheduleActivityState();
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        }
        if (schedulePlacementTerm) {
          schedulePlacementTerm.addEventListener('change', () => {
            if (scheduleTerm) {
              scheduleTerm.value = schedulePlacementTerm.value;
            }
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        }
        if (schedulePlacementWeek) {
          schedulePlacementWeek.addEventListener('change', () => {
            activeScheduleWeek = getPrimaryWeekNumber(schedulePlacementWeek.value, activeScheduleWeek || 1);
            if (scheduleWeekNumber) {
              scheduleWeekNumber.value = buildWeekNumberValue(schedulePlacementWeek.value, activeScheduleWeek || 1);
            }
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        }
        if (schedulePlacementTargetGroups) {
          schedulePlacementTargetGroups.addEventListener('change', () => {
            syncSchedulePlacementState();
            persistWorkspaceState();
          });
        }
        if (schedulePlacementSave) {
          schedulePlacementSave.addEventListener('click', () => {
            const scheduleForm = forms.get('schedule');
            if (!scheduleForm || !scheduleActivity || !scheduleDay || !scheduleClassNumber || !scheduleWeekNumber || !scheduleTerm) {
              return;
            }
            if (!selectedSlot.dayOfWeek || !selectedSlot.classNumber) {
              if (schedulePlacementWarning) {
                schedulePlacementWarning.textContent = 'Спершу вибери слот у сітці.';
              }
              return;
            }
            if (!schedulePlacementActivity || !schedulePlacementActivity.value) {
              if (schedulePlacementWarning) {
                schedulePlacementWarning.textContent = 'Спершу вибери предмет і режим активності.';
              }
              return;
            }
            if (schedulePlacementTerm) {
              scheduleTerm.value = schedulePlacementTerm.value;
            }
            scheduleActivity.value = schedulePlacementActivity.value;
            scheduleDay.value = selectedSlot.dayOfWeek;
            scheduleClassNumber.value = String(selectedSlot.classNumber);
            scheduleWeekNumber.value = buildWeekNumberValue(schedulePlacementWeek ? schedulePlacementWeek.value : activeScheduleWeek, activeScheduleWeek || 1);
            Array.from(scheduleTargetGroups.options).forEach((option) => {
              option.selected = getRequestedValues(schedulePlacementTargetGroups).includes(option.value);
            });
            scheduleForm.requestSubmit();
          });
        }

        document.querySelectorAll('[data-schedule-bulk]').forEach((button) => {
          button.addEventListener('click', () => {
            const action = button.getAttribute('data-schedule-bulk');
            const basePayload = selectedScheduleEntryPayload
              ? { ...selectedScheduleEntryPayload }
              : {
                term_id: scheduleTerm ? scheduleTerm.value : '',
                group_subject_activity_id: scheduleActivity ? scheduleActivity.value : '',
                day_of_week: scheduleDay ? scheduleDay.value : '',
                class_number: scheduleClassNumber ? scheduleClassNumber.value : '',
                week_number: scheduleWeekNumber ? scheduleWeekNumber.value : '',
                target_group_numbers: getRequestedValues(scheduleTargetGroups),
              };
            basePayload.id = '';
            basePayload.schedule_entry_id = '';
            if (action === 'copy-next-week') {
              basePayload.week_number = shiftWeekNumberValue(basePayload.week_number, 1);
            }
            selectedScheduleEntryPayload = basePayload;
            if (schedulePlacementWeek) {
              schedulePlacementWeek.value = buildWeekNumberValue(basePayload.week_number, activeScheduleWeek || 1);
              activeScheduleWeek = getPrimaryWeekNumber(schedulePlacementWeek.value, activeScheduleWeek || 1);
            }
            if (scheduleWeekNumber) {
              scheduleWeekNumber.value = buildWeekNumberValue(basePayload.week_number, activeScheduleWeek || 1);
            }
            selectedSlot = {
              dayOfWeek: String(basePayload.day_of_week || ''),
              classNumber: Number(basePayload.class_number || 0),
            };
            applyPayload('schedule', basePayload);
            syncSchedulePlacementState(basePayload);
            setWorkspaceTab('schedule');
            setScheduleView('advanced');
            persistWorkspaceState();
          });
        });

        if (scheduleSubject) {
          scheduleSubject.addEventListener('change', () => {
            syncAllScheduleActivitySelectors({
              subjectId: Number(scheduleSubject.value || 0),
              activityType: scheduleActivityType ? scheduleActivityType.value : '',
            });
            syncScheduleActivityState();
            syncSchedulePlacementFromAdvancedFields();
          });
        }
        if (scheduleActivityType) {
          scheduleActivityType.addEventListener('change', () => {
            syncAllScheduleActivitySelectors({
              subjectId: Number(scheduleSubject && scheduleSubject.value || 0),
              activityType: scheduleActivityType.value,
            });
            syncScheduleActivityState();
            syncSchedulePlacementFromAdvancedFields();
          });
        }
        if (scheduleTerm) {
          scheduleTerm.addEventListener('change', syncSchedulePlacementFromAdvancedFields);
        }
        if (scheduleDay) {
          scheduleDay.addEventListener('change', syncSchedulePlacementFromAdvancedFields);
        }
        if (scheduleClassNumber) {
          scheduleClassNumber.addEventListener('change', syncSchedulePlacementFromAdvancedFields);
        }
        if (scheduleWeekNumber) {
          scheduleWeekNumber.addEventListener('change', syncSchedulePlacementFromAdvancedFields);
        }
        if (scheduleTargetGroups) {
          scheduleTargetGroups.addEventListener('change', syncSchedulePlacementFromAdvancedFields);
        }
        if (scheduleForm) {
          scheduleForm.addEventListener('submit', () => {
            syncSchedulePlacementFromAdvancedFields();
          });
        }

        if (studentCheckboxes.length) {
          const syncStudentSelection = () => {
            const selectedCount = studentCheckboxes.filter((checkbox) => checkbox.checked).length;
            const targetLabel = bulkGroupId && bulkGroupId.options[bulkGroupId.selectedIndex]
              ? bulkGroupId.options[bulkGroupId.selectedIndex].textContent.trim()
              : '';
            if (studentSelectionCount) {
              studentSelectionCount.textContent = `${selectedCount} вибрано`;
            }
            if (studentBulkConfirmText) {
              studentBulkConfirmText.textContent = selectedCount
                ? `Буде перепризначено ${selectedCount} користувачів у курс «${targetLabel}».`
                : 'Познач студентів, яких треба перенести в цільовий курс.';
            }
          };
          studentCheckboxes.forEach((checkbox) => checkbox.addEventListener('change', syncStudentSelection));
          if (bulkGroupId) {
            bulkGroupId.addEventListener('change', syncStudentSelection);
          }
          if (studentBulkForm) {
            studentBulkForm.addEventListener('submit', (event) => {
              const selectedCount = studentCheckboxes.filter((checkbox) => checkbox.checked).length;
              const targetLabel = bulkGroupId && bulkGroupId.options[bulkGroupId.selectedIndex]
                ? bulkGroupId.options[bulkGroupId.selectedIndex].textContent.trim()
                : 'вибраний курс';
              if (!selectedCount) {
                event.preventDefault();
                return;
              }
              if (!window.confirm(`Перепризначити ${selectedCount} користувачів у курс «${targetLabel}»?`)) {
                event.preventDefault();
              }
            });
          }
          syncStudentSelection();
        }

        if (bachelorCatalogSearch) {
          bachelorCatalogSearch.addEventListener('input', applyBachelorCatalogSearch);
          applyBachelorCatalogSearch();
        }

        if (groupCohort) {
          groupCohort.addEventListener('change', syncGroupTeacherDefaultVisibility);
        }
        window.addEventListener('beforeunload', persistScrollPosition);
        window.addEventListener('pagehide', persistScrollPosition);
        syncGroupTeacherDefaultVisibility();
        syncAllScheduleActivitySelectors({
          activityId: Number(
            (restoredScheduleDraft && restoredScheduleDraft.group_subject_activity_id)
            || (scheduleActivity && scheduleActivity.value)
            || 0
          ),
        });
        syncScheduleActivityState();
        syncSchedulePlacementState();
        updateSubjectDetail(activeSubjectId);
        const initialMode = activeMode;
        setWorkspaceTab(activeWorkspaceTab);
        setStructureTab(activeStructureTab);
        setDiagnosticsTab(activeDiagnosticsTab);
        setScheduleView(activeScheduleView);
        setMode(initialMode);
        if (activeWorkspaceTab === 'subjects' && activeSubjectId) {
          const persistedSubject = getSubjectCardById(activeSubjectId);
          if (persistedSubject) {
            applyPayload('group-subject', persistedSubject);
          }
        }
        if (restoredScheduleDraft) {
          applyPayload('schedule', restoredScheduleDraft);
          setWorkspaceTab('schedule');
          setScheduleView('advanced');
        }
        const didOpenRequestedScheduleEntry = openRequestedScheduleEntry();
        const didOpenRequestedSubject = didOpenRequestedScheduleEntry ? false : openRequestedSubject();
        if (!didOpenRequestedScheduleEntry && !didOpenRequestedSubject) {
          restoreScrollPosition(restoredScrollY);
        }
        persistWorkspaceState();
      })();
    </script>
  </body>
</html>
