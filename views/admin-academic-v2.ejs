                          <button type="button" class="btn btn-primary" id="schedulePlacementSave">Зберегти у вибраний слот</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-bulk="duplicate-selected">Дублювати рядок</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-bulk="copy-next-week">Копія на наступний тиждень</button>
                          <button type="button" class="btn btn-outline-secondary" data-schedule-view-target="advanced">Відкрити advanced editor</button>
                        </div>
                      </div>
                      <div class="academic-v2-timetable mt-4">
                        <div class="academic-v2-timetable-corner">Пара</div>
                        <% dayOptions.forEach((day) => { %>
                          <div class="academic-v2-timetable-day"><%= day %></div>
                        <% }); %>
                        <% scheduleGridRows.forEach((classNumber) => { %>
                          <div class="academic-v2-timetable-row-label"><%= classNumber %></div>
                          <% dayOptions.forEach((day) => { %>
                            <% const slotEntries = scheduleEntriesBySlotKey.get(`${day}::${classNumber}`) || []; %>
                            <div class="academic-v2-timetable-slot" data-schedule-slot data-day-of-week="<%= day %>" data-class-number="<%= classNumber %>">
                              <% slotEntries.forEach((entry) => { %>
                                <button
                                  type="button"
                                  class="academic-v2-schedule-card"
                                  data-editor-target="schedule"
                                  data-editor-payload='<%- toAttr(entry) %>'
                                  data-schedule-entry-week="<%= entry.week_number %>"
                                  data-schedule-entry-id="<%= entry.id %>"
                                >
                                  <strong><%= entry.subject_title %></strong>
                                  <span><%= entry.activity_label || entry.activity_type %></span>
                                  <span><%= entry.target_group_label || (`G${entry.group_number}`) %></span>
                                  <span><%= entry.teacher_names.length ? entry.teacher_names.join(', ') : 'Викладача не призначено' %></span>
                                  <% if (entry.week_number) { %><span>Тиждень <%= entry.week_number %></span><% } %>
                                  <% if (entry.warning_labels.length) { %>
                                    <span class="academic-v2-schedule-warning"><%= entry.warning_labels[0] %></span>
                                  <% } %>
                                </button>
                              <% }); %>
                              <div class="academic-v2-schedule-slot-empty">Натисни, щоб поставити активність</div>
                            </div>
                          <% }); %>
                        <% }); %>
                      </div>
                    </div>

                    <div class="academic-v2-subcard" data-schedule-view-panel="subject">
                      <div class="academic-v2-subcard-topline">За предметом</div>
