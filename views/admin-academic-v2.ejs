                  </div>
                  <div class="academic-v2-chip-row mt-3">
                    <% activityPresetOptions.forEach((preset) => { %>
                      <button
                        type="submit"
                        class="btn btn-sm btn-outline-secondary"
                        formaction="/admin/pathways/v2/group-subject-activities/preset"
                        formmethod="post"
                        name="preset_key"
                          value="<%= preset.value %>"
                      ><%= preset.label %></button>
                    <% }); %>
                  </div>
                </form>

                <div class="academic-v2-subcard">
