                    </form>
                  </div>
                <% } %>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/groups/save" class="academic-v2-subcard" data-editor-form="group">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="group_id" value="" data-editor-input="group.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="groupCohort">Cohort</label>
                      <select id="groupCohort" class="form-select" name="cohort_id" data-editor-input="group.cohort_id">
