                                    <span><%= entry.day_of_week %> · пара <%= entry.class_number %> · тиждень <%= entry.week_number %></span>
                                    <span><%= entry.activity_label || entry.activity_type %> · <%= entry.target_group_label %></span>
                                  </button>
                                <% }); %>
                              </div>
                              <% if (item.hidden_entry_count > 0) { %>
