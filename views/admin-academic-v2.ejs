                <% if (selectedGroup) { %>
                  <div class="academic-v2-actions">
                    <form method="post" action="/admin/pathways/v2/groups/<%= selectedGroup.id %>/apply-stage-template">
                      <%- renderFocusFields() %>
                      <button type="submit" class="btn btn-outline-secondary">Apply stage template</button>
                    </form>
                    <form method="post" action="/admin/pathways/v2/groups/<%= selectedGroup.id %>/resync">
                      <%- renderFocusFields() %>
                      <button type="submit" class="btn btn-outline-secondary">Rebuild legacy projection</button>
                    </form>
                  </div>
                <% } %>
              </div>
              <div class="academic-v2-grid-2">
                <form method="post" action="/admin/pathways/v2/groups/save" class="academic-v2-subcard" data-editor-form="group">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="group_id" value="" data-editor-input="group.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="groupCohort">Cohort</label>
                      <select id="groupCohort" class="form-select" name="cohort_id" data-editor-input="group.cohort_id">
                        <% (scopedCohorts || cohorts || []).forEach((cohort) => { %>
                          <option
                            value="<%= cohort.id %>"
                            data-track-key="<%= cohort.track_key %>"
                            <%= Number(cohort.id) === activeCohortId ? 'selected' : '' %>
                          ><%= cohort.label %> - <%= cohort.admission_year %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupStage">Stage / course number</label>
                      <input id="groupStage" class="form-control" type="number" name="stage_number" data-editor-input="group.stage_number" value="1" required />
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupCampus">Campus</label>
                      <select id="groupCampus" class="form-select" name="campus_key" data-editor-input="group.campus_key">
                        <% campusOptions.forEach((campus) => { %>
                          <option value="<%= campus.value %>"><%= campus.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupCode">Code</label>
                      <input id="groupCode" class="form-control academic-v2-code" type="text" name="code" data-editor-input="group.code" placeholder="BSC26-A" />
                    </div>
                    <div class="academic-v2-field" style="grid-column: 1 / -1;">
                      <label for="groupLabel">Course label</label>
                      <input id="groupLabel" class="form-control" type="text" name="label" data-editor-input="group.label" placeholder="PLED 2026 Kyiv" required />
                    </div>
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="groupActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="group.is_active" checked />
                    <label class="form-check-label" for="groupActive">Active course</label>
                  </div>
                  <input type="hidden" name="is_teacher_registration_default" value="0" data-preserve-reset />
                  <div class="form-check mt-2" id="groupTeacherDefaultField" style="display: none;">
                    <input
                      id="groupTeacherDefault"
                      class="form-check-input"
                      type="checkbox"
                      name="is_teacher_registration_default"
                      value="1"
                      data-editor-input="group.is_teacher_registration_default"
                    />
                    <label class="form-check-label" for="groupTeacherDefault">Default for teacher registration</label>
                    <div class="academic-v2-muted">If several teacher groups share one campus, registration will use this one.</div>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save course</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="group">Reset</button>
                  </div>
                </form>
                <div class="academic-v2-stack">
                  <div class="academic-v2-subcard">
                    <div class="academic-v2-table-wrap">
                      <table class="table academic-v2-table">
                        <thead>
                          <tr>
                            <th>Course</th>
                            <th>Projection</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% (groups || []).forEach((group) => { %>
                            <% const health = projectionHealthByGroup.get(Number(group.id || 0)) || null; %>
                            <tr>
                              <td>
                                <div class="academic-v2-kv">
                                  <strong><%= group.label %></strong>
                                  <span class="academic-v2-muted"><%= group.program_name %> - <%= group.admission_year %> - stage <%= group.stage_number %> - <%= group.campus_key %></span>
                                </div>
                              </td>
                              <td>
                                <span class="academic-v2-chip"><%= group.term_count %> terms</span>
                                <span class="academic-v2-chip"><%= group.group_subject_count %> subjects</span>
                                <span class="academic-v2-chip academic-v2-chip--ok"><%= group.enrolled_users %> users</span>
                                <% if (group.track_key === 'teacher' && group.is_teacher_registration_default) { %>
                                  <span class="academic-v2-chip academic-v2-chip--ok">teacher default</span>
                                <% } %>
                                <% if (health) { %>
                                  <span class="academic-v2-chip <%= health.is_healthy ? 'academic-v2-chip--ok' : 'academic-v2-chip--warm' %>"><%= health.is_healthy ? 'projection ok' : 'needs review' %></span>
                                  <% (health.issues || []).slice(0, 2).forEach((issue) => { %>
                                    <span class="academic-v2-chip"><%= issue %></span>
                                  <% }); %>
                                <% } %>
                              </td>
                              <td class="text-end">
                                <div class="academic-v2-actions justify-content-end">
                                  <a class="btn btn-sm btn-outline-secondary" href="<%= buildFocusHref({ program_id: group.program_id, cohort_id: group.cohort_id, group_id: group.id, term_id: '' }) %>">Focus</a>
                                  <button type="button" class="btn btn-sm btn-primary" data-editor-target="group" data-editor-payload='<%- toAttr(group) %>'>Edit</button>
                                  <form method="post" action="/admin/pathways/v2/groups/<%= group.id %>/delete">
                                    <%- renderFocusFields() %>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                  <form method="post" action="/admin/pathways/v2/enrollments/bulk" class="academic-v2-subcard">
                    <%- renderFocusFields() %>
                    <h3 class="h5 mb-2">Bulk user reassignment</h3>
                    <p class="academic-v2-section-copy mb-3">Assign existing users to the selected course. Projection updates both <span class="academic-v2-code">users.group_id</span> and compatibility legacy placement.</p>
                    <div class="academic-v2-field">
                      <label for="bulkGroupId">Target course</label>
                      <select id="bulkGroupId" class="form-select" name="group_id">
                        <% (scopedGroups || groups || []).forEach((group) => { %>
                          <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field mt-3">
                      <label for="bulkUserIds">Users</label>
                      <select id="bulkUserIds" class="form-select" name="user_ids" multiple size="8">
                        <% (users || []).forEach((user) => { %>
                          <option value="<%= user.id %>"><%= user.full_name %> - <%= user.role %><%= user.group_label ? ` - ${user.group_label}` : '' %><%= user.legacy_course_name ? ` - ${user.legacy_course_name}` : '' %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-actions mt-3">
                      <button type="submit" class="btn btn-primary">Assign selected users</button>
                    </div>
                  </form>
                </div>
              </div>
            </section>

            <section class="academic-v2-card" id="subjects">
              <div class="academic-v2-section-head">
                <div>
                  <h2 class="academic-v2-section-title">Subjects & Teachers</h2>
                  <p class="academic-v2-section-copy">Templates are the global catalog. Course subjects hold teachers, terms, and subgroup defaults. Lecture, seminar, practice, and lab live as separate activities inside each course subject.</p>
                </div>
                <% if (scopedGroupSubjectsWithoutActivities.length) { %>
                  <div class="academic-v2-chip-row">
                    <span class="academic-v2-chip academic-v2-chip--warm"><%= scopedGroupSubjectsWithoutActivities.length %> course subjects missing activity</span>
                  </div>
                <% } %>
              </div>
              <div class="academic-v2-grid-3">
                <form method="post" action="/admin/pathways/v2/templates/save" class="academic-v2-subcard" data-editor-form="template">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="subject_template_id" value="" data-editor-input="template.id" />
                  <div class="academic-v2-field">
                    <label for="templateName">Template name</label>
                    <input id="templateName" class="form-control" type="text" name="name" data-editor-input="template.name" placeholder="Linear Algebra" required />
                  </div>
                  <input type="hidden" name="is_active" value="0" />
                  <div class="form-check mt-3">
                    <input id="templateActive" class="form-check-input" type="checkbox" name="is_active" value="1" data-editor-input="template.is_active" checked />
                    <label class="form-check-label" for="templateActive">Template is active</label>
                  </div>
                  <div class="academic-v2-actions mt-3">
                    <button type="submit" class="btn btn-primary">Save template</button>
                    <button type="button" class="btn btn-outline-secondary" data-editor-reset="template">Reset</button>
                  </div>
                  <% if ((subjectTemplates || []).length) { %>
                    <div class="academic-v2-stack mt-4">
                      <% (subjectTemplates || []).forEach((template) => { %>
                        <div class="academic-v2-subcard">
                          <div class="d-flex flex-wrap justify-content-between gap-2">
                            <div>
                              <strong><%= template.name %></strong>
                              <div class="academic-v2-muted"><%= template.group_subject_count %> linked course subjects</div>
                            </div>
                            <div class="academic-v2-actions">
                              <button type="button" class="btn btn-sm btn-outline-secondary" data-editor-target="template" data-editor-payload='<%- toAttr(template) %>'>Edit</button>
                              <button type="submit" class="btn btn-sm btn-outline-danger" formaction="/admin/pathways/v2/templates/<%= template.id %>/delete" formmethod="post">Delete</button>
                            </div>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  <% } %>
                </form>

                <form method="post" action="/admin/pathways/v2/group-subjects/save" class="academic-v2-subcard" data-editor-form="group-subject">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="group_subject_id" value="" data-editor-input="group-subject.id" />
                  <div class="academic-v2-form-grid">
                    <div class="academic-v2-field">
                      <label for="groupSubjectGroup">Course</label>
                      <select id="groupSubjectGroup" class="form-select" name="group_id" data-editor-input="group-subject.group_id">
                        <% (scopedGroups || groups || []).forEach((group) => { %>
                          <option value="<%= group.id %>" <%= Number(group.id) === activeGroupId ? 'selected' : '' %>><%= group.label %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupSubjectTemplate">Subject template</label>
                      <select id="groupSubjectTemplate" class="form-select" name="subject_template_id" data-editor-input="group-subject.subject_template_id">
                        <% (subjectTemplates || []).forEach((template) => { %>
                          <option value="<%= template.id %>"><%= template.name %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div class="academic-v2-field" style="grid-column: 1 / -1;">
                      <label for="groupSubjectTitle">Live title</label>
                      <input id="groupSubjectTitle" class="form-control" type="text" name="title" data-editor-input="group-subject.title" placeholder="Defaults to template name if empty" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupSubjectGroups">Group count</label>
                      <input id="groupSubjectGroups" class="form-control" type="number" name="group_count" data-editor-input="group-subject.group_count" value="1" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupSubjectDefaultGroup">Default group</label>
                      <input id="groupSubjectDefaultGroup" class="form-control" type="number" name="default_group" data-editor-input="group-subject.default_group" value="1" />
                    </div>
                    <div class="academic-v2-field">
                      <label for="groupSubjectSortOrder">Sort order</label>
                      <input id="groupSubjectSortOrder" class="form-control" type="number" name="sort_order" data-editor-input="group-subject.sort_order" value="0" />
