                          <option value="<%= teacher.id %>"><%= teacher.full_name %></option>
                        <% }); %>
                      </select>
                    </div>
                  </div>
                  <div class="academic-v2-checkboxes mt-3">
                    <input type="hidden" name="is_visible" value="0" />
                    <div class="form-check"><input id="groupSubjectVisible" class="form-check-input" type="checkbox" name="is_visible" value="1" data-editor-input="group-subject.is_visible" checked /><label class="form-check-label" for="groupSubjectVisible">Visible</label></div>
                    <input type="hidden" name="is_required" value="0" />
                    <div class="form-check"><input id="groupSubjectRequired" class="form-check-input" type="checkbox" name="is_required" value="1" data-editor-input="group-subject.is_required" checked /><label class="form-check-label" for="groupSubjectRequired">Required</label></div>
                    <input type="hidden" name="is_general" value="0" />
                    <div class="form-check"><input id="groupSubjectGeneral" class="form-check-input" type="checkbox" name="is_general" value="1" data-editor-input="group-subject.is_general" checked /><label class="form-check-label" for="groupSubjectGeneral">General</label></div>
                    <input type="hidden" name="show_in_teamwork" value="0" />
                    <div class="form-check"><input id="groupSubjectTeamwork" class="form-check-input" type="checkbox" name="show_in_teamwork" value="1" data-editor-input="group-subject.show_in_teamwork" checked /><label class="form-check-label" for="groupSubjectTeamwork">Show in teamwork</label></div>
                  </div>
                    <div class="academic-v2-actions mt-3">
                      <button type="submit" class="btn btn-primary">Save course subject</button>
                      <button type="button" class="btn btn-outline-secondary" data-editor-reset="group-subject">Reset</button>
                    </div>
                </form>

                <form method="post" action="/admin/pathways/v2/group-subject-activities/save" class="academic-v2-subcard" data-editor-form="group-subject-activity">
                  <%- renderFocusFields() %>
                  <input type="hidden" name="group_subject_activity_id" value="" data-editor-input="group-subject-activity.id" />
