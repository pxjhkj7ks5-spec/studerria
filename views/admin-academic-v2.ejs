                        <div class="academic-v2-stack">
                          <% scheduleBySubjectPreview.forEach((item) => { %>
                            <div class="academic-v2-schedule-list-card">
                              <strong><%= item.subject.title %></strong>
                              <div class="academic-v2-chip-row mt-2">
                                <span class="academic-v2-chip"><%= item.entries.length %> слотів</span>
