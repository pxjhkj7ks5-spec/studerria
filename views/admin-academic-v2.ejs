                            <select id="schedulePlacementTerm" class="form-select">
                              <% termCards.forEach((term) => { %>
                                <option value="<%= term.id %>" <%= Number(term.id || 0) === Number(selectedWorkspaceTermId || 0) ? 'selected' : '' %>><%= term.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field academic-v2-field--wide">
                            <label for="schedulePlacementSubject">Предмет</label>
                            <select id="schedulePlacementSubject" class="form-select">
                              <% schedulableSubjects.forEach((subject) => { %>
                                <option value="<%= subject.id %>"><%= subject.title %></option>
                              <% }); %>
                            </select>
                          </div>
                          <div class="academic-v2-field">
                            <label for="schedulePlacementActivityType">Режим активності</label>
