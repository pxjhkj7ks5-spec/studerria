</style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/teamwork.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-teamwork page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', { role, username, t, activePage: 'teamwork', pageTitle: t('menu.teamwork') }) %>
    <%- include('partials/desktop-menu-drawer', { role, t, activePage: 'teamwork' }) %>

    <main class="container py-4">
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>
      <% if (projectionAlert && projectionAlert.body) { %>
        <div class="alert alert-warning glass border-0">
          <strong><%= projectionAlert.title %></strong><br />
          <%= projectionAlert.body %>
        </div>
      <% } %>

      <div class="glass glass-float glass-float--no-top-glare subject-picker-card p-3 mb-4">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
          <div>
            <h5 class="mb-1"><%= teamworkCopy.subjectsTitle %></h5>
            <% if (selectedSubject) { %>
              <div class="text-muted small">
                <span class="course-badge"><%= selectedSubject.course_name %></span>
                <% if (selectedSubject.group_label) { %>
                  <span class="ms-2"><%= selectedSubject.group_label %></span>
                <% } %>
              </div>
            <% } %>
          </div>
          <span class="status-chip status-chip--info"><%= isTeacherMode ? teamworkCopy.roleTeacher : teamworkCopy.roleStudent %></span>
        </div>
        <div class="subject-chip-grid">
          <% if (!subjects.length) { %>
            <span class="text-muted"><%= teamworkCopy.noSubjects %></span>
          <% } else { %>
            <% subjects.forEach(function(s) { %>
              <form method="GET" action="/teamwork" class="subject-nav-form">
                <input type="hidden" name="subject_id" value="<%= s.subject_id %>" />
                <button
                  class="subject-nav-pill <%= selectedSubjectId === s.subject_id ? 'is-active' : '' %>"
                  type="submit"
                  aria-pressed="<%= selectedSubjectId === s.subject_id ? 'true' : 'false' %>"
                >
                  <span class="subject-name"><%= s.subject_name %></span>
                  <span class="subject-meta">
                    <%= s.course_name %><%= s.group_label ? ` • ${s.group_label}` : '' %>
                  </span>
                </button>
              </form>
            <% }); %>
          <% } %>
        </div>
        <% if (selectedSubjectId && isTeacherMode) { %>
          <div class="d-flex justify-content-end mt-3">
            <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#createTaskModal">
              <%= teamworkCopy.createTask %>
            </button>
          </div>
        <% } %>
      </div>
      <div class="living-separator mb-4" aria-hidden="true"></div>

      <% if (selectedSubjectId) { %>
        <% if (!tasks.length) { %>
          <div class="glass p-4 text-center text-muted"><%= teamworkCopy.noTasks %></div>
        <% } %>

        <section class="materials-feed">
        <% tasks.forEach(function(task) { %>
          <article class="glass material-card task-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <h5 class="mb-1"><%= task.title %></h5>
                <div class="text-muted"><%= teamworkCopy.subjectLabel %>: <%= task.subject_name %></div>
                <% if (!isTeacherMode) { %>
                  <div class="text-muted small"><%= teamworkCopy.teacherLabel %>: <%= task.created_by_name %></div>
                <% } %>
                <div class="d-flex flex-wrap gap-2 mt-2 task-settings-line">
                  <span class="task-setting-pill"><%= task.random_distribution ? teamworkCopy.randomDistribution : teamworkCopy.freeGroupChoice %></span>
                  <span class="task-setting-pill"><%= task.lesson_scope === 'seminar' ? teamworkCopy.seminarLabel : teamworkCopy.lectureLabel %>: <%= task.audience_label || teamworkCopy.allGroups %></span>
                  <span class="task-setting-pill"><%= teamworkCopy.groupsCountLabel %>: <%= task.group_count || 1 %></span>
                  <% if (task.member_limits_enabled) { %>
                    <span class="task-setting-pill"><%= teamworkCopy.teamSizeLabel %>: <%= task.min_members %> - <%= task.max_members %></span>
                  <% } %>
                  <span class="task-setting-pill"><%= task.group_lock_enabled ? teamworkCopy.groupsLocked : teamworkCopy.groupsEditable %></span>
                </div>
                <% if (!isTeacherMode && task.group_lock_enabled && task.current_user_group_id) { %>
                  <div class="small text-muted mt-1"><%= teamworkCopy.groupSwitchLocked %></div>
                <% } %>
                <div class="d-flex gap-2 mt-2 task-reactions">
                  <% const reactMap = task.reactions || {}; %>
                  <% const reactedMap = task.reacted || {}; %>
                  <button
                    class="btn btn-outline-light btn-sm react-btn <%= reactedMap['🔥'] ? 'active' : '' %>"
                    data-task-id="<%= task.id %>"
                    data-emoji="🔥"
                    type="button"
                  >
                    <span>🔥</span>
                    <span class="react-count"><%= reactMap['🔥'] || 0 %></span>
                  </button>
                  <button
                    class="btn btn-outline-light btn-sm react-btn <%= reactedMap['👍'] ? 'active' : '' %>"
                    data-task-id="<%= task.id %>"
                    data-emoji="👍"
                    type="button"
                  >
                    <span>👍</span>
                    <span class="react-count"><%= reactMap['👍'] || 0 %></span>
                  </button>
                </div>
              </div>
            </div>

            <div class="row g-3">
              <div class="col-12 col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h6 class="mb-0"><%= teamworkCopy.subgroupsTitle %></h6>
                  <% if (task.is_owner && task.can_create_groups) { %>
                    <form method="POST" action="/teamwork/group/create" class="d-flex gap-2">
                      <input type="hidden" name="task_id" value="<%= task.id %>" />
                      <input class="form-control form-control-sm" name="name" placeholder="<%= teamworkCopy.groupNamePlaceholder %>" />
                      <% if (!task.member_limits_enabled) { %>
                        <input class="form-control form-control-sm" name="max_members" placeholder="<%= teamworkCopy.maxShort %>" type="number" min="1" />
                      <% } %>
                      <button class="btn btn-outline-light btn-sm" type="submit"><%= teamworkCopy.newGroup %></button>
                    </form>
                  <% } %>
                </div>

                <% if (!task.groups.length) { %>
                  <div class="text-muted"><%= teamworkCopy.noGroups %></div>
                <% } %>

                <div class="d-grid gap-3 context-cloud-list">
                  <% task.groups.forEach(function(group) { %>
                    <div class="glass material-card group-card context-cloud-item">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                          <strong><%= group.name %></strong>
                          <% if (task.lesson_scope === 'seminar' && group.seminar_group_number) { %>
                            <span class="text-muted ms-2"><%= teamworkCopy.seminarGroupShort %> <%= group.seminar_group_number %></span>
                          <% } %>
                          <span class="text-muted ms-2"><%= teamworkCopy.leaderLabel %>: <%= group.leader_name %></span>
                          <% if (group.max_members) { %>
                            <span class="text-muted ms-2"><%= teamworkCopy.maxLabel %>: <%= group.max_members %></span>
                          <% } %>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                          <% if (!isTeacherMode) { %>
                            <% if (group.is_member) { %>
                              <% if (task.group_lock_enabled) { %>
                                <span class="small text-muted"><%= teamworkCopy.locked %></span>
                              <% } else { %>
                                <form method="POST" action="/teamwork/group/leave">
                                  <input type="hidden" name="group_id" value="<%= group.id %>" />
                                  <button class="btn btn-outline-secondary btn-sm" type="submit"><%= teamworkCopy.leave %></button>
                                </form>
                              <% } %>
                            <% } else if (!task.current_user_group_id) { %>
                              <form method="POST" action="/teamwork/group/join">
                                <input type="hidden" name="group_id" value="<%= group.id %>" />
                                <button class="btn btn-outline-light btn-sm" type="submit"><%= teamworkCopy.join %></button>
                              </form>
                            <% } else { %>
                              <span class="small text-muted"><%= teamworkCopy.alreadyInAnotherGroup %></span>
                            <% } %>
                          <% } %>
                        </div>
                      </div>
                      <% if (!group.members.length) { %>
                        <div class="small text-muted mb-2"><%= teamworkCopy.membersEmpty %></div>
                      <% } else { %>
                        <div class="member-stack mb-2">
                          <% group.members.forEach(function(member) { %>
                            <div class="member-row context-cloud-item">
                              <span class="member-name"><%= member.member_name %></span>
                              <% if (task.is_owner && task.groups.length > 1) { %>
                                <form method="POST" action="/teamwork/group/move-member" class="member-move-form">
                                  <input type="hidden" name="task_id" value="<%= task.id %>" />
                                  <input type="hidden" name="user_id" value="<%= member.user_id %>" />
                                  <select class="form-select form-select-sm" name="target_group_id">
                                    <% task.groups.forEach(function(targetGroup) { %>
                                      <option value="<%= targetGroup.id %>" <%= Number(targetGroup.id) === Number(group.id) ? 'selected' : '' %>>
                                        <%= targetGroup.name %><%= task.lesson_scope === 'seminar' && targetGroup.seminar_group_number ? ` (${teamworkCopy.seminarGroupShort.toLowerCase()} ${targetGroup.seminar_group_number})` : '' %>
                                      </option>
                                    <% }); %>
                                  </select>
                                  <button class="btn btn-outline-light btn-sm" type="submit"><%= teamworkCopy.move %></button>
                                </form>
                              <% } %>
                            </div>
                          <% }); %>
                        </div>
                      <% } %>
                      <% if (group.is_leader) { %>
                        <form method="POST" action="/teamwork/group/update" class="row g-2 align-items-end">
                          <input type="hidden" name="group_id" value="<%= group.id %>" />
                          <div class="col-12 col-md-5">
                            <label class="form-label"><%= teamworkCopy.nameLabel %></label>
                            <input class="form-control form-control-sm" name="name" placeholder="<%= group.name %>" />
                          </div>
                          <% if (!task.member_limits_enabled) { %>
                            <div class="col-12 col-md-3">
                              <label class="form-label"><%= teamworkCopy.maxMembersLabel %></label>
                              <input class="form-control form-control-sm" name="max_members" type="number" min="1" placeholder="<%= teamworkCopy.noLimitPlaceholder %>" />
                            </div>
                          <% } else { %>
                            <div class="col-12 col-md-3">
                              <label class="form-label"><%= teamworkCopy.maxMembersLabel %></label>
                              <input
                                class="form-control form-control-sm"
                                type="number"
                                value="<%= task.max_members || '' %>"
                                disabled
                              />
                            </div>
                          <% } %>
                          <div class="col-12 col-md-4 d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" type="submit"><%= teamworkCopy.update %></button>
                          </div>
                        </form>
                        <form method="POST" action="/teamwork/group/disband" class="mt-2">
                          <input type="hidden" name="group_id" value="<%= group.id %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit"><%= teamworkCopy.disband %></button>
                        </form>
                      <% } %>
                    </div>
                  <% }); %>
                </div>
              </div>

              <div class="col-12 col-lg-4">
                <div class="glass p-3">
                  <h6><%= teamworkCopy.availableToJoin %></h6>
                  <ul class="list-group list-group-flush mt-2">
                    <% (freeStudents[task.id] || []).forEach(function(stu) { %>
                      <li class="list-group-item bg-transparent context-cloud-item"><%= stu.full_name %></li>
                    <% }); %>
                    <% if (!(freeStudents[task.id] || []).length) { %>
                      <li class="list-group-item bg-transparent text-muted context-cloud-item"><%= teamworkCopy.noFreeStudents %></li>
                    <% } %>
                  </ul>
                </div>
              </div>
            </div>
          </article>
        <% }); %>
        </section>
      <% } %>
    </main>

    <%- include('partials/app-footer') %>

    <% if (isTeacherMode) { %>
      <div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content glass p-3">
            <div class="modal-header">
              <h5 class="modal-title"><%= teamworkCopy.newTaskTitle %></h5>
              <button class="btn-close" data-bs-dismiss="modal" aria-label="<%= teamworkCopy.close %>"></button>
            </div>
            <div class="modal-body">
              <form method="POST" action="/teamwork/task/create">
                <input type="hidden" name="subject_id" value="<%= selectedSubjectId %>" />
                <div class="mb-3">
                  <label class="form-label"><%= teamworkCopy.taskNameLabel %></label>
                  <input class="form-control" name="title" placeholder="<%= teamworkCopy.taskNamePlaceholder %>" required />
                </div>
                <div class="mb-3">
                  <label class="form-label"><%= teamworkCopy.dueDateOptional %></label>
                  <input class="form-control" type="date" name="due_date" />
                </div>

                <div class="glass p-3 mb-3 task-options-block">
                  <div class="lesson-scope-picker mb-3">
                    <label class="form-label d-block"><%= teamworkCopy.lessonTypeLabel %></label>
                    <div class="btn-group w-100 liquid-chip-control" role="group" aria-label="<%= teamworkCopy.lessonScopeAria %>">
                      <input class="btn-check" type="radio" name="lesson_scope" id="lessonScopeLecture" value="lecture" checked />
                      <label class="btn btn-outline-light liquid-chip" for="lessonScopeLecture"><%= teamworkCopy.lectureLabel %></label>
                      <input class="btn-check" type="radio" name="lesson_scope" id="lessonScopeSeminar" value="seminar" />
                      <label class="btn btn-outline-light liquid-chip" for="lessonScopeSeminar"><%= teamworkCopy.seminarLabel %></label>
                    </div>
                  </div>

                  <div id="seminarGroupsPanel" class="seminar-groups-panel is-hidden mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <span class="small text-muted"><%= teamworkCopy.showForGroups %></span>
                      <span class="small text-muted"><%= teamworkCopy.defaultAllGroups %></span>
                    </div>
                    <div class="form-check form-switch mb-2">
                      <input class="form-check-input" type="checkbox" role="switch" id="seminarAllGroupsToggle" name="seminar_group_numbers" value="all" checked />
                      <label class="form-check-label" for="seminarAllGroupsToggle"><%= teamworkCopy.allGroups %></label>
                    </div>
                    <div id="seminarGroupsList" class="seminar-groups-list">
                      <% for (let groupNum = 1; groupNum <= Math.max(1, Number((selectedSubject && selectedSubject.group_count) || 1)); groupNum += 1) { %>
                        <label class="seminar-group-chip">
                          <input class="seminar-group-check" type="checkbox" name="seminar_group_numbers" value="<%= groupNum %>" disabled />
                          <span><%= teamworkCopy.groupSingular %> <%= groupNum %></span>
                        </label>
                      <% } %>
                    </div>
                  </div>

                  <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" role="switch" id="randomDistributionToggle" name="random_distribution" value="1" checked />
                    <label class="form-check-label" for="randomDistributionToggle"><%= teamworkCopy.randomStudents %></label>
                  </div>

                  <div class="mb-3">
                    <label class="form-label" for="groupCountInput"><%= teamworkCopy.groupCountInput %></label>
                    <input class="form-control" id="groupCountInput" type="number" name="group_count" min="1" max="12" value="4" required />
                  </div>

                  <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="memberLimitsToggle" name="limit_members_enabled" value="1" />
                    <label class="form-check-label" for="memberLimitsToggle"><%= teamworkCopy.memberLimits %></label>
                  </div>

                  <div id="memberLimitsPanel" class="member-limits-panel is-disabled">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <span class="small text-muted"><%= teamworkCopy.teamSizeRange %></span>
                      <span class="range-value-chip"><span id="rangeMinValue">2</span> - <span id="rangeMaxValue">4</span></span>
                    </div>
                    <div class="double-range" id="doubleRangeBox">
                      <div class="double-range-track"></div>
                      <div class="double-range-fill" id="doubleRangeFill"></div>
                      <input
                        class="double-range-input"
                        type="range"
                        id="minMembersInput"
                        name="min_members"
                        min="1"
                        max="12"
                        value="2"
                        disabled
                      />
                      <input
                        class="double-range-input"
                        type="range"
                        id="maxMembersInput"
                        name="max_members"
                        min="1"
                        max="12"
                        value="4"
                        disabled
                      />
                      <output class="range-bubble" id="minRangeBubble">2</output>
                      <output class="range-bubble" id="maxRangeBubble">4</output>
                    </div>
                  </div>

                  <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" role="switch" id="groupLockToggle" name="group_lock_enabled" value="1" />
                    <label class="form-check-label" for="groupLockToggle"><%= teamworkCopy.lockGroupMembers %></label>
                  </div>
                  <div class="small text-muted mt-1"><%= teamworkCopy.lockHint %></div>
                </div>

                <button class="btn btn-primary glass w-100" type="submit"><%= teamworkCopy.create %></button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <%- include('partials/mobile-menu-modal', { role, t, activePage: 'teamwork' }) %>
    <%- include('partials/changelog-modal') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const themeToggles = document.querySelectorAll('.theme-toggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-dark';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggles.forEach((btn) => {
        btn.textContent = savedTheme === 'theme-dark' ? btn.dataset.lightLabel : btn.dataset.darkLabel;
        btn.addEventListener('click', () => {
          const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(next);
          localStorage.setItem('ui-theme', next);
          themeToggles.forEach((b) => {
            b.textContent = next === 'theme-dark' ? b.dataset.lightLabel : b.dataset.darkLabel;
          });
        });
      });

      function showCustomTooltip(el, message) {
        document.querySelectorAll('.custom-tooltip').forEach((t) => t.remove());
        const anchor = el.closest('.form-check') || el.closest('.input-group') || el;
        const key = el.id || el.name || anchor.id || '';
        const tip = document.createElement('div');
        tip.className = 'custom-tooltip';
        tip.textContent = message || '<%= teamworkCopy.validationCheckField %>';
        if (key) tip.dataset.for = key;
        document.body.appendChild(tip);

        const rect = anchor.getBoundingClientRect();
        const tipRect = tip.getBoundingClientRect();
        const margin = 10;
        let top = rect.bottom + margin;
        let left = rect.left;
        let placeBelow = true;
        if (top + tipRect.height > window.innerHeight - 8) {
          top = rect.top - tipRect.height - margin;
          placeBelow = false;
        }
        if (left + tipRect.width > window.innerWidth - 8) {
          left = window.innerWidth - tipRect.width - 8;
        }
        if (left < 8) left = 8;
        tip.style.top = `${Math.round(top)}px`;
        tip.style.left = `${Math.round(left)}px`;
        if (placeBelow) tip.classList.add('below');
        requestAnimationFrame(() => tip.classList.add('show'));
        const remove = () => tip.remove();
        tip.addEventListener('click', remove);
        setTimeout(remove, 3500);
      }

      function attachValidationTooltips(root = document) {
        root.querySelectorAll('input, select, textarea').forEach((el) => {
          el.addEventListener('invalid', (event) => {
            event.preventDefault();
            showCustomTooltip(el, el.validationMessage);
          });
          el.addEventListener('input', () => {
            const existing = document.querySelector(`.custom-tooltip[data-for="${el.id}"]`);
            if (existing) existing.remove();
          });
          el.addEventListener('blur', () => {
            const existing = document.querySelector(`.custom-tooltip[data-for="${el.id}"]`);
            if (existing) existing.remove();
          });
        });
      }

      attachValidationTooltips();

      function initTeamSizeRange() {
        const limitsToggle = document.getElementById('memberLimitsToggle');
        const limitsPanel = document.getElementById('memberLimitsPanel');
        const minInput = document.getElementById('minMembersInput');
        const maxInput = document.getElementById('maxMembersInput');
        const minValueEl = document.getElementById('rangeMinValue');
        const maxValueEl = document.getElementById('rangeMaxValue');
        const minBubble = document.getElementById('minRangeBubble');
        const maxBubble = document.getElementById('maxRangeBubble');
        const rangeFill = document.getElementById('doubleRangeFill');
        if (!limitsToggle || !limitsPanel || !minInput || !maxInput || !rangeFill) return;

        const alignBubble = (input, bubble) => {
          if (!input || !bubble) return;
          const min = Number(input.min) || 0;
          const max = Number(input.max) || 100;
          const value = Number(input.value) || min;
          const percent = max === min ? 0 : ((value - min) / (max - min)) * 100;
          bubble.style.left = `calc(${percent}% + (${8 - percent * 0.16}px))`;
          bubble.textContent = String(value);
        };

        const syncRange = (source) => {
          let minValue = Number(minInput.value);
          let maxValue = Number(maxInput.value);
          if (minValue > maxValue) {
            if (source === 'min') {
              maxValue = minValue;
            } else {
              minValue = maxValue;
            }
          }

          minInput.value = String(minValue);
          maxInput.value = String(maxValue);
          if (minValueEl) minValueEl.textContent = String(minValue);
          if (maxValueEl) maxValueEl.textContent = String(maxValue);

          const rangeMin = Number(minInput.min) || 1;
          const rangeMax = Number(minInput.max) || 12;
          const left = ((minValue - rangeMin) / (rangeMax - rangeMin)) * 100;
          const right = ((maxValue - rangeMin) / (rangeMax - rangeMin)) * 100;
          rangeFill.style.left = `${left}%`;
          rangeFill.style.width = `${Math.max(right - left, 0)}%`;

          alignBubble(minInput, minBubble);
          alignBubble(maxInput, maxBubble);
        };

        const applyLimitsState = () => {
          const enabled = limitsToggle.checked;
          minInput.disabled = !enabled;
          maxInput.disabled = !enabled;
          limitsPanel.classList.toggle('is-disabled', !enabled);
          syncRange('max');
        };

        limitsToggle.addEventListener('change', applyLimitsState);
        minInput.addEventListener('input', () => syncRange('min'));
        maxInput.addEventListener('input', () => syncRange('max'));
        window.addEventListener('resize', () => syncRange('max'));

        applyLimitsState();
      }

      initTeamSizeRange();

      function initLessonScopeControls() {
        const lectureRadio = document.getElementById('lessonScopeLecture');
        const seminarRadio = document.getElementById('lessonScopeSeminar');
        const seminarPanel = document.getElementById('seminarGroupsPanel');
        const allGroupsToggle = document.getElementById('seminarAllGroupsToggle');
        const specificGroupChecks = Array.from(document.querySelectorAll('.seminar-group-check'));
        if (!lectureRadio || !seminarRadio || !seminarPanel || !allGroupsToggle) return;

        const applyPickerState = () => {
          const seminarMode = seminarRadio.checked;
          const allGroupsMode = allGroupsToggle.checked;
          seminarPanel.classList.toggle('is-hidden', !seminarMode);
          seminarPanel.classList.toggle('is-disabled', seminarMode && allGroupsMode);
          specificGroupChecks.forEach((input) => {
            input.disabled = !seminarMode || allGroupsMode;
            if (!seminarMode || allGroupsMode) {
              input.checked = false;
            }
          });
        };

        lectureRadio.addEventListener('change', applyPickerState);
        seminarRadio.addEventListener('change', applyPickerState);
        allGroupsToggle.addEventListener('change', applyPickerState);
        applyPickerState();
      }

      initLessonScopeControls();

      function initSubjectSwitchFeedback() {
        const subjectLinks = Array.from(document.querySelectorAll('.subject-nav-pill[href]'));
        if (!subjectLinks.length) return;

        const markPending = (link) => {
          subjectLinks.forEach((item) => item.classList.remove('is-pending'));
          link.classList.add('is-pending');
        };

        subjectLinks.forEach((link) => {
          link.addEventListener('pointerdown', () => markPending(link));
          link.addEventListener('click', () => markPending(link));
          link.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              markPending(link);
            }
          });
        });
      }

      initSubjectSwitchFeedback();

      function updateReactionButtons(container, reactions, reacted) {
        const buttons = container.querySelectorAll('.react-btn');
        buttons.forEach((btn) => {
          const emoji = btn.dataset.emoji;
          const count = reactions && reactions[emoji] ? reactions[emoji] : 0;
          const countEl = btn.querySelector('.react-count');
          if (countEl) countEl.textContent = count;
          if (reacted && reacted[emoji]) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      }

      document.querySelectorAll('.task-reactions .react-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const taskId = Number(btn.dataset.taskId);
          const emoji = btn.dataset.emoji;
          if (Number.isNaN(taskId) || !emoji) return;
          try {
            const res = await fetch('/teamwork/react', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ task_id: taskId, emoji }),
            });
            if (!res.ok) return;
            const data = await res.json();
            const container = btn.closest('.task-reactions');
            if (!container) return;
            updateReactionButtons(container, data.reactions, data.reacted);
          } catch (err) {
            console.error(err);
          }
        });
      });
    </script>
    <%- include('partials/desktop-menu-drawer-script') %>
      <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
