<!doctype html>
<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#fff4ec" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>today's little message</title>
    <link rel="stylesheet" href="/css/mb.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body>
    <main class="mb-shell" data-mb-app>
      <div class="mb-bg" aria-hidden="true">
        <span class="mb-blob mb-blob--peach"></span>
        <span class="mb-blob mb-blob--lilac"></span>
        <span class="mb-blob mb-blob--sky"></span>
        <span class="mb-blob mb-blob--butter"></span>
      </div>

      <section class="mb-login" data-login-screen aria-label="Вхід у приватну сторінку">
        <div class="mb-login-card">
          <div class="mb-mini-cloud" aria-hidden="true">☁️</div>
          <p class="mb-overline">private note</p>
          <h1>today's little message</h1>
          <p class="mb-login-copy">тихий маленький простір тільки для двох</p>
          <form class="mb-login-form" data-login-form autocomplete="off">
            <label for="mbPassword">ключик</label>
            <input id="mbPassword" name="password" type="password" inputmode="text" autocomplete="current-password" placeholder="введи пароль" data-password-input />
            <button type="submit">увійти</button>
            <p class="mb-error" data-login-error role="status" aria-live="polite"></p>
          </form>
        </div>
      </section>

      <section class="mb-app is-hidden" data-app-screen aria-label="Приватне побажання">
        <header class="mb-topbar">
          <div class="mb-avatar mb-avatar--small" data-current-avatar aria-hidden="true"></div>
          <div class="mb-topbar-title">
            <span>побажання від</span>
            <strong data-topbar-name>другого учасника</strong>
          </div>
          <button class="mb-icon-button" type="button" data-logout aria-label="Вийти">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M10 6H6.9A2.9 2.9 0 0 0 4 8.9v6.2A2.9 2.9 0 0 0 6.9 18H10" />
              <path d="M14.2 8.2 18 12l-3.8 3.8" />
              <path d="M17.6 12H9.8" />
            </svg>
          </button>
        </header>

        <section class="mb-note-card" data-message-card data-vibe="soft-glow">
          <div class="mb-card-motion" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <b>🥰</b>
            <b>🥹</b>
            <b>✨</b>
          </div>
          <div class="mb-note-meta">
            <span data-note-date>сьогодні</span>
          </div>
          <div class="mb-author-row">
            <div class="mb-avatar mb-avatar--author" data-author-avatar aria-hidden="true"></div>
            <span>написано для тебе</span>
          </div>
          <p class="mb-note-text" data-message-text>сьогодні тут ще тихо... але, здається, скоро щось зʼявиться 🥹</p>
          <div class="mb-reactions" data-reactions aria-label="Реакції">
            <button type="button">🥹</button>
            <button type="button">🥰</button>
            <button type="button">✨</button>
            <button type="button">🫶</button>
            <button type="button">🤍</button>
            <button type="button">💌</button>
            <button type="button">🌙</button>
            <button type="button">☁️</button>
            <button type="button">🧸</button>
            <button type="button">💫</button>
          </div>
        </section>

        <section class="mb-panel mb-editor">
          <div class="mb-section-head">
            <div>
              <span>little sender</span>
              <h2>написати побажання</h2>
            </div>
            <button class="mb-vibe-random" type="button" data-random-vibe>змінити вайб</button>
          </div>

          <form data-message-form>
            <label for="mbMessage">для неї/нього</label>
            <textarea id="mbMessage" name="text" maxlength="800" rows="6" placeholder="напиши щось тепле, смішне або просто дуже своє..." data-message-input></textarea>

            <div class="mb-vibes" data-vibe-options aria-label="Анімація картки">
              <button type="button" data-vibe="soft-glow" class="is-active">soft glow</button>
              <button type="button" data-vibe="clouds">clouds</button>
              <button type="button" data-vibe="sparkles">sparkles</button>
              <button type="button" data-vibe="tiny-faces">tiny faces</button>
            </div>

            <button class="mb-primary" type="submit">зберегти</button>
          </form>
        </section>

        <section class="mb-panel mb-avatar-editor">
          <div class="mb-section-head">
            <div>
              <span>profile glow</span>
              <h2>змінити аватар</h2>
            </div>
            <div class="mb-avatar mb-avatar--preview" data-avatar-preview aria-hidden="true"></div>
          </div>
          <form data-avatar-form>
            <label for="mbAvatarUrl">URL картинки</label>
            <input id="mbAvatarUrl" name="avatarUrl" type="url" inputmode="url" placeholder="https://..." data-avatar-input />
            <button class="mb-secondary" type="submit">зберегти аватар</button>
          </form>
        </section>
      </section>

      <div class="mb-toast" data-toast role="status" aria-live="polite"></div>
    </main>

    <script src="/js/mb.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
