<!doctype html>
<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f9fbff" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Подаруночок</title>
    <link rel="stylesheet" href="/css/mb.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body>
    <main class="mb-page" data-gift-page>
      <div class="mb-aurora mb-aurora--rose" aria-hidden="true"></div>
      <div class="mb-aurora mb-aurora--mint" aria-hidden="true"></div>
      <div class="mb-aurora mb-aurora--sky" aria-hidden="true"></div>

      <section class="mb-stage" aria-label="Подаруночок">
        <div class="mb-sparkles" aria-hidden="true">
          <span style="--x: 9%; --y: 26%; --d: 0s; --s: 0.78;"></span>
          <span style="--x: 21%; --y: 17%; --d: 1.2s; --s: 0.55;"></span>
          <span style="--x: 77%; --y: 19%; --d: 0.5s; --s: 0.72;"></span>
          <span style="--x: 89%; --y: 39%; --d: 1.7s; --s: 0.48;"></span>
          <span style="--x: 14%; --y: 64%; --d: 0.8s; --s: 0.6;"></span>
          <span style="--x: 83%; --y: 68%; --d: 2.1s; --s: 0.58;"></span>
          <span style="--x: 43%; --y: 11%; --d: 1.9s; --s: 0.44;"></span>
          <span style="--x: 61%; --y: 75%; --d: 1.1s; --s: 0.66;"></span>
        </div>

        <div class="mb-gift-wrap" aria-hidden="true">
          <div class="mb-note">
            <p>Посміхнись,<br />бо посмішка<br />мила в тебе</p>
            <span></span>
          </div>

          <div class="mb-glow"></div>

          <div class="mb-lid">
            <div class="mb-lid-ribbon"></div>
            <div class="mb-bow">
              <i></i>
              <i></i>
              <b></b>
            </div>
          </div>

          <div class="mb-box">
            <div class="mb-box-face mb-box-face--left"></div>
            <div class="mb-box-face mb-box-face--right"></div>
            <div class="mb-box-ribbon"></div>
          </div>

          <div class="mb-confetti">
            <i style="--x: -132px; --y: -152px; --r: 18deg; --d: 0s;"></i>
            <i style="--x: 122px; --y: -168px; --r: -22deg; --d: 0.35s;"></i>
            <i style="--x: -76px; --y: -230px; --r: 34deg; --d: 0.7s;"></i>
            <i style="--x: 84px; --y: -246px; --r: -32deg; --d: 1.05s;"></i>
            <i style="--x: 164px; --y: -92px; --r: 12deg; --d: 1.4s;"></i>
          </div>
        </div>

        <button class="mb-open-button" type="button" data-gift-open aria-expanded="false">
          <span>Відкрити подаруночок</span>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h13m-5-5 5 5-5 5" />
          </svg>
        </button>
      </section>
    </main>

    <script src="/js/mb.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
