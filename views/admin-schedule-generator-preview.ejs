<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Превʼю розкладу</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/pages/schedule.css" />
    <link rel="stylesheet" href="/css/pages/admin-schedule-generator.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-schedule schedule-generator-page schedule-preview-page">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand">Превʼю розкладу</span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted"><%= t('role.admin') %>: <%= username %></span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="Toggle theme"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a
            class="btn btn-outline-primary btn-sm me-2"
            href="/admin/schedule-generator?run=<%= run.id %><% if (selectedLocation) { %>&location=<%= encodeURIComponent(String(selectedLocation)) %><% } %><% if (selectedCourseId) { %>&course_id=<%= selectedCourseId %><% } %><% if (selectedSemesterId) { %>&semester_id=<%= selectedSemesterId %><% } %>"
          >
            Назад до генератора
          </a>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container pt-2 pb-4 schedule-content">
      <% const localeCode = lang === 'en' ? 'en-US' : 'uk-UA'; %>
      <% const previewWeekCarouselText = lang === 'en'
        ? {
            kicker: 'Week navigator',
            aria: 'Week carousel',
            fallback: 'Semester flow',
          }
        : {
            kicker: 'Навігація тижнями',
            aria: 'Карусель тижнів',
            fallback: 'Ритм семестру',
          };
      %>
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>
      <% if (publishSummary) { %>
        <div class="alert alert-success">
          <div class="fw-semibold">Розклад опубліковано</div>
          <div class="small">
            Додано: <%= publishSummary.added %> · Оновлено: <%= publishSummary.updated %> · Видалено: <%= publishSummary.removed %>
          </div>
          <div class="small mt-1">
            <a href="/admin/schedule-list">Відкрити список пар</a>
            · <a href="/admin?tab=admin-history&history_q=<%= publishSummary.operation_id %>">Переглянути в історії</a>
            <% if (publishSummary.backup) { %>
              · <a href="/admin/schedule-generator/backup.csv?op=<%= publishSummary.backup %>">Backup CSV</a>
            <% } %>
          </div>
        </div>
      <% } %>
      <% const previewStats = lastStats && lastStats.diff ? lastStats : null; %>
      <% const previewDiff = previewStats ? previewStats.diff : null; %>
      <% const overwriteCount = previewDiff ? Number(previewDiff.overwrite || 0) : 0; %>

      <div class="glass week-hero liquid-card mb-4">
        <div>
          <h1 class="hero-title weekHeadline mb-1">Превʼю розкладу</h1>
          <div class="hero-sub">Перевір розклад у форматі звичайної сторінки перед публікацією.</div>
        </div>
        <div class="hero-actions">
          <span class="badge-glow"><%= t('schedule.week') %> <%= currentWeek %> / <%= totalWeeks %></span>
        </div>
      </div>

      <div class="glass schedule-panel liquid-card single-panel mb-4 schedule-preview-panel">
        <div class="panel-section">
          <div class="panel-title">Курс</div>
          <div class="panel-body">
            <form method="GET" action="/admin/schedule-generator/<%= run.id %>/preview" class="d-flex gap-2 align-items-center schedule-preview-course-form">
              <input type="hidden" name="week" value="<%= currentWeek %>" />
              <input type="hidden" name="location" value="<%= selectedLocation || '' %>" />
              <input type="hidden" name="semester_id" value="<%= selectedSemesterId || '' %>" />
              <select name="course" class="form-select w-auto" onchange="this.form.submit()">
                <% (courses || []).forEach(function(course) { %>
                  <option value="<%= course.id %>" <%= Number(course.id) === Number(selectedCourseId) ? 'selected' : '' %>><%= course.name %></option>
                <% }); %>
              </select>
            </form>
          </div>
        </div>
        <div class="panel-section panel-sync">
          <div class="panel-title">Публікація</div>
          <% if (previewDiff) { %>
            <div class="panel-body schedule-preview-diff">
              <span class="sync-pill"><span class="chip">Diff</span> +<%= previewDiff.added %> · ~<%= previewDiff.updated %> · −<%= previewDiff.removed %></span>
              <span class="sync-pill"><span class="chip">Перезапис</span> <%= overwriteCount %> слотів</span>
            </div>
            <div class="small text-muted">Operation: <%= previewStats.operation_id || '—' %></div>
          <% } else { %>
            <div class="small text-muted">Немає даних превʼю. Спочатку згенеруйте розклад.</div>
          <% } %>
          <form
            method="POST"
            action="/admin/schedule-generator/<%= run.id %>/publish"
            class="schedule-preview-publish-form mt-2"
            id="publishForm"
            data-has-preview="<%= previewDiff ? '1' : '0' %>"
            data-requires-typed="<%= publishRequiresTyped ? '1' : '0' %>"
          >
            <input type="hidden" name="operation_id" value="<%= previewStats ? (previewStats.operation_id || '') : '' %>" />
            <input type="hidden" name="course_id" value="<%= selectedCourseId %>" />
            <input type="hidden" name="week" value="<%= currentWeek %>" />
            <input type="hidden" name="location" value="<%= selectedLocation || '' %>" />
            <input type="hidden" name="semester_id" value="<%= selectedSemesterId || '' %>" />
            <label class="form-check small">
              <input class="form-check-input" type="checkbox" name="confirm_overwrite" value="1" data-publish-confirm />
              Я розумію, що це перезапише <%= overwriteCount %> слотів
            </label>
            <label class="small text-muted" for="publishConfirmPhrase">Type PUBLISH to continue</label>
            <input class="form-control" id="publishConfirmPhrase" name="confirm_phrase" data-publish-phrase autocomplete="off" />
            <label class="form-check small">
              <input class="form-check-input" type="checkbox" name="replace" value="1" checked />
              Замінити існуючий розклад для семестрів у превʼю
            </label>
            <button class="btn btn-primary" type="submit" id="publishBtn" <%= previewDiff ? '' : 'disabled' %>>Опублікувати</button>
            <div class="small text-muted">Перед публікацією створимо backup CSV.</div>
          </form>
        </div>
      </div>

      <div id="scheduleWeekGrid">
        <% (daysOfWeek || []).forEach(function(day) { %>
          <% const list = scheduleByDay[day] || []; %>
          <% const dateLabel = dayDates && dayDates[day] ? new Date(dayDates[day]).toLocaleDateString(localeCode, { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'Europe/Kyiv' }) : ''; %>
          <div class="card mb-3 glass day-card liquid-card" data-day-date="<%= dayDates && dayDates[day] ? dayDates[day] : '' %>">
            <div class="day-header">
              <div class="day-title">
                <span class="day-name dayTitle"><%= day %></span>
                <% if (dateLabel) { %>
                  <span class="day-date dayDate"><%= dateLabel %></span>
                <% } %>
              </div>
            </div>
            <div class="list-group list-group-flush">
              <% if (!list.length) { %>
                <div class="list-group-item empty-state">Немає пар</div>
              <% } else { %>
                <% list.forEach(function(cls) { %>
                  <% const slot = bellSchedule[cls.class_number] || null; %>
                  <% const timeLabel = slot ? `${slot.start} - ${slot.end}` : `Пара ${cls.class_number}`; %>
                  <% const typeLabel = cls.lesson_type === 'lecture' ? 'Лекція' : cls.lesson_type === 'seminar' ? 'Семінар' : cls.lesson_type === 'lab' ? 'Лаб' : cls.lesson_type === 'practice' ? 'Практика' : (cls.lesson_type || ''); %>
                  <div
                    class="list-group-item schedule-card schedule-card--readonly liquid-card <%= cls.is_mirror ? 'is-mirror' : '' %>"
                    role="article"
                    aria-disabled="true"
                  >
                    <div class="schedule-card-inner">
                      <div class="schedule-main">
                        <div class="schedule-title-row">
                          <div class="schedule-title classSubject"><%= cls.subject_name %></div>
                          <% if (typeLabel) { %>
                            <span class="lesson-pill"><%= typeLabel %></span>
                          <% } %>
                          <% if (cls.is_mirror) { %>
                            <span class="mirror-chip" title="Дзеркало<%= cls.mirror_key ? ': ' + cls.mirror_key : '' %>">A/B</span>
                          <% } %>
                        </div>
                        <div class="schedule-meta classMeta"><%= cls.group_label %> · <%= cls.teacher_name || 'Без викладача' %></div>
                      </div>
                      <div class="schedule-aside">
                        <div class="schedule-time classTime"><%= timeLabel %></div>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </main>

    <div class="modal fade" id="confirmActionModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Confirm action</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id="confirmActionMessage"></div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-warning" id="confirmActionButton">Confirm</button>
          </div>
        </div>
      </div>
    </div>

    <div class="week-rail week-pager" id="weekPager">
      <div class="week-pager-shell">
        <div class="week-pill" id="weekPill" aria-label="<%= t('schedule.week') %> <%= currentWeek %>">
          <div class="week-pill-head week-pill-head--compact">
            <span class="week-pill-kicker"><%= previewWeekCarouselText.kicker %></span>
            <span class="week-pill-count" id="weekPillCount"><%= String(currentWeek).padStart(2, '0') %> / <%= String(totalWeeks || 15).padStart(2, '0') %></span>
          </div>
          <span class="week-pill-progress" aria-hidden="true">
            <span class="week-pill-progress-fill" id="weekPillProgress"></span>
          </span>
          <div class="week-carousel" id="weekCarousel" aria-label="<%= previewWeekCarouselText.aria %>"></div>
        </div>
      </div>
    </div>

    <%- include('partials/app-footer') %>

    <%- include('partials/changelog-modal') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
      const confirmModalEl = document.getElementById('confirmActionModal');
      const confirmModal = confirmModalEl ? new bootstrap.Modal(confirmModalEl) : null;
      const confirmActionMessage = document.getElementById('confirmActionMessage');
      const confirmActionButton = document.getElementById('confirmActionButton');
      let confirmResolve = null;

      const openConfirmModal = (message) =>
        new Promise((resolve) => {
          if (!confirmModal) {
            resolve(window.confirm(message || 'Are you sure?'));
            return;
          }
          confirmResolve = resolve;
          if (confirmActionMessage) confirmActionMessage.textContent = message || '';
          confirmModal.show();
        });

      if (confirmActionButton && confirmModalEl) {
        confirmActionButton.addEventListener('click', () => {
          if (confirmModal) confirmModal.hide();
          if (confirmResolve) confirmResolve(true);
          confirmResolve = null;
        });
        confirmModalEl.addEventListener('hidden.bs.modal', () => {
          if (confirmResolve) confirmResolve(false);
          confirmResolve = null;
        });
      }

      document.addEventListener('click', async (event) => {
        const trigger = event.target.closest('[data-confirm]');
        if (!trigger) return;
        const formId = trigger.getAttribute('form');
        const form = formId ? document.getElementById(formId) : trigger.closest('form');
        if (!form) return;
        event.preventDefault();
        const ok = await openConfirmModal(trigger.dataset.confirm);
        if (ok) form.submit();
      });
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        const persistTheme = (theme) => {
          const normalized = theme === 'light' ? 'light' : 'dark';
          try {
            localStorage.setItem('ui-theme', normalized === 'dark' ? 'theme-dark' : 'theme-light');
            localStorage.setItem('theme', normalized);
          } catch (_error) {
            // Ignore storage failures in private mode.
          }
        };
        const resolveTheme = () => {
          const bootTheme = document.documentElement.getAttribute('data-theme');
          if (bootTheme === 'light' || bootTheme === 'dark') {
            return bootTheme;
          }
          try {
            const uiTheme = localStorage.getItem('ui-theme');
            if (uiTheme === 'theme-light' || uiTheme === 'light') return 'light';
            if (uiTheme === 'theme-dark' || uiTheme === 'dark') return 'dark';
            const legacyTheme = localStorage.getItem('theme');
            if (legacyTheme === 'light' || legacyTheme === 'dark') return legacyTheme;
          } catch (_error) {
            // Ignore storage failures and fallback to dark theme.
          }
          return 'dark';
        };
        const applyTheme = (theme) => {
          const normalized = theme === 'light' ? 'light' : 'dark';
          document.body.classList.toggle('theme-light', normalized === 'light');
          document.body.classList.toggle('theme-dark', normalized === 'dark');
          document.body.setAttribute('data-theme', normalized);
          document.documentElement.setAttribute('data-theme', normalized);
          themeToggle.textContent = normalized === 'light'
            ? themeToggle.dataset.darkLabel
            : themeToggle.dataset.lightLabel;
        };
        const initialTheme = resolveTheme();
        applyTheme(initialTheme);
        persistTheme(initialTheme);
        themeToggle.addEventListener('click', () => {
          const next = document.body.classList.contains('theme-light') ? 'dark' : 'light';
          applyTheme(next);
          persistTheme(next);
        });
      }

      const publishForm = document.getElementById('publishForm');
      if (publishForm) {
        const publishBtn = document.getElementById('publishBtn');
        const confirmCheck = publishForm.querySelector('[data-publish-confirm]');
        const confirmPhrase = publishForm.querySelector('[data-publish-phrase]');
        const hasPreview = publishForm.dataset.hasPreview === '1';
        const requiresTyped = publishForm.dataset.requiresTyped === '1';
        const updatePublishState = () => {
          if (!publishBtn) return;
          if (!hasPreview) {
            publishBtn.disabled = true;
            return;
          }
          const confirmOk = confirmCheck ? confirmCheck.checked : true;
          const typedOk = !requiresTyped || (confirmPhrase && confirmPhrase.value.trim().toUpperCase() === 'PUBLISH');
          publishBtn.disabled = !(confirmOk && typedOk);
        };
        if (confirmCheck) {
          confirmCheck.addEventListener('change', updatePublishState);
        }
        if (confirmPhrase) {
          confirmPhrase.addEventListener('input', updatePublishState);
        }
        updatePublishState();
      }

      const weekPager = document.getElementById('weekPager');
      const weekPill = document.getElementById('weekPill');
      const weekPillCount = document.getElementById('weekPillCount');
      const weekPillProgress = document.getElementById('weekPillProgress');
      const weekCarousel = document.getElementById('weekCarousel');
      const totalWeeks = <%= totalWeeks || 15 %>;
      let currentWeek = <%= currentWeek %>;
      const semesterStartDate = <%- JSON.stringify(semester && semester.start_date ? semester.start_date : null).replace(/</g, '\\u003c') %>;
      const previewLocale = <%- JSON.stringify(localeCode).replace(/</g, '\\u003c') %>;
      const weekLabelText = <%- JSON.stringify(t('schedule.week')).replace(/</g, '\\u003c') %>;
      const weekRangeFallbackText = <%- JSON.stringify(previewWeekCarouselText.fallback).replace(/</g, '\\u003c') %>;
      const kyivWeekFormatter = new Intl.DateTimeFormat(previewLocale, {
        day: 'numeric',
        month: 'short',
        timeZone: 'Europe/Kyiv',
      });

      let isWeekSwitching = false;
      let weekDebounceUntil = 0;
      const weekDebounceMs = 240;

      function clampWeek(value) {
        const parsed = Number(value);
        if (Number.isNaN(parsed)) return 1;
        return Math.max(1, Math.min(totalWeeks, parsed));
      }

      function parseDateUtc(dateStr) {
        if (!dateStr || !/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return null;
        const [y, m, d] = dateStr.split('-').map((n) => Number(n));
        if (!y || !m || !d) return null;
        return Date.UTC(y, m - 1, d);
      }

      function getWeekRange(week) {
        const startUtc = parseDateUtc(semesterStartDate);
        if (startUtc === null) return null;
        const safeWeek = clampWeek(week);
        const start = new Date(startUtc + ((safeWeek - 1) * 7 * 86400000));
        const end = new Date(startUtc + (((safeWeek - 1) * 7) + 6) * 86400000);
        return { start, end };
      }

      function formatWeekRange(week) {
        const range = getWeekRange(week);
        if (!range) return weekRangeFallbackText;
        try {
          if (typeof kyivWeekFormatter.formatRange === 'function') {
            return kyivWeekFormatter.formatRange(range.start, range.end);
          }
        } catch (_error) {
        }
        return `${kyivWeekFormatter.format(range.start)} - ${kyivWeekFormatter.format(range.end)}`;
      }

      function getWeekCarouselOffsets() {
        return window.innerWidth <= 560 ? [-1, 0, 1] : [-2, -1, 0, 1, 2];
      }

      function renderWeekCarousel(activeWeek) {
        if (!weekCarousel) return;
        weekCarousel.textContent = '';
        const fragment = document.createDocumentFragment();
        const offsets = getWeekCarouselOffsets();
        weekCarousel.style.setProperty('--week-carousel-columns', String(offsets.length));
        weekCarousel.dataset.compact = offsets.length <= 3 ? 'true' : 'false';
        weekCarousel.dataset.viewport = window.innerWidth <= 560 ? 'mobile' : 'desktop';
        let activeChip = null;

        offsets.forEach((offset) => {
          const week = activeWeek + offset;
          const distance = Math.abs(offset);
          if (week < 1 || week > totalWeeks) {
            const ghost = document.createElement('span');
            ghost.className = 'week-carousel-card week-carousel-card--ghost';
            ghost.dataset.distance = String(distance);
            ghost.dataset.offset = String(offset);
            ghost.setAttribute('aria-hidden', 'true');
            fragment.appendChild(ghost);
            return;
          }

          const chip = document.createElement('button');
          chip.type = 'button';
          chip.className = 'week-carousel-card';
          chip.dataset.week = String(week);
          chip.dataset.distance = String(distance);
          chip.dataset.offset = String(offset);
          chip.setAttribute('aria-label', `${weekLabelText} ${week}`);
          if (week === activeWeek) {
            chip.classList.add('is-active');
            chip.setAttribute('aria-current', 'page');
            activeChip = chip;
          }
          chip.innerHTML = `
            <span class="week-carousel-card__shine" aria-hidden="true"></span>
            <span class="week-carousel-card__label">${weekLabelText}</span>
            <span class="week-carousel-card__number">${String(week).padStart(2, '0')}</span>
            <span class="week-carousel-card__range">${formatWeekRange(week)}</span>
          `;
          chip.addEventListener('click', () => goToWeek(week));
          fragment.appendChild(chip);
        });

        weekCarousel.appendChild(fragment);
        if (weekCarousel.dataset.viewport === 'mobile' && activeChip && typeof activeChip.scrollIntoView === 'function') {
          window.requestAnimationFrame(() => {
            activeChip.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'auto' });
          });
        }
      }

      function updateSchedule(week) {
        const safe = clampWeek(week);
        const params = new URLSearchParams(window.location.search);
        params.set('week', safe);
        window.location.search = params.toString();
      }

      function syncWeekPager(week) {
        const safe = clampWeek(week);
        const displayWeek = String(safe).padStart(2, '0');
        currentWeek = safe;
        if (weekPillCount) {
          weekPillCount.textContent = `${displayWeek} / ${String(totalWeeks).padStart(2, '0')}`;
        }
        if (weekPillProgress) {
          const ratio = totalWeeks > 0 ? safe / totalWeeks : 1;
          weekPillProgress.style.transform = `scaleX(${ratio})`;
        }
        if (weekPill) weekPill.setAttribute('aria-label', `${weekLabelText} ${safe}`);
        renderWeekCarousel(safe);
      }

      function goToWeek(targetWeek) {
        const safeWeek = clampWeek(targetWeek);
        if (safeWeek === currentWeek || isWeekSwitching) return;

        const now = Date.now();
        if (now < weekDebounceUntil) return;
        weekDebounceUntil = now + weekDebounceMs;
        isWeekSwitching = true;
        if (weekPager) {
          weekPager.dataset.direction = safeWeek > currentWeek ? 'forward' : 'backward';
        }

        syncWeekPager(safeWeek);
        setTimeout(() => {
          isWeekSwitching = false;
          if (weekPager) {
            delete weekPager.dataset.direction;
          }
        }, 260);
        requestAnimationFrame(() => updateSchedule(safeWeek));
      }

      function animateWeekChange(nextWeek) {
        goToWeek(nextWeek);
      }

      const isTypingTarget = (el) => {
        if (!el) return false;
        const tag = el.tagName ? el.tagName.toLowerCase() : '';
        return tag === 'input' || tag === 'textarea' || tag === 'select' || el.isContentEditable;
      };

      if (weekPager) {
        let startX = 0;
        let startY = 0;
        weekPager.addEventListener('touchstart', (event) => {
          startX = event.touches[0].clientX;
          startY = event.touches[0].clientY;
        }, { passive: true });
        weekPager.addEventListener('touchend', (event) => {
          const endX = event.changedTouches[0].clientX;
          const endY = event.changedTouches[0].clientY;
          const deltaX = endX - startX;
          const deltaY = endY - startY;
          if (Math.abs(deltaX) < 42 || Math.abs(deltaX) < Math.abs(deltaY)) return;
          if (deltaX < 0) animateWeekChange(currentWeek + 1);
          if (deltaX > 0) animateWeekChange(currentWeek - 1);
        }, { passive: true });
        syncWeekPager(currentWeek);
      }

      document.addEventListener('keydown', (event) => {
        if (isTypingTarget(event.target)) return;
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          animateWeekChange(currentWeek - 1);
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          animateWeekChange(currentWeek + 1);
        }
      });

      window.addEventListener('resize', () => {
        if (!weekPager) return;
        syncWeekPager(currentWeek);
      });
    </script>
