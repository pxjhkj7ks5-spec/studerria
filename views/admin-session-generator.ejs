        const publishCreditCount = document.getElementById('sessionPublishCreditCount');
        const publishRoomCount = document.getElementById('sessionPublishRoomCount');
        const publishConflictCount = document.getElementById('sessionPublishConflictCount');
        const publishOutOfWindowCount = document.getElementById('sessionPublishOutOfWindowCount');
        const publishJournalStatus = document.getElementById('sessionPublishJournalStatus');
        const publishImpactHint = document.getElementById('sessionPublishImpactHint');
        const deleteWindowBtn = document.getElementById('sessionDeleteWindowBtn');
        const deleteWindowStatus = document.getElementById('sessionDeleteWindowScopeStatus');
        const deleteWindowHint = document.getElementById('sessionDeleteWindowHint');
        const deleteWindowDateCount = document.getElementById('sessionDeleteWindowDateCount');
        const deleteWindowPublishedCount = document.getElementById('sessionDeleteWindowPublishedCount');
