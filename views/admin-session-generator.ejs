    location === 'munich' ? sessionGeneratorText.locationMunich : sessionGeneratorText.locationKyiv;
  const formatSessionGroupLabel = (groupNumber, groupCount) => groupNumber
    ? `${sessionGeneratorText.groupPrefix} ${groupNumber}`
    : (groupCount > 1 ? `${sessionGeneratorText.allGroups} (${groupCount})` : sessionGeneratorText.allSimple);
  const formatSessionSemesterOption = (semester) =>
    `${semester.title || (sessionGeneratorText.semesterPrefix + semester.id)} · ${semester.weeks_count || '—'} ${sessionGeneratorText.weeksShort}`;
  const formatSessionFreeBusyLabel = (freeCount, busyCount) =>
    `${sessionGeneratorText.free} ${freeCount || 0} / ${sessionGeneratorText.busy} ${busyCount || 0}`;
  const sessionGeneratorFormState = form && typeof form === 'object' ? form : {};
  const sessionGeneratorDraftMeta = draftMeta && typeof draftMeta === 'object' ? draftMeta : null;
  const sessionGeneratorSelectedSemesterId = typeof selectedSemesterId !== 'undefined'
    ? selectedSemesterId
    : (sessionGeneratorFormState.semester_id || '');
  const sessionGeneratorExplicitDates = Array.isArray(explicitSessionDates) ? explicitSessionDates : [];
  const sessionGeneratorCleanupPreviewWindow = cleanupPreviewWindow && typeof cleanupPreviewWindow === 'object'
    ? cleanupPreviewWindow
    : {
        targetDatesCount: sessionGeneratorExplicitDates.length,
        publishedEventsCount: 0,
        journalColumnsCount: 0,
        subjectsCount: 0,
      };
  const sessionGeneratorCleanupPreviewAllActive = cleanupPreviewAllActive && typeof cleanupPreviewAllActive === 'object'
    ? cleanupPreviewAllActive
    : {
        targetDatesCount: 0,
        publishedEventsCount: 0,
        journalColumnsCount: 0,
        subjectsCount: 0,
      };
  const sessionGeneratorNavBase = {
    location: activeLocation,
    course_id: sessionGeneratorFormState.course_id || '',
    semester_id: sessionGeneratorSelectedSemesterId || '',
    draft_id: sessionGeneratorDraftMeta && sessionGeneratorDraftMeta.id ? sessionGeneratorDraftMeta.id : '',
    window_mode: sessionGeneratorFormState.window_mode || 'weeks',
    start_date: sessionGeneratorFormState.start_date || '',
    session_days: sessionGeneratorFormState.session_days || '',
    session_weeks_count: sessionGeneratorFormState.session_weeks_count || '',
    session_weeks_set: sessionGeneratorFormState.session_weeks_set || '',
    max_events_per_day: sessionGeneratorFormState.max_events_per_day || '',
    reserve_every: sessionGeneratorFormState.reserve_every || '',
    exam_gap_days: sessionGeneratorFormState.exam_gap_days || '',
    retake_gap_days: sessionGeneratorFormState.retake_gap_days || '',
    retake_window_days: sessionGeneratorFormState.retake_window_days || '',
    include_weekends: sessionGeneratorFormState.include_weekends ? '1' : '0',
    include_consultations: sessionGeneratorFormState.include_consultations ? '1' : '0',
    respect_study_days: sessionGeneratorFormState.respect_study_days ? '1' : '0',
    day_grouping_mode: sessionGeneratorFormState.day_grouping_mode || 'none',
    exam_sequence: sessionGeneratorFormState.exam_sequence || 'exam_only',
    credit_sequence: sessionGeneratorFormState.credit_sequence || 'credit_only',
    strategy: sessionGeneratorFormState.strategy || 'exams_first',
    explicit_dates_json: sessionGeneratorExplicitDates.length ? JSON.stringify(sessionGeneratorExplicitDates) : '',
  };
  const buildSessionGeneratorHref = (overrides = {}) => {
    const params = new URLSearchParams();
    Object.entries({ ...sessionGeneratorNavBase, ...overrides }).forEach(([key, value]) => {
      if (value === undefined || value === null || value === '') return;
      params.set(key, String(value));
    });
    return `/admin/session-generator${params.toString() ? `?${params.toString()}` : ''}`;
  };
