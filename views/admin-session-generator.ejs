    <script>
      (function() {
        const themeToggle = document.getElementById('themeToggle');
        if (themeToggle) {
          const applyTheme = (theme) => {
            document.body.classList.toggle('theme-light', theme === 'light');
            document.body.classList.toggle('theme-dark', theme === 'dark');
            document.body.setAttribute('data-theme', theme);
            document.documentElement.setAttribute('data-theme', theme);
            themeToggle.textContent = theme === 'light'
              ? (themeToggle.dataset.darkLabel || '🌙')
              : (themeToggle.dataset.lightLabel || '☀️');
          };
          const storedTheme = localStorage.getItem('ui-theme');
          const normalizedTheme = storedTheme === 'theme-light' || storedTheme === 'light' ? 'light' : 'dark';
          localStorage.setItem('ui-theme', normalizedTheme === 'dark' ? 'theme-dark' : 'theme-light');
          applyTheme(normalizedTheme);
          themeToggle.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'light' : 'dark';
            localStorage.setItem('ui-theme', next === 'dark' ? 'theme-dark' : 'theme-light');
            applyTheme(next);
          });
        }

        const locationInput = document.getElementById('sessionLocationInput');
        const draftNavLinks = Array.from(document.querySelectorAll('[data-draft-action]'));
        const draftSwitcher = document.querySelector('[data-draft-switch]');
        const form = document.getElementById('sessionGeneratorForm');
        const publishForm = document.querySelector('form[action="/admin/session-generator/publish"]');
        const toggleSessionAdvancedSectionsBtn = document.getElementById('toggleSessionAdvancedSections');
        const sessionAdvancedSections = Array.from(document.querySelectorAll('.session-optional-section'));
        const sessionActionForms = Array.from(document.querySelectorAll('[data-session-action-form]'));
        const sessionActionManualInputs = sessionActionForms
          .map((actionForm) => actionForm.querySelector('[data-manual-assignments-payload]'))
          .filter(Boolean);
        const publishDraftInput = publishForm ? publishForm.querySelector('input[name="draft_id"]') : null;
        const draftIdInput = document.getElementById('sessionDraftIdInput');
        const liveConflictStatus = document.getElementById('manualLiveConflictStatus');
        const manualBlockReasonBox = document.getElementById('manualBlockReasonBox');
        const manualConflictsRecheckBtn = document.getElementById('manualConflictsRecheckBtn');
        const manualAutoConsultationsBtn = document.getElementById('manualAutoConsultationsBtn');
        const slotFilterTeacher = document.getElementById('slotFilterTeacher');
        const slotFilterSubject = document.getElementById('slotFilterSubject');
        const slotFilterGroup = document.getElementById('slotFilterGroup');
        const slotFilterType = document.getElementById('slotFilterType');
        const slotFilterFreeOnly = document.getElementById('slotFilterFreeOnly');
        const slotFiltersResetBtn = document.getElementById('slotFiltersResetBtn');
        const activeAssignmentTypeChip = document.getElementById('activeAssignmentTypeChip');
