        const deleteWindowDraftCount = document.getElementById('sessionDeleteWindowDraftCount');
        const deleteAllBtn = document.getElementById('sessionDeleteAllBtn');
        const deleteAllStatus = document.getElementById('sessionDeleteAllScopeStatus');
