          targetDatesCount: Number(cleanupPreviewAllActiveBase && cleanupPreviewAllActiveBase.targetDatesCount ? cleanupPreviewAllActiveBase.targetDatesCount : 0) || 0,
          publishedEventsCount: Number(cleanupPreviewAllActiveBase && cleanupPreviewAllActiveBase.publishedEventsCount ? cleanupPreviewAllActiveBase.publishedEventsCount : 0) || 0,
          journalColumnsCount: Number(cleanupPreviewAllActiveBase && cleanupPreviewAllActiveBase.journalColumnsCount ? cleanupPreviewAllActiveBase.journalColumnsCount : 0) || 0,
          subjectsCount: Number(cleanupPreviewAllActiveBase && cleanupPreviewAllActiveBase.subjectsCount ? cleanupPreviewAllActiveBase.subjectsCount : 0) || 0,
        };
        const sessionWindowDateSet = new Set((sessionWindowExplicitDates || []).map((date) => String(date || '').slice(0, 10)).filter(Boolean));
        let lastHoveredSlotKey = '';
        let liveConflictRequestToken = 0;
        let saveDraftTimer = null;
        let liveConflictTimer = null;
        let lastSyncedSubjectFilter = '';
        const dragState = {
          active: false,
          pointerId: null,
          mode: 'add',
          visitedSlotKeys: new Set(),
        };

        const escapeHtml = (rawValue) => String(rawValue || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
        const formatRoomLabelById = (roomId) => {
          const normalizedRoomId = Number(roomId || 0);
          if (!Number.isInteger(normalizedRoomId) || normalizedRoomId < 1) {
            return '';
          }
          const room = roomById.get(normalizedRoomId);
          if (!room) {
            return `${sessionGeneratorRoomText.room} #${normalizedRoomId}`;
          }
          return String(room.room_label || room.label || room.code || `${sessionGeneratorRoomText.room} #${normalizedRoomId}`);
        };

        const slotKey = (date, classNumber) => `${String(date || '')}|${Number(classNumber || 0)}`;

        const parseBusyMeta = (button) => {
          if (!button) return [];
          const raw = String(button.dataset.slotBusyMeta || '').trim();
          if (!raw) return [];
          try {
            const decoded = decodeURIComponent(raw);
            const payload = JSON.parse(decoded);
            return Array.isArray(payload) ? payload : [];
          } catch (_err) {
            return [];
          }
        };

        const slotMetaByKey = new Map();
        slotButtons.forEach((button) => {
          const key = slotKey(button.dataset.slotDate, button.dataset.slotClass);
          slotMetaByKey.set(key, {
            button,
            date: String(button.dataset.slotDate || ''),
            class_number: Number(button.dataset.slotClass || 0),
            day_name: String(button.dataset.slotDay || ''),
            week_number: Number(button.dataset.slotWeek || 0) || null,
            busy_rows: parseBusyMeta(button),
          });
        });
        const explicitSessionDates = Array.from(new Set(Array.from(slotMetaByKey.values())
          .map((slot) => String(slot.date || ''))
          .filter(Boolean)))
          .sort();

        const normalizeAssignmentType = (value) => {
          const raw = String(value || '').trim().toLowerCase();
          if (raw === 'credit') return 'credit';
          if (raw === 'consultation' || raw === 'consult' || raw === 'cons') return 'consultation';
          return 'exam';
        };

        const normalizeAssignmentRow = (rawRow) => {
          const row = rawRow || {};
          const subjectId = Number(row.subject_id || 0);
          const subject = manualSubjectMap.get(subjectId);
          if (!subject) return null;
          const classNumber = Number(row.class_number || 0);
          if (!Number.isFinite(classNumber) || classNumber < 1 || classNumber > 7) return null;
          const date = String(row.date || '').slice(0, 10);
          if (!date) return null;
          const groupCount = Math.max(1, Number(subject.group_count || 1));
          const groupNumberRaw = Number(row.group_number || 0);
          const groupNumber = Number.isFinite(groupNumberRaw) && groupNumberRaw > 0
            ? Math.floor(groupNumberRaw)
            : null;
          const roomIdRaw = Number(row.room_id || 0);
          const roomId = Number.isFinite(roomIdRaw) && roomIdRaw > 0
            ? Math.floor(roomIdRaw)
            : null;
          if (groupNumber && groupNumber > groupCount) return null;
          return {
            subject_id: subjectId,
            subject_name: String(subject.name || ''),
            group_number: groupNumber,
            room_id: roomId,
            room_label: formatRoomLabelById(roomId),
            group_label: groupNumber
              ? formatClientGroupLabel(groupNumber, groupCount)
              : formatClientGroupLabel(null, groupCount),
            type: normalizeAssignmentType(row.type),
            date,
            day_name: String(row.day_name || ''),
            class_number: classNumber,
            note: row.note ? String(row.note).slice(0, 255) : '',
          };
        };

        const assignmentKey = (item) => {
          const group = Number(item && item.group_number ? item.group_number : 0);
          return [
            String(item && item.date ? item.date : ''),
            String(item && item.class_number ? item.class_number : ''),
            String(item && item.subject_id ? item.subject_id : ''),
            String(item && item.type ? item.type : ''),
            String(group),
            String(item && item.room_id ? item.room_id : ''),
          ].join('|');
        };

        const sortAssignments = (rows) => [...(rows || [])].sort((a, b) => {
          const typeOrder = { exam: 1, consultation: 2, credit: 3 };
          const byDate = String(a.date || '').localeCompare(String(b.date || ''));
          if (byDate !== 0) return byDate;
          const byClass = Number(a.class_number || 0) - Number(b.class_number || 0);
          if (byClass !== 0) return byClass;
          if (a.type !== b.type) return Number(typeOrder[a.type] || 9) - Number(typeOrder[b.type] || 9);
          const bySubject = String(a.subject_name || '').localeCompare(String(b.subject_name || ''), <%- JSON.stringify(sessionGeneratorLocale) %>);
          if (bySubject !== 0) return bySubject;
          return Number(a.group_number || 0) - Number(b.group_number || 0);
        });

        const dedupeAssignments = (rows) => {
          const seen = new Set();
          const result = [];
          (rows || []).forEach((row) => {
            const normalized = normalizeAssignmentRow(row);
            if (!normalized) return;
            const key = assignmentKey(normalized);
            if (seen.has(key)) return;
            seen.add(key);
            result.push(normalized);
          });
          return result;
        };

        const getAssignmentTeacherIds = (assignment) => {
          const subjectId = String(Number(assignment && assignment.subject_id ? assignment.subject_id : 0));
          const subjectMap = sessionTeacherMapPayload && typeof sessionTeacherMapPayload === 'object'
            ? sessionTeacherMapPayload[subjectId]
            : null;
          if (!subjectMap) return [];
          const allIds = Array.isArray(subjectMap.all) ? subjectMap.all : [];
          const byGroup = subjectMap.by_group && typeof subjectMap.by_group === 'object'
            ? subjectMap.by_group
            : {};
          const groupKey = assignment && assignment.group_number ? String(assignment.group_number) : '';
          const groupIds = groupKey && Array.isArray(byGroup[groupKey]) ? byGroup[groupKey] : [];
          return Array.from(new Set([...(allIds || []), ...(groupIds || [])]
            .map((value) => Number(value))
            .filter((value) => Number.isFinite(value) && value > 0)));
        };

        const formatAssignmentTypeLabel = (type) => type === 'credit'
          ? sessionGeneratorText.credit
          : (type === 'consultation' ? sessionGeneratorText.consultation : sessionGeneratorText.exam);
        const formatAssignmentTypeChipLabel = (type) =>
          String(sessionGeneratorTypeShortLabels[type] || sessionGeneratorTypeShortLabels.exam || '').toUpperCase();
        const resolveAssignmentTone = (type) => type === 'credit'
          ? 'danger'
          : (type === 'consultation' ? 'muted' : 'info');
        const formatIsoDateLabel = (isoDate) => {
          if (!isoDate) return '—';
          const date = new Date(`${isoDate}T00:00:00`);
          if (Number.isNaN(date.getTime())) return isoDate;
          return date.toLocaleDateString(<%- JSON.stringify(sessionGeneratorLocale === 'en' ? 'en-US' : 'uk-UA') %>, {
            day: 'numeric',
            month: 'short',
          });
        };
        const diffClientDays = (left, right) => {
          if (!left || !right) return null;
          const leftDate = new Date(`${left}T00:00:00Z`);
          const rightDate = new Date(`${right}T00:00:00Z`);
          if (Number.isNaN(leftDate.getTime()) || Number.isNaN(rightDate.getTime())) return null;
          return Math.round((leftDate.getTime() - rightDate.getTime()) / (24 * 60 * 60 * 1000));
        };
        const shiftIsoDate = (isoDate, deltaDays) => {
          if (!isoDate) return '';
          const date = new Date(`${isoDate}T00:00:00Z`);
          if (Number.isNaN(date.getTime())) return '';
          date.setUTCDate(date.getUTCDate() + Number(deltaDays || 0));
          return date.toISOString().slice(0, 10);
        };
        const isAssessmentAssignment = (assignment) => String(assignment && assignment.type ? assignment.type : '') !== 'consultation';
        const getAssessmentAssignments = (rows) => (Array.isArray(rows) ? rows : manualAssignments)
          .filter((row) => isAssessmentAssignment(row));
        const getSelectedTimelineGroupNumber = () => {
          const activeGroup = Number(manualGroupSelect && manualGroupSelect.value ? manualGroupSelect.value : 0);
          if (Number.isFinite(activeGroup) && activeGroup > 0) return activeGroup;
          const filteredGroup = Number(slotFilterGroup && slotFilterGroup.value ? slotFilterGroup.value : 0);
          if (Number.isFinite(filteredGroup) && filteredGroup > 0) return filteredGroup;
          return 0;
        };
        const getLoadLevelMeta = (count) => {
          if (count >= 5) return { level: 'high', label: sessionGeneratorText.loadHigh };
          if (count >= 3) return { level: 'medium', label: sessionGeneratorText.loadMedium };
          return { level: 'low', label: sessionGeneratorText.loadLow };
        };
        const setPlannerNotice = (text) => {
          if (!manualBlockReasonBox || !text) return;
          manualBlockReasonBox.textContent = text;
        };
        const getHypotheticalAssessmentRows = (candidate) => {
          if (!candidate || !isAssessmentAssignment(candidate) || !Number(candidate.group_number || 0)) {
            return getAssessmentAssignments();
          }
          const rows = getAssessmentAssignments([...manualAssignments, candidate]);
          const dedup = new Map();
          rows.forEach((row) => {
            dedup.set(assignmentKey(row), row);
          });
          return Array.from(dedup.values());
        };
        const buildWarningsForCandidate = (candidate, rows, slotConflict) => {
          const warnings = [];
          if (slotConflict && Number(slotConflict.conflicts_total || 0) > 0) {
            warnings.push({
              key: 'teacher',
              label: candidate && Number(candidate.room_id || 0) > 0
                ? sessionGeneratorRoomText.roomConflict
                : sessionGeneratorText.warningTeacherConflict,
              detail: String(slotConflict.reason_text || ''),
              tone: 'danger',
            });
          }
          if (!candidate || !isAssessmentAssignment(candidate)) {
            return warnings;
          }
          const groupNumber = Number(candidate.group_number || 0);
          if (!Number.isFinite(groupNumber) || groupNumber < 1) {
            return warnings;
          }
          const pool = Array.isArray(rows) ? rows : getAssessmentAssignments();
          const sameDayCount = pool.filter((row) =>
            Number(row.group_number || 0) === groupNumber && String(row.date || '') === String(candidate.date || '')
          ).length;
          if (sameDayCount > 1) {
            warnings.push({
              key: 'same-day',
              label: sessionGeneratorText.warningSameDayGroup,
              detail: '',
              tone: 'warn',
            });
          }
          const overloadCount = pool.filter((row) => {
            if (Number(row.group_number || 0) !== groupNumber) return false;
            const delta = diffClientDays(String(row.date || ''), String(candidate.date || ''));
            return delta !== null && Math.abs(delta) <= 2;
          }).length;
          if (overloadCount >= 3) {
            warnings.push({
              key: 'overload',
              label: sessionGeneratorText.warningGroupOverload,
              detail: '',
              tone: 'warn',
            });
          }
          return warnings;
        };
        const createWarningStack = (warnings) => {
          if (!warnings.length) return null;
          const uniqueWarnings = [];
          const seen = new Set();
          warnings.forEach((warning) => {
            const key = String(warning && warning.key ? warning.key : warning && warning.label ? warning.label : '');
            if (!key || seen.has(key)) return;
            seen.add(key);
            uniqueWarnings.push(warning);
          });
          const stack = document.createElement('div');
          stack.className = 'slot-warning-stack';
          uniqueWarnings.forEach((warning) => {
            const chip = document.createElement('span');
            chip.className = `slot-warning-chip ${warning.tone === 'warn' ? 'warn' : ''}`.trim();
            chip.textContent = `\u26A0 ${warning.label || ''}`;
            stack.appendChild(chip);
          });
          const detail = uniqueWarnings.find((warning) => warning && warning.detail);
          if (detail) {
            const detailNode = document.createElement('div');
            detailNode.className = 'slot-warning-detail';
            detailNode.textContent = detail.detail;
            stack.appendChild(detailNode);
          }
          return stack;
        };
        const createAssignmentCard = (item) => {
          const card = document.createElement('div');
          card.className = 'slot-assignment-item';
          const subject = document.createElement('div');
          subject.className = 'slot-assignment-subject';
          subject.textContent = item.subject_name || '';
          card.appendChild(subject);
          const meta = document.createElement('div');
          meta.className = 'slot-assignment-meta';
          const typeChip = document.createElement('span');
          typeChip.className = `mark-pill ${resolveAssignmentTone(item.type)}`;
          typeChip.textContent = formatAssignmentTypeChipLabel(item.type);
          meta.appendChild(typeChip);
          const groupBadge = document.createElement('span');
          groupBadge.className = 'group-badge';
          groupBadge.textContent = item.group_label || sessionGeneratorText.allGroups;
          meta.appendChild(groupBadge);
          if (item.room_label) {
            const roomBadge = document.createElement('span');
            roomBadge.className = 'group-badge';
            roomBadge.textContent = item.room_label;
            meta.appendChild(roomBadge);
          }
          card.appendChild(meta);
          return card;
        };
        const createTimelineEmptyState = (message) => {
          const empty = document.createElement('div');
          empty.className = 'timeline-empty';
          empty.textContent = message || '';
          return empty;
        };
        const createGroupTimelineItem = (row, hasShortGap) => {
          const item = document.createElement('div');
          item.className = 'group-timeline-item';
          const date = document.createElement('div');
          date.className = 'group-timeline-date';
          date.textContent = formatIsoDateLabel(row.date || '');
          item.appendChild(date);
          const title = document.createElement('div');
          title.className = 'group-timeline-title';
          title.textContent = row.subject_name || '';
          item.appendChild(title);
          const meta = document.createElement('div');
          meta.className = 'group-timeline-meta';
          const typeChip = document.createElement('span');
          typeChip.className = `mark-pill ${resolveAssignmentTone(row.type)}`;
          typeChip.textContent = formatAssignmentTypeChipLabel(row.type);
          meta.appendChild(typeChip);
          const groupBadge = document.createElement('span');
          groupBadge.className = 'group-badge';
          groupBadge.textContent = row.group_label || sessionGeneratorText.allGroups;
          meta.appendChild(groupBadge);
          if (hasShortGap) {
            const warningChip = document.createElement('span');
            warningChip.className = 'slot-warning-chip warn';
            warningChip.textContent = `\u26A0 ${sessionGeneratorText.warningShortGap}`;
            meta.appendChild(warningChip);
          }
          item.appendChild(meta);
          return item;
        };
        const createSlotAssignmentStack = (slotRows) => {
          const stack = document.createElement('div');
          stack.className = 'slot-assignment-stack';
          slotRows.slice(0, 2).forEach((item) => {
            stack.appendChild(createAssignmentCard(item));
          });
          if (slotRows.length > 2) {
            const more = document.createElement('div');
            more.className = 'small text-muted';
            more.textContent = formatClientMoreLabel(slotRows.length - 2);
            stack.appendChild(more);
          }
          return stack;
        };

        const buildCandidateFromSlot = (button) => {
          if (!button || !manualSubjectSelect) return null;
          const subjectId = Number(manualSubjectSelect.value || 0);
          const subject = manualSubjectMap.get(subjectId);
          if (!subject) return null;
          const classNumber = Number(button.dataset.slotClass || 0);
          const date = String(button.dataset.slotDate || '');
          const dayName = String(button.dataset.slotDay || '');
          if (!classNumber || !date) return null;
          const groupNumber = manualGroupSelect && manualGroupSelect.value
            ? Number(manualGroupSelect.value)
            : null;
          const roomId = manualRoomSelect && manualRoomSelect.value
            ? Number(manualRoomSelect.value)
            : null;
          const normalized = normalizeAssignmentRow({
            subject_id: subjectId,
            subject_name: subject.name,
            group_number: Number.isFinite(groupNumber) && groupNumber > 0 ? groupNumber : null,
            room_id: Number.isFinite(roomId) && roomId > 0 ? roomId : null,
            type: manualSelectedType,
            date,
            day_name: dayName,
            class_number: classNumber,
            note: '',
          });
          return normalized;
        };

        const slotMatchesFilters = (slotKeyValue, slotRows) => {
          const teacherFilter = Number(slotFilterTeacher && slotFilterTeacher.value ? slotFilterTeacher.value : 0);
          const subjectFilter = Number(slotFilterSubject && slotFilterSubject.value ? slotFilterSubject.value : 0);
          const groupFilter = Number(slotFilterGroup && slotFilterGroup.value ? slotFilterGroup.value : 0);
          const typeFilter = String(slotFilterType && slotFilterType.value ? slotFilterType.value : '').trim();
          const hasFilters = !!(teacherFilter || subjectFilter || groupFilter || typeFilter);
          if (!hasFilters) return true;
          const slotMeta = slotMetaByKey.get(slotKeyValue);
          const busyRows = slotMeta && Array.isArray(slotMeta.busy_rows) ? slotMeta.busy_rows : [];
          const subjectMatch = !subjectFilter
            || slotRows.some((row) => Number(row.subject_id || 0) === subjectFilter)
            || busyRows.some((row) => Number(row.subject_id || 0) === subjectFilter);
          const groupMatch = !groupFilter
            || slotRows.some((row) => {
              const rowGroup = Number(row.group_number || 0);
              return !rowGroup || rowGroup === groupFilter;
            })
            || busyRows.some((row) => Number(row.group_number || 0) === groupFilter);
          const typeMatch = !typeFilter
            || slotRows.some((row) => String(row.type || '') === typeFilter);
          const teacherMatch = !teacherFilter
            || slotRows.some((row) => getAssignmentTeacherIds(row).includes(teacherFilter))
            || busyRows.some((row) => Array.isArray(row.teacher_ids) && row.teacher_ids.map(Number).includes(teacherFilter));
          return subjectMatch && groupMatch && typeMatch && teacherMatch;
        };

        const syncManualTypeButtons = () => {
          manualTypeButtons.forEach((button) => {
            const type = String(button.dataset.manualType || '');
            const isActive = type === manualSelectedType;
            button.classList.toggle('active', isActive);
            button.classList.toggle('btn-outline-primary', !isActive && type === 'exam');
            button.classList.toggle('btn-primary', isActive && type === 'exam');
            button.classList.toggle('btn-outline-secondary', !isActive && type === 'consultation');
            button.classList.toggle('btn-secondary', isActive && type === 'consultation');
            button.classList.toggle('btn-outline-danger', !isActive && type === 'credit');
            button.classList.toggle('btn-danger', isActive && type === 'credit');
          });
        };

        const updateManualGroupOptions = () => {
          if (!manualGroupSelect || !manualSubjectSelect) return;
          const subjectId = Number(manualSubjectSelect.value || 0);
          const subject = manualSubjectMap.get(subjectId);
          manualGroupSelect.replaceChildren();
          const allGroupsOption = document.createElement('option');
          allGroupsOption.value = '';
          allGroupsOption.textContent = sessionGeneratorText.allSubjectGroups;
          manualGroupSelect.appendChild(allGroupsOption);
          if (!subject) {
            manualGroupSelect.disabled = true;
            return;
          }
          const groupCount = Math.max(1, Number(subject.group_count || 1));
          for (let index = 1; index <= groupCount; index += 1) {
            const option = document.createElement('option');
            option.value = String(index);
            option.textContent = `${sessionGeneratorText.groupPrefix} ${index}`;
            manualGroupSelect.appendChild(option);
          }
          manualGroupSelect.disabled = false;
        };

        const updateActiveAssignmentBar = () => {
          if (!activeAssignmentTypeChip || !activeAssignmentTitle || !activeAssignmentSubtitle) return;
          const subjectId = Number(manualSubjectSelect && manualSubjectSelect.value ? manualSubjectSelect.value : 0);
          const subject = manualSubjectMap.get(subjectId);
          const subjectLabel = subject && subject.name ? subject.name : sessionGeneratorText.activeSelectionEmpty;
          const groupValue = Number(manualGroupSelect && manualGroupSelect.value ? manualGroupSelect.value : 0);
          const groupLabel = subject
            ? formatClientGroupLabel(groupValue > 0 ? groupValue : null, Math.max(1, Number(subject.group_count || 1)))
            : sessionGeneratorText.allGroups;
          activeAssignmentTypeChip.textContent = formatAssignmentTypeChipLabel(manualSelectedType);
          activeAssignmentTypeChip.className = `mark-pill active-selection-type ${resolveAssignmentTone(manualSelectedType)}`;
          activeAssignmentTitle.textContent = `${formatAssignmentTypeLabel(manualSelectedType)} · ${subjectLabel}`;
          activeAssignmentSubtitle.textContent = `${groupLabel} · ${sessionGeneratorText.activeSelectionShortcuts}`;
        };

        const syncActiveAssignmentRoomMeta = () => {
          if (!activeAssignmentTitle || !activeAssignmentSubtitle) return;
          const subjectId = Number(manualSubjectSelect && manualSubjectSelect.value ? manualSubjectSelect.value : 0);
          const subject = manualSubjectMap.get(subjectId);
          const subjectLabel = subject && subject.name ? subject.name : sessionGeneratorText.activeSelectionEmpty;
          const groupValue = Number(manualGroupSelect && manualGroupSelect.value ? manualGroupSelect.value : 0);
          const roomValue = Number(manualRoomSelect && manualRoomSelect.value ? manualRoomSelect.value : 0);
          const groupLabel = subject
            ? formatClientGroupLabel(groupValue > 0 ? groupValue : null, Math.max(1, Number(subject.group_count || 1)))
            : sessionGeneratorText.allGroups;
          const subtitleParts = [groupLabel];
          const roomLabel = formatRoomLabelById(roomValue);
          if (roomLabel) {
            subtitleParts.push(`${sessionGeneratorRoomText.room}: ${roomLabel}`);
          }
          subtitleParts.push(sessionGeneratorText.activeSelectionShortcuts);
          activeAssignmentTitle.textContent = `${formatAssignmentTypeLabel(manualSelectedType)} | ${subjectLabel}`;
          activeAssignmentSubtitle.textContent = subtitleParts.join(' | ');
        };

        const updateDayLoadIndicators = () => {
          const loadByDate = new Map();
          getAssessmentAssignments().forEach((row) => {
            const date = String(row.date || '');
            if (!date) return;
            loadByDate.set(date, Number(loadByDate.get(date) || 0) + 1);
          });
          document.querySelectorAll('[data-day-load-chip]').forEach((chip) => {
            const date = String(chip.getAttribute('data-day-date') || '');
            const count = Number(loadByDate.get(date) || 0);
            const meta = getLoadLevelMeta(count);
            chip.setAttribute('data-load-level', meta.level);
            chip.textContent = `${meta.label} · ${count}`;
            chip.title = `${count} ${sessionGeneratorText.loadAssessments}`;
          });
        };

        const updateManualMetrics = () => {
          const rows = sortAssignments(getAssessmentAssignments());
          let examCount = 0;
          let consultationCount = 0;
          let creditCount = 0;
          rows.forEach((row) => {
            const type = String(row && row.type ? row.type : 'exam');
            if (type === 'consultation') {
              consultationCount += 1;
            } else if (type === 'credit') {
              creditCount += 1;
            } else {
              examCount += 1;
            }
          });
          if (manualMetricTotal) manualMetricTotal.textContent = String(rows.length);
          if (manualMetricExam) manualMetricExam.textContent = String(examCount);
          if (manualMetricConsultation) manualMetricConsultation.textContent = String(consultationCount);
          if (manualMetricCredit) manualMetricCredit.textContent = String(creditCount);
        };

        const renderGroupTimeline = () => {
          if (!groupTimelineRoot || !groupTimelineLabel) return;
          const groupNumber = getSelectedTimelineGroupNumber();
          if (!Number.isFinite(groupNumber) || groupNumber < 1) {
            groupTimelineLabel.textContent = sessionGeneratorText.groupTimelineHint;
            groupTimelineRoot.replaceChildren(createTimelineEmptyState(sessionGeneratorText.groupTimelineHint));
            return;
          }
          groupTimelineLabel.textContent = `${sessionGeneratorText.groupPrefix} ${groupNumber}`;
          const rows = sortAssignments(getAssessmentAssignments().filter((row) => {
            const rowGroup = Number(row.group_number || 0);
            return rowGroup === 0 || rowGroup === groupNumber;
          }));
          if (!rows.length) {
            groupTimelineRoot.replaceChildren(createTimelineEmptyState(sessionGeneratorText.groupTimelineEmpty));
            return;
          }
          const fragment = document.createDocumentFragment();
          rows.forEach((row, index) => {
            const previous = index > 0 ? rows[index - 1] : null;
            const gap = previous ? diffClientDays(String(row.date || ''), String(previous.date || '')) : null;
            const hasShortGap = gap !== null && gap < 2;
            fragment.appendChild(createGroupTimelineItem(row, hasShortGap));
          });
          groupTimelineRoot.replaceChildren(fragment);
        };

        const updateBlockReasonMessage = (button) => {
          if (!manualBlockReasonBox) return;
          if (!button) {
            manualBlockReasonBox.textContent = sessionGeneratorText.blockReasonNeedSelection;
            return;
          }
          const candidate = buildCandidateFromSlot(button);
          if (!candidate) {
            manualBlockReasonBox.textContent = sessionGeneratorText.blockReasonNeedSubjectGroup;
            return;
          }
          const currentSlotKey = slotKey(candidate.date, candidate.class_number);
          const reasons = [];
          const exactAssignmentExists = manualAssignments.some((row) => assignmentKey(row) === assignmentKey(candidate));
          if (exactAssignmentExists) {
            reasons.push(sessionGeneratorText.blockReasonDuplicate);
          }
          const slotMeta = slotMetaByKey.get(currentSlotKey);
          const busyRows = slotMeta && Array.isArray(slotMeta.busy_rows) ? slotMeta.busy_rows : [];
          if (busyRows.length) {
            reasons.push(sessionGeneratorText.blockReasonBusy);
          }
          const slotConflict = liveConflictState && liveConflictState.slot_conflicts
            ? liveConflictState.slot_conflicts[currentSlotKey]
            : null;
          if (slotConflict && slotConflict.reason_text) {
            reasons.push(`${sessionGeneratorText.teacherConflictPrefix} ${slotConflict.reason_text}`);
            reasons[reasons.length - 1] = slotConflict.reason_text;
          }
          const hypotheticalRows = getHypotheticalAssessmentRows(candidate);
          const candidateWarnings = buildWarningsForCandidate(candidate, hypotheticalRows, slotConflict);
          candidateWarnings.forEach((warning) => {
            reasons.push(warning.detail ? `${warning.label}: ${warning.detail}` : warning.label);
          });
          if (explicitSessionDates.length && !explicitSessionDates.includes(candidate.date)) {
            reasons.push(sessionGeneratorText.blockReasonOutOfWindow);
          }
          if (!reasons.length) {
            reasons.push(sessionGeneratorText.blockReasonSuitable);
          }
          manualBlockReasonBox.textContent = reasons.join(' ');
        };

        const renderSlotAssignments = () => {
          slotButtons.forEach((button) => {
            const date = String(button.dataset.slotDate || '');
            const classNumber = Number(button.dataset.slotClass || 0);
            const currentSlotKey = slotKey(date, classNumber);
            const slotRows = sortAssignments(manualAssignments.filter((item) =>
              String(item.date || '') === date && Number(item.class_number || 0) === classNumber
            ));
            const holder = button.querySelector('[data-slot-assignment]');
            const conflictHolder = button.querySelector('[data-slot-conflict]');
            const matchesFilters = slotMatchesFilters(currentSlotKey, slotRows);
            button.classList.toggle('is-filter-hidden', !matchesFilters);
            button.classList.remove('is-conflict');
            button.classList.remove('is-recommended');
            button.classList.remove('is-dimmed-occupied');
            button.classList.remove('is-free-highlight');
            const showOnlyFree = !!(slotFilterFreeOnly && slotFilterFreeOnly.checked);
            const slotIsFree = button.classList.contains('is-free');
            if (showOnlyFree) {
              button.classList.toggle('is-dimmed-occupied', !slotIsFree);
              button.classList.toggle('is-free-highlight', slotIsFree);
            }
            if (!holder) return;
            if (!slotRows.length) {
              holder.replaceChildren();
              button.classList.remove('is-assigned');
            } else {
              button.classList.add('is-assigned');
              holder.replaceChildren(createSlotAssignmentStack(slotRows));
            }
            const slotConflict = liveConflictState && liveConflictState.slot_conflicts
              ? liveConflictState.slot_conflicts[currentSlotKey]
              : null;
            const slotWarnings = [];
            slotRows.forEach((row) => {
              slotWarnings.push(...buildWarningsForCandidate(row, getAssessmentAssignments(), slotConflict));
            });
            if (conflictHolder) {
              const warningStack = createWarningStack(slotWarnings);
              conflictHolder.replaceChildren(...(warningStack ? [warningStack] : []));
            }
            button.classList.toggle('is-conflict', slotWarnings.length > 0);
            const hasSubjectSelection = Number(manualSubjectSelect && manualSubjectSelect.value ? manualSubjectSelect.value : 0) > 0;
            if (hasSubjectSelection && slotIsFree && !slotWarnings.length && matchesFilters) {
              button.classList.add('is-recommended');
            }
          });
        };

        const renderPlannerSurface = () => {
          updateActiveAssignmentBar();
          syncActiveAssignmentRoomMeta();
          updateManualMetrics();
          updateDayLoadIndicators();
          renderSlotAssignments();
          renderGroupTimeline();
        };

        const updatePublishImpactSummary = (rows) => {
          const normalizedRows = Array.isArray(rows) ? rows : [];
          const subjectIds = new Set();
          const groupKeys = new Set();
          const roomIds = new Set();
          let examCount = 0;
          let consultationCount = 0;
          let creditCount = 0;

          normalizedRows.forEach((row) => {
            const subjectId = Number(row && row.subject_id ? row.subject_id : 0);
            if (subjectId > 0) {
              subjectIds.add(subjectId);
              groupKeys.add(`${subjectId}|${Number(row && row.group_number ? row.group_number : 0) || 'all'}`);
            }
            const roomId = Number(row && row.room_id ? row.room_id : 0);
            if (roomId > 0) {
              roomIds.add(roomId);
            }
            const type = String(row && row.type ? row.type : 'exam');
            if (type === 'consultation') {
              consultationCount += 1;
            } else if (type === 'credit') {
              creditCount += 1;
            } else {
              examCount += 1;
            }
          });

          const conflictTotal = Number(liveConflictState && liveConflictState.conflicts_total ? liveConflictState.conflicts_total : 0);
          const outOfWindowTotal = Number(liveConflictState && liveConflictState.out_of_window_total ? liveConflictState.out_of_window_total : 0);
          const journalStatus = !normalizedRows.length
            ? sessionGeneratorText.publishImpactJournalIdle
            : (conflictTotal || outOfWindowTotal
              ? sessionGeneratorText.publishImpactJournalReview
              : sessionGeneratorText.publishImpactJournalReady);
          let hintText = sessionGeneratorText.publishImpactHint;
          if (normalizedRows.length && (conflictTotal || outOfWindowTotal)) {
            hintText = liveConflictState && liveConflictState.summary
              ? String(liveConflictState.summary)
              : sessionGeneratorText.publishHint;
          } else if (!normalizedRows.length) {
            hintText = sessionGeneratorText.publishSourceEmpty;
          }

          if (publishSubjectCount) publishSubjectCount.textContent = String(subjectIds.size);
          if (publishGroupCount) publishGroupCount.textContent = String(groupKeys.size);
          if (publishExamCount) publishExamCount.textContent = String(examCount);
          if (publishConsultationCount) publishConsultationCount.textContent = String(consultationCount);
          if (publishCreditCount) publishCreditCount.textContent = String(creditCount);
          if (publishRoomCount) publishRoomCount.textContent = String(roomIds.size);
          if (publishConflictCount) publishConflictCount.textContent = String(conflictTotal);
          if (publishOutOfWindowCount) publishOutOfWindowCount.textContent = String(outOfWindowTotal);
          if (publishJournalStatus) publishJournalStatus.textContent = journalStatus;
          if (publishImpactHint) publishImpactHint.textContent = hintText;
        };

        const setCleanupStatusPill = (element, variant) => {
          if (!element) return;
          element.classList.remove('muted', 'info', 'warn', 'danger');
          element.classList.add(variant || 'muted');
        };

        const updateCleanupSummary = ({ preview, draftCount, scope, elements }) => {
          if (!elements) return;
          const targetDatesCount = Number(preview && preview.targetDatesCount ? preview.targetDatesCount : 0) || 0;
          const publishedEventsCount = Number(preview && preview.publishedEventsCount ? preview.publishedEventsCount : 0) || 0;
          const journalColumnsCount = Number(preview && preview.journalColumnsCount ? preview.journalColumnsCount : 0) || 0;
          const subjectsCount = Number(preview && preview.subjectsCount ? preview.subjectsCount : 0) || 0;
          const normalizedDraftCount = Number(draftCount || 0) || 0;
          const hasPublishedCleanup = publishedEventsCount > 0 || journalColumnsCount > 0;
          const hasDraftCleanup = normalizedDraftCount > 0;
          let statusText = sessionGeneratorText.cleanupScopeEmpty;
          let hintText = scope === 'window'
            ? sessionGeneratorText.cleanupWindowHintIdle
            : sessionGeneratorText.cleanupAllHintIdle;
          let pillVariant = 'muted';

          if (hasPublishedCleanup && hasDraftCleanup) {
            statusText = sessionGeneratorText.cleanupScopeMixed;
            hintText = scope === 'window'
              ? sessionGeneratorText.cleanupWindowHintMixed
              : sessionGeneratorText.cleanupAllHintMixed;
            pillVariant = 'danger';
          } else if (hasPublishedCleanup) {
            statusText = sessionGeneratorText.cleanupScopePublishedOnly;
            hintText = scope === 'window'
              ? sessionGeneratorText.cleanupWindowHintPublishedOnly
              : sessionGeneratorText.cleanupAllHintPublishedOnly;
            pillVariant = 'warn';
          } else if (hasDraftCleanup) {
            statusText = sessionGeneratorText.cleanupScopeDraftOnly;
            hintText = scope === 'window'
              ? sessionGeneratorText.cleanupWindowHintDraftOnly
              : sessionGeneratorText.cleanupAllHintDraftOnly;
            pillVariant = 'info';
          }

          if (elements.dateCount) elements.dateCount.textContent = String(targetDatesCount);
          if (elements.publishedCount) elements.publishedCount.textContent = String(publishedEventsCount);
          if (elements.journalCount) elements.journalCount.textContent = String(journalColumnsCount);
          if (elements.subjectCount) elements.subjectCount.textContent = String(subjectsCount);
          if (elements.draftCount) elements.draftCount.textContent = String(normalizedDraftCount);
          if (elements.status) {
            elements.status.textContent = statusText;
            setCleanupStatusPill(elements.status, pillVariant);
          }
          if (elements.hint) {
            elements.hint.textContent = hintText;
          }
          if (elements.button) {
            elements.button.disabled = !hasPublishedCleanup && !hasDraftCleanup;
          }
        };

        const serializeManualAssignments = (rows) => rows.map((row) => ({
          subject_id: Number(row.subject_id || 0),
          type: row.type === 'credit' ? 'credit' : (row.type === 'consultation' ? 'consultation' : 'exam'),
          date: row.date || '',
          class_number: Number(row.class_number || 0),
          group_number: row.group_number ? Number(row.group_number) : null,
          room_id: row.room_id ? Number(row.room_id) : null,
          note: row.note || '',
        }));

        const syncCleanupState = (rows) => {
          const normalizedRows = Array.isArray(rows) ? rows : [];
          const selectedWindowDraftCount = normalizedRows.filter((row) =>
            row && row.date && sessionWindowDateSet.has(String(row.date).slice(0, 10))
          ).length;
          updateCleanupSummary({
            preview: cleanupPreviewWindow,
            draftCount: selectedWindowDraftCount,
            scope: 'window',
            elements: {
              button: deleteWindowBtn,
              status: deleteWindowStatus,
              hint: deleteWindowHint,
              dateCount: deleteWindowDateCount,
              publishedCount: deleteWindowPublishedCount,
              journalCount: deleteWindowJournalCount,
              subjectCount: deleteWindowSubjectCount,
              draftCount: deleteWindowDraftCount,
            },
          });
          updateCleanupSummary({
            preview: cleanupPreviewAllActive,
            draftCount: normalizedRows.length,
            scope: 'all',
            elements: {
              button: deleteAllBtn,
              status: deleteAllStatus,
              hint: deleteAllHint,
              publishedCount: deleteAllPublishedCount,
              journalCount: deleteAllJournalCount,
              subjectCount: deleteAllSubjectCount,
              draftCount: deleteAllDraftCount,
            },
          });
        };

        const syncPublishState = () => {
          if (!publishBtn || !manualAssignmentsInput) return;
          const rows = sortAssignments(manualAssignments);
          const serializedRows = rows.length ? JSON.stringify(serializeManualAssignments(rows)) : '';
          publishBtn.disabled = rows.length === 0;
          if (checkConflictsBtn) {
            checkConflictsBtn.disabled = rows.length === 0;
          }
          manualAssignmentsInput.value = serializedRows;
          sessionActionManualInputs.forEach((input) => {
            input.value = serializedRows;
          });
          if (publishSourceHint) {
            publishSourceHint.textContent = rows.length
              ? sessionGeneratorText.publishSourceManual
              : sessionGeneratorText.publishSourceEmpty;
          }
          if (publishCount) {
            publishCount.textContent = String(rows.length);
          }
          updatePublishImpactSummary(rows);
          syncCleanupState(rows);
        };

        const setLiveConflictStatusText = (text, mode) => {
          if (!liveConflictStatus) return;
          liveConflictStatus.textContent = text || sessionGeneratorText.liveConflictNoData;
          liveConflictStatus.classList.remove('live-conflict-ok', 'live-conflict-err');
          if (mode === 'ok') liveConflictStatus.classList.add('live-conflict-ok');
          if (mode === 'err') liveConflictStatus.classList.add('live-conflict-err');
        };

        const getDraftPayloadFromForm = () => {
          const payload = {};
          if (!publishForm) return payload;
          [
            'window_mode',
            'start_date',
            'session_days',
            'session_weeks_count',
            'session_weeks_set',
            'max_events_per_day',
            'reserve_every',
            'exam_gap_days',
            'retake_gap_days',
            'retake_window_days',
            'include_weekends',
            'include_consultations',
            'respect_study_days',
            'day_grouping_mode',
            'exam_sequence',
            'credit_sequence',
            'strategy',
          ].forEach((key) => {
            const input = publishForm.querySelector(`input[name="${key}"]`);
            if (!input) return;
            payload[key] = input.value;
          });
          return payload;
        };

        const persistDraftSoon = () => {
          if (!publishForm) return;
          if (saveDraftTimer) {
            window.clearTimeout(saveDraftTimer);
          }
          saveDraftTimer = window.setTimeout(async () => {
            saveDraftTimer = null;
            const courseIdInput = publishForm.querySelector('input[name="course_id"]');
            const semesterIdInput = publishForm.querySelector('input[name="semester_id"]');
            const locationInputLocal = publishForm.querySelector('input[name="location"]');
            const payload = {
              draft_id: draftIdInput && draftIdInput.value ? Number(draftIdInput.value) : null,
              location: locationInputLocal ? locationInputLocal.value : 'kyiv',
              course_id: courseIdInput ? Number(courseIdInput.value || 0) : null,
              semester_id: semesterIdInput ? Number(semesterIdInput.value || 0) : null,
              manual_assignments_json: sortAssignments(manualAssignments),
              form_json: getDraftPayloadFromForm(),
            };
            try {
              const response = await fetch('/admin/session-generator/draft/save', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-Requested-With': 'XMLHttpRequest',
                },
                body: JSON.stringify(payload),
              });
              if (!response.ok) return;
              const data = await response.json();
              if (!data || !data.ok) return;
              if (data.draft_id) {
                const nextId = String(data.draft_id);
                if (draftIdInput) draftIdInput.value = nextId;
                if (publishDraftInput) publishDraftInput.value = nextId;
                sessionActionForms.forEach((actionForm) => {
                  const draftInput = actionForm.querySelector('input[name="draft_id"]');
                  if (draftInput) draftInput.value = nextId;
                });
              }
            } catch (_err) {
              // Silent autosave failure.
            }
          }, 450);
        };

        const runLiveConflictCheck = async (force = false) => {
          const rows = sortAssignments(manualAssignments);
          if (!rows.length) {
            liveConflictState = {
              conflicts_total: 0,
              unresolved_total: 0,
              out_of_window_total: 0,
              summary: '',
              slot_conflicts: {},
            };
            setLiveConflictStatusText(sessionGeneratorText.liveConflictEmpty, 'ok');
            updatePublishImpactSummary(rows);
            renderPlannerSurface();
            if (force) {
              updateBlockReasonMessage(lastHoveredSlotKey && slotMetaByKey.get(lastHoveredSlotKey)
                ? slotMetaByKey.get(lastHoveredSlotKey).button
                : null);
            }
            return;
          }
          const myToken = ++liveConflictRequestToken;
          const courseIdInput = publishForm ? publishForm.querySelector('input[name="course_id"]') : null;
          const semesterIdInput = publishForm ? publishForm.querySelector('input[name="semester_id"]') : null;
          const payload = {
            course_id: courseIdInput ? Number(courseIdInput.value || 0) : null,
            semester_id: semesterIdInput ? Number(semesterIdInput.value || 0) : null,
            manual_assignments_json: rows,
            explicit_dates_json: explicitSessionDates,
          };
          try {
            const response = await fetch('/admin/session-generator/conflicts/live', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
              },
              body: JSON.stringify(payload),
            });
            if (!response.ok) {
              throw new Error('live_conflict_request_failed');
            }
            const data = await response.json();
            if (myToken !== liveConflictRequestToken) return;
            if (!data || !data.ok) {
              throw new Error('live_conflict_payload_invalid');
            }
            liveConflictState = {
              conflicts_total: Number(data.conflicts_total || 0),
              unresolved_total: Number(data.unresolved_total || 0),
              out_of_window_total: Number(data.out_of_window_total || 0),
              summary: String(data.summary || ''),
              slot_conflicts: data.slot_conflicts && typeof data.slot_conflicts === 'object'
                ? data.slot_conflicts
                : {},
            };
            if (!liveConflictState.conflicts_total && !liveConflictState.out_of_window_total) {
              setLiveConflictStatusText(
                formatLiveConflictNotFound(Number(data.checked_rows || 0)),
                'ok'
              );
            } else {
              const base = liveConflictState.summary || formatLiveConflictBase(liveConflictState.conflicts_total);
              const outOfWindowPart = liveConflictState.out_of_window_total
                ? formatLiveConflictOutOfWindow(liveConflictState.out_of_window_total)
                : '';
              setLiveConflictStatusText(`${base}${outOfWindowPart}`.trim(), 'err');
            }
          } catch (_err) {
            if (myToken !== liveConflictRequestToken) return;
            setLiveConflictStatusText(sessionGeneratorText.liveConflictUpdateFailed, 'err');
          }
          updatePublishImpactSummary(rows);
          renderPlannerSurface();
          if (force) {
            updateBlockReasonMessage(lastHoveredSlotKey && slotMetaByKey.get(lastHoveredSlotKey)
              ? slotMetaByKey.get(lastHoveredSlotKey).button
              : null);
          }
        };

        const runLiveConflictCheckSoon = () => {
          if (liveConflictTimer) {
            window.clearTimeout(liveConflictTimer);
          }
          liveConflictTimer = window.setTimeout(() => {
            liveConflictTimer = null;
            runLiveConflictCheck();
          }, 260);
        };

        const toggleManualAssignmentFromSlot = (button, explicitMode) => {
          const candidate = buildCandidateFromSlot(button);
          if (!candidate) {
            window.alert(sessionGeneratorText.chooseSubjectAlert);
            return false;
          }
          const key = assignmentKey(candidate);
          const existingIndex = manualAssignments.findIndex((item) => assignmentKey(item) === key);
          const mode = explicitMode || (existingIndex >= 0 ? 'remove' : 'add');
          if (mode === 'remove') {
            if (existingIndex < 0) return false;
            manualAssignments.splice(existingIndex, 1);
          } else {
            if (existingIndex >= 0) return false;
            manualAssignments.push(candidate);
          }
          manualAssignments = dedupeAssignments(manualAssignments);
          renderPlannerSurface();
          syncPublishState();
          persistDraftSoon();
          runLiveConflictCheckSoon();
          updateBlockReasonMessage(button);
          return true;
        };

        const activateDragMode = (button, pointerId) => {
          const candidate = buildCandidateFromSlot(button);
          if (!candidate) return false;
          const exists = manualAssignments.some((item) => assignmentKey(item) === assignmentKey(candidate));
          dragState.active = true;
          dragState.pointerId = pointerId;
          dragState.mode = exists ? 'remove' : 'add';
          dragState.visitedSlotKeys = new Set();
          document.body.classList.add('session-dragging');
          return true;
        };

        const applyDragToSlot = (button) => {
          if (!dragState.active || !button) return;
          const currentKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
          if (!currentKey || dragState.visitedSlotKeys.has(currentKey)) return;
          dragState.visitedSlotKeys.add(currentKey);
          const changed = toggleManualAssignmentFromSlot(button, dragState.mode);
          if (changed) {
            button.classList.add('is-drag-target');
          }
        };

        const stopDragMode = () => {
          if (!dragState.active) return;
          dragState.active = false;
          dragState.pointerId = null;
          dragState.visitedSlotKeys = new Set();
          document.body.classList.remove('session-dragging');
          slotButtons.forEach((button) => button.classList.remove('is-drag-target'));
        };

        const removeAssignmentsAtSlot = (slotKeyValue) => {
          if (!slotKeyValue) return false;
          const slotMeta = slotMetaByKey.get(slotKeyValue);
          if (!slotMeta || !slotMeta.button) return false;
          const candidate = buildCandidateFromSlot(slotMeta.button);
          const beforeCount = manualAssignments.length;
          if (candidate) {
            const candidateKey = assignmentKey(candidate);
            manualAssignments = manualAssignments.filter((item) => assignmentKey(item) !== candidateKey);
          }
          if (manualAssignments.length === beforeCount) {
            manualAssignments = manualAssignments.filter((item) => slotKey(item.date, item.class_number) !== slotKeyValue);
          }
          if (manualAssignments.length === beforeCount) {
            return false;
          }
          manualAssignments = dedupeAssignments(manualAssignments);
          renderPlannerSurface();
          syncPublishState();
          persistDraftSoon();
          runLiveConflictCheckSoon();
          updateBlockReasonMessage(slotMeta.button);
          return true;
        };

        const autoAddConsultationsFromDraft = () => {
          const examRows = sortAssignments(manualAssignments.filter((row) => String(row.type || '') === 'exam'));
          if (!examRows.length) {
            setPlannerNotice(sessionGeneratorText.autoConsultationsEmpty);
            return;
          }
          const nextAssignments = [...manualAssignments];
          const existingKeys = new Set(nextAssignments.map((row) => assignmentKey(row)));
          let added = 0;
          let skipped = 0;
          examRows.forEach((examRow) => {
            const consultationDate = shiftIsoDate(examRow.date, -1);
            const consultationSlotKey = slotKey(consultationDate, examRow.class_number);
            const consultationSlotMeta = slotMetaByKey.get(consultationSlotKey);
            if (!consultationSlotMeta) {
              skipped += 1;
              return;
            }
            const consultationRow = normalizeAssignmentRow({
              ...examRow,
              type: 'consultation',
              date: consultationDate,
              day_name: consultationSlotMeta.day_name || examRow.day_name || '',
            });
            if (!consultationRow) {
              skipped += 1;
              return;
            }
            const consultationKey = assignmentKey(consultationRow);
            if (existingKeys.has(consultationKey)) {
              skipped += 1;
              return;
            }
            existingKeys.add(consultationKey);
            nextAssignments.push(consultationRow);
            added += 1;
          });
          if (!added && !skipped) {
            setPlannerNotice(sessionGeneratorText.autoConsultationsEmpty);
            return;
          }
          manualAssignments = dedupeAssignments(nextAssignments);
          renderPlannerSurface();
          syncPublishState();
          persistDraftSoon();
          runLiveConflictCheckSoon();
          setPlannerNotice(
            String(sessionGeneratorText.autoConsultationsDone || '')
              .replace('%ADDED%', String(added))
              .replace('%SKIPPED%', String(skipped))
          );
        };

        const canHandlePlannerShortcut = (event) => {
          if (!event || event.defaultPrevented || event.metaKey || event.ctrlKey || event.altKey) return false;
          const target = event.target;
          if (!(target instanceof HTMLElement)) return true;
          if (target.isContentEditable) return false;
          const tagName = String(target.tagName || '').toLowerCase();
          return !['input', 'textarea', 'select'].includes(tagName);
        };

        manualTypeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const type = String(button.dataset.manualType || '').trim();
            manualSelectedType = type === 'credit'
              ? 'credit'
              : (type === 'consultation' ? 'consultation' : 'exam');
            syncManualTypeButtons();
            renderPlannerSurface();
          });
        });
        if (manualSubjectSelect) {
          manualSubjectSelect.addEventListener('change', () => {
            updateManualGroupOptions();
            if (slotFilterSubject) {
              const selectedSubject = String(manualSubjectSelect.value || '').trim();
              const currentFilter = String(slotFilterSubject.value || '').trim();
              if (!currentFilter || currentFilter === lastSyncedSubjectFilter) {
                slotFilterSubject.value = selectedSubject;
                lastSyncedSubjectFilter = selectedSubject;
              }
            }
            renderPlannerSurface();
          });
        }
        if (manualGroupSelect) {
          manualGroupSelect.addEventListener('change', () => {
            const selectedGroup = String(manualGroupSelect.value || '').trim();
            if (slotFilterGroup && selectedGroup && !String(slotFilterGroup.value || '').trim()) {
              slotFilterGroup.value = selectedGroup;
            }
            renderPlannerSurface();
          });
        }
        if (manualRoomSelect) {
          manualRoomSelect.addEventListener('change', () => {
            renderPlannerSurface();
            updateBlockReasonMessage(lastHoveredSlotKey && slotMetaByKey.get(lastHoveredSlotKey)
              ? slotMetaByKey.get(lastHoveredSlotKey).button
              : null);
          });
        }
        if (manualPlanClearBtn) {
          manualPlanClearBtn.addEventListener('click', () => {
            manualAssignments = [];
            renderPlannerSurface();
            syncPublishState();
            persistDraftSoon();
            runLiveConflictCheckSoon();
          });
        }
        if (manualAutoConsultationsBtn) {
          manualAutoConsultationsBtn.addEventListener('click', () => {
            autoAddConsultationsFromDraft();
          });
        }
        if (manualConflictsRecheckBtn) {
          manualConflictsRecheckBtn.addEventListener('click', () => {
            runLiveConflictCheck(true);
          });
        }
        [slotFilterTeacher, slotFilterSubject, slotFilterGroup, slotFilterType, slotFilterFreeOnly].forEach((filterSelect) => {
          if (!filterSelect) return;
          filterSelect.addEventListener('change', () => {
            if (filterSelect === slotFilterSubject) {
              lastSyncedSubjectFilter = String(slotFilterSubject && slotFilterSubject.value ? slotFilterSubject.value : '').trim();
            }
            renderPlannerSurface();
          });
        });
        if (slotFiltersResetBtn) {
          slotFiltersResetBtn.addEventListener('click', () => {
            if (slotFilterTeacher) slotFilterTeacher.value = '';
            if (slotFilterSubject) slotFilterSubject.value = '';
            if (slotFilterGroup) slotFilterGroup.value = '';
            if (slotFilterType) slotFilterType.value = '';
            if (slotFilterFreeOnly) slotFilterFreeOnly.checked = false;
            lastSyncedSubjectFilter = '';
            renderPlannerSurface();
          });
        }
        const resetRoomForm = () => {
          if (sessionRoomIdInput) sessionRoomIdInput.value = '';
          if (sessionRoomBuildingInput) sessionRoomBuildingInput.value = '';
          if (sessionRoomCodeInput) sessionRoomCodeInput.value = '';
          if (sessionRoomLabelInput) sessionRoomLabelInput.value = '';
          if (sessionRoomTypeInput) sessionRoomTypeInput.value = 'classroom';
          if (sessionRoomCapacityInput) sessionRoomCapacityInput.value = '';
          if (sessionRoomNotesInput) sessionRoomNotesInput.value = '';
          if (sessionRoomActiveInput) sessionRoomActiveInput.value = '1';
        };
        const populateRoomFormFromButton = (button) => {
          if (!button) return;
          if (sessionRoomIdInput) sessionRoomIdInput.value = String(button.dataset.roomId || '');
          if (sessionRoomBuildingInput) sessionRoomBuildingInput.value = String(button.dataset.roomBuilding || '');
          if (sessionRoomCodeInput) sessionRoomCodeInput.value = String(button.dataset.roomCode || '');
          if (sessionRoomLabelInput) sessionRoomLabelInput.value = String(button.dataset.roomLabel || '');
          if (sessionRoomTypeInput) sessionRoomTypeInput.value = String(button.dataset.roomType || 'classroom');
          if (sessionRoomCapacityInput) sessionRoomCapacityInput.value = String(button.dataset.roomCapacity || '');
          if (sessionRoomNotesInput) sessionRoomNotesInput.value = String(button.dataset.roomNotes || '');
          if (sessionRoomActiveInput) sessionRoomActiveInput.value = String(button.dataset.roomActive || '1');
          if (sessionRoomLabelInput) {
            sessionRoomLabelInput.focus();
            sessionRoomLabelInput.select();
          }
          if (sessionRoomForm) {
            sessionRoomForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        };
        if (sessionRoomResetBtn) {
          sessionRoomResetBtn.addEventListener('click', () => {
            resetRoomForm();
          });
        }
        roomEditButtons.forEach((button) => {
          button.addEventListener('click', () => {
            populateRoomFormFromButton(button);
          });
        });

        slotButtons.forEach((button) => {
          button.addEventListener('pointerdown', (event) => {
            if (event.button !== 0) return;
            const started = activateDragMode(button, event.pointerId);
            if (!started) return;
            applyDragToSlot(button);
            lastHoveredSlotKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
            updateBlockReasonMessage(button);
            event.preventDefault();
          });
          button.addEventListener('pointerenter', (event) => {
            if (!dragState.active) return;
            if (dragState.pointerId !== null && dragState.pointerId !== event.pointerId) return;
            applyDragToSlot(button);
            lastHoveredSlotKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
            updateBlockReasonMessage(button);
          });
          button.addEventListener('mouseenter', () => {
            lastHoveredSlotKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
            updateBlockReasonMessage(button);
          });
          button.addEventListener('focus', () => {
            lastHoveredSlotKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
            updateBlockReasonMessage(button);
          });
          button.addEventListener('click', (event) => {
            if (dragState.active) {
              event.preventDefault();
            }
          });
        });
        window.addEventListener('pointermove', (event) => {
          if (!dragState.active) return;
          if (dragState.pointerId !== null && dragState.pointerId !== event.pointerId) return;
          const hovered = document.elementFromPoint(event.clientX, event.clientY);
          const button = hovered instanceof Element ? hovered.closest('[data-slot-btn]') : null;
          if (!button) return;
          applyDragToSlot(button);
          lastHoveredSlotKey = slotKey(button.dataset.slotDate, button.dataset.slotClass);
          updateBlockReasonMessage(button);
        });
        window.addEventListener('pointerup', (event) => {
          if (!dragState.active) return;
          if (dragState.pointerId !== null && dragState.pointerId !== event.pointerId) return;
          stopDragMode();
        });
        window.addEventListener('pointercancel', () => {
          stopDragMode();
        });
        window.addEventListener('keydown', (event) => {
          if (!canHandlePlannerShortcut(event)) return;
          const rawKey = String(event.key || '').toLowerCase();
          if (rawKey === 'e' || rawKey === 'c' || rawKey === 'z') {
            manualSelectedType = rawKey === 'z'
              ? 'credit'
              : (rawKey === 'c' ? 'consultation' : 'exam');
            syncManualTypeButtons();
            renderPlannerSurface();
            event.preventDefault();
            return;
          }
          if (rawKey === 'delete' || rawKey === 'backspace') {
            const removed = removeAssignmentsAtSlot(lastHoveredSlotKey);
            if (removed) {
              event.preventDefault();
            }
          }
        });

        manualAssignments = dedupeAssignments(manualAssignmentsSeed);
        resetRoomForm();
        if (manualSubjectSelect && !manualSubjectSelect.value && manualSubjects.length) {
          manualSubjectSelect.value = String(manualSubjects[0].id);
        }
        updateManualGroupOptions();
        if (slotFilterSubject && manualSubjectSelect && manualSubjectSelect.value) {
          slotFilterSubject.value = String(manualSubjectSelect.value || '').trim();
          lastSyncedSubjectFilter = slotFilterSubject.value;
        }
        syncManualTypeButtons();
        renderPlannerSurface();
        syncPublishState();
        setLiveConflictStatusText(sessionGeneratorText.liveConflictUpdating, null);
        runLiveConflictCheck();

        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
          if (window.bootstrap && window.bootstrap.Tooltip) {
            window.bootstrap.Tooltip.getOrCreateInstance(el);
          }
        });
      })();
    </script>
    <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
