          semester_id: '<%= sessionGeneratorSelectedSemesterId || "" %>',
          window_mode: '<%= sessionGeneratorFormState.window_mode || "weeks" %>',
          start_date: '<%= sessionGeneratorFormState.start_date || "" %>',
          session_days: '<%= sessionGeneratorFormState.session_days || "" %>',
          session_weeks_count: '<%= sessionGeneratorFormState.session_weeks_count || "" %>',
          session_weeks_set: '<%= sessionGeneratorFormState.session_weeks_set || "" %>',
          include_weekends: '<%= sessionGeneratorFormState.include_weekends ? "1" : "0" %>',
          respect_study_days: '<%= sessionGeneratorFormState.respect_study_days ? "1" : "0" %>',
        };
        const draftNavigationStateKeys = [
          'location',
          'course_id',
          'semester_id',
          'draft_id',
          'window_mode',
          'start_date',
          'session_days',
          'session_weeks_count',
          'session_weeks_set',
          'max_events_per_day',
          'reserve_every',
          'exam_gap_days',
          'retake_gap_days',
          'retake_window_days',
          'include_consultations',
          'day_grouping_mode',
          'exam_sequence',
          'credit_sequence',
          'strategy',
        ];
        const draftNavigationCheckboxKeys = [
          'include_weekends',
          'respect_study_days',
        ];

        const setSessionAdvancedSections = (expanded) => {
          document.body.classList.toggle('show-advanced-session', expanded);
          if (!toggleSessionAdvancedSectionsBtn) return;
          toggleSessionAdvancedSectionsBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
          toggleSessionAdvancedSectionsBtn.textContent = expanded
            ? (toggleSessionAdvancedSectionsBtn.dataset.hideLabel || '')
            : (toggleSessionAdvancedSectionsBtn.dataset.showLabel || '');
        };

        if (toggleSessionAdvancedSectionsBtn && sessionAdvancedSections.length) {
          setSessionAdvancedSections(false);
          toggleSessionAdvancedSectionsBtn.addEventListener('click', () => {
            const expanded = toggleSessionAdvancedSectionsBtn.getAttribute('aria-expanded') === 'true';
            setSessionAdvancedSections(!expanded);
          });
        }
        document.querySelectorAll('[data-location]').forEach((btn) => {
          btn.addEventListener('click', () => {
            if (!locationInput || !form) return;
            locationInput.value = btn.dataset.location || 'kyiv';
            form.submit();
          });
        });

        const buildSessionGeneratorUrlFromForm = (overrides = {}) => {
          const params = new URLSearchParams();
          if (form) {
            const formData = new FormData(form);
            draftNavigationStateKeys.forEach((key) => {
              const value = formData.get(key);
              if (value === null || value === undefined) return;
              const normalized = String(value).trim();
              if (!normalized) return;
              params.set(key, normalized);
            });
            draftNavigationCheckboxKeys.forEach((key) => {
              const input = form.querySelector(`input[name="${key}"]`);
              if (!input) return;
              params.set(key, input.checked ? '1' : '0');
            });
          }
          if (!params.get('location') && locationInput && locationInput.value) {
            params.set('location', locationInput.value);
          }
          const shouldPreserveExplicitDates = Object.entries(sessionWindowStateBase).every(([key, value]) => {
            return String(params.get(key) || '') === String(value || '');
          });
          if (shouldPreserveExplicitDates && Array.isArray(sessionWindowExplicitDates) && sessionWindowExplicitDates.length) {
            params.set('explicit_dates_json', JSON.stringify(sessionWindowExplicitDates));
          }
          ['ok', 'err'].forEach((key) => params.delete(key));
          Object.entries(overrides || {}).forEach(([key, value]) => {
            if (value === undefined || value === null || value === '') {
              params.delete(key);
              return;
            }
            params.set(key, String(value));
          });
          return `/admin/session-generator${params.toString() ? `?${params.toString()}` : ''}`;
        };

        draftNavLinks.forEach((link) => {
          link.addEventListener('click', (event) => {
            event.preventDefault();
            const action = String(link.dataset.draftAction || '').trim();
            const nextDraftId = String(link.dataset.draftId || '').trim();
            window.location.href = buildSessionGeneratorUrlFromForm({
              draft_action: action || null,
              draft_id: action === 'new' ? null : (nextDraftId || null),
            });
          });
        });

        if (draftSwitcher) {
          draftSwitcher.addEventListener('change', () => {
            const selectedOption = draftSwitcher.options[draftSwitcher.selectedIndex];
            const nextDraftId = selectedOption ? String(selectedOption.dataset.draftId || '').trim() : '';
            if (nextDraftId) {
              window.location.href = buildSessionGeneratorUrlFromForm({
                draft_action: null,
                draft_id: nextDraftId,
              });
              return;
            }
            const url = String(draftSwitcher.value || '').trim();
            if (!url) return;
            window.location.href = url;
          });
        }

