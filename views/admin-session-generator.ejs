    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/pages/admin-schedule-generator.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <style>
      .session-generator-page {
        background:
          radial-gradient(1300px 700px at 8% -5%, rgba(74, 160, 255, 0.2), transparent 60%),
          radial-gradient(900px 500px at 95% 0%, rgba(73, 220, 202, 0.14), transparent 64%),
          radial-gradient(800px 500px at 50% 120%, rgba(255, 180, 120, 0.12), transparent 62%),
          var(--app-bg, #0f1320);
        min-height: 100vh;
      }
      .session-shell {
        position: relative;
      }
      .session-shell::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 18px 18px;
        pointer-events: none;
        opacity: 0.22;
      }
      .session-shell > * {
        position: relative;
        z-index: 1;
      }
      .session-hero {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        padding: 0.95rem;
        border: 1px solid rgba(255,255,255,0.14);
        background: linear-gradient(145deg, rgba(255,255,255,0.14), rgba(255,255,255,0.05));
        box-shadow:
          0 10px 28px rgba(0, 0, 0, 0.2),
          inset 0 1px 0 rgba(255,255,255,0.16);
        backdrop-filter: blur(14px) saturate(120%);
      }
      .session-hero::after {
        content: '';
        position: absolute;
        inset: auto -12% 55% -12%;
        height: 120px;
        background: radial-gradient(circle at 50% 100%, rgba(255,255,255,0.18), rgba(255,255,255,0));
        pointer-events: none;
      }
      .session-lead {
        color: rgba(255,255,255,0.78);
        max-width: 64ch;
      }
      body.theme-light .session-lead {
        color: rgba(20,28,38,0.68);
      }
      .session-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .session-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        padding: 0.35rem 0.7rem;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.06);
        font-size: 0.82rem;
        color: rgba(255,255,255,0.92);
      }
      body.theme-light .session-chip {
        border-color: rgba(24,36,60,0.12);
        background: rgba(255,255,255,0.7);
        color: rgba(20,28,38,0.86);
      }
      .session-chip strong {
        font-size: 0.9rem;
      }
      .session-hero-actions {
        margin-top: 0.75rem;
      }
      .session-generator-page .session-optional-section {
        display: none;
      }
      .session-generator-page.show-advanced-session .session-optional-section {
        display: block;
      }
      .liquid-panel {
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.12);
        background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
        box-shadow:
          0 8px 24px rgba(0,0,0,0.18),
          inset 0 1px 0 rgba(255,255,255,0.14);
        backdrop-filter: blur(14px) saturate(120%);
      }
      body.theme-light .liquid-panel {
        border-color: rgba(24,36,60,0.10);
        background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(248,252,255,0.72));
      }
      .liquid-panel .card-body {
        padding: 0.9rem;
      }
      .panel-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }
      .panel-title-row h5 {
        margin: 0;
        font-weight: 700;
        letter-spacing: 0.01em;
      }
      .location-toggle-group {
        display: inline-flex;
        gap: 0.35rem;
        padding: 0.25rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
      }
      body.theme-light .location-toggle-group {
        border-color: rgba(24,36,60,0.1);
        background: rgba(255,255,255,0.75);
      }
      .location-toggle-group .btn {
        border-radius: 999px;
        padding-inline: 0.8rem;
      }
      .soft-divider {
        height: 1px;
        background: linear-gradient(90deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
        margin: 0.8rem 0;
      }
      body.theme-light .soft-divider {
        background: linear-gradient(90deg, rgba(20,28,38,0.12), rgba(20,28,38,0.03));
      }
      .session-subtle {
        color: rgba(255,255,255,0.7);
        font-size: 0.9rem;
      }
      body.theme-light .session-subtle {
        color: rgba(20,28,38,0.65);
      }
      .session-stat-grid {
        display: grid;
        gap: 0.6rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .session-stat {
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        padding: 0.65rem 0.75rem;
      }
      body.theme-light .session-stat {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.64);
      }
      .session-stat-label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.64);
      }
      body.theme-light .session-stat-label {
        color: rgba(20,28,38,0.56);
      }
      .session-stat-value {
        font-weight: 700;
        font-size: 1rem;
      }
      .mark-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.2rem;
        padding: 0.18rem 0.45rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.92);
      }
      .mark-pill + .mark-pill {
        margin-left: 0.22rem;
      }
      body.theme-light .mark-pill {
        border-color: rgba(20,28,38,0.1);
        background: rgba(255,255,255,0.72);
        color: rgba(20,28,38,0.86);
      }
      .mark-pill.exam { background: rgba(255, 95, 95, 0.16); border-color: rgba(255, 125, 125, 0.3); }
      .mark-pill.credit { background: rgba(87, 197, 255, 0.14); border-color: rgba(114, 210, 255, 0.28); }
      .mark-pill.accent { background: rgba(255, 196, 74, 0.14); border-color: rgba(255, 210, 110, 0.28); }
      .mark-pill.warn { background: rgba(255, 173, 85, 0.14); border-color: rgba(255, 193, 125, 0.28); }
      .mark-pill.danger { background: rgba(255, 113, 140, 0.16); border-color: rgba(255, 138, 160, 0.28); }
      .mark-pill.info { background: rgba(92, 163, 255, 0.14); border-color: rgba(126, 183, 255, 0.28); }
      .mark-pill.muted { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.14); }
      body.theme-light .mark-pill.muted { background: rgba(20,28,38,0.04); border-color: rgba(20,28,38,0.08); }
      .legend-grid {
        display: grid;
        gap: 0.55rem;
      }
      .legend-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        border-radius: 14px;
        padding: 0.45rem 0.5rem;
        background: rgba(255,255,255,0.03);
      }
      body.theme-light .legend-item { background: rgba(20,28,38,0.03); }
      .timeline-day {
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        overflow: hidden;
      }
      body.theme-light .timeline-day {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.68);
      }
      .timeline-day-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 0.85rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.02));
      }
      body.theme-light .timeline-day-header {
        border-bottom-color: rgba(20,28,38,0.07);
        background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(248,252,255,0.65));
      }
      .timeline-day-header.is-weekend {
        box-shadow: inset 0 0 0 9999px rgba(255, 171, 54, 0.06);
      }
      .timeline-day-header.is-reserve {
        box-shadow: inset 0 0 0 9999px rgba(255, 205, 84, 0.08);
      }
      .timeline-day-title {
        font-weight: 700;
        line-height: 1.15;
      }
      .timeline-day-subtitle {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.66);
      }
      body.theme-light .timeline-day-subtitle { color: rgba(20,28,38,0.56); }
      .timeline-list {
        padding: 0.55rem;
        display: grid;
        gap: 0.45rem;
      }
      .timeline-empty {
        padding: 0.8rem;
        text-align: center;
        color: rgba(255,255,255,0.55);
        font-size: 0.86rem;
      }
      body.theme-light .timeline-empty { color: rgba(20,28,38,0.52); }
      .timeline-item {
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.09);
        background: rgba(255,255,255,0.03);
        padding: 0.6rem 0.65rem;
      }
      body.theme-light .timeline-item {
        border-color: rgba(20,28,38,0.07);
        background: rgba(255,255,255,0.62);
      }
      .timeline-item.kind-assessment.exam {
        box-shadow: inset 3px 0 0 rgba(255, 113, 140, 0.75);
      }
      .timeline-item.kind-assessment.credit {
        box-shadow: inset 3px 0 0 rgba(93, 186, 255, 0.78);
      }
      .timeline-item.kind-consultation {
        box-shadow: inset 3px 0 0 rgba(255, 219, 119, 0.6);
      }
      .timeline-item.kind-reserve,
      .timeline-item.kind-retake {
        box-shadow: inset 3px 0 0 rgba(255, 168, 84, 0.66);
      }
      .timeline-item-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.6rem;
      }
      .timeline-item-title {
        font-weight: 650;
        font-size: 0.93rem;
        line-height: 1.15;
      }
      .timeline-item-subject {
        margin-top: 0.15rem;
        font-size: 0.84rem;
        color: rgba(255,255,255,0.78);
      }
      body.theme-light .timeline-item-subject { color: rgba(20,28,38,0.68); }
      .timeline-item-meta {
        margin-top: 0.25rem;
        font-size: 0.76rem;
        color: rgba(255,255,255,0.62);
      }
      body.theme-light .timeline-item-meta { color: rgba(20,28,38,0.56); }
      .timeline-note {
        margin-top: 0.3rem;
        font-size: 0.76rem;
        color: rgba(255,255,255,0.72);
      }
      body.theme-light .timeline-note { color: rgba(20,28,38,0.6); }
      .subject-table-wrap {
        overflow: auto;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
      }
      body.theme-light .subject-table-wrap { border-color: rgba(20,28,38,0.08); }
      .subject-table {
        margin: 0;
        min-width: 720px;
        --bs-table-bg: transparent;
        --bs-table-striped-bg: rgba(255,255,255,0.03);
        --bs-table-color: inherit;
        --bs-table-border-color: rgba(255,255,255,0.08);
      }
      body.theme-light .subject-table {
        --bs-table-striped-bg: rgba(20,28,38,0.02);
        --bs-table-border-color: rgba(20,28,38,0.07);
      }
      .subject-table td,
      .subject-table th {
        vertical-align: middle;
      }
      .subject-type-chip {
        border-radius: 999px;
        padding: 0.22rem 0.55rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.03em;
      }
      .subject-type-chip.exam {
        background: rgba(255,113,140,0.14);
        color: #ffd3dc;
        border: 1px solid rgba(255,113,140,0.22);
      }
      .subject-type-chip.credit {
        background: rgba(93,186,255,0.14);
        color: #d4efff;
        border: 1px solid rgba(93,186,255,0.22);
      }
      body.theme-light .subject-type-chip.exam {
        color: #8a3146;
      }
      body.theme-light .subject-type-chip.credit {
        color: #1f5272;
      }
      .liquid-alert {
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        padding: 0.65rem 0.85rem;
        font-size: 0.88rem;
      }
      body.theme-light .liquid-alert {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.7);
      }
      .liquid-alert.warn {
        box-shadow: inset 3px 0 0 rgba(255, 176, 79, 0.72);
      }
      .liquid-alert.info {
        box-shadow: inset 3px 0 0 rgba(88, 174, 255, 0.7);
      }
      .liquid-alert.danger {
        box-shadow: inset 3px 0 0 rgba(255, 113, 140, 0.78);
      }
      .manual-controls-col,
      .manual-slots-col {
        min-width: 0;
      }
      .manual-controls-stack {
        position: sticky;
        top: 0.85rem;
      }
      .manual-control-block {
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px;
        padding: 0.55rem;
        background: rgba(255,255,255,0.03);
      }
      body.theme-light .manual-control-block {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.72);
      }
      .manual-input-grid {
        display: grid;
        gap: 0.55rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .manual-input-item {
        min-width: 0;
      }
      .manual-input-item-wide {
        grid-column: 1 / -1;
      }
      .manual-actions-grid {
        display: grid;
        gap: 0.45rem;
      }
      .manual-shortcuts-copy {
        font-size: 0.8rem;
      }
      .planner-status-stack {
        display: grid;
        gap: 0.45rem;
        margin-bottom: 0.6rem;
      }
      .planner-dock {
        position: sticky;
        top: 0.85rem;
        z-index: 7;
        display: grid;
        gap: 0.6rem;
        margin-bottom: 0.7rem;
      }
      .active-selection-bar {
        display: grid;
        gap: 0.6rem;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.12);
        background: linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
        box-shadow:
          0 8px 20px rgba(0,0,0,0.16),
          inset 0 1px 0 rgba(255,255,255,0.16);
        padding: 0.65rem 0.72rem;
        backdrop-filter: blur(10px) saturate(120%);
      }
      body.theme-light .active-selection-bar {
        border-color: rgba(20,28,38,0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,252,255,0.78));
      }
      .active-selection-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .active-selection-label {
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.62);
      }
      body.theme-light .active-selection-label {
        color: rgba(20,28,38,0.52);
      }
      .active-selection-summary {
        display: flex;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 0.7rem;
        min-width: 0;
      }
      .active-selection-type {
        min-width: 3.2rem;
        justify-content: center;
      }
      .active-selection-copy {
        min-width: 0;
      }
      .active-selection-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }
      .active-selection-metrics .mark-pill {
        letter-spacing: 0.02em;
      }
      .active-selection-metrics .mark-pill strong {
        margin-left: 0.2rem;
        font-size: 0.74rem;
      }
      .active-selection-title {
        font-weight: 700;
        line-height: 1.15;
      }
      .active-selection-subtitle {
        margin-top: 0.15rem;
        font-size: 0.83rem;
        color: rgba(255,255,255,0.7);
      }
      body.theme-light .active-selection-subtitle {
        color: rgba(20,28,38,0.6);
      }
      .active-selection-hint {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        align-items: center;
      }
      .planner-filter-bar {
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.05);
        padding: 0.42rem 0.55rem;
      }
      body.theme-light .planner-filter-bar {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.78);
      }
      .planner-filter-details {
        margin: 0;
      }
      .planner-filter-details > summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        padding: 0.12rem 0.08rem;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.84);
        user-select: none;
      }
      .planner-filter-details > summary::-webkit-details-marker {
        display: none;
      }
      body.theme-light .planner-filter-details > summary {
        color: rgba(20,28,38,0.8);
      }
      .planner-filter-summary-note {
        color: rgba(255,255,255,0.62);
        font-size: 0.74rem;
      }
      body.theme-light .planner-filter-summary-note {
        color: rgba(20,28,38,0.56);
      }
      .planner-filter-details[open] > summary {
        margin-bottom: 0.45rem;
      }
      .planner-filter-grid {
        display: grid;
        gap: 0.65rem;
        grid-template-columns: repeat(auto-fit, minmax(152px, 1fr));
        align-items: end;
      }
      .planner-filter-item label {
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.58);
      }
      body.theme-light .planner-filter-item label {
        color: rgba(20,28,38,0.54);
      }
      .planner-filter-actions {
        display: flex;
        align-items: end;
        justify-content: flex-start;
      }
      .planner-filter-toggle {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 100%;
        border-radius: 14px;
        padding: 0.5rem 0.65rem;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        font-size: 0.82rem;
      }
      body.theme-light .planner-filter-toggle {
        border-color: rgba(20,28,38,0.08);
        background: rgba(20,28,38,0.03);
      }
      .planner-filter-toggle input {
        margin: 0;
      }
      .planner-shell-grid {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: 1fr;
        align-items: start;
      }
      .planner-main-column,
      .planner-side-column {
        min-width: 0;
      }
      .planner-side-card {
        position: static;
      }
      .group-timeline-list {
        display: grid;
        gap: 0.6rem;
      }
      .group-timeline-item {
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        padding: 0.7rem;
        display: grid;
        gap: 0.24rem;
      }
      body.theme-light .group-timeline-item {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.74);
      }
      .group-timeline-date {
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: rgba(255,255,255,0.62);
      }
      body.theme-light .group-timeline-date {
        color: rgba(20,28,38,0.54);
      }
      .group-timeline-title {
        font-weight: 650;
        line-height: 1.2;
      }
      .group-timeline-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        align-items: center;
      }
      .manual-type-group {
        display: grid !important;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        width: 100%;
      }
      .manual-type-group > .btn {
        min-width: 0;
        margin-left: 0 !important;
        white-space: normal;
        overflow-wrap: anywhere;
        line-height: 1.15;
        padding-inline: 0.55rem;
      }
      .manual-type-group > .btn:not(:first-child) {
        border-left-width: 1px;
      }
      .manual-type-group > .btn[data-manual-type="consultation"] {
        border-color: rgba(45, 212, 191, 0.34);
      }
      .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary {
        color: rgba(153, 246, 228, 0.96);
        background: rgba(20, 184, 166, 0.08);
      }
      .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary:hover,
      .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary:focus-visible {
        color: rgba(204, 251, 241, 0.98);
        background: rgba(20, 184, 166, 0.2);
        border-color: rgba(94, 234, 212, 0.62);
      }
      .manual-type-group > .btn[data-manual-type="consultation"].btn-secondary,
      .manual-type-group > .btn[data-manual-type="consultation"].active {
        color: #ecfeff;
        background: linear-gradient(135deg, rgba(13, 148, 136, 0.96), rgba(20, 184, 166, 0.9));
        border-color: rgba(94, 234, 212, 0.74);
        box-shadow: 0 10px 24px rgba(13, 148, 136, 0.28);
      }
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"] {
        border-color: rgba(13, 148, 136, 0.36);
      }
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary {
        color: rgba(15, 118, 110, 0.92);
        background: rgba(20, 184, 166, 0.08);
      }
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary:hover,
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"].btn-outline-secondary:focus-visible {
        color: rgba(17, 94, 89, 0.96);
        background: rgba(20, 184, 166, 0.18);
        border-color: rgba(13, 148, 136, 0.52);
      }
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"].btn-secondary,
      body.theme-light .manual-type-group > .btn[data-manual-type="consultation"].active {
        color: #f0fdfa;
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.96), rgba(13, 148, 136, 0.9));
        border-color: rgba(13, 148, 136, 0.7);
        box-shadow: 0 10px 22px rgba(15, 118, 110, 0.24);
      }
      .planner-queue {
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        padding: 0.7rem;
      }
      body.theme-light .planner-queue {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.68);
      }
      .planner-event-btn {
        width: 100%;
        text-align: left;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03);
        color: inherit;
        padding: 0.6rem 0.65rem;
        display: grid;
        gap: 0.2rem;
        transition: border-color 140ms ease, transform 140ms ease, background-color 140ms ease;
      }
      body.theme-light .planner-event-btn {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.7);
      }
      .planner-event-btn:hover {
        border-color: rgba(110, 185, 255, 0.38);
      }
      .planner-event-btn.is-selected {
        border-color: rgba(82, 170, 255, 0.55);
        background: rgba(82, 170, 255, 0.10);
        box-shadow: inset 0 0 0 1px rgba(82, 170, 255, 0.22);
      }
      .planner-event-btn.is-assigned {
        opacity: 0.58;
      }
      .planner-event-main {
        font-weight: 650;
        line-height: 1.15;
      }
      .planner-event-sub {
        font-size: 0.76rem;
        color: rgba(255,255,255,0.64);
      }
      body.theme-light .planner-event-sub { color: rgba(20,28,38,0.54); }
      .planner-event-marks {
        display: flex;
        flex-wrap: wrap;
        gap: 0.2rem;
      }
      .slot-day-card {
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        padding: 0.65rem;
      }
      body.theme-light .slot-day-card {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.7);
      }
      .slot-day-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.6rem;
        margin-bottom: 0.55rem;
      }
      .slot-day-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.35rem;
      }
      .day-load-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.38rem;
        border-radius: 999px;
        padding: 0.28rem 0.58rem;
        border: 1px solid rgba(255,255,255,0.14);
        font-size: 0.72rem;
        font-weight: 700;
      }
      .day-load-chip[data-load-level="low"] {
        background: rgba(113, 228, 182, 0.16);
        border-color: rgba(113, 228, 182, 0.36);
      }
      .day-load-chip[data-load-level="medium"] {
        background: rgba(255, 205, 97, 0.16);
        border-color: rgba(255, 205, 97, 0.34);
      }
      .day-load-chip[data-load-level="high"] {
        background: rgba(255, 113, 140, 0.16);
        border-color: rgba(255, 113, 140, 0.34);
      }
      .slot-row-grid {
        display: grid;
        gap: 0.45rem;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      }
      .slot-cell {
        position: relative;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03);
        color: inherit;
        text-align: left;
        padding: 0.52rem 0.56rem;
        min-height: 78px;
        display: grid;
        align-content: start;
        gap: 0.14rem;
      }
      body.theme-light .slot-cell {
        border-color: rgba(20,28,38,0.08);
        background: rgba(255,255,255,0.78);
      }
      .slot-cell.is-free:hover {
        border-color: rgba(88, 174, 255, 0.42);
      }
      .slot-cell.is-busy {
        opacity: 0.72;
        background: rgba(255, 163, 92, 0.08);
      }
      .slot-cell.is-assigned {
        border-color: rgba(82, 170, 255, 0.5);
        background: rgba(82, 170, 255, 0.10);
        box-shadow: inset 0 0 0 1px rgba(82, 170, 255, 0.18);
      }
      .slot-cell.is-filter-hidden {
        opacity: 0.28;
      }
      .slot-cell.is-dimmed-occupied {
        opacity: 0.22;
      }
      .slot-cell.is-drag-target {
        border-color: rgba(113, 228, 182, 0.62);
        box-shadow: inset 0 0 0 1px rgba(113, 228, 182, 0.42);
      }
      .slot-cell.is-conflict {
        border-color: rgba(255, 110, 130, 0.74);
        background: rgba(255, 110, 130, 0.14);
        box-shadow: inset 0 0 0 1px rgba(255, 110, 130, 0.46);
      }
      .slot-cell.is-recommended {
        border-color: rgba(113, 228, 182, 0.72);
        background: rgba(113, 228, 182, 0.14);
      }
      .slot-cell.is-free-highlight {
        border-color: rgba(113, 228, 182, 0.7);
        box-shadow: inset 0 0 0 1px rgba(113, 228, 182, 0.3);
      }
      .slot-cell-top {
        font-weight: 700;
        font-size: 0.78rem;
      }
      .slot-cell-time {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.62);
      }
      body.theme-light .slot-cell-time { color: rgba(20,28,38,0.54); }
      .slot-cell-content,
      .slot-busy-stack,
      .slot-assignment-stack,
      .slot-warning-stack {
        display: grid;
        gap: 0.28rem;
      }
      .slot-cell-empty {
        font-size: 0.78rem;
        line-height: 1.2;
        color: rgba(255,255,255,0.58);
        padding-top: 0.14rem;
      }
      body.theme-light .slot-cell-empty {
        color: rgba(20,28,38,0.5);
      }
      .slot-busy-item,
      .slot-assignment-item {
        border-radius: 10px;
        padding: 0.32rem 0.4rem;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.08);
      }
      body.theme-light .slot-busy-item,
      body.theme-light .slot-assignment-item {
        border-color: rgba(20,28,38,0.06);
        background: rgba(255,255,255,0.72);
      }
      .slot-busy-subject,
      .slot-assignment-subject {
        font-size: 0.78rem;
        font-weight: 650;
        line-height: 1.15;
        margin-bottom: 0.2rem;
      }
      .slot-busy-meta,
      .slot-assignment-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        align-items: center;
        font-size: 0.68rem;
        color: rgba(255,255,255,0.68);
      }
      body.theme-light .slot-busy-meta,
      body.theme-light .slot-assignment-meta {
        color: rgba(20,28,38,0.58);
      }
      .group-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        border-radius: 999px;
        padding: 0.15rem 0.45rem;
        background: rgba(88, 174, 255, 0.12);
        border: 1px solid rgba(88, 174, 255, 0.24);
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.03em;
      }
      .slot-cell-assignment {
        margin-top: 0.12rem;
        color: rgba(255,255,255,0.88);
        word-break: break-word;
      }
      body.theme-light .slot-cell-assignment { color: rgba(20,28,38,0.78); }
      .slot-cell-conflict {
        margin-top: 0.14rem;
        display: grid;
        gap: 0.22rem;
      }
      .slot-warning-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.32rem;
        width: fit-content;
        border-radius: 999px;
        padding: 0.14rem 0.42rem;
        background: rgba(255, 113, 140, 0.14);
        border: 1px solid rgba(255, 113, 140, 0.26);
        font-size: 0.64rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: rgba(255, 219, 225, 0.98);
      }
      body.theme-light .slot-warning-chip {
        color: rgba(131, 26, 48, 0.94);
      }
      .slot-warning-chip.warn {
        background: rgba(255, 200, 102, 0.16);
        border-color: rgba(255, 200, 102, 0.28);
        color: rgba(255, 243, 209, 0.98);
      }
      body.theme-light .slot-warning-chip.warn {
        color: rgba(120, 77, 10, 0.92);
      }
      .slot-warning-detail {
        font-size: 0.66rem;
        line-height: 1.2;
        color: rgba(255, 210, 218, 0.92);
      }
      body.theme-light .slot-warning-detail {
        color: rgba(163, 36, 58, 0.88);
      }
      .live-conflict-ok {
        box-shadow: inset 3px 0 0 rgba(113, 228, 182, 0.85);
      }
      .live-conflict-err {
        box-shadow: inset 3px 0 0 rgba(255, 110, 130, 0.85);
      }
      .tiny-dot {
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: currentColor;
        opacity: 0.7;
        display: inline-block;
      }
      body.session-dragging {
        user-select: none;
        cursor: crosshair;
      }
      @media (max-width: 991px) {
        .session-stat-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }
      @media (min-width: 1800px) {
        .planner-shell-grid {
          grid-template-columns: minmax(0, 1fr) minmax(280px, 340px);
        }
        .planner-side-card {
          position: sticky;
          top: 0.85rem;
        }
      }
      @media (max-width: 1399px) {
        .planner-filter-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }
      @media (max-width: 767px) {
        .session-hero {
          padding: 0.9rem;
          border-radius: 18px;
        }
        .session-stat-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .timeline-day-header {
          flex-direction: column;
          align-items: flex-start;
        }
        .manual-controls-stack {
          position: static;
        }
        .manual-input-grid {
          grid-template-columns: 1fr;
        }
        .planner-shell-grid,
        .planner-filter-grid {
          grid-template-columns: 1fr;
        }
        .planner-filter-actions {
          justify-content: stretch;
        }
        .planner-filter-actions .btn {
          width: 100%;
        }
        .panel-title-row {
          align-items: flex-start;
          flex-direction: column;
        }
        .location-toggle-group {
          width: 100%;
          justify-content: stretch;
        }
        .location-toggle-group .btn {
          flex: 1 1 auto;
        }
      }
      @media (max-width: 575px) {
        .manual-type-group {
          grid-template-columns: 1fr;
        }
      }
      @media (prefers-reduced-motion: no-preference) {
        .session-hero,
        .liquid-panel,
        .timeline-day {
          animation: sessionFadeIn 280ms ease both;
        }
        .timeline-day { animation-duration: 360ms; }
        @keyframes sessionFadeIn {
          from { opacity: 0; transform: translateY(8px); }
          to { opacity: 1; transform: translateY(0); }
        }
      }
    </style>
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark schedule-generator-page session-generator-page">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand"><%= sessionGeneratorText.navTitle %></span>
        <div class="d-flex align-items-center flex-wrap gap-2 justify-content-end">
          <span class="text-muted small"><%= t('role.admin') %>: <%= username %></span>
          <button
            class="theme-toggle theme-toggle-min"
            type="button"
            id="themeToggle"
            aria-label="<%= sessionGeneratorText.themeToggleAria %>"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-secondary btn-sm" href="/admin/schedule-generator"><%= sessionGeneratorText.scheduleGenerator %></a>
          <a class="btn btn-outline-primary btn-sm" href="/admin"><%= sessionGeneratorText.backToAdmin %></a>
          <form method="POST" action="/logout" class="m-0">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4 session-shell">
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>

      <div class="session-hero mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <h1 class="h3 mb-2"><%= sessionGeneratorText.heroTitle %></h1>
            <div class="session-lead"><%= sessionGeneratorText.heroLead %></div>
          </div>
          <div class="session-chip-row">
            <span class="session-chip"><span class="tiny-dot"></span> <strong><%= formatSessionLocationLabel(activeLocation) %></strong></span>
            <% if (selectedCourse) { %>
              <span class="session-chip"><%= sessionGeneratorText.course %>: <strong><%= selectedCourse.name %></strong></span>
            <% } %>
            <% if (activeSemester) { %>
              <span class="session-chip"><%= sessionGeneratorText.semester %>: <strong><%= activeSemester.title || (sessionGeneratorText.semesterPrefix + activeSemester.id) %></strong></span>
            <% } %>
          </div>
        </div>
        <div class="session-hero-actions">
          <button
            class="btn btn-outline-secondary btn-sm"
            type="button"
            id="toggleSessionAdvancedSections"
            data-show-label="<%= sessionGeneratorText.advancedToggleShow %>"
            data-hide-label="<%= sessionGeneratorText.advancedToggleHide %>"
            aria-expanded="false"
          >
            <%= sessionGeneratorText.advancedToggleShow %>
          </button>
        </div>
      </div>

      <% if (uiHints && uiHints.length) { %>
        <div class="d-grid gap-2 mb-3">
          <% uiHints.forEach(function(hint) { %>
            <div class="liquid-alert info"><%= hint %></div>
          <% }); %>
        </div>
      <% } %>

      <div class="row g-4">
        <div class="col-12 col-xxl-3">
          <div class="card liquid-panel mb-4">
            <div class="card-body">
              <div class="panel-title-row">
                <h5><%= sessionGeneratorText.calendarTitle %></h5>
                <div class="location-toggle-group" role="tablist" aria-label="<%= sessionGeneratorText.campusAria %>">
                  <button class="btn btn-sm <%= activeLocation === 'kyiv' ? 'btn-primary' : 'btn-outline-secondary' %>" type="button" data-location="kyiv"><%= sessionGeneratorText.locationKyiv %></button>
                  <button class="btn btn-sm <%= activeLocation === 'munich' ? 'btn-primary' : 'btn-outline-secondary' %>" type="button" data-location="munich"><%= sessionGeneratorText.locationMunich %></button>
                </div>
              </div>
              <div class="session-subtle mb-2"><%= sessionGeneratorText.calendarHint %></div>
              <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                <a
                  class="btn btn-outline-secondary btn-sm"
                  href="<%= buildSessionGeneratorHref({ draft_id: '', draft_action: 'new' }) %>"
                  data-draft-action="new"
                >
                  <%= sessionGeneratorText.newPlan %>
                </a>
                <% if (draftMeta && draftMeta.id) { %>
                  <a
                    class="btn btn-outline-secondary btn-sm"
                    href="<%= buildSessionGeneratorHref({ draft_id: draftMeta.id, draft_action: 'clear' }) %>"
                    data-draft-action="clear"
                    data-draft-id="<%= draftMeta.id %>"
                  >
                    <%= sessionGeneratorText.clearPlan %>
                  </a>
                <% } %>
                <% if (draftMeta && draftMeta.list && draftMeta.list.length > 1) { %>
                  <div class="d-flex align-items-center gap-2 ms-auto">
                    <label class="small text-muted m-0" for="draftSwitcherSelect"><%= sessionGeneratorText.drafts %></label>
                    <select class="form-select form-select-sm" id="draftSwitcherSelect" style="width: auto;" data-draft-switch>
                      <% draftMeta.list.forEach(function(d) { %>
                        <option value="<%= buildSessionGeneratorHref({ draft_id: d.id, draft_action: '' }) %>" data-draft-id="<%= d.id %>" <%= Number(d.id) === Number(draftMeta.id) ? 'selected' : '' %>>
                          #<%= d.id %>
                        </option>
                      <% }); %>
                    </select>
                  </div>
                <% } %>
              </div>
              <form method="GET" action="/admin/session-generator" id="sessionGeneratorForm" class="row g-3">
                <input type="hidden" name="location" id="sessionLocationInput" value="<%= activeLocation %>" />
                <input type="hidden" name="draft_id" id="sessionDraftIdInput" value="<%= draftMeta && draftMeta.id ? draftMeta.id : '' %>" />
                <div class="col-12">
                  <label class="form-label"><%= sessionGeneratorText.course %></label>
                  <select class="form-select" name="course_id" onchange="this.form.submit()">
                    <% const locationCourses = (coursesByLocation && coursesByLocation[activeLocation]) || []; %>
                    <% if (!locationCourses.length) { %>
                      <option value=""><%= sessionGeneratorText.noCourses %></option>
                    <% } %>
                    <% locationCourses.forEach(function(course) { %>
                      <option value="<%= course.id %>" <%= Number(course.id) === Number(form && form.course_id) ? 'selected' : '' %>><%= course.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label"><%= sessionGeneratorText.semester %></label>
                  <select class="form-select" name="semester_id" onchange="this.form.submit()" <%= (semesters && semesters.length) ? '' : 'disabled' %>>
                    <% if (!(semesters && semesters.length)) { %>
                      <option value=""><%= sessionGeneratorText.noSemesters %></option>
                    <% } %>
                    <% (semesters || []).forEach(function(sem) { %>
                      <option value="<%= sem.id %>" <%= Number(sem.id) === Number(selectedSemesterId) ? 'selected' : '' %>>
                        <%= formatSessionSemesterOption(sem) %>
                      </option>
                    <% }); %>
                  </select>
                </div>
                <input type="hidden" name="window_mode" value="<%= form && form.window_mode ? form.window_mode : 'weeks' %>" />
                <div class="col-4">
                  <label class="form-label"><%= sessionGeneratorText.sessionWeeksCount %></label>
                  <input class="form-control" type="number" min="1" max="12" name="session_weeks_count" value="<%= form && form.session_weeks_count %>" />
                </div>
                <div class="col-8">
                  <label class="form-label"><%= sessionGeneratorText.sessionWeeksSet %></label>
                  <input class="form-control" type="text" name="session_weeks_set" value="<%= (form && form.session_weeks_set) || '' %>" placeholder="<%= sessionGeneratorText.sessionWeeksPlaceholder %>" />
                  <div class="small text-muted mt-1">
                    <% if (sessionWeekNumbers && sessionWeekNumbers.length) { %>
                      <%= sessionGeneratorText.sessionWeeksSelected %> <%= sessionWeekNumbers.join(', ') %>
                    <% } else { %>
                      <%= sessionGeneratorText.sessionWeeksFallback %>
                    <% } %>
                  </div>
                </div>
                <input type="hidden" name="start_date" value="<%= (form && form.start_date) || '' %>" />
                <input type="hidden" name="session_days" value="<%= form && form.session_days ? form.session_days : 14 %>" />
                <div class="col-12 col-sm-4">
                  <label class="form-label"><%= sessionGeneratorText.activeStudyDays %></label>
                  <div class="form-control d-flex align-items-center flex-wrap gap-1" style="min-height: 38px;">
                    <% if (activeStudyDayNames && activeStudyDayNames.length) { %>
                      <% activeStudyDayNames.forEach(function(day) { %>
                        <span class="mark-pill info"><%= day.slice(0,2) %></span>
                      <% }); %>
                    <% } else { %>
                      <span class="text-muted small"><%= sessionGeneratorText.noSettings %></span>
                    <% } %>
                  </div>
                </div>
                <div class="col-12 d-grid gap-2">
                  <label class="form-check">
                    <input class="form-check-input" type="checkbox" name="include_weekends" value="1" <%= form && form.include_weekends ? 'checked' : '' %> />
                    <span class="form-check-label"><%= sessionGeneratorText.allowWeekends %></span>
                  </label>
                  <label class="form-check">
                    <input class="form-check-input" type="checkbox" name="respect_study_days" value="1" <%= form && form.respect_study_days ? 'checked' : '' %> />
                    <span class="form-check-label"><%= sessionGeneratorText.respectStudyDays %></span>
                  </label>
                </div>
                <input type="hidden" name="max_events_per_day" value="<%= form && form.max_events_per_day ? form.max_events_per_day : 3 %>" />
                <input type="hidden" name="reserve_every" value="<%= form && form.reserve_every ? form.reserve_every : 0 %>" />
                <input type="hidden" name="exam_gap_days" value="<%= form && form.exam_gap_days ? form.exam_gap_days : 0 %>" />
                <input type="hidden" name="retake_gap_days" value="<%= form && form.retake_gap_days ? form.retake_gap_days : 2 %>" />
                <input type="hidden" name="retake_window_days" value="<%= form && form.retake_window_days ? form.retake_window_days : 3 %>" />
                <input type="hidden" name="strategy" value="<%= form && form.strategy ? form.strategy : 'balanced' %>" />
                <input type="hidden" name="day_grouping_mode" value="<%= form && form.day_grouping_mode ? form.day_grouping_mode : 'none' %>" />
                <input type="hidden" name="exam_sequence" value="<%= form && form.exam_sequence ? form.exam_sequence : 'exam_only' %>" />
                <input type="hidden" name="credit_sequence" value="<%= form && form.credit_sequence ? form.credit_sequence : 'credit_only' %>" />
                <input type="hidden" name="include_consultations" value="0" />
                <div class="col-12 d-grid">
                  <button class="btn btn-primary" type="submit" <%= form && form.course_id ? '' : 'disabled' %>><%= sessionGeneratorText.updateSlotGrid %></button>
                </div>
                <div class="col-12 session-subtle">
                  <%= sessionGeneratorText.manualOnly %>
                </div>
              </form>
            </div>
          </div>

          <div class="card liquid-panel mb-4 session-optional-section">
            <div class="card-body">
              <div class="panel-title-row">
                <h5><%= sessionGeneratorText.legendTitle %></h5>
                <span class="session-subtle"><%= sessionGeneratorText.legendLabel %></span>
              </div>
              <div class="legend-grid">
                <% (sessionMarkLegend || []).forEach(function(mark) { %>
                  <div class="legend-item">
                    <span class="mark-pill <%= mark.tone || 'muted' %>"><%= mark.code %></span>
                    <span class="small"><%= mark.label %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>

        </div>

        <div class="col-12 col-xxl-9">
          <% const manualSubjectRows = (subjects || [])
            .map(function(subject) {
              return {
                id: Number(subject.id),
                name: subject.name || '',
                group_count: Math.max(1, Number(subject.group_count || 1)),
              };
            })
            .filter(function(subject) { return Number.isFinite(subject.id) && subject.id > 0; })
            .sort(function(a, b) { return String(a.name || '').localeCompare(String(b.name || ''), sessionGeneratorLocale); }); %>
          <% const manualGroupLimit = manualSubjectRows.reduce(function(maxValue, subject) {
            return Math.max(maxValue, Math.max(1, Number(subject.group_count || 1)));
          }, 1); %>

          <div class="card liquid-panel mb-4">
            <div class="card-body">
              <div class="panel-title-row">
                <h5><%= sessionGeneratorText.manualTitle %></h5>
                <span class="session-subtle"><%= sessionGeneratorText.manualHint %></span>
              </div>
              <div class="row g-3">
                <div class="col-12 col-xxl-3 manual-controls-col">
                  <div class="d-grid gap-3 manual-controls-stack">
                    <div class="manual-control-block">
                      <label class="form-label"><%= sessionGeneratorText.sessionType %></label>
                      <div class="btn-group w-100 manual-type-group" role="group" aria-label="<%= sessionGeneratorText.sessionType %>">
                        <button class="btn btn-outline-primary active" type="button" data-manual-type="exam"><%= sessionGeneratorText.exam %></button>
                        <button class="btn btn-outline-secondary" type="button" data-manual-type="consultation"><%= sessionGeneratorText.consultation %></button>
                        <button class="btn btn-outline-danger" type="button" data-manual-type="credit"><%= sessionGeneratorText.credit %></button>
                      </div>
                    </div>
                    <div class="manual-input-grid">
                      <div class="manual-input-item manual-input-item-wide">
                        <label class="form-label" for="manualSubjectSelect"><%= sessionGeneratorText.subject %></label>
                        <select class="form-select" id="manualSubjectSelect">
                          <option value=""><%= sessionGeneratorText.chooseSubject %></option>
                          <% manualSubjectRows.forEach(function(subject) { %>
                            <option value="<%= subject.id %>"><%= subject.name %></option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="manual-input-item">
                        <label class="form-label" for="manualGroupSelect"><%= sessionGeneratorText.group %></label>
                        <select class="form-select" id="manualGroupSelect" disabled>
                          <option value=""><%= sessionGeneratorText.allSubjectGroups %></option>
                        </select>
                      </div>
                      <div class="manual-input-item">
                        <label class="form-label" for="manualRoomSelect"><%= lang === 'en' ? 'Room' : 'Кабінет' %></label>
                        <select class="form-select" id="manualRoomSelect">
                          <option value=""><%= lang === 'en' ? 'No room selected' : 'Без кабінету' %></option>
                          <% (rooms || []).forEach(function(room) { %>
                            <option value="<%= room.id %>"><%= room.room_label || room.label || room.code || `Room ${room.id}` %><%= Number(room.is_active || 0) === 1 ? '' : (lang === 'en' ? ' (archived)' : ' (архів)') %></option>
                          <% }) %>
                        </select>
                      </div>
                    </div>
                    <div class="manual-actions-grid">
                      <button class="btn btn-primary btn-sm" type="button" id="manualAutoConsultationsBtn"><%= sessionGeneratorText.autoConsultations %></button>
                      <button class="btn btn-outline-secondary btn-sm" type="button" id="manualPlanClearBtn"><%= sessionGeneratorText.clearManualPlan %></button>
                      <button class="btn btn-outline-secondary btn-sm" type="button" id="manualConflictsRecheckBtn"><%= sessionGeneratorText.refreshLiveConflicts %></button>
                    </div>
                    <div class="session-subtle manual-shortcuts-copy"><%= sessionGeneratorText.keyboardHint %></div>
                  </div>
                </div>
                <div class="col-12 col-xxl-9 manual-slots-col">
                  <% if (!(slotBoard && slotBoard.length)) { %>
                    <div class="timeline-empty"><%= sessionGeneratorText.noSlots %></div>
                  <% } else { %>
                    <div class="planner-shell-grid">
                      <div class="planner-main-column">
                        <div class="planner-status-stack">
                          <div class="liquid-alert info" id="manualLiveConflictStatus">
                            <%= sessionGeneratorText.liveConflictIdle %>
                          </div>
                          <div class="liquid-alert warn" id="manualBlockReasonBox">
                            <%= sessionGeneratorText.blockReasonIdle %>
                          </div>
                        </div>
                        <div class="planner-dock">
                          <div class="active-selection-bar" id="activeAssignmentBar">
                            <div class="active-selection-head">
                              <div>
                                <div class="active-selection-label"><%= sessionGeneratorText.activeSelectionLabel %></div>
                                <div class="active-selection-subtitle"><%= sessionGeneratorText.activeSelectionHint %></div>
                              </div>
                              <span class="mark-pill muted"><%= sessionGeneratorText.keyboardHint %></span>
                            </div>
                            <div class="active-selection-summary">
                              <span class="mark-pill info active-selection-type" id="activeAssignmentTypeChip"><%= sessionGeneratorText.typeShortExam %></span>
                              <div class="active-selection-copy">
                                <div class="active-selection-title" id="activeAssignmentTitle"><%= sessionGeneratorText.activeSelectionEmpty %></div>
                                <div class="active-selection-subtitle" id="activeAssignmentSubtitle"><%= sessionGeneratorText.activeSelectionShortcuts %></div>
                              </div>
                            </div>
                            <div class="active-selection-metrics" id="activeSelectionMetrics">
                              <span class="mark-pill muted"><%= sessionGeneratorText.events %>: <strong id="manualMetricTotal">0</strong></span>
                              <span class="mark-pill exam"><%= sessionGeneratorText.exam %>: <strong id="manualMetricExam">0</strong></span>
                              <span class="mark-pill accent"><%= sessionGeneratorText.consultation %>: <strong id="manualMetricConsultation">0</strong></span>
                              <span class="mark-pill credit"><%= sessionGeneratorText.credit %>: <strong id="manualMetricCredit">0</strong></span>
                            </div>
                          </div>

                          <div class="planner-filter-bar">
                            <details class="planner-filter-details">
                              <summary>
                                <span><%= sessionGeneratorText.filtersTitle %></span>
                                <span class="planner-filter-summary-note"><%= sessionGeneratorText.manualHint %></span>
                              </summary>
                              <div class="planner-filter-grid">
                                <div class="planner-filter-item">
                                  <label class="form-label small mb-1" for="slotFilterTeacher"><%= sessionGeneratorText.filterTeacher %></label>
                                  <select class="form-select form-select-sm" id="slotFilterTeacher">
                                    <option value=""><%= sessionGeneratorText.allTeachers %></option>
                                    <% (sessionTeacherFilterOptions || []).forEach(function(teacher) { %>
                                      <option value="<%= teacher.id %>"><%= teacher.name %></option>
                                    <% }); %>
                                  </select>
                                </div>
                                <div class="planner-filter-item">
                                  <label class="form-label small mb-1" for="slotFilterSubject"><%= sessionGeneratorText.filterSubject %></label>
                                  <select class="form-select form-select-sm" id="slotFilterSubject">
                                    <option value=""><%= sessionGeneratorText.allSubjects %></option>
                                    <% manualSubjectRows.forEach(function(subject) { %>
                                      <option value="<%= subject.id %>"><%= subject.name %></option>
                                    <% }); %>
                                  </select>
                                </div>
                                <div class="planner-filter-item">
                                  <label class="form-label small mb-1" for="slotFilterGroup"><%= sessionGeneratorText.filterGroup %></label>
                                  <select class="form-select form-select-sm" id="slotFilterGroup">
                                    <option value=""><%= sessionGeneratorText.allGroups %></option>
                                    <% for (let groupIdx = 1; groupIdx <= manualGroupLimit; groupIdx += 1) { %>
                                      <option value="<%= groupIdx %>"><%= sessionGeneratorText.groupPrefix %> <%= groupIdx %></option>
                                    <% } %>
                                  </select>
                                </div>
                                <div class="planner-filter-item">
                                  <label class="form-label small mb-1" for="slotFilterType"><%= sessionGeneratorText.filterEventType %></label>
                                  <select class="form-select form-select-sm" id="slotFilterType">
                                    <option value=""><%= sessionGeneratorText.allTypes %></option>
                                    <option value="exam"><%= sessionGeneratorText.exam %></option>
                                    <option value="consultation"><%= sessionGeneratorText.consultation %></option>
                                    <option value="credit"><%= sessionGeneratorText.credit %></option>
                                  </select>
                                </div>
                                <label class="planner-filter-toggle">
                                  <input class="form-check-input" type="checkbox" id="slotFilterFreeOnly" />
                                  <span><%= sessionGeneratorText.filterFreeOnly %></span>
                                </label>
                                <div class="planner-filter-actions">
                                  <button class="btn btn-outline-secondary btn-sm" type="button" id="slotFiltersResetBtn"><%= sessionGeneratorText.filterReset %></button>
                                </div>
                              </div>
                            </details>
                          </div>
                        </div>

                        <div class="d-grid gap-2" id="sessionSlotBoardRoot">
                          <% (slotBoard || []).forEach(function(day) { %>
                            <div class="slot-day-card">
                              <div class="slot-day-head">
                                <div>
                                  <div class="timeline-day-title"><%= day.day_short || '' %> · <%= day.date || '' %></div>
                                  <div class="timeline-day-subtitle"><%= day.day_name || '' %> · <%= sessionGeneratorText.week %> <%= day.week_number || '—' %></div>
                                </div>
                                <div class="slot-day-meta">
                                  <span class="day-load-chip" data-day-load-chip data-day-date="<%= day.date || '' %>"><%= sessionGeneratorText.loadLow %></span>
                                  <span class="mark-pill muted"><%= formatSessionFreeBusyLabel(day.free_count, day.busy_count) %></span>
                                </div>
                              </div>
                              <div class="slot-row-grid">
                                <% (day.slots || []).forEach(function(slot) { %>
                                  <button
                                    class="slot-cell <%= slot.is_busy ? 'is-busy' : 'is-free' %>"
                                    type="button"
                                    data-slot-btn
                                    data-slot-date="<%= day.date || '' %>"
                                    data-slot-day="<%= day.day_name || '' %>"
                                    data-slot-week="<%= day.week_number || '' %>"
                                    data-slot-class="<%= slot.class_number || '' %>"
                                    data-slot-time="<%= slot.time_label || '' %>"
                                    data-slot-busy-meta="<%= encodeURIComponent(JSON.stringify(slot.busy || [])) %>"
                                  >
                                    <div class="slot-cell-top"><%= sessionGeneratorText.pair %> <%= slot.class_number %></div>
                                    <div class="slot-cell-time"><%= slot.time_label || '' %></div>
                                    <% if (slot.is_busy && slot.busy && slot.busy.length) { %>
                                      <div class="slot-cell-content slot-busy-stack">
                                        <% slot.busy.slice(0, 2).forEach(function(busy, idx) { %>
                                          <div class="slot-busy-item">
                                            <div class="slot-busy-subject"><%= busy.subject_name || sessionGeneratorText.pairFallback %></div>
                                            <div class="slot-busy-meta">
                                              <span class="group-badge"><%= busy.group_number ? (sessionGeneratorText.groupPrefix + ' ' + busy.group_number) : sessionGeneratorText.allSimple %></span>
                                              <% if (busy.teacher_names && busy.teacher_names.length) { %>
                                                <span><%= busy.teacher_names[0] %><%= idx === 1 && slot.busy.length > 2 ? '…' : '' %></span>
                                              <% } %>
                                              <% if (busy.room_label) { %>
                                                <span><%= busy.room_label %></span>
                                              <% } %>
                                            </div>
                                          </div>
                                        <% }); %>
                                      </div>
                                    <% } else { %>
                                      <div class="slot-cell-content slot-cell-empty"><%= sessionGeneratorText.freeSlot %></div>
                                    <% } %>
                                    <div class="slot-cell-assignment" data-slot-assignment></div>
                                    <div class="slot-cell-conflict" data-slot-conflict></div>
                                  </button>
                                <% }); %>
                              </div>
                            </div>
                          <% }); %>
                        </div>
                      </div>

                      <aside class="planner-side-column session-optional-section">
                        <div class="card liquid-panel planner-side-card">
                          <div class="card-body">
                            <div class="panel-title-row">
                              <h5><%= sessionGeneratorText.groupTimelineTitle %></h5>
                              <span class="session-subtle" id="groupTimelineLabel"><%= sessionGeneratorText.groupTimelineHint %></span>
                            </div>
                            <div class="group-timeline-list" id="groupTimelineRoot">
                              <div class="timeline-empty"><%= sessionGeneratorText.groupTimelineHint %></div>
                            </div>
                          </div>
                        </div>
                      </aside>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <article class="card liquid-panel mb-4 session-optional-section">
            <div class="card-body d-grid gap-3">
              <div class="panel-title-row">
                <h5><%= lang === 'en' ? 'Room fund' : 'Кабінетний фонд' %></h5>
                <span class="session-subtle"><%= lang === 'en' ? 'Manage reusable rooms for this course and assign them inside the planner.' : 'Створюйте кабінети для курсу і призначайте їх прямо в планувальнику.' %></span>
              </div>
              <form method="POST" action="/admin/session-generator/rooms/save" class="row g-2" id="sessionRoomForm">
                <input type="hidden" name="location" value="<%= activeLocation %>" />
                <input type="hidden" name="course_id" value="<%= form && form.course_id ? form.course_id : '' %>" />
                <input type="hidden" name="semester_id" value="<%= selectedSemesterId || (form && form.semester_id) || '' %>" />
                <input type="hidden" name="draft_id" value="<%= draftMeta && draftMeta.id ? draftMeta.id : '' %>" />
                <input type="hidden" name="room_id" id="sessionRoomId" value="" />
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomBuilding"><%= lang === 'en' ? 'Building' : 'Корпус' %></label>
                  <input class="form-control" id="sessionRoomBuilding" name="building" maxlength="80" />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomCode"><%= lang === 'en' ? 'Code' : 'Код' %></label>
                  <input class="form-control" id="sessionRoomCode" name="code" maxlength="60" />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomLabel"><%= lang === 'en' ? 'Label' : 'Назва' %></label>
                  <input class="form-control" id="sessionRoomLabel" name="label" maxlength="120" required />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomType"><%= lang === 'en' ? 'Type' : 'Тип' %></label>
                  <select class="form-select" id="sessionRoomType" name="room_type">
                    <% (roomTypeOptions || []).forEach(function(typeValue) { %>
                      <option value="<%= typeValue %>"><%= typeValue %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomCapacity"><%= lang === 'en' ? 'Capacity' : 'Місткість' %></label>
                  <input class="form-control" id="sessionRoomCapacity" name="capacity" type="number" min="1" max="999" />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label" for="sessionRoomActive"><%= lang === 'en' ? 'Status' : 'Статус' %></label>
                  <select class="form-select" id="sessionRoomActive" name="is_active">
                    <option value="1"><%= lang === 'en' ? 'Active' : 'Активний' %></option>
                    <option value="0"><%= lang === 'en' ? 'Archived' : 'Архівний' %></option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label" for="sessionRoomNotes"><%= lang === 'en' ? 'Notes' : 'Нотатки' %></label>
                  <textarea class="form-control" id="sessionRoomNotes" name="notes" rows="2" maxlength="500"></textarea>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                  <button class="btn btn-outline-primary" type="submit"><%= lang === 'en' ? 'Save room' : 'Зберегти кабінет' %></button>
                  <button class="btn btn-outline-secondary" type="button" id="sessionRoomResetBtn"><%= lang === 'en' ? 'Reset form' : 'Очистити форму' %></button>
                </div>
              </form>
              <% if ((rooms || []).length) { %>
                <div class="d-grid gap-2">
                  <% (rooms || []).forEach(function(room) { %>
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 border rounded-4 p-3">
                      <div>
                        <div class="fw-semibold"><%= room.room_label || room.label || room.code || `Room ${room.id}` %></div>
                        <div class="session-subtle">
                          <%= room.room_type || 'classroom' %>
                          <% if (room.capacity) { %> · <%= room.capacity %> <%=(lang === 'en' ? 'seats' : 'місць')%><% } %>
                          <% if (Number(room.is_active || 0) !== 1) { %> · <%= lang === 'en' ? 'archived' : 'архів' %><% } %>
                        </div>
                      </div>
                      <div class="d-flex flex-wrap gap-2">
                        <button
                          class="btn btn-outline-secondary btn-sm"
                          type="button"
                          data-room-edit
                          data-room-id="<%= room.id %>"
                          data-room-building="<%= room.building || '' %>"
                          data-room-code="<%= room.code || '' %>"
                          data-room-label="<%= room.label || '' %>"
                          data-room-type="<%= room.room_type || 'classroom' %>"
                          data-room-capacity="<%= room.capacity || '' %>"
                          data-room-notes="<%= room.notes || '' %>"
                          data-room-active="<%= Number(room.is_active || 0) === 1 ? 1 : 0 %>"
                        >
                          <%= lang === 'en' ? 'Edit' : 'Редагувати' %>
                        </button>
                        <form method="POST" action="/admin/session-generator/rooms/<%= room.id %>/delete">
                          <input type="hidden" name="location" value="<%= activeLocation %>" />
                          <input type="hidden" name="course_id" value="<%= form && form.course_id ? form.course_id : '' %>" />
                          <input type="hidden" name="semester_id" value="<%= selectedSemesterId || (form && form.semester_id) || '' %>" />
                          <input type="hidden" name="draft_id" value="<%= draftMeta && draftMeta.id ? draftMeta.id : '' %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit"><%= lang === 'en' ? 'Archive' : 'Архівувати' %></button>
                        </form>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="liquid-alert info"><%= lang === 'en' ? 'No rooms yet for this course.' : 'Для цього курсу ще немає кабінетів.' %></div>
              <% } %>
            </div>
          </article>

          <form method="POST" action="/admin/session-generator/publish" class="card liquid-panel mb-4" data-session-action-form>
            <div class="card-body d-grid gap-2">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                  <div class="fw-semibold"><%= sessionGeneratorText.publishTitle %></div>
                  <div class="session-subtle" id="sessionPublishSourceHint"><%= sessionGeneratorText.publishSourceManual %></div>
                </div>
                <span class="mark-pill info"><%= sessionGeneratorText.events %>: <span id="sessionPublishCount">0</span></span>
              </div>
              <div class="session-subtle"><%= sessionGeneratorText.publishHint %></div>
              <div class="fw-semibold"><%= sessionGeneratorText.publishImpactTitle %></div>
              <div class="session-stat-grid">
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactSubjects %></div>
                  <div class="session-stat-value" id="sessionPublishSubjectCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactGroups %></div>
                  <div class="session-stat-value" id="sessionPublishGroupCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactExams %></div>
                  <div class="session-stat-value" id="sessionPublishExamCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactConsultations %></div>
                  <div class="session-stat-value" id="sessionPublishConsultationCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactCredits %></div>
                  <div class="session-stat-value" id="sessionPublishCreditCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactRooms %></div>
                  <div class="session-stat-value" id="sessionPublishRoomCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactConflicts %></div>
                  <div class="session-stat-value" id="sessionPublishConflictCount">0</div>
                </div>
                <div class="session-stat">
                  <div class="session-stat-label"><%= sessionGeneratorText.publishImpactOutOfWindow %></div>
                  <div class="session-stat-value" id="sessionPublishOutOfWindowCount">0</div>
                </div>
              </div>
              <div class="session-stat">
                <div class="session-stat-label"><%= sessionGeneratorText.publishImpactJournal %></div>
                <div class="session-stat-value" id="sessionPublishJournalStatus"><%= sessionGeneratorText.publishImpactJournalIdle %></div>
                <div class="session-subtle" id="sessionPublishImpactHint"><%= sessionGeneratorText.publishImpactHint %></div>
              </div>
              <input type="hidden" name="location" value="<%= activeLocation %>" />
              <input type="hidden" name="course_id" value="<%= form && form.course_id ? form.course_id : '' %>" />
              <input type="hidden" name="semester_id" value="<%= selectedSemesterId || (form && form.semester_id) || '' %>" />
              <input type="hidden" name="draft_id" value="<%= draftMeta && draftMeta.id ? draftMeta.id : '' %>" />
              <input type="hidden" name="window_mode" value="<%= form && form.window_mode ? form.window_mode : 'weeks' %>" />
              <input type="hidden" name="start_date" value="<%= form && form.start_date ? form.start_date : '' %>" />
              <input type="hidden" name="session_days" value="<%= form && form.session_days ? form.session_days : '' %>" />
              <input type="hidden" name="session_weeks_count" value="<%= form && form.session_weeks_count ? form.session_weeks_count : '' %>" />
              <input type="hidden" name="session_weeks_set" value="<%= form && form.session_weeks_set ? form.session_weeks_set : '' %>" />
              <input type="hidden" name="max_events_per_day" value="<%= form && form.max_events_per_day ? form.max_events_per_day : '' %>" />
              <input type="hidden" name="reserve_every" value="<%= form && form.reserve_every ? form.reserve_every : '' %>" />
              <input type="hidden" name="exam_gap_days" value="<%= form && form.exam_gap_days ? form.exam_gap_days : '' %>" />
              <input type="hidden" name="retake_gap_days" value="<%= form && form.retake_gap_days ? form.retake_gap_days : '' %>" />
              <input type="hidden" name="retake_window_days" value="<%= form && form.retake_window_days ? form.retake_window_days : '' %>" />
              <input type="hidden" name="include_weekends" value="<%= form && form.include_weekends ? 1 : 0 %>" />
              <input type="hidden" name="include_consultations" value="<%= form && form.include_consultations ? 1 : 0 %>" />
