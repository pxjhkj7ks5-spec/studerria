                  <div class="legend-item">
                    <span class="mark-pill <%= mark.tone || 'muted' %>"><%= mark.code %></span>
                    <span class="small"><%= mark.label %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>

        </div>

        <div class="col-12 col-xl-8">
          <% const manualSubjectRows = (subjects || [])
            .map(function(subject) {
              return {
                id: Number(subject.id),
                name: subject.name || '',
                group_count: Math.max(1, Number(subject.group_count || 1)),
              };
            })
            .filter(function(subject) { return Number.isFinite(subject.id) && subject.id > 0; })
            .sort(function(a, b) { return String(a.name || '').localeCompare(String(b.name || ''), 'uk'); }); %>

          <div class="card liquid-panel mb-4">
            <div class="card-body">
              <div class="panel-title-row">
                <h5>Ручне призначення сесії</h5>
                <span class="session-subtle">оберіть тип і предмет, потім клік по слоту</span>
              </div>
              <div class="row g-3">
                <div class="col-12 col-lg-4">
                  <div class="d-grid gap-2">
                    <div>
                      <label class="form-label">Тип контролю</label>
                      <div class="btn-group w-100" role="group" aria-label="Session type">
                        <button class="btn btn-outline-primary active" type="button" data-manual-type="exam">Екзамен</button>
                        <button class="btn btn-outline-secondary" type="button" data-manual-type="consultation">Консультація</button>
                        <button class="btn btn-outline-danger" type="button" data-manual-type="credit">Залік</button>
                      </div>
                    </div>
                    <div>
                      <label class="form-label" for="manualSubjectSelect">Предмет</label>
                      <select class="form-select" id="manualSubjectSelect">
                        <option value="">Оберіть предмет</option>
                        <% manualSubjectRows.forEach(function(subject) { %>
                          <option value="<%= subject.id %>"><%= subject.name %></option>
                        <% }); %>
                      </select>
                    </div>
                    <div>
                      <label class="form-label" for="manualGroupSelect">Група</label>
                      <select class="form-select" id="manualGroupSelect" disabled>
                        <option value="">Усі групи предмета</option>
                      </select>
                    </div>
                    <div class="liquid-alert info">
                      1) Оберіть тип (екзамен/консультація/залік), предмет і групу. 2) Натисніть слот у розкладі справа. 3) Повторний клік цим самим вибором видаляє подію.
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" type="button" id="manualPlanClearBtn">Очистити ручний план</button>
                  </div>
                </div>
                <div class="col-12 col-lg-8">
                  <% if (!(slotBoard && slotBoard.length)) { %>
                    <div class="timeline-empty">Немає слотів для поточних параметрів сесії.</div>
                  <% } else { %>
                    <div class="d-grid gap-2">
                      <% (slotBoard || []).forEach(function(day) { %>
                        <div class="slot-day-card">
                          <div class="slot-day-head">
                            <div>
                              <div class="timeline-day-title"><%= day.day_short || '' %> · <%= day.date || '' %></div>
                              <div class="timeline-day-subtitle"><%= day.day_name || '' %> · тиждень <%= day.week_number || '—' %></div>
                            </div>
                            <span class="mark-pill muted">вільно <%= day.free_count || 0 %> / зайнято <%= day.busy_count || 0 %></span>
                          </div>
                          <div class="slot-row-grid">
                            <% (day.slots || []).forEach(function(slot) { %>
                              <button
                                class="slot-cell <%= slot.is_busy ? 'is-busy' : 'is-free' %>"
                                type="button"
                                data-slot-btn
                                data-slot-date="<%= day.date || '' %>"
                                data-slot-day="<%= day.day_name || '' %>"
                                data-slot-class="<%= slot.class_number || '' %>"
                                data-slot-time="<%= slot.time_label || '' %>"
                              >
                                <div class="slot-cell-top">Пара <%= slot.class_number %></div>
                                <div class="slot-cell-time"><%= slot.time_label || '' %></div>
                                <% if (slot.is_busy && slot.busy && slot.busy.length) { %>
                                  <div class="slot-cell-content">
                                    <% slot.busy.slice(0, 2).forEach(function(busy, idx) { %>
                                      <div><%= busy.subject_name || 'Пара' %> · Г<%= busy.group_number || '-' %><%= idx === 1 && slot.busy.length > 2 ? '…' : '' %></div>
                                    <% }); %>
                                  </div>
                                <% } else { %>
                                  <div class="slot-cell-content text-muted">Вільний слот</div>
                                <% } %>
                                <div class="slot-cell-assignment" data-slot-assignment></div>
                              </button>
                            <% }); %>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

