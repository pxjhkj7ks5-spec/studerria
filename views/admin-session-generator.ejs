    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
      (function() {
        const themeToggle = document.getElementById('themeToggle');
        if (themeToggle) {
          const applyTheme = (theme) => {
            document.body.classList.toggle('theme-light', theme === 'light');
            document.body.classList.toggle('theme-dark', theme === 'dark');
            themeToggle.textContent = theme === 'light' ? (themeToggle.dataset.darkLabel || '🌙') : (themeToggle.dataset.lightLabel || '☀️');
          };
          const stored = localStorage.getItem('theme') || 'light';
          applyTheme(stored);
          themeToggle.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'light' : 'dark';
            localStorage.setItem('theme', next);
            applyTheme(next);
          });
        }

        const locationInput = document.getElementById('sessionLocationInput');
        const draftSwitcher = document.querySelector('[data-draft-switch]');
        const form = document.getElementById('sessionGeneratorForm');
        document.querySelectorAll('[data-location]').forEach((btn) => {
          btn.addEventListener('click', () => {
            if (!locationInput || !form) return;
            locationInput.value = btn.dataset.location || 'kyiv';
            form.submit();
          });
        });

        if (draftSwitcher) {
          draftSwitcher.addEventListener('change', () => {
            const url = String(draftSwitcher.value || '').trim();
            if (!url) return;
            window.location.href = url;
          });
        }

        const manualTypeButtons = Array.from(document.querySelectorAll('[data-manual-type]'));
        const manualSubjectSelect = document.getElementById('manualSubjectSelect');
        const manualGroupSelect = document.getElementById('manualGroupSelect');
        const manualPlanClearBtn = document.getElementById('manualPlanClearBtn');
        const manualAssignmentsInput = document.getElementById('manualAssignmentsInput');
        const publishBtn = document.getElementById('sessionPublishBtn');
        const checkConflictsBtn = document.getElementById('sessionCheckConflictsBtn');
        const publishSourceHint = document.getElementById('sessionPublishSourceHint');
        const publishCount = document.getElementById('sessionPublishCount');
        const slotButtons = Array.from(document.querySelectorAll('[data-slot-btn]'));

        const manualSubjects = <%- JSON.stringify(manualSubjectRows || []) %>;
        const manualSubjectMap = new Map((manualSubjects || []).map((subject) => [Number(subject.id), subject]));
        let manualSelectedType = 'exam';
        let manualAssignments = [];

        const escapeHtml = (rawValue) => String(rawValue || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');

        const assignmentKey = (item) => {
          const group = Number(item && item.group_number ? item.group_number : 0);
          return [
            String(item && item.date ? item.date : ''),
            String(item && item.class_number ? item.class_number : ''),
            String(item && item.subject_id ? item.subject_id : ''),
            String(item && item.type ? item.type : ''),
            String(group),
          ].join('|');
        };

        const sortAssignments = (rows) => [...(rows || [])].sort((a, b) => {
          const typeOrder = { exam: 1, consultation: 2, credit: 3 };
          const byDate = String(a.date || '').localeCompare(String(b.date || ''));
          if (byDate !== 0) return byDate;
          const byClass = Number(a.class_number || 0) - Number(b.class_number || 0);
          if (byClass !== 0) return byClass;
          if (a.type !== b.type) return Number(typeOrder[a.type] || 9) - Number(typeOrder[b.type] || 9);
          const bySubject = String(a.subject_name || '').localeCompare(String(b.subject_name || ''), 'uk');
          if (bySubject !== 0) return bySubject;
          return Number(a.group_number || 0) - Number(b.group_number || 0);
        });

        const syncManualTypeButtons = () => {
          manualTypeButtons.forEach((button) => {
            const type = String(button.dataset.manualType || '');
            const isActive = type === manualSelectedType;
            button.classList.toggle('active', isActive);
            button.classList.toggle('btn-outline-primary', !isActive && type === 'exam');
            button.classList.toggle('btn-primary', isActive && type === 'exam');
            button.classList.toggle('btn-outline-secondary', !isActive && type === 'consultation');
            button.classList.toggle('btn-secondary', isActive && type === 'consultation');
            button.classList.toggle('btn-outline-danger', !isActive && type === 'credit');
            button.classList.toggle('btn-danger', isActive && type === 'credit');
          });
        };

        const updateManualGroupOptions = () => {
          if (!manualGroupSelect || !manualSubjectSelect) return;
          const subjectId = Number(manualSubjectSelect.value || 0);
          const subject = manualSubjectMap.get(subjectId);
          if (!subject) {
            manualGroupSelect.innerHTML = '<option value="">Усі групи предмета</option>';
            manualGroupSelect.disabled = true;
            return;
          }
          const groupCount = Math.max(1, Number(subject.group_count || 1));
          const options = ['<option value="">Усі групи предмета</option>'];
          for (let index = 1; index <= groupCount; index += 1) {
            options.push(`<option value="${index}">Група ${index}</option>`);
          }
          manualGroupSelect.innerHTML = options.join('');
          manualGroupSelect.disabled = false;
        };

        const renderSlotAssignments = () => {
          slotButtons.forEach((button) => {
            const date = String(button.dataset.slotDate || '');
            const classNumber = Number(button.dataset.slotClass || 0);
            const slotRows = sortAssignments(manualAssignments.filter((item) =>
              String(item.date || '') === date && Number(item.class_number || 0) === classNumber
            ));
            const holder = button.querySelector('[data-slot-assignment]');
            if (!holder) return;
            if (!slotRows.length) {
              holder.innerHTML = '';
              button.classList.remove('is-assigned');
              return;
            }
            button.classList.add('is-assigned');
            const rowsHtml = slotRows.slice(0, 2).map((item) => `
              <div><span class="mark-pill ${item.type === 'credit' ? 'danger' : (item.type === 'consultation' ? 'muted' : 'info')}">${item.type === 'credit' ? 'Залік' : (item.type === 'consultation' ? 'Конс' : 'Екз')}</span> ${escapeHtml(item.subject_name)} · ${escapeHtml(item.group_label || 'Усі групи')}</div>
            `).join('');
            const moreHtml = slotRows.length > 2
              ? `<div class="small text-muted">+${slotRows.length - 2} ще</div>`
              : '';
            holder.innerHTML = rowsHtml + moreHtml;
          });
        };

        const syncPublishState = () => {
          if (!publishBtn || !manualAssignmentsInput) return;
          const rows = sortAssignments(manualAssignments);
          publishBtn.disabled = rows.length === 0;
          if (checkConflictsBtn) {
            checkConflictsBtn.disabled = rows.length === 0;
          }
          manualAssignmentsInput.value = rows.length ? JSON.stringify(rows.map((row) => ({
            subject_id: Number(row.subject_id || 0),
            type: row.type === 'credit' ? 'credit' : (row.type === 'consultation' ? 'consultation' : 'exam'),
            date: row.date || '',
            class_number: Number(row.class_number || 0),
            group_number: row.group_number ? Number(row.group_number) : null,
            note: row.note || '',
          }))) : '';
          if (publishSourceHint) {
            publishSourceHint.textContent = rows.length
              ? 'Джерело: ручний план'
              : 'Джерело: ручний план (порожньо)';
          }
          if (publishCount) {
            publishCount.textContent = String(rows.length);
          }
        };

        const toggleManualAssignmentFromSlot = (button) => {
          if (!button || !manualSubjectSelect) return;
          const subjectId = Number(manualSubjectSelect.value || 0);
          const subject = manualSubjectMap.get(subjectId);
          if (!subject) {
            window.alert('Оберіть предмет перед додаванням події.');
            return;
          }
          const classNumber = Number(button.dataset.slotClass || 0);
          const date = String(button.dataset.slotDate || '');
          const dayName = String(button.dataset.slotDay || '');
          if (!classNumber || !date) return;
          const groupNumber = manualGroupSelect && manualGroupSelect.value
            ? Number(manualGroupSelect.value)
            : null;
          const groupLabel = groupNumber
            ? `Група ${groupNumber}`
            : (Number(subject.group_count || 1) > 1 ? `Всі групи (${subject.group_count})` : 'Всі');
          const candidate = {
            subject_id: Number(subject.id),
            subject_name: String(subject.name || ''),
            group_number: Number.isFinite(groupNumber) && groupNumber > 0 ? groupNumber : null,
            group_label: groupLabel,
            type: manualSelectedType,
            date,
            day_name: dayName,
            class_number: classNumber,
            note: '',
          };
          const key = assignmentKey(candidate);
          const existingIndex = manualAssignments.findIndex((item) => assignmentKey(item) === key);
          if (existingIndex >= 0) {
            manualAssignments.splice(existingIndex, 1);
          } else {
            manualAssignments.push(candidate);
          }
          renderSlotAssignments();
          syncPublishState();
        };

        if (manualSubjectSelect && !manualSubjectSelect.value && manualSubjects.length) {
          manualSubjectSelect.value = String(manualSubjects[0].id);
        }
        updateManualGroupOptions();
        syncManualTypeButtons();
        renderSlotAssignments();
        syncPublishState();

        manualTypeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const type = String(button.dataset.manualType || '').trim();
            manualSelectedType = type === 'credit'
              ? 'credit'
              : (type === 'consultation' ? 'consultation' : 'exam');
            syncManualTypeButtons();
          });
        });
        if (manualSubjectSelect) {
          manualSubjectSelect.addEventListener('change', updateManualGroupOptions);
        }
        if (manualPlanClearBtn) {
          manualPlanClearBtn.addEventListener('click', () => {
            manualAssignments = [];
            renderSlotAssignments();
            syncPublishState();
          });
        }
        slotButtons.forEach((button) => {
          button.addEventListener('click', () => {
            toggleManualAssignmentFromSlot(button);
          });
        });

        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
          if (window.bootstrap && window.bootstrap.Tooltip) {
            window.bootstrap.Tooltip.getOrCreateInstance(el);
          }
        });
      })();
    </script>
    <script src="/js/design-system.js" defer></script>
  </body>
</html>
