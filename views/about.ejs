<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studerria · Про сайт</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/pages/about.css" />
    <link rel="stylesheet" href="/css/modal-enhanced.css" />
  </head>
  <body class="studerria-theme theme-dark page-about page-local-topbar">
    <%- include('partials/topbar', { role, username, t, activePage: 'about', pageTitle: 'Про сайт' }) %>

    <section class="studerria-about-shell" aria-labelledby="studerria-about-title">
      <article class="glass-panel studerria-about-hero">
        <div class="studerria-about-badges" aria-hidden="true">
          <span class="status-chip status-chip--info">Про сайт</span>
          <span class="status-chip status-chip--neutral">Візія</span>
        </div>
        <div class="studerria-about-hero-grid">
          <div class="studerria-about-copy">
            <p class="studerria-about-overline">Studerria</p>
            <h1 class="studerria-about-title" id="studerria-about-title">Studerria</h1>
            <p class="studerria-about-subtitle">Про сайт / Візія</p>
            <p class="studerria-about-lead">
              Єдиний навчальний простір для розкладу, журналу, командної роботи, персонального простору та моніторингу успішності вашого навчання або викладання.
            </p>
          </div>
        </div>
      </article>

      <section class="studerria-about-grid" aria-label="Studerria overview cards">
        <% (aboutCards || []).forEach(function(card) { %>
          <article class="glass-panel studerria-about-card">
            <div class="studerria-about-card-head">
              <span class="<%= card.chipClass %>"><%= card.kicker %></span>
              <h2 class="studerria-about-card-title"><%= card.title %></h2>
            </div>
            <p class="studerria-about-card-copy"><%= card.body %></p>
            <ul class="studerria-about-list">
              <% (card.items || []).forEach(function(item) { %>
                <li><span><%= item %></span></li>
              <% }); %>
            </ul>
          </article>
        <% }); %>
      </section>

      <%- include('partials/app-footer') %>
    </section>

    <%- include('partials/changelog-modal') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/js/design-system.js" defer></script>
  </body>
</html>
