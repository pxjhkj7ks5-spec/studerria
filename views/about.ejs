<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studerria · <%= aboutPage && aboutPage.pageTitle ? aboutPage.pageTitle : (lang === 'en' ? 'About' : 'Про сайт') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/pages/about.css" />
    <link rel="stylesheet" href="/css/modal-enhanced.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/mobile-workflows.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-about page-local-topbar">
    <%- include('partials/topbar', { role, username, t, activePage: 'about', pageTitle: aboutPage && aboutPage.pageTitle ? aboutPage.pageTitle : (lang === 'en' ? 'About' : 'Про сайт') }) %>

    <section class="studerria-about-shell" aria-labelledby="studerria-about-title">
      <article class="glass-panel studerria-about-hero">
        <div class="studerria-about-badges" aria-hidden="true">
          <span class="status-chip status-chip--info"><%= aboutPage && aboutPage.badgePrimary ? aboutPage.badgePrimary : (lang === 'en' ? 'About' : 'Про сайт') %></span>
          <span class="status-chip status-chip--neutral"><%= aboutPage && aboutPage.badgeSecondary ? aboutPage.badgeSecondary : (lang === 'en' ? 'Vision' : 'Візія') %></span>
        </div>
        <div class="studerria-about-hero-grid">
          <div class="studerria-about-copy">
            <p class="studerria-about-overline">Studerria</p>
            <h1 class="studerria-about-title" id="studerria-about-title">Studerria</h1>
            <p class="studerria-about-subtitle"><%= aboutPage && aboutPage.subtitle ? aboutPage.subtitle : (lang === 'en' ? 'About / Vision' : 'Про сайт / Візія') %></p>
            <p class="studerria-about-lead"><%= aboutPage && aboutPage.lead ? aboutPage.lead : '' %></p>
            <% if (aboutPage && aboutPage.intro) { %>
              <p class="studerria-about-lead"><%= aboutPage.intro %></p>
            <% } %>
          </div>
        </div>
      </article>

      <section class="studerria-about-grid" aria-label="<%= lang === 'en' ? 'Studerria overview cards' : 'Картки огляду Studerria' %>">
        <% ((aboutPage && aboutPage.cards) || []).forEach(function(card) { %>
          <article class="glass-panel studerria-about-card">
            <div class="studerria-about-card-head">
              <span class="<%= card.chipClass %>"><%= card.kicker %></span>
              <h2 class="studerria-about-card-title"><%= card.title %></h2>
            </div>
            <p class="studerria-about-card-copy"><%= card.body %></p>
            <ul class="studerria-about-list">
              <% (card.items || []).forEach(function(item) { %>
                <li><span><%= item %></span></li>
              <% }); %>
            </ul>
          </article>
        <% }); %>
      </section>

      <%- include('partials/app-footer') %>
    </section>

    <%- include('partials/changelog-modal') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script src="/js/design-system.js" defer></script>
  </body>
</html>
