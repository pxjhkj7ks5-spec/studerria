<!doctype html>
<html lang="<%= lang %>" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title><%= legalTitle %> · Studerria</title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--legal" data-theme="light">
    <main class="td-legal-main">
      <a class="td-legal-logo" href="/login" aria-label="Studerria login">
        <%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %>
      </a>

      <article class="td-legal-card td-glass-panel">
        <header class="td-legal-head">
          <a class="td-legal-back" href="/login"><%= t('legal.backToLogin') %></a>
          <p class="td-lite-kicker">Studerria</p>
          <h1><%= legalTitle %></h1>
          <p><%= legalLead %></p>
          <span><%= t('legal.lastUpdated') %></span>
        </header>

        <div class="td-legal-sections">
          <% legalSections.forEach(function(section) { %>
            <section class="td-legal-section">
              <h2><%= section.title %></h2>
              <% if (section.body) { %>
                <p><%= section.body %></p>
              <% } %>
              <% if (section.items && section.items.length) { %>
                <ul>
                  <% section.items.forEach(function(item) { %>
                    <li><%= item %></li>
                  <% }); %>
                </ul>
              <% } %>
            </section>
          <% }); %>
        </div>
      </article>
    </main>

    <%- include('partials/app-footer') %>
    <script src="/js/studerria-background.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
    <script src="/js/login-auth.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
