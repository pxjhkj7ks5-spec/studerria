<!doctype html>
<html lang="<%= lang || 'uk' %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title>Studerria Vision</title>
    <link rel="stylesheet" href="/css/vision-bg.css" />
    <%- include('partials/studerria-system-head') %>
  </head>
  <body class="studerria-theme theme-dark page-vision" data-theme="dark">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/vision-bg') %>

    <div class="vision-shell">
      <header class="vision-header">
        <a href="/" class="vision-logo" aria-label="Studerria home">Studerria</a>
        <nav class="vision-nav" aria-label="Design system sections">
          <a href="#schedule">Schedule</a>
          <a href="#admin">Admin</a>
          <a href="#profile">Profile</a>
          <a href="#primitives">Primitives</a>
        </nav>
        <div class="vision-header-actions">
          <button
            type="button"
            class="theme-toggle"
            id="visionThemeToggle"
            data-light-label="Світла"
            data-dark-label="Темна"
            aria-label="Toggle theme"
          >
            Світла
          </button>
          <a class="signup-btn" href="/login">Open app</a>
        </div>
      </header>

      <main class="vision-main">
        <section class="hero-section" id="schedule">
          <div class="hero-copy">
            <p class="hero-kicker">Studerria visual system</p>
            <h1>Calm product surfaces for daily study work.</h1>
            <p>
              One restrained interface language for schedule, admin, profile, login and future dashboard
              screens: deep indigo in dark mode, soft lavender daylight in light mode, and liquid-glass
              only where it improves hierarchy.
            </p>
            <div class="hero-actions">
              <a href="/schedule" class="btn-primary">Schedule</a>
              <a href="#primitives" class="btn-secondary">View primitives</a>
            </div>
          </div>

          <article class="vision-showcase" aria-label="Schedule reference">
            <header class="vision-showcase-head">
              <div>
                <p class="st-kicker">Schedule surface</p>
                <h2 class="st-title">Тиждень 14</h2>
              </div>
              <span class="st-badge">Сьогодні</span>
            </header>

            <div class="vision-days" aria-label="Week cards">
              <div class="vision-day is-active"><strong>Пн</strong><span>14 квіт · 4 пари</span></div>
              <div class="vision-day"><strong>Вт</strong><span>15 квіт · 4 пари</span></div>
              <div class="vision-day"><strong>Ср</strong><span>16 квіт · 3 пари</span></div>
              <div class="vision-day"><strong>Чт</strong><span>17 квіт · 5 пар</span></div>
              <div class="vision-day"><strong>Пт</strong><span>18 квіт · 4 пари</span></div>
              <div class="vision-day"><strong>Сб</strong><span>19 квіт · —</span></div>
            </div>

            <div class="vision-lessons">
              <article class="vision-lesson">
                <div class="vision-lesson-number">1</div>
                <div>
                  <h3>Правознавство</h3>
                  <p>10:00 - 11:20 · група 1 · ауд. 201</p>
                </div>
                <span class="st-badge">Лекція</span>
              </article>
              <article class="vision-lesson">
                <div class="vision-lesson-number">2</div>
                <div>
                  <h3>Політологія</h3>
                  <p>11:40 - 13:00 · група 2 · ауд. 305</p>
                </div>
                <span class="st-badge">Семінар</span>
              </article>
              <article class="vision-lesson">
                <div class="vision-lesson-number">3</div>
                <div>
                  <h3>Іноземна мова</h3>
                  <p>15:10 - 16:30 · група 3 · ауд. 409</p>
                </div>
                <span class="st-badge">Практика</span>
              </article>
            </div>
          </article>
        </section>

        <section class="vision-system" id="admin">
          <aside class="threads-panel" aria-label="Admin navigation reference">
            <div class="panel-head">
              <p class="st-kicker">Navigation</p>
              <h2>Адмін-панель</h2>
              <p>Compact sidebars, calm active states, readable labels and no decorative overload.</p>
            </div>
            <div class="threads-list">
              <article class="thread-card"><h3>Overview</h3><p>Primary status and key actions.</p></article>
              <article class="thread-card"><h3>Academic Setup</h3><p>Program, term and schedule structure.</p></article>
              <article class="thread-card"><h3>Messages</h3><p>Communication tools stay visually secondary.</p></article>
            </div>
          </aside>

          <section class="conversation-panel" id="profile" aria-label="Profile and controls reference">
            <header class="conversation-head">
              <div class="avatar" aria-hidden="true">MA</div>
              <div>
                <p class="st-kicker">Profile surface</p>
                <h2>Редагування профілю</h2>
                <p>Centered card language shared by login and profile forms.</p>
              </div>
            </header>

            <div class="conversation-stream" role="list">
              <article class="message" role="listitem">
                <h3>Primary card</h3>
                <p>Liquid-glass is strongest on focused surfaces like login and profile.</p>
              </article>
              <article class="message" role="listitem">
                <h3>Data cards</h3>
                <p>Schedule and admin content stays more solid for readability.</p>
              </article>
              <article class="message" role="listitem">
                <h3>Light mode</h3>
                <p>The same geometry and accents, translated into soft daylight materials.</p>
              </article>
            </div>

            <form class="conversation-compose" action="#" method="post" onsubmit="return false;">
              <label for="visionConversationInput" class="sr-only">Reference input</label>
              <input id="visionConversationInput" type="text" value="Марченко Андрій" aria-label="Reference input" />
              <button type="submit">Save</button>
            </form>

            <footer>
              <span>Deep indigo</span>
              <span>Restrained purple</span>
              <strong>Production UI</strong>
            </footer>
          </section>
        </section>

        <section class="vision-primitives" id="primitives" aria-label="Reusable primitives">
          <article class="vision-primitive"><strong>Page Background</strong><span>Dark indigo and soft daylight gradients with one restrained wave layer.</span></article>
          <article class="vision-primitive"><strong>Liquid Surface</strong><span>Used on nav, login, profile and selected elevated panels.</span></article>
          <article class="vision-primitive"><strong>Data Surface</strong><span>More opaque cards for schedule rows, metrics, tables and lists.</span></article>
          <article class="vision-primitive"><strong>Controls</strong><span>Rounded inputs, ghost buttons, gradient CTA and visible focus rings.</span></article>
        </section>
      </main>
    </div>

    <script src="/js/vision-bg.js" defer></script>
  </body>
</html>
