<!doctype html>
<html lang="uk" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Studerria Design Lab</title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--hub" data-theme="light">
    <main class="td-hub-shell" aria-label="Studerria design experiments">
      <header class="td-hub-hero td-glass-panel">
        <a class="td-hub-brand" href="/vision" aria-label="Studerria">
          <span class="td-hub-mark" aria-hidden="true">
            <%- include('partials/test-brand-mark', { className: 'td-brand-glyph' }) %>
          </span>
          <span>Studerria</span>
        </a>
        <button class="td-theme-toggle td-hub-theme-toggle" type="button" data-theme-toggle aria-label="Увімкнути темну тему" aria-pressed="false">
          <%- include('partials/test-icon', { name: 'moon', className: 'td-button-icon td-theme-moon' }) %>
          <%- include('partials/test-icon', { name: 'sun', className: 'td-button-icon td-theme-sun' }) %>
          <span data-theme-label>Dark</span>
        </button>
        <p class="td-eyebrow">Design experiment</p>
        <h1>Studerria Design Lab</h1>
        <p>
          Apple-inspired redesign experiments for a calm academic workspace:
          violet primary actions, glass surfaces, top navigation, and soft
          blue-lavender light mode.
        </p>
      </header>

      <section class="td-hub-grid" aria-label="Test pages">
        <a class="td-hub-card td-surface-card" href="/testlogin">
          <span class="td-card-icon">
            <%- include('partials/test-icon', { name: 'lock', className: 'td-card-svg' }) %>
          </span>
          <span class="td-hub-card-copy">
            <strong>Login concept</strong>
            <small>Clean centered sign-in card with premium glass details.</small>
          </span>
          <%- include('partials/test-icon', { name: 'arrowRight', className: 'td-hub-arrow' }) %>
        </a>

        <a class="td-hub-card td-surface-card" href="/testhome">
          <span class="td-card-icon">
            <%- include('partials/test-icon', { name: 'home', className: 'td-card-svg' }) %>
          </span>
          <span class="td-hub-card-copy">
            <strong>Home concept</strong>
            <small>Dashboard with top navbar, stats, tasks, progress, and AI strip.</small>
          </span>
          <%- include('partials/test-icon', { name: 'arrowRight', className: 'td-hub-arrow' }) %>
        </a>

        <a class="td-hub-card td-surface-card" href="/testschedule">
          <span class="td-card-icon">
            <%- include('partials/test-icon', { name: 'calendar', className: 'td-card-svg' }) %>
          </span>
          <span class="td-hub-card-copy">
            <strong>Schedule concept</strong>
            <small>Weekly calendar grid with soft event blocks and visible rhythm.</small>
          </span>
          <%- include('partials/test-icon', { name: 'arrowRight', className: 'td-hub-arrow' }) %>
        </a>
      </section>

      <section class="td-system-panel td-glass-panel" aria-label="Design system notes">
        <div>
          <p class="td-eyebrow">System direction</p>
          <h2>Liquid minimal Studerria</h2>
        </div>
        <div class="td-system-list">
          <span>Violet primary actions</span>
          <span>Apple-like top navigation</span>
          <span>Soft glass surfaces</span>
          <span>Calm academic workspace</span>
        </div>
      </section>
    </main>
    <script src="/js/test-design.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
