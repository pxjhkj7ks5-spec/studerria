<script>
  (function bootstrapStuderriaTestTheme() {
    var root = document.documentElement;
    var stored = null;
    try {
      stored = localStorage.getItem('studerria-test-theme');
    } catch (_error) {}
    var theme = stored === 'dark' ? 'dark' : 'light';
    root.setAttribute('data-theme', theme);
    window.__studerriaTestTheme = theme;
  })();
</script>
