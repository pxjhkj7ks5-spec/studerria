<%
  const activeSection = typeof active !== 'undefined' ? String(active) : 'home';
  const mainNavItems = [
    { id: 'home', label: 'Home', href: '/testhome', icon: 'home' },
    { id: 'schedule', label: 'Schedule', href: '/testschedule', icon: 'calendar' },
    { id: 'homework', label: 'Homework', href: '#homework', icon: 'homework' },
    { id: 'messages', label: 'Messages', href: '#messages', icon: 'messages' },
    { id: 'teamwork', label: 'Teamwork', href: '#teamwork', icon: 'teamwork' },
    { id: 'materials', label: 'Resources', href: '#materials', icon: 'files' },
    { id: 'grades', label: 'Grades', href: '#grades', icon: 'grades' }
  ];
  const adminNavItems = [
    { id: 'admin', label: 'Admin', href: '#admin', icon: 'admin' },
    { id: 'students', label: 'Students', href: '#students', icon: 'users' },
    { id: 'subjects', label: 'Subjects', href: '#subjects', icon: 'book' },
    { id: 'setup', label: 'Academic setup', href: '#setup', icon: 'settings' }
  ];
%>
<header class="td-mobile-topbar" aria-label="Studerria mobile navigation">
  <button class="td-icon-button td-sidebar-toggle" type="button" data-sidebar-toggle aria-label="Відкрити навігацію" aria-expanded="false">
    <%- include('test-icon', { name: 'menu', className: 'td-button-icon' }) %>
  </button>
  <a class="td-mobile-brand" href="/vision" aria-label="Studerria Design Lab">
    <span class="td-brand-mark" aria-hidden="true">
      <%- include('test-brand-mark', { className: 'td-brand-glyph' }) %>
    </span>
    <span>Studerria</span>
  </a>
  <button class="td-icon-button td-theme-toggle" type="button" data-theme-toggle aria-label="Увімкнути темну тему" aria-pressed="false">
    <%- include('test-icon', { name: 'moon', className: 'td-button-icon td-theme-moon' }) %>
    <%- include('test-icon', { name: 'sun', className: 'td-button-icon td-theme-sun' }) %>
  </button>
</header>

<aside class="td-sidebar" aria-label="Studerria test sidebar">
  <div class="td-sidebar-inner">
    <div class="td-sidebar-top">
      <a class="td-sidebar-brand" href="/vision" aria-label="Studerria Design Lab">
        <span class="td-brand-mark" aria-hidden="true">
          <%- include('test-brand-mark', { className: 'td-brand-glyph' }) %>
        </span>
        <span class="td-sidebar-brand-copy">
          <strong>Studerria</strong>
          <small>Student OS</small>
        </span>
      </a>
      <button class="td-icon-button td-theme-toggle td-sidebar-theme" type="button" data-theme-toggle aria-label="Увімкнути темну тему" aria-pressed="false">
        <%- include('test-icon', { name: 'moon', className: 'td-button-icon td-theme-moon' }) %>
        <%- include('test-icon', { name: 'sun', className: 'td-button-icon td-theme-sun' }) %>
      </button>
    </div>

    <nav class="td-sidebar-nav" aria-label="Основна навігація">
      <span class="td-sidebar-section-title">Student</span>
      <% mainNavItems.forEach(function(item) { %>
        <a
          href="<%= item.href %>"
          class="td-sidebar-link <%= item.id === activeSection ? 'is-active' : '' %>"
          <%= item.id === activeSection ? 'aria-current="page"' : '' %>
        >
          <%- include('test-icon', { name: item.icon, className: 'td-sidebar-icon' }) %>
          <span><%= item.label %></span>
        </a>
      <% }); %>
    </nav>

    <nav class="td-sidebar-nav td-sidebar-nav--secondary" aria-label="Адміністративний preview">
      <span class="td-sidebar-section-title">Staff preview</span>
      <% adminNavItems.forEach(function(item) { %>
        <a href="<%= item.href %>" class="td-sidebar-link <%= item.id === activeSection ? 'is-active' : '' %>">
          <%- include('test-icon', { name: item.icon, className: 'td-sidebar-icon' }) %>
          <span><%= item.label %></span>
        </a>
      <% }); %>
    </nav>

    <div class="td-sidebar-spacer"></div>

    <div class="td-sidebar-footer">
      <a class="td-sidebar-link td-sidebar-link--settings <%= activeSection === 'settings' ? 'is-active' : '' %>" href="#settings">
        <%- include('test-icon', { name: 'settings', className: 'td-sidebar-icon' }) %>
        <span>Settings</span>
      </a>
      <div class="td-sidebar-user">
        <span class="td-avatar" aria-hidden="true">А</span>
        <span class="td-user-copy">
          <strong>Андрій Марченко</strong>
          <small>Студент</small>
        </span>
      </div>
      <button class="td-sidebar-logout" type="button">
        <%- include('test-icon', { name: 'logout', className: 'td-sidebar-icon' }) %>
        <span>Logout</span>
      </button>
    </div>
  </div>
</aside>
<button class="td-sidebar-backdrop" type="button" data-sidebar-dismiss aria-label="Закрити навігацію"></button>
