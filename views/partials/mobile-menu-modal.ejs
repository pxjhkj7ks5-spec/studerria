<%
  const isMyDay = activePage === 'my-day';
  const isProfile = activePage === 'profile';
  const isTeamwork = activePage === 'teamwork';
  const isSubjects = activePage === 'subjects';
  const isJournal = activePage === 'journal';
  const isTeacherWorkspace = activePage === 'teacher-workspace';
  const mobileSettings = (typeof settings !== 'undefined') ? settings : null;
  const mobileHasCustomAdminPanelAccess = (typeof hasCustomAdminPanelAccess !== 'undefined')
    ? Boolean(hasCustomAdminPanelAccess)
    : false;
  const mobileCustomAdminPanelHref = (typeof customAdminPanelHref !== 'undefined')
    ? customAdminPanelHref
    : '/admin';
%>
<div class="modal fade" id="mobileMenuModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Меню</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="d-grid gap-2">
          <% if (role === 'admin') { %>
            <form method="POST" action="/admin/switch-to-admin">
              <button class="btn w-100 glass mobile-menu-action" type="submit">🛠️ <%= t('schedule.backToAdmin') %></button>
            </form>
          <% } else if (mobileHasCustomAdminPanelAccess) { %>
            <a class="btn w-100 glass mobile-menu-action" href="<%= mobileCustomAdminPanelHref || '/admin' %>">🛠️ <%= t('schedule.backToAdmin') %></a>
          <% } %>
          <% if (role === 'starosta') { %>
            <a class="btn w-100 glass mobile-menu-action" href="/starosta">🧑‍🏫 <%= t('menu.starosta') %></a>
          <% } %>
          <% if (role === 'deanery') { %>
            <a class="btn w-100 glass mobile-menu-action" href="/deanery">🏛️ <%= t('menu.deanery') %></a>
          <% } %>
          <% if (!isMyDay) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/home">🏠 Головна</a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">📅 Розклад</a>
          <% } %>
          <% if (!isJournal) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/journal">📘 Журнал</a>
          <% } %>
          <% if (!isTeamwork) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/teamwork">🤝 <%= t('menu.teamwork') %></a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">📅 Повернутись до розкладу</a>
          <% } %>
          <% if (role === 'teacher' && !isTeacherWorkspace) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/teacher/workspace">Teacher workspace</a>
          <% } %>
          <% if (!isSubjects) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/subjects">📚 Предмети</a>
          <% } %>
          <% if ((activePage === 'schedule' || isMyDay) && mobileSettings && mobileSettings.allow_custom_deadlines) { %>
            <% if (activePage === 'schedule') { %>
              <button class="btn w-100 glass mobile-menu-action" type="button" data-bs-toggle="modal" data-bs-target="#customDeadlineModal">
                🌀 Дивні дедлайни
              </button>
            <% } else { %>
              <a class="btn w-100 glass mobile-menu-action" href="/schedule">🌀 Дивні дедлайни</a>
            <% } %>
          <% } %>
          <% if ((activePage === 'schedule' || isMyDay) && mobileSettings && mobileSettings.allow_messages) { %>
            <% if (activePage === 'schedule') { %>
              <button class="btn w-100 glass mobile-menu-action" type="button" id="messagesBtnMobile" aria-label="<%= t('messages.aria') %>">
                💬 Повідомлення
              </button>
            <% } else { %>
              <a class="btn w-100 glass mobile-menu-action" href="/schedule">💬 Повідомлення</a>
            <% } %>
          <% } %>
          <% if (!isProfile) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/profile">👤 <%= t('schedule.profile') %></a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">📅 Повернутись до розкладу</a>
          <% } %>
          <button
            class="btn w-100 glass mobile-menu-action theme-toggle"
            type="button"
            data-light-label="☀️ Зміна теми"
            data-dark-label="🌙 Зміна теми"
          >
            🌙 Зміна теми
          </button>
          <form method="POST" action="/logout">
            <button class="btn w-100 glass mobile-menu-action" type="submit">🚪 <%= t('schedule.logout') %></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
