<%
  const isMyDay = activePage === 'my-day';
  const isProfile = activePage === 'profile';
  const isTeamwork = activePage === 'teamwork';
  const isSubjects = activePage === 'subjects';
  const isJournal = activePage === 'journal';
%>
<div class="modal fade" id="mobileMenuModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Меню</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="d-grid gap-2">
          <% if (isSubjects) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">Повернутись до розкладу</a>
            <button
              class="btn w-100 glass mobile-menu-action theme-toggle"
              type="button"
              data-light-label="☀️"
              data-dark-label="🌙"
            >
              🌙
            </button>
          <% } else { %>
          <% if (role === 'admin') { %>
            <form method="POST" action="/admin/switch-to-admin">
              <button class="btn w-100 glass mobile-menu-action" type="submit"><%= t('schedule.backToAdmin') %></button>
            </form>
          <% } else if (hasCustomAdminPanelAccess) { %>
            <a class="btn w-100 glass mobile-menu-action" href="<%= customAdminPanelHref || '/admin' %>"><%= t('schedule.backToAdmin') %></a>
          <% } %>
          <% if (role === 'starosta') { %>
            <a class="btn w-100 glass mobile-menu-action" href="/starosta"><%= t('menu.starosta') %></a>
          <% } %>
          <% if (role === 'deanery') { %>
            <a class="btn w-100 glass mobile-menu-action" href="/deanery"><%= t('menu.deanery') %></a>
          <% } %>
          <% if (activePage === 'schedule' && settings && settings.allow_messages) { %>
            <button class="btn w-100 glass mobile-menu-action" type="button" id="messagesBtnMobile" aria-label="<%= t('messages.aria') %>">
              💬 Повідомлення
            </button>
          <% } %>
          <% if (!isMyDay) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/my-day">Головна</a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">Повернутись до розкладу</a>
          <% } %>
          <% if (!isSubjects) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/subjects">Предмети</a>
          <% } %>
          <% if (!isJournal) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/journal">Журнал</a>
          <% } %>
          <% if (!isTeamwork) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/teamwork"><%= t('menu.teamwork') %></a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">Повернутись до розкладу</a>
          <% } %>
          <button
            class="btn w-100 glass mobile-menu-action theme-toggle"
            type="button"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <% if (!isProfile) { %>
            <a class="btn w-100 glass mobile-menu-action" href="/profile"><%= t('schedule.profile') %></a>
          <% } else { %>
            <a class="btn w-100 glass mobile-menu-action" href="/schedule">Повернутись до розкладу</a>
          <% } %>
          <form method="POST" action="/logout">
            <button class="btn w-100 glass mobile-menu-action" type="submit"><%= t('schedule.logout') %></button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
