<footer class="app-footer td-login-footer">
  <button
    type="button"
    class="td-language-pill"
    data-lang-toggle
    data-current-lang="<%= lang === 'en' ? 'en' : 'uk' %>"
    aria-label="<%= lang === 'en' ? t('language.switchToUkrainian') : t('language.switchToEnglish') %>"
  ><%= lang === 'en' ? 'EN' : 'UA' %> <%- include('test-icon', { name: 'chevronDown', className: 'td-mini-chevron' }) %></button>
  <button type="button" class="td-language-pill td-theme-toggle" id="tdThemeToggleMirror" data-theme-toggle aria-label="<%= t('theme.toggleToDark') %>" aria-pressed="false">
    <%- include('test-icon', { name: 'moon', className: 'td-mini-chevron td-theme-moon' }) %>
    <%- include('test-icon', { name: 'sun', className: 'td-mini-chevron td-theme-sun' }) %>
    <span data-theme-label>Dark</span>
  </button>
  <a class="footer-link" href="/help"><%= t('footer.support') %></a>
  <a class="footer-link" href="/terms"><%= t('footer.terms') %></a>
  <a class="footer-link" href="/privacy"><%= t('footer.privacy') %></a>
  <button type="button" class="td-footer-link footer-link" data-auth-changelog-open><%= t('footer.changelog') %></button>
  <span class="footer-signature"><%= t('footer.copyright') %></span>
</footer>
<%- include('auth-lite-changelog') %>
<script>
  if (!window.__appFooterControlsBound) {
    const normalizeTheme = (rawValue) => {
      const value = String(rawValue || '').trim().toLowerCase();
      if (value === 'dark' || value === 'theme-dark') return 'dark';
      if (value === 'light' || value === 'theme-light') return 'light';
      return '';
    };

    const readStoredTheme = () => {
      try {
        return (
          normalizeTheme(window.localStorage.getItem('ui-theme'))
          || normalizeTheme(window.localStorage.getItem('studerria-test-theme'))
        );
      } catch (_error) {
        return '';
      }
    };

    const resolveTheme = () => {
      const body = document.body;
      const root = document.documentElement;
      if (body && body.classList.contains('theme-dark')) return 'dark';
      if (body && body.classList.contains('theme-light')) return 'light';
      const bodyTheme = body ? normalizeTheme(body.getAttribute('data-theme')) : '';
      if (bodyTheme) return bodyTheme;
      const rootTheme = normalizeTheme(root && root.getAttribute('data-theme'));
      return rootTheme || readStoredTheme() || 'light';
    };

    const syncThemeControls = (theme) => {
      const isDark = theme === 'dark';
      document.querySelectorAll('[data-theme-toggle]').forEach((control) => {
        if (!(control instanceof HTMLElement)) return;
        control.setAttribute('aria-pressed', isDark ? 'true' : 'false');
        control.setAttribute('aria-label', isDark
          ? <%- JSON.stringify(t('theme.toggleToLight')) %>
          : <%- JSON.stringify(t('theme.toggleToDark')) %>);
        control.querySelectorAll('[data-theme-label]').forEach((label) => {
          label.textContent = isDark ? 'Light' : 'Dark';
        });
      });
    };

    const persistTheme = (theme) => {
      try {
        window.localStorage.setItem('ui-theme', theme === 'dark' ? 'theme-dark' : 'theme-light');
        window.localStorage.setItem('studerria-test-theme', theme);
      } catch (_error) {}
    };

    const applyTheme = (theme) => {
      const next = theme === 'dark' ? 'dark' : 'light';
      const body = document.body;
      const root = document.documentElement;
      root.setAttribute('data-theme', next);
      if (body) {
        body.setAttribute('data-theme', next);
        body.classList.remove('theme-light', 'theme-dark', 'light', 'dark');
        body.classList.add(next === 'dark' ? 'theme-dark' : 'theme-light');
      }
      persistTheme(next);
      syncThemeControls(next);
      window.dispatchEvent(new CustomEvent('studerria:theme-toggled', {
        detail: { theme: next === 'dark' ? 'theme-dark' : 'theme-light' },
      }));
    };

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      if (!target) return;

      const langButton = target.closest('.app-footer [data-lang-toggle]');
      if (langButton instanceof HTMLElement) {
        event.preventDefault();
        event.stopImmediatePropagation();
        const current = String(langButton.getAttribute('data-current-lang') || document.documentElement.lang || 'uk')
          .trim()
          .toLowerCase();
        const next = current === 'en' ? 'uk' : 'en';
        const url = new URL(window.location.href);
        url.searchParams.set('lang', next);
        window.location.assign(url.toString());
        return;
      }

      const themeButton = target.closest('.app-footer [data-theme-toggle]');
      if (themeButton instanceof HTMLElement) {
        event.preventDefault();
        event.stopImmediatePropagation();
        applyTheme(resolveTheme() === 'dark' ? 'light' : 'dark');
        return;
      }

      const changelogModal = document.querySelector('[data-auth-changelog]');
      if (!changelogModal) return;
      const changelogSheet = changelogModal.querySelector('.td-lite-sheet');
      const open = target.closest('[data-auth-changelog-open]');
      if (open) {
        event.preventDefault();
        changelogModal.hidden = false;
        document.body?.classList.add('studerria-changelog-open');
        requestAnimationFrame(() => {
          changelogModal.classList.add('is-open');
          if (changelogSheet) changelogSheet.focus({ preventScroll: true });
        });
        return;
      }
      const close = target.closest('[data-auth-changelog-close]');
      if (close && !changelogModal.hidden) {
        event.preventDefault();
        changelogModal.classList.remove('is-open');
        document.body?.classList.remove('studerria-changelog-open');
        setTimeout(() => {
          changelogModal.hidden = true;
        }, 180);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      const changelogModal = document.querySelector('[data-auth-changelog]');
      if (!changelogModal || changelogModal.hidden) return;
      changelogModal.classList.remove('is-open');
      document.body?.classList.remove('studerria-changelog-open');
      setTimeout(() => {
        changelogModal.hidden = true;
      }, 180);
    });

    syncThemeControls(resolveTheme());
    window.__appFooterControlsBound = true;
  }
</script>
<script src="/js/islands/checklist-toolbar-island.js" defer></script>
<script src="/js/islands/insights-period-preset-island.js" defer></script>
