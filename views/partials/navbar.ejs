<%
  const safeForceAppNavbar = (typeof forceAppNavbar !== 'undefined') && Boolean(forceAppNavbar);
  const safeShowGlobalNavbar = (typeof showGlobalNavbar === 'undefined') ? true : showGlobalNavbar !== false;
  const safeUserNav = (typeof userNav !== 'undefined' && userNav) ? userNav : null;
  const providedNavItems = Array.isArray(typeof navItems !== 'undefined' ? navItems : null) ? navItems : [];
  const safeNavMeta = (typeof navMeta !== 'undefined' && navMeta) ? navMeta : null;
  const translate = (typeof t === 'function') ? t : null;

  const shouldRenderNavbar = safeShowGlobalNavbar || safeForceAppNavbar;
  const currentRole = String((safeUserNav && safeUserNav.role) || role || '').trim();
  const userRoles = Array.isArray(safeUserNav && safeUserNav.roles) ? safeUserNav.roles : (currentRole ? [currentRole] : []);
  const isAuthed = Boolean(safeUserNav && safeUserNav.isAuthenticated) || Boolean(currentRole);
  const activeRawPath = String((typeof currentPath !== 'undefined' && currentPath) || '').split('#')[0] || '';
  const activePath = activeRawPath.split('?')[0] || '';
  const activeNavId = String((typeof activePage !== 'undefined' && activePage) || '').trim();
  const displayName = String((safeUserNav && safeUserNav.name) || username || '').trim();
  const normalizeRole = (value) => String(value || '').trim().toLowerCase();
  const normalizedRoleSet = new Set(userRoles.map(normalizeRole).filter(Boolean));
  if (currentRole) normalizedRoleSet.add(normalizeRole(currentRole));
  const hasRole = (...roles) => roles.some((roleKey) => normalizedRoleSet.has(normalizeRole(roleKey)));
  const markCurrent = (items) => items.map((item) => {
    const next = { ...item };
    const hrefRaw = String(next.href || '');
    const hrefNoHash = hrefRaw.split('#')[0] || '';
    const hrefPath = hrefNoHash.split('?')[0] || '';
    const hasHrefQuery = hrefRaw.includes('?');
    const hasHrefHash = hrefRaw.includes('#');
    const isCurrent = activeNavId
      ? String(next.id || '') === activeNavId
      : Boolean(
        activePath
          && hrefPath
          && !hasHrefHash
          && (
            (hasHrefQuery && activeRawPath === hrefNoHash)
            || (!hasHrefQuery && (activePath === hrefPath || (hrefPath !== '/' && activePath.startsWith(`${hrefPath}/`))))
          )
      );
    if (isCurrent) next.isCurrent = true;
    if (Array.isArray(next.children) && next.children.length) {
      next.children = markCurrent(next.children);
      if (next.children.some((child) => child.isCurrent || child.isCurrentContainer)) {
        next.isCurrentContainer = true;
      }
    }
    return next;
  });
  const fallbackStudentNav = [
    { id: 'home', label: 'Home', href: '/home' },
    { id: 'schedule', label: 'Schedule', href: '/schedule' },
    { id: 'homework', label: 'Homework', href: '/schedule#homework' },
    { id: 'messages', label: 'Messages', href: '/schedule?panel=messages', navAction: 'messages' },
    { id: 'teamwork', label: 'Teamwork', href: '/teamwork' },
    { id: 'subjects', label: 'Resources', href: '/subjects' },
    { id: 'profile', label: 'Profile', href: '/profile' },
    { id: 'help', label: 'Help', href: '/help' },
    { id: 'theme', label: 'Theme', navAction: 'theme-toggle' },
  ];
  const fallbackStaffNav = [
    { id: 'admin', label: 'Dashboard', href: '/admin' },
    { id: 'schedule', label: 'Schedule', href: '/schedule' },
    { id: 'admin-schedule', label: 'Schedule list', href: '/admin/schedule-list' },
    { id: 'admin-students', label: 'Students', href: '/admin?tab=admin-users' },
    { id: 'admin-groups', label: 'Groups', href: '/admin?tab=admin-users' },
    { id: 'admin-subjects', label: 'Subjects', href: '/admin?tab=admin-subjects' },
    { id: 'admin-homework', label: 'Homework', href: '/admin?tab=admin-homework' },
    { id: 'messages', label: 'Messages', href: '/admin?tab=admin-messages' },
    { id: 'setup', label: 'Academic Setup', href: '/admin/pathways' },
    { id: 'reports', label: 'Reports', href: '/admin/overview' },
    { id: 'profile', label: 'Settings', href: '/profile' },
    { id: 'theme', label: 'Theme', navAction: 'theme-toggle' },
  ];
  const fallbackLimitedStaffNav = [
    { id: 'admin', label: 'Dashboard', href: '/admin' },
    { id: 'schedule', label: 'Schedule', href: '/schedule' },
    { id: 'admin-homework', label: 'Homework', href: '/admin?tab=admin-homework' },
    { id: 'admin-teamwork', label: 'Teamwork', href: '/admin?tab=admin-teamwork' },
    { id: 'messages', label: 'Messages', href: '/admin?tab=admin-messages' },
    { id: 'profile', label: 'Settings', href: '/profile' },
    { id: 'theme', label: 'Theme', navAction: 'theme-toggle' },
  ];
  const fallbackTeacherNav = [
    { id: 'teacher-hub', label: 'Home', href: '/teacher' },
    { id: 'schedule', label: 'Schedule', href: '/schedule' },
    { id: 'teacher-subjects', label: 'Subjects', href: '/teacher/subjects' },
    { id: 'teacher-workspace', label: 'Homework', href: '/teacher/workspace' },
    { id: 'journal', label: 'Journal', href: '/journal' },
    { id: 'messages', label: 'Messages', href: '/schedule?panel=messages', navAction: 'messages' },
    { id: 'profile', label: 'Settings', href: '/profile' },
    { id: 'theme', label: 'Theme', navAction: 'theme-toggle' },
  ];
  const fallbackNavItems = hasRole('admin')
    ? fallbackStaffNav
    : (hasRole('deanery', 'starosta')
      ? fallbackLimitedStaffNav
      : (hasRole('teacher') ? fallbackTeacherNav : fallbackStudentNav));
  const safeNavItems = markCurrent(providedNavItems.length ? providedNavItems : fallbackNavItems);
  const flattenSidebarItems = (items) => items.reduce((result, item) => {
    if (!item || item.hidden || String(item.section || 'main') !== 'main') {
      return result;
    }
    const children = Array.isArray(item.children) ? item.children : [];
    if (!item.hideInSidebar && ((item.href && !item.isDisabledLink) || item.navAction || !children.length || item.isCurrent || item.isCurrentContainer)) {
      result.push({
        ...item,
        children: [],
        isCurrent: Boolean(item.isCurrent),
        isCurrentContainer: Boolean(item.isCurrentContainer),
      });
    }
    if (children.length) {
      result.push(...flattenSidebarItems(children));
    }
    return result;
  }, []);
  const visibleNavItems = flattenSidebarItems(safeNavItems);
  const shouldRenderAppNav = safeForceAppNavbar || (isAuthed && visibleNavItems.length > 0);
  const allowMessages = Boolean(safeUserNav && safeUserNav.flags && safeUserNav.flags.allowMessages);
  const personalLabel = String((safeNavMeta && safeNavMeta.personalLabel) || (safeUserNav && safeUserNav.personalLabel) || 'Особисте').trim() || 'Особисте';
  const roleLabelMap = {
    admin: (translate ? translate('role.admin') : 'Адмін'),
    starosta: (translate ? translate('role.starosta') : 'Староста'),
    deanery: (translate ? translate('role.deanery') : 'Деканат'),
    teacher: (translate ? translate('role.teacher') : 'Викладач'),
    student: (translate ? translate('role.student') : 'Студент'),
  };
  const displayRoleLabel = roleLabelMap[currentRole] || currentRole || '';
  const displayRoleText = displayName
    ? `${displayRoleLabel}: ${displayName}`
    : displayRoleLabel;
  const userInitial = (displayName || displayRoleLabel || 'S').trim().charAt(0).toUpperCase() || 'S';
  const mobileGlyphMap = {
    admin: 'AD',
    deanery: 'DN',
    home: 'HM',
    learning: 'ED',
    schedule: 'WK',
    journal: 'JR',
    'journal-insights': 'IN',
    teamwork: 'TW',
    'custom-deadlines': 'DL',
    subjects: 'SB',
    personal: 'ME',
    profile: 'PR',
    help: 'HP',
    messages: 'MS',
    theme: 'TH',
    starosta: 'ST',
    'teacher-workspace': 'TW',
    'teacher-hub': 'TH',
    'teacher-subjects': 'TS',
  };

  const escapeHtml = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  const getMobileGlyph = (item) => {
    const mapped = mobileGlyphMap[item && item.id ? item.id : ''];
    if (mapped) {
      return mapped;
    }

    const labelParts = String(item && item.label ? item.label : '')
      .split(/\s+/)
      .map((part) => String(part || '').replace(/[^A-Za-z0-9]/g, ''))
      .filter(Boolean);

    if (!labelParts.length) {
      return 'GO';
    }

    return labelParts
      .slice(0, 2)
      .map((part) => part.charAt(0).toUpperCase())
      .join('');
  };

  const buildMobileMeta = (trail) => {
    if (!Array.isArray(trail) || trail.length <= 1) {
      return '';
    }
    return trail.slice(1).join(' / ');
  };

  const toMobileDescriptor = (item, trail) => ({
    id: String(item && item.id ? item.id : item && item.label ? item.label : 'nav-item'),
    label: String(item && item.label ? item.label : ''),
    href: String(item && item.href ? item.href : '#'),
    navAction: String(item && item.navAction ? item.navAction : ''),
    glyph: getMobileGlyph(item),
    meta: buildMobileMeta(trail),
    isCurrent: Boolean(item && (item.isCurrent || item.isCurrentContainer)),
    hasUnread: allowMessages && String(item && item.id ? item.id : '') === 'messages',
  });

  const flattenMobileItems = (items, trail) => items.reduce((result, item) => {
    if (!item) {
      return result;
    }

    if ((item.href && !item.isDisabledLink) || item.navAction) {
      result.push(toMobileDescriptor(item, trail));
    }

    if (Array.isArray(item.children) && item.children.length) {
      const nextTrail = item.label ? [...trail, String(item.label)] : trail;
      result.push(...flattenMobileItems(item.children, nextTrail));
    }

    return result;
  }, []);

  const mobilePrimaryItems = [];
  const mobileSections = [];
  visibleNavItems.forEach((item) => {
    if (Array.isArray(item.children) && item.children.length) {
      const sectionItems = flattenMobileItems(item.children, [String(item.label || '')]);
      if (sectionItems.length) {
        mobileSections.push({
          title: String(item.label || ''),
          items: sectionItems,
        });
      }
      return;
    }

    if ((item.href && !item.isDisabledLink) || item.navAction) {
      mobilePrimaryItems.push(toMobileDescriptor(item, []));
    }
  });

  const buildTriggerClass = (level, item) => {
    const classNames = [level === 0 ? 'snav-link' : 'snav-menu-link'];
    if (Array.isArray(item.children) && item.children.length) {
      classNames.push('snav-trigger');
    }
    if (item.navAction === 'theme-toggle') {
      classNames.push('theme-toggle');
    }
    if (item.isCurrentContainer) {
      classNames.push('is-current');
    }
    if (item.isCurrent) {
      classNames.push('is-current');
    }
    return classNames.join(' ');
  };

  const renderTriggerLabel = (item, level) => {
    const label = escapeHtml(item.label || '');
    const unreadMarker = allowMessages && (item.id === 'personal' || item.id === 'messages')
      ? `<span class="snav-unread-chip" data-message-indicator="${item.id}" hidden aria-hidden="true"></span>`
      : '';
    let indicator = '';
    if (Array.isArray(item.children) && item.children.length && level > 0) {
      indicator = '<span class="snav-indicator snav-indicator--submenu" aria-hidden="true">&rsaquo;</span>';
    }
    const icon = `<span class="snav-icon nav-icon" data-snav-icon="${escapeHtml(item.id || 'nav')}" aria-hidden="true"></span>`;
    return `${icon}<span class="snav-label">${label}${unreadMarker}</span>${indicator}`;
  };

  const renderTrigger = (item, level) => {
    const hasChildren = Array.isArray(item.children) && item.children.length > 0;
    const attrs = [
      `class="${buildTriggerClass(level, item)}"`,
      `data-nav-label="${escapeHtml(item.label || '')}"`,
    ];

    if (hasChildren) {
      attrs.push('data-nav-trigger');
      attrs.push('aria-haspopup="true"');
      attrs.push('aria-expanded="false"');
    }

    if (item.navAction) {
      attrs.push(`data-nav-action="${escapeHtml(item.navAction)}"`);
    }

    if (item.navAction === 'theme-toggle') {
      attrs.push('data-light-label="Зміна теми"');
      attrs.push('data-dark-label="Зміна теми"');
      attrs.push('data-static-label="true"');
    }

    if (item.isCurrent || item.isCurrentContainer) {
      attrs.push('aria-current="page"');
    }

    if (item.navAction === 'theme-toggle' || item.isDisabledLink) {
      return `<button type="button" ${attrs.join(' ')}>${renderTriggerLabel(item, level)}</button>`;
    }

    const href = item.href || '#';
    return `<a href="${escapeHtml(href)}" ${attrs.join(' ')}>${renderTriggerLabel(item, level)}</a>`;
  };

  const renderMenuItems = (items, level) => items.map((item) => {
    const hasChildren = Array.isArray(item.children) && item.children.length > 0;
    const classNames = ['snav-item', `snav-item--level-${level}`];
    if (hasChildren) {
      classNames.push('snav-item--has-children');
    }
    if (item.isCurrentContainer) {
      classNames.push('is-current');
    }
    if (item.isCurrent) {
      classNames.push('is-current');
    }

    const itemId = escapeHtml(item.id || item.label || `nav-item-${level}`);
    const panelClass = level === 0
      ? 'snav-menu snav-menu--dropdown'
      : 'snav-menu snav-menu--flyout';

    let html = `<li class="${classNames.join(' ')}" data-nav-item-id="${itemId}" data-nav-level="${level}">`;
    html += renderTrigger(item, level);
    if (hasChildren) {
      html += `<div class="${panelClass}" hidden>`;
      html += `<ul class="snav-menu-list" data-nav-level="${level + 1}">`;
      html += renderMenuItems(item.children, level + 1);
      html += '</ul></div>';
    }
    html += '</li>';
    return html;
  }).join('');

  const renderMobileLink = (item) => {
    const classNames = ['snav-mobile-link'];
    if (item.isCurrent) {
      classNames.push('is-current');
    }

    const attrs = [
      `class="${classNames.join(' ')}"`,
      'data-mobile-nav-dismiss',
      `data-nav-label="${escapeHtml(item.label || '')}"`,
    ];

    if (item.navAction) {
      attrs.push(`data-nav-action="${escapeHtml(item.navAction)}"`);
    }

    if (item.navAction === 'theme-toggle') {
      attrs.push('data-theme-toggle');
      attrs.push('data-light-label="Зміна теми"');
      attrs.push('data-dark-label="Зміна теми"');
      attrs.push('data-static-label="true"');
    }

    if (item.isCurrent) {
      attrs.push('aria-current="page"');
    }

    const metaHtml = item.meta
      ? `<span class="snav-mobile-link-meta">${escapeHtml(item.meta)}</span>`
      : '';
    const unreadHtml = item.hasUnread
      ? '<span class="snav-unread-chip" data-message-indicator="messages" hidden aria-hidden="true"></span>'
      : '';
    const contentHtml = `
      <span class="snav-mobile-link-glyph" aria-hidden="true">${escapeHtml(item.glyph || 'GO')}</span>
      <span class="snav-mobile-link-copy">
        <span class="snav-mobile-link-title"><span data-mobile-link-label>${escapeHtml(item.label || '')}</span>${unreadHtml}</span>
        ${metaHtml}
      </span>
      <span class="snav-mobile-link-chevron" aria-hidden="true">&rsaquo;</span>
    `;

    if (item.navAction === 'theme-toggle') {
      return `<button type="button" ${attrs.join(' ')}>${contentHtml}</button>`;
    }

    return `<a href="${escapeHtml(item.href || '#')}" ${attrs.join(' ')}>${contentHtml}</a>`;
  };
%>
<% if (shouldRenderNavbar) { %>
  <% if (shouldRenderAppNav) { %>
    <nav class="navbar navbar-expand-lg topbar topbar--title-spotlight studerria-nav-shell" aria-label="Global Navigation" data-studerria-nav>
      <div class="container">
        <div class="snav-main">
          <div class="snav-brand-stack">
            <span class="navbar-brand text-white topbar-title-spotlight" aria-label="Studerria">Studerria</span>
            <% if (displayRoleText) { %>
              <span class="snav-mobile-meta"><%= displayRoleText %></span>
            <% } %>
          </div>
          <span class="snav-brand-spacer" aria-hidden="true"></span>
          <ul class="snav-list" data-nav-level="0">
            <%- renderMenuItems(visibleNavItems, 0) %>
          </ul>
        </div>
        <div class="d-flex align-items-center gap-2 topbar-actions snav-actions justify-content-end">
          <% if (displayRoleText) { %>
            <div class="snav-account-card" aria-label="Поточний профіль">
              <span class="snav-account-avatar" aria-hidden="true"><%= userInitial %></span>
              <span class="snav-account-copy">
                <span class="snav-account-name"><%= displayName || 'Studerria' %></span>
                <span class="snav-user-meta"><%= displayRoleLabel || displayRoleText %></span>
              </span>
            </div>
          <% } %>
          <button
            type="button"
            class="snav-mobile-trigger"
            data-mobile-nav-toggle
            aria-label="Відкрити навігацію"
            aria-expanded="false"
            aria-controls="studerriaMobileNav"
          >
            <span class="snav-mobile-trigger-line"></span>
            <span class="snav-mobile-trigger-line"></span>
          </button>
          <form method="POST" action="/logout" class="snav-logout-form">
            <button class="theme-toggle-min snav-logout-btn" type="submit" aria-label="Вийти">
              <span class="snav-icon nav-icon" data-snav-icon="logout" aria-hidden="true"></span>
              <span>Вийти</span>
            </button>
          </form>
        </div>
      </div>
      <div
        class="snav-mobile-sheet"
        id="studerriaMobileNav"
        data-mobile-nav-sheet
        hidden
        aria-hidden="true"
      >
        <button
          type="button"
          class="snav-mobile-backdrop"
          data-mobile-nav-backdrop
          aria-label="Закрити навігацію"
          tabindex="-1"
        ></button>
        <section
          class="snav-mobile-panel"
          role="dialog"
          aria-modal="true"
          aria-labelledby="studerriaMobileNavTitle"
        >
          <div class="snav-mobile-panel-head">
            <div class="snav-mobile-panel-copy">
              <p class="snav-mobile-kicker">Простір</p>
              <h2 class="snav-mobile-title" id="studerriaMobileNavTitle">Studerria</h2>
              <% if (displayRoleText) { %>
                <p class="snav-mobile-panel-meta"><%= displayRoleText %></p>
              <% } %>
            </div>
            <button
              type="button"
              class="snav-mobile-close"
              data-mobile-nav-close
              aria-label="Закрити навігацію"
            >
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
          <div class="snav-mobile-scroll">
            <% if (mobilePrimaryItems.length) { %>
              <section class="snav-mobile-section" aria-label="Основна навігація">
                <div class="snav-mobile-section-label">Огляд</div>
                <div class="snav-mobile-link-list">
                  <% mobilePrimaryItems.forEach((item) => { %>
                    <%- renderMobileLink(item) %>
                  <% }) %>
                </div>
              </section>
            <% } %>
            <% mobileSections.forEach((section) => { %>
              <section class="snav-mobile-section" aria-label="<%= section.title %>">
                <div class="snav-mobile-section-label"><%= section.title %></div>
                <div class="snav-mobile-link-list">
                  <% section.items.forEach((item) => { %>
                    <%- renderMobileLink(item) %>
                  <% }) %>
                </div>
              </section>
            <% }) %>
          </div>
          <div class="snav-mobile-footer">
            <div class="snav-mobile-account">
              <span class="snav-mobile-account-label">Активний профіль</span>
              <span class="snav-mobile-account-value"><%= displayRoleText || 'Профіль Studerria' %></span>
            </div>
            <form method="POST" action="/logout" class="snav-mobile-logout-form">
              <button type="submit" class="snav-mobile-logout-btn" data-mobile-nav-dismiss>Вийти</button>
            </form>
          </div>
        </section>
      </div>
    </nav>
  <% } else { %>
    <nav class="studerria-navbar" aria-label="Global Navigation">
      <span class="studerria-brand" aria-label="Studerria">Studerria</span>

      <div class="studerria-nav-links">
        <% if (isAuthed) { %>
          <a class="studerria-nav-link" href="/home">Головна</a>
          <a class="studerria-nav-link" href="/schedule">Навчання</a>
          <a class="studerria-nav-link" href="/profile"><%= personalLabel %></a>
          <% if (userRoles.some((roleKey) => ['admin', 'deanery', 'starosta', 'teacher'].includes(roleKey))) { %>
            <a class="studerria-nav-link" href="/admin">Адмінка</a>
          <% } %>
        <% } else { %>
          <a class="studerria-nav-link" href="/">Overview</a>
          <a class="studerria-nav-link" href="/login">Login</a>
        <% } %>
      </div>

      <div class="studerria-nav-actions">
        <% if (displayName) { %>
          <span class="studerria-user-pill" title="Signed in"><%= displayName %></span>
        <% } %>
        <button
          type="button"
          class="studerria-theme-toggle"
          id="studerriaThemeToggle"
          aria-label="Toggle theme"
          data-light-label="Зміна теми"
          data-dark-label="Зміна теми"
          data-static-label="true"
        >
          Зміна теми
        </button>
        <% if (isAuthed) { %>
          <a class="studerria-signup" href="/home">Open App</a>
        <% } else { %>
          <a class="studerria-signup" href="/register">Sign up</a>
        <% } %>
      </div>
    </nav>
  <% } %>
<% } %>
