<%
  const authLiteChangelogItems = Array.isArray(changelog) ? changelog.slice(0, 10) : [];
%>
<div class="td-lite-modal" data-auth-changelog hidden role="dialog" aria-modal="true" aria-labelledby="authChangelogTitle">
  <button class="td-lite-modal-backdrop" type="button" data-auth-changelog-close aria-label="Закрити changelog"></button>
  <section class="td-lite-sheet td-glass-panel" tabindex="-1">
    <header class="td-lite-sheet-head">
      <div>
        <p class="td-lite-kicker">Studerria updates</p>
        <h2 id="authChangelogTitle">Changelog</h2>
      </div>
      <button class="td-lite-close" type="button" data-auth-changelog-close aria-label="Закрити">×</button>
    </header>

    <div class="td-lite-release-list">
      <% if (authLiteChangelogItems.length) { %>
        <% authLiteChangelogItems.forEach(function(entry) { %>
          <article class="td-lite-release">
            <div class="td-lite-release-head">
              <strong>v<%= entry.version %></strong>
              <% if (entry.date) { %>
                <span><%= entry.date %></span>
              <% } %>
            </div>
            <ul>
              <% (entry.items || []).forEach(function(item) { %>
                <li><%= item %></li>
              <% }); %>
            </ul>
          </article>
        <% }); %>
      <% } else { %>
        <p class="td-lite-empty">Оновлень поки немає.</p>
      <% } %>
    </div>
  </section>
</div>
