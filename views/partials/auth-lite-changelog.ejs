<%
  const authLiteChangelogItems = Array.isArray(changelog) ? changelog.slice(0, 10) : [];
%>
<div class="td-lite-modal" data-auth-changelog hidden role="dialog" aria-modal="true" aria-labelledby="authChangelogTitle">
  <button class="td-lite-modal-backdrop" type="button" data-auth-changelog-close aria-label="<%= t('changelog.close') %>"></button>
  <section class="td-lite-sheet td-glass-panel" tabindex="-1">
    <header class="td-lite-sheet-head">
      <div>
        <p class="td-lite-kicker"><%= t('changelog.releaseNotes') %></p>
        <h2 id="authChangelogTitle"><%= t('changelog.title') %></h2>
      </div>
      <button class="td-lite-close" type="button" data-auth-changelog-close aria-label="<%= t('changelog.close') %>">
        <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" focusable="false">
          <path d="M7 7l10 10M17 7L7 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <div class="td-lite-release-list">
      <% if (authLiteChangelogItems.length) { %>
        <% authLiteChangelogItems.forEach(function(entry) { %>
          <article class="td-lite-release">
            <div class="td-lite-release-head">
              <strong>v<%= entry.version %></strong>
              <% if (entry.date) { %>
                <span><%= entry.date %></span>
              <% } %>
            </div>
            <ul>
              <% (entry.items || []).forEach(function(item) { %>
                <li><%= item %></li>
              <% }); %>
            </ul>
          </article>
        <% }); %>
      <% } else { %>
        <p class="td-lite-empty"><%= t('changelog.noUpdates') %></p>
      <% } %>
    </div>
    <footer class="td-lite-sheet-footer">
      <a class="td-secondary-button" href="/changelog"><%= t('changelog.openAll') %></a>
    </footer>
  </section>
</div>
