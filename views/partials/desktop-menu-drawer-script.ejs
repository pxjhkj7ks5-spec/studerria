<script>
  (() => {
    const drawer = document.getElementById('scheduleActionDrawer');
    const toggle = document.getElementById('scheduleDrawerToggle');
    const closeBtn = document.getElementById('scheduleDrawerClose');
    if (!drawer || !toggle) return;
    if (drawer.dataset.drawerWired === '1') return;
    drawer.dataset.drawerWired = '1';

    const setDrawerOpen = (open) => {
      const canDesktopDrawer = window.innerWidth > 991;
      const isOpen = Boolean(open) && canDesktopDrawer;
      document.body.classList.toggle('schedule-drawer-open', isOpen);
      drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };

    toggle.addEventListener('click', () => {
      const isOpen = document.body.classList.contains('schedule-drawer-open');
      setDrawerOpen(!isOpen);
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', () => setDrawerOpen(false));
    }

    document.addEventListener('click', (event) => {
      if (!document.body.classList.contains('schedule-drawer-open')) return;
      const insideDrawer = drawer.contains(event.target);
      const onToggle = toggle.contains(event.target);
      if (!insideDrawer && !onToggle) {
        setDrawerOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && document.body.classList.contains('schedule-drawer-open')) {
        setDrawerOpen(false);
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth <= 991) {
        setDrawerOpen(false);
      }
    });
  })();
</script>
