<div id="visionBg" class="vision-bg" aria-hidden="true">
  <div class="vision-gradient"></div>

  <div class="bg-morph-layer">
    <div class="bg-shape-wrap morph-blob morph-primary" data-depth="0.022">
      <svg class="bg-blob" viewBox="0 0 600 600" role="presentation" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="visionBlobGradientPrimary" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color: var(--morph-primary-a)" />
            <stop offset="50%" style="stop-color: var(--morph-primary-b)" />
            <stop offset="100%" style="stop-color: var(--morph-primary-c)" />
          </linearGradient>
        </defs>
        <path
          id="blob-path"
          data-blob-path="primary"
          d="M300 80 C380 60 460 140 480 240 C500 340 420 420 320 440 C220 460 140 400 120 300 C100 200 180 100 300 80 Z"
          fill="url(#visionBlobGradientPrimary)"
        />
      </svg>
    </div>

    <div class="bg-shape-wrap morph-blob morph-secondary" data-depth="0.016">
      <svg class="bg-blob" viewBox="0 0 600 600" role="presentation" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="visionBlobGradientSecondary" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color: var(--morph-secondary-a)" />
            <stop offset="50%" style="stop-color: var(--morph-secondary-b)" />
            <stop offset="100%" style="stop-color: var(--morph-secondary-c)" />
          </linearGradient>
        </defs>
        <path
          id="blob-path-secondary"
          data-blob-path="secondary"
          d="M306 96 C404 84 482 166 500 258 C518 346 444 436 346 456 C236 478 146 414 126 314 C108 220 184 108 306 96 Z"
          fill="url(#visionBlobGradientSecondary)"
        />
      </svg>
    </div>
  </div>

  <div class="mouse-trail" id="visionMouseTrail"></div>
  <div class="noise-overlay"></div>
  <div class="dot-pattern dot-left"></div>
  <div class="dot-pattern dot-right"></div>
</div>
