<%
  const markClass = typeof className !== 'undefined' ? String(className) : 'td-brand-glyph';
  const gradientId = `td-brand-gradient-${Math.random().toString(36).slice(2, 10)}`;
  const maskId = `td-brand-mask-${Math.random().toString(36).slice(2, 10)}`;
%>
<svg class="<%= markClass %>" viewBox="0 0 96 96" aria-hidden="true" focusable="false">
  <defs>
    <linearGradient id="<%= gradientId %>" x1="18" y1="82" x2="78" y2="14" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#5f86ff" />
      <stop offset="0.5" stop-color="#7c3aed" />
      <stop offset="1" stop-color="#f08be8" />
    </linearGradient>
    <mask id="<%= maskId %>">
      <rect width="96" height="96" fill="white" />
      <path class="td-brand-glyph__cutout" d="M69 25 39 42c-8 4.5-8 16.5 0 21 6 3.4 13.5 2.8 19.5-.8L69 56" />
    </mask>
  </defs>
  <g mask="url(#<%= maskId %>)">
    <path class="td-brand-glyph__segment" stroke="url(#<%= gradientId %>)" d="M67 16 31 37c-12 7-12 25 0 32 8 4.8 18.5 4 26.5-.8L68 62" />
    <path class="td-brand-glyph__segment" stroke="url(#<%= gradientId %>)" d="M29 80 65 59c12-7 12-25 0-32-8-4.8-18.5-4-26.5.8L28 34" />
  </g>
</svg>
