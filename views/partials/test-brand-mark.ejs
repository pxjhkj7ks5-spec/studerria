<%
  const markClass = typeof className !== 'undefined' ? String(className) : 'td-brand-glyph';
%>
<img
  class="<%= markClass %> td-brand-logo td-brand-logo--light"
  src="/assets/brand/studerria-mark-light-512.png"
  width="512"
  height="512"
  alt=""
  loading="eager"
  decoding="async"
  aria-hidden="true"
/>
<img
  class="<%= markClass %> td-brand-logo td-brand-logo--dark"
  src="/assets/brand/studerria-mark-dark-512.png"
  width="512"
  height="512"
  alt=""
  loading="eager"
  decoding="async"
  aria-hidden="true"
/>
