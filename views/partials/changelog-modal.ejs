<div
  class="modal fade changelog-liquid-modal"
  id="changelogModal"
  tabindex="-1"
  aria-hidden="true"
  data-studerria-modal="changelog"
>
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content changelog-sheet">
      <div class="modal-header">
        <div class="changelog-modal__header-copy">
          <h5 class="modal-title"><%= t('changelog.title') %></h5>
          <span class="status-chip status-chip--info"><%= t('changelog.releaseNotes') %></span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('changelog.close') %>"></button>
      </div>
      <div class="modal-body">
        <% if (changelog && changelog.length) { %>
          <%
            const changelogSeriesMap = new Map();
            changelog.forEach(function(entry) {
              const versionParts = String(entry.version || '').split('.');
              const seriesKey = versionParts.length >= 2 ? `${versionParts[0]}.${versionParts[1]}` : String(entry.version || 'other');
              if (!changelogSeriesMap.has(seriesKey)) {
                changelogSeriesMap.set(seriesKey, []);
              }
              changelogSeriesMap.get(seriesKey).push(entry);
            });
            const changelogSeries = Array.from(changelogSeriesMap.entries());
          %>
          <% changelogSeries.forEach(function(seriesEntry, seriesIndex) { %>
            <% const seriesKey = seriesEntry[0]; %>
            <% const seriesItems = seriesEntry[1] || []; %>
            <details class="changelog-series" <%= seriesIndex === 0 ? 'open' : '' %>>
              <summary class="changelog-series__summary">
                <span class="changelog-series__title">
                  <span>v<%= seriesKey %>.x</span>
                  <span class="changelog-series__count"><%= seriesItems.length %> <%= t('changelog.releases') %></span>
                </span>
                <span class="changelog-series__chevron" aria-hidden="true">›</span>
              </summary>
              <div class="changelog-series__body">
                <% seriesItems.forEach(function(entry) { %>
                  <div class="changelog-release">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                      <span class="fw-semibold">v<%= entry.version %></span>
                      <% if (entry.date) { %>
                        <span class="text-muted small"><%= entry.date %></span>
                      <% } %>
                    </div>
                    <ul>
                      <% (entry.items || []).forEach(function(item) { %>
                        <li><%= item %></li>
                      <% }); %>
                    </ul>
                  </div>
                <% }); %>
              </div>
            </details>
          <% }); %>
        <% } else { %>
          <p class="text-muted mb-0"><%= t('changelog.noUpdates') %></p>
        <% } %>
      </div>
      <div class="modal-footer">
        <a class="btn btn-outline-secondary glass" href="/changelog"><%= t('changelog.openAll') %></a>
        <button type="button" class="btn btn-outline-secondary glass" data-bs-dismiss="modal"><%= t('changelog.close') %></button>
      </div>
    </div>
  </div>
</div>
<script src="/js/changelog-modal.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
