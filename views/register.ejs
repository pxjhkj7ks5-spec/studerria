<!doctype html>
<%
  const registerErrorCode = String(error || '').trim();
  const registerErrorText = (() => {
    if (!registerErrorCode) return '';
    const errorKeyMap = {
      'missing-name': 'register.errorFullNameRequired',
      'missing-password': 'register.errorPasswordRequired',
      'short-password': 'register.errorPasswordTooShort',
      'missing-confirm-password': 'register.errorConfirmPasswordRequired',
      'password-mismatch': 'register.errorPasswordMismatch',
      'consent-required': 'register.errorConsentRequired',
      'user-exists': 'register.errorUserExists',
      'db-error': 'register.errorDb',
      'too-many-requests': 'register.errorTooManyRequests',
      'Check your details': 'register.errorCheckDetails',
      'User already exists': 'register.errorUserExists',
      'Database error': 'register.errorDb',
      'Too many requests': 'register.errorTooManyRequests',
    };
    const translationKey = errorKeyMap[registerErrorCode];
    return translationKey ? t(translationKey) : registerErrorCode;
  })();
%>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title><%= t('register.title') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
  </head>
  <body class="studerria-theme theme-light td-page td-page--login page-register" data-theme="light">
    <%- include('partials/theme-bootstrap-body') %>
    <main class="td-login-main">
      <section class="td-login-brand" aria-label="Studerria">
        <span class="td-login-logo" aria-hidden="true">
          <%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %>
        </span>
      </section>

      <section class="td-login-card td-glass-panel tooltip-host" aria-label="<%= t('register.title') %>">
        <header class="td-login-card-head">
          <h1><%= t('register.title') %></h1>
          <p>Створи профіль Studerria для свого навчального простору.</p>
        </header>

        <% if (registerErrorText) { %>
          <div class="alert alert-danger login-feedback-stack" role="alert">
            <%= registerErrorText %>
          </div>
        <% } %>

        <form id="registerForm" class="td-form" method="POST" action="/register" novalidate>
          <label class="td-field" for="full_name">
            <span><%= t('register.fullName') %></span>
            <span class="td-input-wrap">
              <%- include('partials/test-icon', { name: 'user', className: 'td-input-icon' }) %>
              <input
                id="full_name"
                name="full_name"
                type="text"
                placeholder="<%= t('register.fullNamePlaceholder') %>"
                value="<%= pendingFullName || '' %>"
                autocomplete="name"
                required
              />
            </span>
          </label>

          <label class="td-field" for="password">
            <span><%= t('register.password') %></span>
            <span class="td-input-wrap td-input-wrap--password input-with-icon">
              <%- include('partials/test-icon', { name: 'lock', className: 'td-input-icon' }) %>
              <input
                id="password"
                name="password"
                type="password"
                placeholder="<%= t('register.passwordPlaceholder') %>"
                autocomplete="new-password"
                minlength="8"
                required
              />
              <button class="td-password-reveal is-visible" type="button" id="togglePassword" aria-label="Показати пароль">
                <%- include('partials/test-icon', { name: 'eye', className: 'td-password-eye td-password-eye--show' }) %>
                <%- include('partials/test-icon', { name: 'eyeOff', className: 'td-password-eye td-password-eye--hide' }) %>
              </button>
            </span>
          </label>

          <label class="td-field" for="confirm_password">
            <span><%= t('register.confirmPassword') %></span>
            <span class="td-input-wrap td-input-wrap--password input-with-icon">
              <%- include('partials/test-icon', { name: 'lock', className: 'td-input-icon' }) %>
              <input
                id="confirm_password"
                name="confirm_password"
                type="password"
                placeholder="<%= t('register.confirmPasswordPlaceholder') %>"
                autocomplete="new-password"
                minlength="8"
                required
              />
              <button class="td-password-reveal is-visible" type="button" id="toggleConfirmPassword" aria-label="Показати пароль">
                <%- include('partials/test-icon', { name: 'eye', className: 'td-password-eye td-password-eye--show' }) %>
                <%- include('partials/test-icon', { name: 'eyeOff', className: 'td-password-eye td-password-eye--hide' }) %>
              </button>
            </span>
          </label>

          <div class="td-form-row td-form-row--stack">
            <label class="td-checkbox" for="agree">
              <input type="checkbox" id="agree" name="agree" required />
              <span>
                Я погоджуюсь із
                <a href="/terms" target="_blank" rel="noopener">умовами використання</a>,
                <a href="/privacy" target="_blank" rel="noopener">політикою конфіденційності</a>
                та даю згоду на обробку персональних даних для роботи Studerria.
              </span>
            </label>
            <button
              type="button"
              class="td-inline-link"
              data-bs-toggle="modal"
              data-bs-target="#privacyModal"
            >
              <%= t('register.more') %>
            </button>
          </div>
          <div class="field-error" id="consent-error" aria-live="polite"></div>

          <button type="submit" class="td-primary-button"><%= t('register.continue') %></button>
        </form>

        <p class="td-login-bottom"><a href="/login"><%= t('register.haveAccount') %></a></p>
      </section>
    </main>

    <footer class="td-login-footer">
      <button type="button" class="td-language-pill">UA <%- include('partials/test-icon', { name: 'chevronDown', className: 'td-mini-chevron' }) %></button>
      <button type="button" class="td-language-pill td-theme-toggle" id="tdThemeToggleMirror" aria-label="Увімкнути темну тему" aria-pressed="false">
        <%- include('partials/test-icon', { name: 'moon', className: 'td-mini-chevron td-theme-moon' }) %>
        <%- include('partials/test-icon', { name: 'sun', className: 'td-mini-chevron td-theme-sun' }) %>
        <span data-theme-label>Dark</span>
      </button>
      <a href="/help">Підтримка</a>
      <a href="/terms">Умови використання</a>
      <a href="/privacy">Політика конфіденційності</a>
      <button type="button" class="td-footer-link" data-bs-toggle="modal" data-bs-target="#changelogModal">Changelog</button>
      <span>© Studerria 2026</span>
    </footer>
    <div class="modal fade" id="privacyModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><%= t('register.modalTitle') %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p><%= t('register.modalIntro') %></p>
            <ul>
              <li><%= t('register.modalItem1') %></li>
              <li><%= t('register.modalItem2') %></li>
              <li><%= t('register.modalItem3') %></li>
              <li><%= t('register.modalItem4') %></li>
            </ul>
            <p><%= t('register.modalOutro') %></p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary glass" data-bs-dismiss="modal"><%= t('register.modalClose') %></button>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/changelog-modal') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const registerValidationCopy = {
        checkField: <%- JSON.stringify(t('schedule.validation.checkField')) %>,
        fullNameRequired: <%- JSON.stringify(t('register.errorFullNameRequired')) %>,
        passwordRequired: <%- JSON.stringify(t('register.errorPasswordRequired')) %>,
        passwordTooShort: <%- JSON.stringify(t('register.errorPasswordTooShort')) %>,
        confirmPasswordRequired: <%- JSON.stringify(t('register.errorConfirmPasswordRequired')) %>,
        passwordMismatch: <%- JSON.stringify(t('register.errorPasswordMismatch')) %>,
        consentRequired: <%- JSON.stringify(t('register.errorConsentRequired')) %>,
      };
      function showCustomTooltip(el, message) {
        document.querySelectorAll('.custom-tooltip').forEach((t) => t.remove());
        const anchor = el.closest('.input-with-icon') || el.closest('.form-check') || el.closest('.input-group') || el;
        const tooltipHost = anchor.closest('.tooltip-host');
        const renderHost = tooltipHost || document.body;
        const key = el.id || el.name || anchor.id || '';
        const tip = document.createElement('div');
        tip.className = 'custom-tooltip';
        tip.textContent = message || registerValidationCopy.checkField;
        if (key) tip.dataset.for = key;
        renderHost.appendChild(tip);

        const rect = anchor.getBoundingClientRect();
        const tipRect = tip.getBoundingClientRect();
        const margin = 10;
        const viewportPadding = 8;
        const arrowPadding = 18;
        let anchorCenter = rect.left + (rect.width / 2);
        let top = rect.bottom + margin;
        let left = anchorCenter - (tipRect.width / 2);
        let placeBelow = true;
        if (tooltipHost) {
          const hostRect = tooltipHost.getBoundingClientRect();
          const hostHeight = Math.max(hostRect.height, tooltipHost.scrollHeight, tooltipHost.clientHeight);
          anchorCenter = (rect.left - hostRect.left) + (rect.width / 2);
          top = (rect.bottom - hostRect.top) + margin;
          left = anchorCenter - (tipRect.width / 2);
          const aboveTop = (rect.top - hostRect.top) - tipRect.height - margin;
          if (top + tipRect.height > hostHeight - viewportPadding && aboveTop >= -viewportPadding) {
            top = aboveTop;
            placeBelow = false;
          }
          const maxLeft = Math.max(viewportPadding, hostRect.width - tipRect.width - viewportPadding);
          if (left > maxLeft) left = maxLeft;
          if (left < viewportPadding) left = viewportPadding;
          tip.style.position = 'absolute';
        } else {
          if (top + tipRect.height > window.innerHeight - viewportPadding) {
            top = rect.top - tipRect.height - margin;
            placeBelow = false;
          }
          if (left + tipRect.width > window.innerWidth - viewportPadding) {
            left = window.innerWidth - tipRect.width - viewportPadding;
          }
          if (left < viewportPadding) left = viewportPadding;
          tip.style.position = 'fixed';
        }
        const arrowLeft = Math.max(
          arrowPadding,
          Math.min(tipRect.width - arrowPadding, anchorCenter - left)
        );
        tip.style.top = `${Math.round(top)}px`;
        tip.style.left = `${Math.round(left)}px`;
        tip.style.setProperty('--tooltip-arrow-left', `${Math.round(arrowLeft)}px`);
        if (placeBelow) tip.classList.add('below');
        requestAnimationFrame(() => tip.classList.add('show'));
        const remove = () => tip.remove();
        tip.addEventListener('click', remove);
        setTimeout(remove, 3500);
      }

      const registerForm = document.getElementById('registerForm');
      const nameInput = document.getElementById('full_name');
      const passwordInput = document.getElementById('password');
      const confirmInput = document.getElementById('confirm_password');
      const agreeInput = document.getElementById('agree');
      const consentError = document.getElementById('consent-error');
      const togglePassword = document.getElementById('togglePassword');
      const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');

      const toggleField = (btn, input) => {
        if (!btn || !input) return;
        btn.addEventListener('click', () => {
          const isHidden = input.type === 'password';
          input.type = isHidden ? 'text' : 'password';
          btn.classList.toggle('is-showing', isHidden);
          btn.setAttribute('aria-label', isHidden ? 'Сховати пароль' : 'Показати пароль');
        });
      };
      toggleField(togglePassword, passwordInput);
      toggleField(toggleConfirmPassword, confirmInput);

      function clearInvalidState() {
        document.querySelectorAll('.field-invalid').forEach((el) => el.classList.remove('field-invalid'));
        document.querySelectorAll('.custom-tooltip').forEach((t) => t.remove());
        if (consentError) {
          consentError.textContent = '';
          consentError.classList.remove('is-visible');
        }
      }

      function markInvalid(el, message, options = {}) {
        const shouldFocus = options.focusField !== false;
        clearInvalidState();
        el.classList.add('field-invalid');
        if (el === agreeInput && consentError) {
          consentError.textContent = message || 'Поставте прапорець згоди';
          consentError.classList.add('is-visible');
        } else {
          showCustomTooltip(el, message);
        }
        if (shouldFocus) {
          el.focus({ preventScroll: true });
        }
      }

      function getFieldValidationMessage(el) {
        if (el === nameInput && !nameInput.value.trim()) {
          return nameInput.validationMessage || 'Заповніть ім\'я';
        }
        if (el === passwordInput && !passwordInput.value) {
          return passwordInput.validationMessage || 'Вкажіть пароль';
        }
        if (el === confirmInput && !confirmInput.value) {
          return confirmInput.validationMessage || 'Підтвердіть пароль';
        }
        if (el === confirmInput && passwordInput && confirmInput.value !== passwordInput.value) {
          return 'Паролі не співпадають';
        }
        if (el === agreeInput && !agreeInput.checked) {
          return 'Поставте прапорець згоди';
        }
        return '';
      }

      function getFieldValidationMessage(el) {
        if (el === nameInput && !nameInput.value.trim()) {
          return registerValidationCopy.fullNameRequired;
        }
        if (el === passwordInput && !passwordInput.value) {
          return registerValidationCopy.passwordRequired;
        }
        if (el === passwordInput && passwordInput.value.length < 8) {
          return registerValidationCopy.passwordTooShort;
        }
        if (el === confirmInput && !confirmInput.value) {
          return registerValidationCopy.confirmPasswordRequired;
        }
        if (el === confirmInput && passwordInput && confirmInput.value !== passwordInput.value) {
          return registerValidationCopy.passwordMismatch;
        }
        if (el === agreeInput && !agreeInput.checked) {
          return registerValidationCopy.consentRequired;
        }
        return '';
      }

      function validateField(el, showTip = false, options = {}) {
        if (!el) return true;
        const message = getFieldValidationMessage(el);
        if (message) {
          if (showTip) {
            markInvalid(el, message, options);
          }
          return false;
        }
        el.classList.remove('field-invalid');
        if (el === agreeInput && consentError) {
          consentError.textContent = '';
          consentError.classList.remove('is-visible');
        }
        return true;
      }

      function validateRegister(showTip = false) {
        const fields = [nameInput, passwordInput, confirmInput, agreeInput];
        for (const field of fields) {
          if (!validateField(field, showTip, { focusField: true })) {
            return false;
          }
        }
        clearInvalidState();
        return true;
      }

      [nameInput, passwordInput, confirmInput, agreeInput].forEach((el) => {
        if (!el) return;
        el.addEventListener('blur', () => {
          validateField(el, true, { focusField: false });
        });
        el.addEventListener('input', () => {
          el.classList.remove('field-invalid');
          document.querySelectorAll('.custom-tooltip').forEach((t) => t.remove());
          if (el === agreeInput && consentError) {
            consentError.textContent = '';
            consentError.classList.remove('is-visible');
          }
        });
        el.addEventListener('change', () => {
          el.classList.remove('field-invalid');
          document.querySelectorAll('.custom-tooltip').forEach((t) => t.remove());
          if (el === agreeInput && consentError) {
            consentError.textContent = '';
            consentError.classList.remove('is-visible');
          }
        });
      });

      if (registerForm) {
        registerForm.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            registerForm.requestSubmit();
          }
        });
        registerForm.addEventListener('submit', (event) => {
          if (!validateRegister(true)) {
            event.preventDefault();
          }
        });
      }
      const themeToggle = document.getElementById('tdThemeToggleMirror');
      const applyThemeAttr = () => {
        if (document.body.classList.contains('theme-dark')) {
          document.body.setAttribute('data-theme', 'dark');
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.body.setAttribute('data-theme', 'light');
          document.documentElement.setAttribute('data-theme', 'light');
        }
      };
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      applyThemeAttr();
      if (themeToggle) {
        const label = themeToggle.querySelector('[data-theme-label]');
        if (label) label.textContent = savedTheme === 'theme-dark' ? 'Light' : 'Dark';
      }

      const tdThemeToggle = document.getElementById('tdThemeToggleMirror');
      const syncTdThemeToggle = () => {
        if (!tdThemeToggle) return;
        const isDark = document.body.classList.contains('theme-dark');
        tdThemeToggle.setAttribute('aria-pressed', String(isDark));
        tdThemeToggle.setAttribute('aria-label', isDark ? 'Увімкнути світлу тему' : 'Увімкнути темну тему');
        const label = tdThemeToggle.querySelector('[data-theme-label]');
        if (label) label.textContent = isDark ? 'Light' : 'Dark';
      };
      if (tdThemeToggle) {
        tdThemeToggle.addEventListener('click', () => {
          themeToggle.click();
          syncTdThemeToggle();
        });
        syncTdThemeToggle();
      }
    </script>
    <script src="/js/studerria-background.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
