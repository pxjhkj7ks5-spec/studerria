<%
  const currentStep = ['account', 'group', 'subjects'].includes(String(step || '')) ? String(step) : 'account';
  const errorMap = {
    'missing-name': 'Вкажіть повне імʼя.',
    'short-password': 'Пароль має містити щонайменше 8 символів.',
    'password-mismatch': 'Паролі не збігаються.',
    'consent-required': 'Потрібна згода з умовами.',
    'user-exists': 'Користувач із таким імʼям вже існує.',
    'missing-group': 'Оберіть групу.',
    'invalid-group': 'Ця група недоступна для реєстрації.',
    'repair-failed': 'Групу ще не готово для реєстрації.',
    'missing_group': 'Оберіть групи для всіх обовʼязкових предметів.',
    'projection_incomplete': 'Академічне налаштування для групи ще не завершене.',
    db: 'Тимчасова помилка реєстрації.',
  };
  const registerError = errorMap[String(error || '')] || String(error || '');
%>
<section class="tg-page-head">
  <p class="tg-kicker">Studerria</p>
  <h1>Реєстрація</h1>
  <div class="tg-stepper" aria-label="Registration progress">
    <span class="<%= currentStep === 'account' ? 'is-active' : '' %>">1</span>
    <span class="<%= currentStep === 'group' ? 'is-active' : '' %>">2</span>
    <span class="<%= currentStep === 'subjects' ? 'is-active' : '' %>">3</span>
  </div>
</section>

<% if (registerError) { %>
  <div class="tg-alert"><%= registerError %></div>
<% } %>

<% if (currentStep === 'account') { %>
  <section class="tg-card">
    <form class="tg-form" method="POST" action="/tg/register">
      <input type="hidden" name="action" value="account" />
      <label>
        <span>Повне імʼя</span>
        <input name="full_name" type="text" autocomplete="name" placeholder="Імʼя та прізвище" value="<%= suggestedName || '' %>" required />
      </label>
      <label>
        <span>Пароль</span>
        <input name="password" type="password" autocomplete="new-password" minlength="8" required />
      </label>
      <label>
        <span>Повторіть пароль</span>
        <input name="confirm_password" type="password" autocomplete="new-password" minlength="8" required />
      </label>
      <label class="tg-check">
        <input type="checkbox" name="agree" required />
        <span>Погоджуюсь з умовами використання та політикою приватності.</span>
      </label>
      <button class="tg-primary" type="submit">Продовжити</button>
    </form>
    <p class="tg-inline-note">Вже є акаунт? <a href="/tg/login">Увійти</a></p>
  </section>
<% } %>

<% if (currentStep === 'group') { %>
  <section class="tg-card">
    <h2>Оберіть групу</h2>
    <% if (pendingUser) { %>
      <p class="tg-muted"><%= pendingUser.full_name %></p>
    <% } %>
    <form class="tg-form" method="POST" action="/tg/register">
      <input type="hidden" name="action" value="group" />
      <div class="tg-choice-list">
        <% (groups || []).forEach(function(group) { %>
          <label class="tg-choice <%= group.selection_blocked ? 'is-disabled' : '' %>">
            <input type="radio" name="group_id" value="<%= group.group_id %>" <%= group.selection_blocked ? 'disabled' : '' %> required />
            <span>
              <strong><%= group.label || ('Group ' + group.group_id) %></strong>
              <small><%= group.track_key %> · <%= group.campus_key %> · <%= group.visible_subject_count %> subjects</small>
            </span>
          </label>
        <% }); %>
      </div>
      <% if (!(groups || []).length) { %>
        <p class="tg-muted">Групи для реєстрації ще не налаштовані.</p>
      <% } %>
      <button class="tg-primary" type="submit" <%= !(groups || []).length ? 'disabled' : '' %>>Продовжити</button>
    </form>
  </section>
<% } %>

<% if (currentStep === 'subjects') { %>
  <section class="tg-card">
    <h2>Вибір предметів</h2>
    <p class="tg-muted">Оберіть свою групу для кожного предмета або пропустіть необовʼязковий предмет.</p>
    <form class="tg-form" method="POST" action="/tg/register">
      <input type="hidden" name="action" value="subjects" />
      <%- include('subject-picker', { registerSubjectCards }) %>
      <button class="tg-primary" type="submit">Завершити</button>
    </form>
  </section>
<% } %>
