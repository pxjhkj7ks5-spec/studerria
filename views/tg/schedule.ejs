<section class="tg-page-head">
  <h1>Розклад</h1>
  <div class="tg-weekbar">
    <a href="/studerria-tg/schedule?week=<%= Math.max(1, Number(currentWeek || 1) - 1) %>" aria-label="Previous week">Prev</a>
    <strong>Week <%= currentWeek || 1 %> / <%= totalWeeks || 1 %></strong>
    <a href="/studerria-tg/schedule?week=<%= Math.min(Number(totalWeeks || 1), Number(currentWeek || 1) + 1) %>" aria-label="Next week">Next</a>
  </div>
</section>

<% if (typeof welcome !== 'undefined' && welcome) { %>
  <div class="tg-success">Акаунт готовий. Telegram привʼязано.</div>
<% } %>
<% if (typeof success !== 'undefined' && success === 'homework-created') { %>
  <div class="tg-success">ДЗ додано.</div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="tg-alert">
    <% if (error === 'missing-fields') { %>
      Заповніть опис ДЗ.
    <% } else if (error === 'invalid-link') { %>
      Лінк має починатися з http або https.
    <% } else if (error === 'subject-denied' || error === 'group-denied' || error === 'schedule-denied') { %>
      Не вдалося привʼязати ДЗ до цієї пари.
    <% } else if (error === 'homework-failed' || error === 'db') { %>
      Не вдалося додати ДЗ.
    <% } else { %>
      Не вдалося завантажити розклад.
    <% } %>
  </div>
<% } %>

<section class="tg-schedule">
  <% const tgTodayIso = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Kyiv' }); %>
  <% (days || []).forEach(function(day) { %>
    <% const dayDate = scheduleDayDates && scheduleDayDates[day] ? scheduleDayDates[day] : null; %>
    <article class="tg-day <%= dayDate && dayDate.iso === tgTodayIso ? 'is-today' : '' %>">
      <h2>
        <span><%= day %></span>
        <% if (dayDate && dayDate.label) { %>
          <time datetime="<%= dayDate.iso || '' %>"><%= dayDate.label %></time>
        <% } %>
      </h2>
      <% const rows = scheduleByDay && scheduleByDay[day] ? scheduleByDay[day] : []; %>
      <% if (!rows.length) { %>
        <p class="tg-muted">Немає пар.</p>
      <% } %>
      <% rows.forEach(function(item) { %>
        <% const homeworkItems = Array.isArray(item.homework_items) ? item.homework_items : []; %>
        <% const lessonMeta = `${item.subject_name || 'Предмет'}${item.class_number ? ` · ${item.class_number} пара` : ''}${item.group_number ? ` · група ${item.group_number}` : ''}${item.class_date ? ` · ${item.class_date}` : ''}`; %>
        <div class="tg-lesson">
          <div class="tg-lesson-time">
            <strong aria-label="Пара <%= item.class_number || '' %>"><%= item.class_number || '' %></strong>
            <span><%= item.time_label || '' %></span>
          </div>
          <div>
            <h3><%= item.subject_name %></h3>
            <p>
              <% if (item.lesson_type) { %><span><%= item.lesson_type %></span><% } %>
              <% if (item.group_number) { %><span>Group <%= item.group_number %></span><% } %>
              <% if (item.room_label) { %><span><%= item.room_label %></span><% } %>
            </p>
            <div class="tg-lesson-actions">
              <% if (homeworkItems.length) { %>
                <button
                  class="tg-inline-action tg-inline-action--primary"
                  type="button"
                  data-tg-homework-view
                  data-tg-homework-view-meta="<%= lessonMeta %>"
                  data-tg-homework-items="<%= JSON.stringify(homeworkItems) %>"
                >
                  Подивитись ДЗ <span><%= homeworkItems.length %></span>
                </button>
              <% } %>
              <button
                class="tg-inline-action"
                type="button"
                data-tg-homework-open
                data-subject-id="<%= item.subject_id || '' %>"
                data-course-id="<%= item.course_id || item.owner_course_id || '' %>"
                data-group-number="<%= item.group_number || '' %>"
                data-day-of-week="<%= item.day_of_week || day %>"
                data-class-number="<%= item.class_number || '' %>"
                data-class-date="<%= item.class_date || (dayDate && dayDate.iso ? dayDate.iso : '') %>"
                data-time="<%= item.time_label || '' %>"
                data-subject-name="<%= item.subject_name || 'Предмет' %>"
              >
                Додати ДЗ
              </button>
            </div>
          </div>
        </div>
      <% }); %>
    </article>
  <% }); %>
</section>

<div class="tg-modal" id="tgHomeworkModal" hidden>
  <div class="tg-modal-backdrop" data-tg-homework-close></div>
  <section class="tg-modal-panel" role="dialog" aria-modal="true" aria-labelledby="tgHomeworkTitle">
    <div class="tg-modal-head">
      <div>
        <h2 id="tgHomeworkTitle">Додати ДЗ</h2>
        <p class="tg-muted" data-tg-homework-meta>Пара</p>
      </div>
      <button class="tg-icon-button" type="button" data-tg-homework-close aria-label="Закрити">×</button>
    </div>
    <form class="tg-form" method="POST" action="/studerria-tg/homework/create" enctype="multipart/form-data" autocomplete="off">
      <input type="hidden" name="subject_id" data-tg-homework-field="subject_id" />
      <input type="hidden" name="course_id" data-tg-homework-field="course_id" />
      <input type="hidden" name="group_number" data-tg-homework-field="group_number" />
      <input type="hidden" name="day_of_week" data-tg-homework-field="day_of_week" />
      <input type="hidden" name="class_number" data-tg-homework-field="class_number" />
      <input type="hidden" name="class_date" data-tg-homework-field="class_date" />
      <input type="hidden" name="time" data-tg-homework-field="time" />
      <input type="hidden" name="current_week" value="<%= currentWeek || 1 %>" />
      <label>
        <span>Опис ДЗ</span>
        <textarea name="description" rows="4" maxlength="1200" placeholder="Що треба зробити?" required></textarea>
      </label>
      <label>
        <span>Файл</span>
        <input name="attachment" type="file" />
      </label>
      <label>
        <span>Лінк</span>
        <input name="link_url" type="url" inputmode="url" placeholder="https://..." />
      </label>
      <button class="tg-primary" type="submit">Зберегти</button>
    </form>
  </section>
</div>

<div class="tg-modal" id="tgHomeworkViewModal" hidden>
  <div class="tg-modal-backdrop" data-tg-homework-view-close></div>
  <section class="tg-modal-panel" role="dialog" aria-modal="true" aria-labelledby="tgHomeworkViewTitle">
    <div class="tg-modal-head">
      <div>
        <h2 id="tgHomeworkViewTitle">ДЗ на пару</h2>
        <p class="tg-muted" data-tg-homework-view-meta>Пара</p>
      </div>
      <button class="tg-icon-button" type="button" data-tg-homework-view-close aria-label="Закрити">×</button>
    </div>
    <div class="tg-homework-list" data-tg-homework-view-list></div>
  </section>
</div>
