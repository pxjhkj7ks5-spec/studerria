<div class="tg-subject-list">
  <% (registerSubjectCards || []).forEach(function(subject) { %>
    <article class="tg-subject-card <%= subject.ready ? 'is-ready' : 'is-pending' %>" data-tg-subject-card>
      <div class="tg-subject-card-head">
        <div>
          <h3><%= subject.name %></h3>
          <p>
            <%= subject.requiredFlag ? 'Обовʼязковий' : 'Вибірковий' %>
            <%= subject.autoAssigned ? ' · автоматично' : (' · ' + subject.groupCount + ' групи') %>
          </p>
        </div>
        <span class="tg-subject-status <%= subject.ready ? 'is-ready' : 'is-pending' %>" data-tg-subject-status>
          <%= subject.ready ? 'Готово' : 'Обрати' %>
        </span>
      </div>
      <% if (subject.autoAssigned) { %>
        <input type="hidden" name="subject_<%= subject.id %>" value="<%= subject.selectedGroup || 1 %>" />
        <span class="tg-pill">Група 1</span>
      <% } else { %>
        <div class="tg-group-options">
          <% for (let groupNumber = 1; groupNumber <= subject.groupCount; groupNumber += 1) { %>
            <label>
              <input
                type="radio"
                name="subject_<%= subject.id %>"
                value="<%= groupNumber %>"
                <%= subject.selectedGroup === groupNumber ? 'checked' : '' %>
                <%= subject.requiredFlag ? 'required' : '' %>
              />
              <span>Група <%= groupNumber %></span>
            </label>
          <% } %>
          <% if (subject.allowNotTaught) { %>
            <label class="tg-skip">
              <input type="checkbox" name="optout_<%= subject.id %>" value="1" <%= subject.optedOut ? 'checked' : '' %> />
              <span>Не вивчаю</span>
            </label>
          <% } %>
        </div>
      <% } %>
    </article>
  <% }); %>
  <% if (!(registerSubjectCards || []).length) { %>
    <div class="tg-empty-state">
      <strong>Предмети ще не підтягнулись</strong>
      <span>Поверніться до вибору курсу або відкрийте mini app ще раз.</span>
    </div>
  <% } %>
</div>
