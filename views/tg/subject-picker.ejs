<div class="tg-subject-list">
  <% (registerSubjectCards || []).forEach(function(subject) { %>
    <article class="tg-subject-card">
      <div>
        <h3><%= subject.name %></h3>
        <p><%= subject.requiredFlag ? 'Обовʼязковий' : 'Вибірковий' %><%= subject.autoAssigned ? ' · група 1 автоматично' : '' %></p>
      </div>
      <% if (subject.autoAssigned) { %>
        <span class="tg-pill">Group 1</span>
      <% } else { %>
        <div class="tg-group-options">
          <% for (let groupNumber = 1; groupNumber <= subject.groupCount; groupNumber += 1) { %>
            <label>
              <input type="radio" name="subject_<%= subject.id %>" value="<%= groupNumber %>" <%= subject.selectedGroup === groupNumber ? 'checked' : '' %> />
              <span><%= groupNumber %></span>
            </label>
          <% } %>
          <% if (subject.allowNotTaught) { %>
            <label class="tg-skip">
              <input type="checkbox" name="optout_<%= subject.id %>" value="1" <%= subject.optedOut ? 'checked' : '' %> />
              <span>Skip</span>
            </label>
          <% } %>
        </div>
      <% } %>
    </article>
  <% }); %>
  <% if (!(registerSubjectCards || []).length) { %>
    <p class="tg-muted">Для цієї групи поки немає доступних предметів.</p>
  <% } %>
</div>
