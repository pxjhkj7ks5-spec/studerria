<section class="tg-page-head">
  <h1>Предмети</h1>
  <p class="tg-muted">Оновіть групи для предметів, які формують ваш персональний розклад.</p>
</section>

<% if (error) { %>
  <div class="tg-alert"><%= error === 'missing_group' ? 'Оберіть групи для всіх обовʼязкових предметів.' : 'Не вдалося зберегти вибір.' %></div>
<% } %>
<% if (success) { %>
  <div class="tg-success">Вибір збережено.</div>
<% } %>

<%
  const subjectCards = registerSubjectCards || [];
  const selectedSubjectsCount = subjectCards.filter(function(subject) { return subject && subject.ready; }).length;
  const pendingSubjectsCount = subjectCards.filter(function(subject) { return subject && subject.pending; }).length;
%>

<section class="tg-card tg-register-card">
  <div class="tg-card-head">
    <div>
      <h2>Групи предметів</h2>
      <p class="tg-muted">Ці налаштування формують розклад і Teamwork.</p>
    </div>
    <% if (subjectCards.length) { %>
      <span class="tg-count-badge" data-tg-subject-count><%= selectedSubjectsCount %>/<%= subjectCards.length %></span>
    <% } %>
  </div>
  <% if (subjectState && subjectState.scope && subjectState.scope.group_label) { %>
    <p class="tg-section-note"><%= subjectState.scope.group_label %></p>
  <% } %>
  <% if (subjectCards.length) { %>
    <div class="tg-progress-line" aria-label="Прогрес вибору предметів" data-tg-subject-progress>
      <span style="width: <%= Math.round((selectedSubjectsCount / Math.max(1, subjectCards.length)) * 100) %>%"></span>
    </div>
    <p class="tg-inline-note" data-tg-subject-remaining><%= pendingSubjectsCount ? ('Залишилось обрати: ' + pendingSubjectsCount) : 'Усе готово.' %></p>
  <% } %>
  <form class="tg-form" method="POST" action="/studerria-tg/subjects" data-tg-subject-picker>
    <%- include('subject-picker', { registerSubjectCards: subjectCards }) %>
    <button class="tg-primary" type="submit">Зберегти</button>
  </form>
</section>
