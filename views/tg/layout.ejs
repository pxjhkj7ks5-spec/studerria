<!doctype html>
<html lang="<%= lang || 'uk' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f6f4f0" />
    <meta name="color-scheme" content="light dark" />
    <title><%= pageTitle || 'Studerria' %></title>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <link rel="stylesheet" href="/css/pages/tg-mini.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <script src="https://telegram.org/js/telegram-web-app.js" defer></script>
    <script>
      window.__studerriaTg = {
        currentPath: <%- JSON.stringify(currentPath || '') %>,
        authenticated: <%- JSON.stringify(Boolean(sessionUser)) %>
      };
    </script>
  </head>
  <body class="tg-mini tg-mini--<%= currentTgPage || 'start' %>" data-current-page="<%= currentTgPage || '' %>">
    <main class="tg-shell">
      <%- bodyHtml || '' %>
    </main>

    <% if (sessionUser) { %>
      <nav class="tg-bottom-nav" aria-label="Telegram mini app navigation">
        <a class="tg-nav-item <%= currentTgPage === 'schedule' ? 'is-active' : '' %>" href="/studerria-tg/schedule">
          <span class="tg-nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 3.75v2.5M17 3.75v2.5M4.75 9h14.5M6.5 5.25h11a2 2 0 0 1 2 2v10.25a2 2 0 0 1-2 2h-11a2 2 0 0 1-2-2V7.25a2 2 0 0 1 2-2Z" />
              <path d="M8 12.25h2.1M13.9 12.25H16M8 15.75h2.1M13.9 15.75H16" />
            </svg>
          </span>
          <span>Розклад</span>
        </a>
        <a class="tg-nav-item <%= currentTgPage === 'teamwork' ? 'is-active' : '' %>" href="/studerria-tg/teamwork">
          <span class="tg-nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M8.75 11.25a2.9 2.9 0 1 0 0-5.8 2.9 2.9 0 0 0 0 5.8Z" />
              <path d="M15.45 11.25a2.65 2.65 0 1 0 0-5.3" />
              <path d="M3.95 18.7c.55-2.75 2.28-4.45 4.8-4.45s4.25 1.7 4.8 4.45" />
              <path d="M13.8 14.55c2.35.22 3.9 1.76 4.35 4.15" />
            </svg>
          </span>
          <span>Teamwork</span>
        </a>
        <a class="tg-nav-item <%= currentTgPage === 'profile' ? 'is-active' : '' %>" href="/studerria-tg/profile">
          <span class="tg-nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 12.35a3.7 3.7 0 1 0 0-7.4 3.7 3.7 0 0 0 0 7.4ZM5.8 19.2c.75-2.7 2.95-4.35 6.2-4.35s5.45 1.65 6.2 4.35" />
            </svg>
          </span>
          <span>Профіль</span>
        </a>
      </nav>
    <% } %>

    <script src="/js/tg-mini.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
