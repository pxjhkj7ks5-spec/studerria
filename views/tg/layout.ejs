<!doctype html>
<html lang="<%= lang || 'uk' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f8fb" />
    <title><%= pageTitle || 'Studerria' %></title>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <link rel="stylesheet" href="/css/pages/tg-mini.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <script src="https://telegram.org/js/telegram-web-app.js" defer></script>
    <script>
      window.__studerriaTg = {
        currentPath: <%- JSON.stringify(currentPath || '') %>,
        authenticated: <%- JSON.stringify(Boolean(sessionUser)) %>
      };
    </script>
  </head>
  <body class="tg-mini tg-mini--<%= currentTgPage || 'start' %>" data-current-page="<%= currentTgPage || '' %>">
    <main class="tg-shell">
      <%- bodyHtml || '' %>
    </main>

    <% if (sessionUser) { %>
      <nav class="tg-bottom-nav" aria-label="Telegram mini app navigation">
        <a class="tg-nav-item <%= currentTgPage === 'schedule' ? 'is-active' : '' %>" href="/tg/schedule">
          <span class="tg-nav-icon">S</span>
          <span>Schedule</span>
        </a>
        <a class="tg-nav-item <%= currentTgPage === 'subjects' ? 'is-active' : '' %>" href="/tg/subjects">
          <span class="tg-nav-icon">D</span>
          <span>Subjects</span>
        </a>
        <a class="tg-nav-item <%= currentTgPage === 'profile' ? 'is-active' : '' %>" href="/tg/profile">
          <span class="tg-nav-icon">P</span>
          <span>Profile</span>
        </a>
      </nav>
    <% } %>

    <button class="tg-changelog-button" type="button" data-tg-changelog-open>Changelog</button>
    <section class="tg-modal" data-tg-changelog hidden>
      <button class="tg-modal-backdrop" type="button" data-tg-changelog-close aria-label="Close changelog"></button>
      <article class="tg-modal-sheet" role="dialog" aria-modal="true" aria-labelledby="tgChangelogTitle" tabindex="-1">
        <header class="tg-modal-head">
          <div>
            <p>Studerria</p>
            <h2 id="tgChangelogTitle">Changelog</h2>
          </div>
          <button type="button" data-tg-changelog-close aria-label="Close">&times;</button>
        </header>
        <div class="tg-changelog-list">
          <% (changelog || []).slice(0, 20).forEach(function(item) { %>
            <article class="tg-changelog-item">
              <strong><%= item.version || '' %></strong>
              <p><%= item.title || item.summary || '' %></p>
            </article>
          <% }); %>
          <% if (!(changelog || []).length) { %>
            <p class="tg-muted">No changelog entries yet.</p>
          <% } %>
        </div>
      </article>
    </section>

    <script src="/js/tg-mini.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
