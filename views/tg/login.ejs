<%
  const loginErrorMap = {
    missing: 'Заповніть імʼя та пароль.',
    invalid: 'Не вдалося увійти. Перевірте дані.',
    db: 'Тимчасова помилка входу.',
    'student-only': 'Цей mini app доступний тільки для студентського акаунта.',
    'telegram-required': 'Відкрийте сторінку з Telegram mini app, щоб привʼязати акаунт.',
    'telegram-occupied': 'Цей Telegram вже привʼязаний до іншого акаунта.',
    'quarantine-later': 'Акаунт тимчасово очікує перевірки.',
  };
  const loginError = loginErrorMap[String(error || '')] || '';
%>
<section class="tg-page-head">
  <p class="tg-kicker">Studerria</p>
  <h1>Вхід</h1>
  <p class="tg-muted">Увійдіть один раз, і Telegram буде відкривати ваш студентський простір автоматично.</p>
</section>

<section class="tg-card">
  <% if (loginError) { %>
    <div class="tg-alert"><%= loginError %></div>
  <% } %>
  <form class="tg-form" method="POST" action="/tg/login">
    <label>
      <span>Повне імʼя</span>
      <input name="full_name" type="text" autocomplete="username" placeholder="Ваше імʼя у Studerria" value="<%= suggestedName || '' %>" required />
    </label>
    <label>
      <span>Пароль</span>
      <input name="password" type="password" autocomplete="current-password" placeholder="Пароль" required />
    </label>
    <button class="tg-primary" type="submit">Увійти і привʼязати Telegram</button>
  </form>
  <p class="tg-inline-note">Немає акаунта? <a href="/tg/register">Зареєструватися</a></p>
</section>
