<!doctype html>
<html lang="uk" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Studerria · Test Schedule</title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--app td-page--schedule" data-theme="light">
    <div class="td-app-shell">
      <section class="td-app-frame td-glass-panel" aria-label="Studerria schedule concept">
        <%- include('partials/test-top-nav', { active: 'schedule' }) %>

        <main class="td-app-content td-schedule-workspace">
          <header class="td-page-header">
            <div>
              <p class="td-page-kicker">Week 14 · 13-19 травня</p>
              <h1>Твій розклад</h1>
              <p>Середа, 15 травня. Пари, аудиторії та найближчі дії на день.</p>
            </div>
            <div class="td-page-actions" aria-label="Керування розкладом">
              <button class="td-small-button" type="button">Today</button>
              <button class="td-small-button" type="button">This week</button>
              <span class="td-button-cluster">
                <button class="td-icon-button" type="button" aria-label="Попередній тиждень">
                  <%- include('partials/test-icon', { name: 'chevronLeft', className: 'td-button-icon' }) %>
                </button>
                <button class="td-icon-button" type="button" aria-label="Наступний тиждень">
                  <%- include('partials/test-icon', { name: 'chevronRight', className: 'td-button-icon' }) %>
                </button>
              </span>
            </div>
          </header>

          <section class="td-day-switcher td-surface-card" aria-label="Дні тижня">
            <button class="td-day-pill" type="button">
              <span>Mon</span>
              <strong>13</strong>
              <small>3 пари</small>
            </button>
            <button class="td-day-pill" type="button">
              <span>Tue</span>
              <strong>14</strong>
              <small>2 пари</small>
            </button>
            <button class="td-day-pill is-active is-today" type="button" aria-current="date">
              <span>Wed</span>
              <strong>15</strong>
              <small>4 пари</small>
            </button>
            <button class="td-day-pill" type="button">
              <span>Thu</span>
              <strong>16</strong>
              <small>2 пари</small>
            </button>
            <button class="td-day-pill" type="button">
              <span>Fri</span>
              <strong>17</strong>
              <small>3 пари</small>
            </button>
            <button class="td-day-pill" type="button">
              <span>Sat</span>
              <strong>18</strong>
              <small>1 пара</small>
            </button>
            <button class="td-day-pill is-quiet" type="button">
              <span>Sun</span>
              <strong>19</strong>
              <small>вільно</small>
            </button>
          </section>

          <section class="td-schedule-layout">
            <article class="td-schedule-panel td-surface-card" aria-label="Пари на сьогодні">
              <header class="td-section-head">
                <div>
                  <h2>Сьогодні</h2>
                  <p>4 пари · наступна о 11:00</p>
                </div>
                <span class="td-live-pill"><i></i>Now</span>
              </header>

              <div class="td-lesson-list">
                <article class="td-lesson-card td-lesson-card--lecture">
                  <time>09:00 - 10:30</time>
                  <div class="td-lesson-main">
                    <strong>Операційні системи</strong>
                    <span>CS-23 · Лекція · проф. Ірина Коваль</span>
                  </div>
                  <div class="td-lesson-meta">
                    <span class="td-location"><%- include('partials/test-icon', { name: 'pin', className: 'td-inline-icon' }) %> ауд. 204</span>
                    <span class="td-badge td-badge--blue">Lecture</span>
                  </div>
                </article>

                <article class="td-lesson-card td-lesson-card--practice is-now">
                  <time>11:00 - 12:30</time>
                  <div class="td-lesson-main">
                    <strong>Бази даних</strong>
                    <span>CS-23 · Практика · Андрій Мельник</span>
                  </div>
                  <div class="td-lesson-meta">
                    <span class="td-location"><%- include('partials/test-icon', { name: 'pin', className: 'td-inline-icon' }) %> ауд. 301</span>
                    <span class="td-badge td-badge--violet">Now</span>
                  </div>
                </article>

                <article class="td-lesson-card td-lesson-card--seminar">
                  <time>13:10 - 14:40</time>
                  <div class="td-lesson-main">
                    <strong>Англійська мова</strong>
                    <span>Група 2 · Семінар · Олена Сидоренко</span>
                  </div>
                  <div class="td-lesson-meta">
                    <span class="td-location"><%- include('partials/test-icon', { name: 'pin', className: 'td-inline-icon' }) %> ауд. 105</span>
                    <span class="td-badge td-badge--soft">Seminar</span>
                  </div>
                </article>

                <article class="td-lesson-card td-lesson-card--lab">
                  <time>15:00 - 16:30</time>
                  <div class="td-lesson-main">
                    <strong>Математичний аналіз</strong>
                    <span>CS-23 · Лабораторна · Марія Литвин</span>
                  </div>
                  <div class="td-lesson-meta">
                    <span class="td-location"><%- include('partials/test-icon', { name: 'pin', className: 'td-inline-icon' }) %> ауд. 405</span>
                    <span class="td-badge td-badge--green">Lab</span>
                  </div>
                </article>
              </div>
            </article>

            <aside class="td-schedule-aside" aria-label="Огляд дня">
              <section class="td-overview-card td-surface-card">
                <header class="td-section-head">
                  <div>
                    <h2>Today overview</h2>
                    <p>Короткий стан дня</p>
                  </div>
                </header>
                <div class="td-overview-grid">
                  <span><strong>4</strong><small>Пари</small></span>
                  <span><strong>2</strong><small>Аудиторії</small></span>
                  <span><strong>1</strong><small>Дедлайн</small></span>
                </div>
                <div class="td-next-card">
                  <span class="td-next-icon"><%- include('partials/test-icon', { name: 'calendarCheck', className: 'td-stat-svg' }) %></span>
                  <div>
                    <strong>Наступна пара</strong>
                    <span>Бази даних · 11:00 · ауд. 301</span>
                  </div>
                </div>
              </section>

              <section class="td-overview-card td-surface-card" id="homework">
                <header class="td-section-head">
                  <div>
                    <h2>Найближче ДЗ</h2>
                    <p>До завтра</p>
                  </div>
                  <span class="td-badge td-badge--violet">1 task</span>
                </header>
                <div class="td-homework-item">
                  <strong>SQL joins practice</strong>
                  <span>Бази даних · здати до 18:00</span>
                </div>
              </section>

              <section class="td-empty-state td-surface-card" aria-label="Приклад порожнього дня">
                <span class="td-empty-orb"><%- include('partials/test-icon', { name: 'calendar', className: 'td-empty-icon' }) %></span>
                <div>
                  <h2>Неділя вільна</h2>
                  <p>Коли на день немає пар, показуємо спокійний empty state замість порожньої області.</p>
                </div>
              </section>
            </aside>
          </section>
        </main>
      </section>
    </div>
    <script src="/js/test-design.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
