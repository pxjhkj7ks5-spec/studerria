            <input type="hidden" name="source_course_id" value="<%= selectedCourseValue %>" />
            <input type="hidden" name="track" value="<%= activeTrack %>" />
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
            <input type="hidden" name="sync_pathways" value="1" />
            <div class="section-header mb-2">
              <div>
                <h3 class="section-title h5 mb-1"><%= ui.catalogAssignTitle %></h3>
                <p class="section-subtitle mb-0"><%= ui.catalogAssignSubtitle %></p>
              </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
