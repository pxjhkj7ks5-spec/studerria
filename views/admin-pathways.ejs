                    <%= isUk ? 'Ще немає жодного готового курсу для призначення' : 'No target courses are ready for assignment yet' %>
                  <% } %>
                </strong>
                <span>
                  <% if (catalogReadyTargetCount > 0 && catalogBlockedTargetCount > 0) { %>
                    <%= isUk ? `${catalogBlockedTargetCount} курс(ів) залишаються заблокованими, доки не стануть visible в mapping цієї когорти.` : `${catalogBlockedTargetCount} course(s) are still blocked until they become visible in this cohort mapping.` %>
                  <% } else if (catalogReadyTargetCount > 0) { %>
                    <%= isUk ? 'У focused cohort mode призначення піде тільки по замаплених курсах нижче.' : 'In focused cohort mode, assignment stays scoped to the mapped courses below.' %>
                  <% } else { %>
                    <%= isUk ? 'Спершу завершіть course mapping для цієї когорти, і тоді призначення з каталогу розблокується.' : 'Finish course mapping for this cohort first, then catalog assignment will unlock.' %>
