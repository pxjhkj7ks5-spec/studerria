              <span class="chip"><%= ui.programsChip %>: <%= (programs || []).length %></span>
              <span class="chip"><%= ui.admissionsChip %>: <%= (admissions || []).length %></span>
              <span class="chip"><%= ui.mappedCoursesChip %>: <%= studyContextList.length %></span>
              <span class="chip"><%= ui.visibleSubjectsChip %>: <%= moderationQueueList.length %></span>
            </div>
            <div class="hero-focus-strip">
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.courseScope %></span>
                <strong><%= selectedCourseLabel || ui.noCourseSelected %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.trackFilter %></span>
                <strong><%= activeTrackLabel %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.focusedCohort %></span>
                <strong><%= cohortFocusLabel %></strong>
