                <span class="chip"><%= trackLabels[String(cohortHealth.track_key)] || cohortHealth.track_key %></span>
                <span class="chip"><%= cohortHealth.course_label %></span>
              </div>
              <div class="hero-health__grid">
                <% (cohortHealth.signals || []).forEach((signal) => { %>
                  <a class="health-signal-card is-<%= signal.tone || 'muted' %>" href="<%= signal.href %>">
                    <span class="health-signal-card__label"><%= signal.label %></span>
                    <strong class="health-signal-card__value"><%= signal.value %></strong>
                    <span class="health-signal-card__meta"><%= signal.meta %></span>
                  </a>
                <% }) %>
              </div>
              <% if (cohortAlertsList.length && cohortAlertsList[0] && cohortAlertsList[0].target) { %>
                <div class="mt-3 d-grid">
                  <a class="btn btn-soft btn-pill" href="#<%= cohortAlertsList[0].target %>"><%= cohortAlertsList[0].action_label || ui.openSection %></a>
                </div>
              <% } %>
            <% } else { %>
              <div class="hero-health__empty"><%= ui.heroHealthEmpty %></div>
            <% } %>
          </aside>
        </div>
      </section>

      <nav class="glass focus-nav mb-3" aria-label="<%= ui.navAria %>">
        <div class="focus-nav__links">
          <% sectionLinks.forEach((item) => { %>
            <a class="focus-nav__link" href="<%= item.href %>"><%= item.label %></a>
          <% }) %>
        </div>
        <div class="focus-nav__meta">
          <span class="focus-nav__meta-label"><%= ui.navFocus %></span>
          <strong class="focus-nav__meta-value"><%= cohortFocusLabel %></strong>
        </div>
      </nav>

      <section class="glass section mb-3" id="pathways-flow">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= isUk ? 'Серпневий setup flow' : 'August setup flow' %></h2>
            <p class="section-subtitle"><%= isUk ? 'Primary path без legacy-мепінгу: спочатку програми і пресети, далі intake year, потім live contexts, semesters, offerings, а вже після цього teachers та users.' : 'Primary path without legacy mapping: start with programs and presets, create the intake year, then prepare live contexts, semesters, offerings, and only then align teachers and users.' %></p>
          </div>
          <span class="chip"><%= selectedStudyContextItem ? (isUk ? 'Context у фокусі' : 'Context focused') : (isUk ? 'Оберіть context' : 'Pick a context') %></span>
        </div>
        <div class="setup-flow-grid">
          <a class="setup-flow-card" href="#pathways-programs">
            <span class="setup-flow-card__step">01</span>
            <strong class="setup-flow-card__title"><%= isUk ? 'Програми і пресети' : 'Programs and presets' %></strong>
            <span class="setup-flow-card__meta"><%= isUk ? `${(filteredPrograms || programs || []).length} програм у фокусі` : `${(filteredPrograms || programs || []).length} programs in scope` %></span>
          </a>
          <a class="setup-flow-card" href="#pathways-intake">
            <span class="setup-flow-card__step">02</span>
            <strong class="setup-flow-card__title"><%= isUk ? 'Створити intake year' : 'Create intake year' %></strong>
            <span class="setup-flow-card__meta"><%= isUk ? 'Один admission year для кількох програм з авто-stage-1 contexts' : 'One admission year for multiple programs with auto-created stage 1 contexts' %></span>
          </a>
          <a class="setup-flow-card" href="#pathways-admissions">
            <span class="setup-flow-card__step">03</span>
            <strong class="setup-flow-card__title"><%= isUk ? 'Когорта і promote' : 'Cohort and promote' %></strong>
            <span class="setup-flow-card__meta"><%= isUk ? `Років вступу: ${(admissions || []).length}` : `Admission years: ${(admissions || []).length}` %></span>
          </a>
          <a class="setup-flow-card" href="#pathways-contexts">
            <span class="setup-flow-card__step">04</span>
            <strong class="setup-flow-card__title"><%= isUk ? 'Контексти, семестри, offerings' : 'Contexts, semesters, offerings' %></strong>
            <span class="setup-flow-card__meta"><%= selectedStudyContextItem ? `${selectedStudyContextSemestersList.length} / ${selectedStudyContextOfferingsList.length}` : `${studyContextList.length}` %> <%= isUk ? (selectedStudyContextItem ? 'семестрів / offerings' : 'context cards') : (selectedStudyContextItem ? 'semesters / offerings' : 'context cards') %></span>
          </a>
          <a class="setup-flow-card" href="<%= selectedStudyContextItem ? buildAdminScopeUrl(selectedStudyContextItem, 'admin-teachers') : '/teacher/workspace' %>">
            <span class="setup-flow-card__step">05</span>
            <strong class="setup-flow-card__title"><%= isUk ? 'Teachers і users' : 'Teachers and users' %></strong>
            <span class="setup-flow-card__meta"><%= selectedStudyContextItem ? (isUk ? `Юзерів у context: ${Number(selectedStudyContextItem.user_count || 0)}` : `Context users: ${Number(selectedStudyContextItem.user_count || 0)}`) : (isUk ? 'Після setup відкрийте teacher scope' : 'Open teacher scope after setup') %></span>
          </a>
        </div>
      </section>

      <% if (cohortAlertsList.length) { %>
        <section class="pathways-alert-stack mb-3">
          <% cohortAlertsList.forEach((alert) => { %>
            <article class="glass pathways-alert pathways-alert--<%= alert.tone || 'info' %>">
              <div class="pathways-alert__body">
                <strong class="pathways-alert__title"><%= alert.title %></strong>
                <p class="pathways-alert__text"><%= alert.body %></p>
              </div>
              <% if (alert.target) { %>
                <a class="btn btn-soft btn-pill pathways-alert__action" href="#<%= alert.target %>"><%= alert.action_label || ui.openSection %></a>
              <% } %>
            </article>
          <% }) %>
        </section>
      <% } %>

      <section class="glass section mb-3" id="pathways-registration-impact">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= isUk ? 'Вплив на реєстрацію' : 'Registration impact' %></h2>
            <p class="section-subtitle"><%= isUk ? 'Панель коротко показує, що саме зараз побачить студент у вибраній когорті: чи відкриється курс, чи буде список предметів і чи не ламається маршрут кампусом.' : 'This panel shows what students see in the selected cohort right now: whether the course route opens, whether subjects are visible, and whether campus routing stays stable.' %></p>
          </div>
          <span class="chip"><%= selectedAdmissionValue > 0 ? (registrationExperience ? registrationExperience.title : (isUk ? 'Немає даних' : 'No data')) : ui.selectAdmissionFirst %></span>
        </div>
        <% if (selectedAdmissionValue > 0 && registrationExperience) { %>
          <div class="pathways-banner pathways-banner--<%= registrationExperience.tone || 'muted' %>">
            <strong><%= registrationExperience.title %></strong>
            <span><%= registrationExperience.body %></span>
          </div>
          <% if (Array.isArray(registrationExperience.stages) && registrationExperience.stages.length) { %>
            <div class="scope-summary-grid mt-3">
              <% registrationExperience.stages.forEach((stage) => { %>
                <div class="scope-summary-card">
                  <span class="scope-summary-card__label"><%= stage.label %></span>
                  <strong><%= stage.value %></strong>
                  <% if (stage.hint) { %>
                    <span class="catalog-subject-meta d-block mt-1"><%= stage.hint %></span>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
        <% } else { %>
          <div class="soft-panel muted"><%= ui.selectAdmissionFirst %></div>
        <% } %>
      </section>

      <section class="glass section mb-3" id="pathways-scope">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.scopeTitle %></h2>
            <p class="section-subtitle"><%= ui.scopeSubtitle %></p>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="chip"><%= activeTrackLabel %></span>
            <% if (selectedProgramValue > 0 || selectedAdmissionValue > 0) { %>
              <a class="btn btn-soft btn-sm btn-pill" href="<%= buildPathwaysUrl({ program_id: null, admission_id: null }) %>"><%= ui.clearFocus %></a>
            <% } %>
          </div>
        </div>
        <form method="GET" action="/admin/pathways" class="row g-2 mt-1">
          <div class="col-12 col-md-6 col-xl-4">
            <label class="form-label small" for="pathwayCourseSelect"><%= ui.courseScope %></label>
            <select id="pathwayCourseSelect" class="form-select compact-select" name="course">
              <% (courses || []).forEach((course) => { %>
                <option value="<%= course.id %>" <%= Number(course.id) === Number(selectedCourseValue) ? 'selected' : '' %>>
                  <%= buildCourseLabel(course) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <label class="form-label small" for="pathwayTrackSelect"><%= ui.trackFilter %></label>
            <select id="pathwayTrackSelect" class="form-select compact-select" name="track">
              <% (trackFilterOptions || []).forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>>
                  <%= trackLabels[String(item.key)] || item.label %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-xl-2 align-self-end d-grid">
            <button type="submit" class="btn btn-primary btn-pill"><%= ui.applyScope %></button>
          </div>
          <%- renderPathwaysFocusFields({}, { exclude: ['courseId', 'track'] }) %>
        </form>
        <div class="scope-summary-grid">
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.courseScope %></span>
            <strong><%= selectedCourseLabel || ui.noCourseSelected %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.programFocus %></span>
            <strong><%= selectedProgram ? selectedProgram.name : ui.noProgramSelected %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.admissionFocus %></span>
            <strong><%= selectedAdmission ? `${selectedAdmission.admission_year}${selectedAdmission.label ? ` · ${selectedAdmission.label}` : ''}` : ui.noAdmissionSelected %></strong>
          </div>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-programs">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.programsTitle %></h2>
            <p class="section-subtitle"><%= ui.programsSubtitle %></p>
          </div>
        </div>

        <form method="POST" action="/admin/pathways/programs/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
          <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.track %></label>
            <select name="track_key" class="form-select compact-select" required>
              <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>><%= trackLabels[String(item.key)] || item.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.code %></label>
            <input class="form-control compact-input" type="text" name="code" maxlength="40" placeholder="BSC-AI" />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.programName %></label>
            <input class="form-control compact-input" type="text" name="name" maxlength="140" required placeholder="Bachelor AI" />
          </div>
          <div class="col-8 col-md-1">
            <label class="form-label small"><%= ui.sort %></label>
            <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="100" />
          </div>
          <div class="col-4 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit"><%= ui.add %></button>
          </div>
        </form>

        <div class="program-grid">
          <% (filteredPrograms || []).forEach((program) => { %>
            <form method="POST" action="/admin/pathways/programs/<%= program.id %>/update" class="soft-panel program-card <%= Number(program.id) === Number(selectedProgramValue) ? 'is-selected' : '' %>">
              <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
              <input type="hidden" name="track" value="<%= activeTrack %>" />
              <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
              <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
              <div class="program-card__header">
                <div>
                  <div class="program-card__eyebrow"><%= ui.programEyebrow %> #<%= program.id %></div>
                  <div class="row-label"><%= program.name %></div>
                </div>
                <div class="program-card__actions">
                  <% if (program.code) { %>
                    <span class="chip"><%= program.code %></span>
                  <% } %>
                  <a class="btn btn-soft btn-sm btn-pill" href="<%= buildPathwaysUrl({ program_id: program.id, admission_id: null }) %>"><%= ui.open %></a>
                </div>
              </div>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small"><%= ui.track %></label>
                  <select class="form-select compact-select" name="track_key" required>
                    <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                      <option value="<%= item.key %>" <%= item.key === program.track_key ? 'selected' : '' %>><%= trackLabels[String(item.key)] || item.label %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-sm-3">
                  <label class="form-label small"><%= ui.code %></label>
                  <input class="form-control compact-input" type="text" name="code" maxlength="40" value="<%= program.code || '' %>" />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small"><%= ui.programName %></label>
                  <input class="form-control compact-input" type="text" name="name" maxlength="140" required value="<%= program.name %>" />
                </div>
                <div class="col-7 col-sm-3">
                  <label class="form-label small"><%= ui.sort %></label>
                  <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="<%= program.sort_order %>" />
                </div>
                <div class="col-5 col-sm-4 align-self-end">
                  <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="program_active_<%= program.id %>" name="is_active" value="1" <%= program.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="program_active_<%= program.id %>"><%= ui.activeToggle %></label>
                  </div>
                </div>
                <div class="col-12 col-sm-5 align-self-end d-grid">
                  <button class="btn btn-primary btn-pill" type="submit"><%= ui.save %></button>
                </div>
              </div>
              <div class="program-card__footer muted"><%= ui.admissionsInProgram %>: <%= Number(program.admissions_count || 0) %></div>
            </form>
          <% }) %>
          <% if (!(filteredPrograms || []).length) { %>
            <div class="soft-panel">
              <div class="muted"><%= ui.noPrograms %></div>
            </div>
          <% } %>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-intake">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= setupUi.intakeTitle %></h2>
            <p class="section-subtitle"><%= setupUi.intakeSubtitle %></p>
          </div>
          <span class="chip"><%= (filteredPrograms || []).length || (programs || []).length %></span>
        </div>
        <form method="POST" action="/admin/pathways/intake/create" class="soft-panel">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
          <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
          <input type="hidden" name="study_context_id" value="<%= selectedStudyContextValue %>" />
          <input type="hidden" name="preset_id" value="<%= selectedProgramPresetValue %>" />
          <div class="row g-3">
            <div class="col-12 col-lg-3">
              <label class="form-label small"><%= ui.admissionYear %></label>
              <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= selectedAdmission ? Number(selectedAdmission.admission_year || 0) + 1 : '' %>" placeholder="2027" required />
            </div>
            <div class="col-12 col-lg-9">
              <label class="form-label small d-block"><%= setupUi.intakePrograms %></label>
              <div class="d-grid gap-2">
                <% ((filteredPrograms && filteredPrograms.length) ? filteredPrograms : (programs || [])).forEach((program) => { %>
                  <label class="subject-row" data-checklist-row data-checklist-text="<%= `${program.name} ${program.code || ''} ${trackLabels[String(program.track_key)] || program.track_key}` %>">
                    <span>
                      <span class="row-label"><%= program.name %></span>
                      <span class="muted d-block"><%= program.code || '—' %> / <%= trackLabels[String(program.track_key)] || program.track_key %></span>
                    </span>
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="program_ids[]"
                        value="<%= program.id %>"
                        <%= Number(selectedProgramValue) === Number(program.id) || (((filteredPrograms || []).length || (programs || []).length) === 1) ? 'checked' : '' %>
                      />
                  </label>
                <% }) %>
              </div>
            </div>
            <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
              <button class="btn btn-primary btn-pill" type="submit"><%= setupUi.createIntake %></button>
              <span class="muted"><%= selectedProgramValue > 0 ? `${ui.programLabel}: ${selectedProgram ? selectedProgram.name : ''}` : setupUi.intakePrograms %></span>
            </div>
          </div>
        </form>
      </section>

      <section class="glass section mb-3" id="pathways-admissions">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.admissionsTitle %></h2>
            <p class="section-subtitle"><%= ui.admissionsSubtitle %></p>
          </div>
          <% if (selectedProgram) { %>
            <span class="chip"><%= selectedProgram.name %></span>
          <% } %>
        </div>

        <form id="pathwaysAdmissionCreateForm" method="POST" action="/admin/pathways/admissions/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
          <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.programLabel %></label>
            <select class="form-select compact-select" name="program_id" required>
              <option value=""><%= ui.selectProgram %></option>
              <% (filteredPrograms || []).forEach((program) => { %>
                <option value="<%= program.id %>" <%= Number(program.id) === Number(selectedProgramValue) ? 'selected' : '' %>>
                  <%= program.name %> (<%= trackLabels[String(program.track_key)] || program.track_key %>)
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.admissionYear %></label>
            <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= new Date().getUTCFullYear() %>" required />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.label %></label>
            <input class="form-control compact-input" type="text" name="label" maxlength="120" placeholder="<%= ui.cohortPlaceholder %>" />
          </div>
          <div class="col-12 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit"><%= ui.add %></button>
          </div>
        </form>

        <div class="admission-grid">
          <% admissionCards.forEach((admission) => { %>
            <form class="soft-panel admission-card <%= admission.is_selected ? 'is-selected' : '' %>" method="POST" action="/admin/pathways/admissions/<%= admission.id %>/update">
              <%- renderPathwaysFocusFields({ programId: admission.program_id, admissionId: admission.id, studyContextId: admission.is_selected ? selectedStudyContextValue : 0 }) %>
              <div class="admission-card__head">
                <div>
                  <div class="admission-card__eyebrow"><%= ui.admissionEyebrow %></div>
                  <div class="admission-card__title"><%= admission.admission_year %><%= admission.label ? ` · ${admission.label}` : '' %></div>
                </div>
                <div class="admission-card__status-stack">
                  <div class="admission-card__status">
                    <span class="status-pill status-pill--<%= admission.status_tone %>"><%= admission.status_label %></span>
                    <% if (admission.is_selected) { %>
                      <span class="status-pill status-pill--focus"><%= ui.focusedPill %></span>
                    <% } %>
                  </div>
                  <% if ((admission.status_detail_lines || []).length) { %>
                    <div class="admission-card__popover" role="note">
                      <strong class="admission-card__popover-title"><%= ui.statusWhyTitle %></strong>
                      <ul class="admission-card__popover-list">
                        <% (admission.status_detail_lines || []).forEach((line) => { %>
                          <li><%= line %></li>
                        <% }) %>
                      </ul>
                    </div>
                  <% } %>
                </div>
              </div>
              <div class="admission-card__metrics">
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.coursesShort %></span>
                  <strong class="mini-stat__value"><%= admission.mapping_visible_count %>/<%= admission.mapping_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.subjectsShort %></span>
                  <strong class="mini-stat__value"><%= admission.subject_visible_count %>/<%= admission.subject_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.campusesShort %></span>
                  <strong class="mini-stat__value"><%= formatCampusStatus(admission.campus_ambiguous_count, admission.campus_ready_count) %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.usersShort %></span>
                  <strong class="mini-stat__value"><%= admission.users_count %></strong>
                </div>
              </div>
              <% if ((admission.status_notes || []).length) { %>
                <div class="admission-card__notes">
                  <% (admission.status_notes || []).forEach((note) => { %>
                    <span class="chip"><%= note %></span>
                  <% }) %>
                </div>
              <% } %>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small"><%= ui.year %></label>
                  <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= admission.admission_year %>" required />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small"><%= ui.label %></label>
                  <input class="form-control compact-input" type="text" name="label" maxlength="120" value="<%= admission.label || '' %>" />
                </div>
                <div class="col-12 col-sm-3 align-self-end">
                  <div class="form-check admission-card__check">
                    <input class="form-check-input" type="checkbox" id="adm_active_<%= admission.id %>" name="is_active" value="1" <%= admission.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="adm_active_<%= admission.id %>"><%= ui.activeToggle %></label>
                  </div>
                </div>
              </div>
              <div class="admission-card__footer">
                <a class="btn btn-soft btn-pill" href="<%= buildPathwaysUrl({ program_id: admission.program_id, admission_id: admission.id }) %>"><%= ui.focusCohort %></a>
                <div class="admission-card__footer-actions">
                  <div class="admission-card__action-stack">
                    <% if (admission.can_delete) { %>
                      <button
