                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="context_offering_required_<%= offering.id %>" name="is_required" value="1" <%= offering.is_required ? 'checked' : '' %> /><label class="form-check-label" for="context_offering_required_<%= offering.id %>"><%= contextOfferingUi.required %></label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="context_offering_general_<%= offering.id %>" name="is_general" value="1" <%= offering.is_general ? 'checked' : '' %> /><label class="form-check-label" for="context_offering_general_<%= offering.id %>"><%= contextOfferingUi.general %></label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="context_offering_teamwork_<%= offering.id %>" name="show_in_teamwork" value="1" <%= offering.show_in_teamwork ? 'checked' : '' %> /><label class="form-check-label" for="context_offering_teamwork_<%= offering.id %>"><%= contextOfferingUi.teamwork %></label></div>
                                  </div>
                                </div>
                                <div class="col-12 col-lg-4 d-grid">
                                  <button class="btn btn-primary btn-pill" type="submit"><%= contextOfferingUi.save %></button>
                                </div>
                              </form>
                              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-2">
                                <span class="catalog-subject-meta">#<%= offering.id %><% if (offering.is_shared) { %> / shared<% } %><% if (!offering.is_active) { %> / inactive<% } %></span>
