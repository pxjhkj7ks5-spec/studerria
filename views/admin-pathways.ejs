                </span>
              </div>
            <% } %>
            <div class="catalog-target-list mb-3">
              <% (catalogTargetList || []).forEach((course) => { %>
                <label class="catalog-target-row <%= course.is_available ? '' : 'is-disabled' %>" data-catalog-course-row data-catalog-course-text="<%= `${course.name || ''} ${course.course_id || ''} ${course.is_available ? catalogTargetReadyLabel : catalogTargetBlockedLabel}` %>">
                  <span data-catalog-course-text>
                    <span class="row-label"><%= buildCourseLabel(course) %></span>
                    <span class="catalog-subject-meta d-block">#<%= course.course_id %><%= course.location ? ` · ${formatCampusLabel(course.location)}` : '' %><%= selectedAdmissionValue > 0 ? ` · ${course.is_available ? catalogTargetReadyLabel : catalogTargetBlockedLabel}` : '' %></span>
                  </span>
                  <input class="form-check-input" type="checkbox" name="target_course_ids" value="<%= course.course_id %>" <%= course.is_available ? '' : 'disabled' %> />
                </label>
              <% }) %>
            </div>

            <div class="catalog-subject-meta mb-3"><%= ui.sourceCourse %>: <%= selectedCourseLabel || ui.noCourseSelected %></div>
            <div class="d-grid">
              <button class="btn btn-primary btn-pill" type="submit"><%= ui.assignToCourses %></button>
            </div>
          </form>
        </div>

        <div class="catalog-grid">
          <% (subjectCatalogList || []).forEach((catalogEntry) => { %>
            <article class="soft-panel catalog-card">
              <div class="catalog-card-header">
                <label class="catalog-select-row flex-grow-1" data-catalog-row data-catalog-text="<%= `${catalogEntry.name || ''} ${(catalogEntry.instances || []).map((instance) => instance.course_names || '').join(' ')}` %>">
                  <input class="form-check-input mt-1" type="checkbox" name="catalog_ids" value="<%= catalogEntry.id %>" form="pathwayCatalogAssignForm" />
                  <span class="catalog-select-copy" data-catalog-text>
                    <span class="row-label"><%= catalogEntry.name %></span>
                    <span class="catalog-subject-meta">
                      <%= ui.instancesCount %>: <%= Number(catalogEntry.total_instances || 0) %> · <%= ui.coursesCount %>: <%= Number(catalogEntry.total_courses || 0) %>
                    </span>
                  </span>
                </label>
                <div class="catalog-chip-group">
                  <span class="chip catalog-count"><%= Number(catalogEntry.total_instances || 0) %> <%= ui.instancesCount.toLowerCase() %></span>
                  <span class="chip catalog-count"><%= Number(catalogEntry.total_courses || 0) %> <%= ui.coursesCount.toLowerCase() %></span>
                </div>
              </div>
              <div class="catalog-subject-list">
                <% (catalogEntry.instances || []).forEach((subject) => { %>
                  <div class="catalog-instance-row <%= subject.is_visible ? '' : 'is-hidden' %>">
                    <div class="catalog-instance-head">
                      <div>
                        <div class="row-label">
                          <%= subject.is_shared ? ui.catalogInstanceShared : ui.catalogInstanceSeparate %> · #<%= subject.id %>
                        </div>
                        <div class="catalog-subject-meta">
                          <%= ui.groups %>: <%= Number(subject.group_count || 1) %> ·
                          <%= ui.defaultGroup || 'Default group' %>: <%= Number(subject.default_group || 1) %> ·
                          Teamwork: <%= subject.show_in_teamwork ? ui.yes : ui.no %> ·
                          <%= subject.is_visible ? ui.catalogVisibleShown : ui.catalogVisibleHidden %>
                        </div>
                      </div>
                      <span class="status-pill status-pill--<%= subject.is_shared ? 'focus' : 'info' %>">
                        <%= subject.is_shared ? ui.catalogInstanceShared : ui.catalogInstanceSeparate %>
                      </span>
                    </div>
                    <div>
                      <div class="catalog-subject-meta">
                        <%= ui.catalogOwnerCourse %>:
                        <%= ((subject.course_labels || []).find((label) => Number(label.id) === Number(subject.owner_course_id || 0)) || {}).name || ('#' + Number(subject.owner_course_id || 0)) %>
                      </div>
                      <% if (subject.binding_description) { %>
                        <div class="catalog-subject-meta"><%= subject.binding_description %></div>
                      <% } %>
                    </div>
                    <div class="catalog-course-chip-wrap">
                      <% (subject.course_labels || []).forEach((courseLabel) => { %>
                        <form method="POST" action="/admin/pathways/subjects/<%= subject.id %>/course/<%= courseLabel.id %>/remove">
                          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                          <input type="hidden" name="track" value="<%= activeTrack %>" />
                          <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                          <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
                          <button class="catalog-course-chip" type="submit">
                            <span><%= courseLabel.name %></span>
                            <span class="catalog-course-chip-remove" aria-hidden="true">×</span>
                          </button>
                        </form>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
                <% if (!(catalogEntry.instances || []).length) { %>
                  <div class="soft-panel muted catalog-empty"><%= ui.catalogNoInstances %></div>
                <% } %>
              </div>
            </article>
          <% }) %>
          <% if (!subjectCatalogList.length) { %>
            <div class="soft-panel muted catalog-empty">
              <div><%= ui.catalogEmptyState %></div>
              <div class="mt-2">
                <a class="btn btn-soft btn-pill" href="#pathwaysCatalogCreateForm"><%= ui.catalogCreateAction %></a>
              </div>
            </div>
          <% } %>
        </div>
      </section>

      <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/changelog-modal') %>
    <%- include('partials/mobile-menu-modal', {
      role,
      t,
      activePage: 'admin-pathways',
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script src="/js/design-system.js" defer></script>
    <script>
      (function initCompatibilityShell() {
        const shell = document.getElementById('pathways-compatibility');
        if (!shell || shell.tagName !== 'DETAILS') return;
        const compatibilityHashes = new Set([
          '#pathways-compatibility',
          '#pathways-mapping',
          '#pathways-subjects',
          '#pathways-campuses',
          '#pathways-migration',
        ]);
        function syncCompatibilityShell() {
          if (compatibilityHashes.has(window.location.hash)) {
            shell.open = true;
          }
        }
        syncCompatibilityShell();
        window.addEventListener('hashchange', syncCompatibilityShell);
      })();

      (function initThemeToggles() {
        function applyStandaloneTheme(rawTheme) {
          const theme = rawTheme === 'theme-light' || rawTheme === 'light' ? 'light' : 'dark';
          const storedTheme = theme === 'light' ? 'theme-light' : 'theme-dark';
          document.documentElement.setAttribute('data-theme', theme);
          document.body.setAttribute('data-theme', theme);
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(storedTheme);
          localStorage.setItem('ui-theme', storedTheme);
          return storedTheme;
        }

        const themeToggles = document.querySelectorAll('.theme-toggle');
        const activeTheme = applyStandaloneTheme(localStorage.getItem('ui-theme') || 'theme-dark');

        themeToggles.forEach((btn) => {
          btn.textContent = activeTheme === 'theme-dark' ? btn.dataset.lightLabel : btn.dataset.darkLabel;
          btn.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
            const nextStoredTheme = applyStandaloneTheme(next);
            themeToggles.forEach((toggle) => {
              toggle.textContent = nextStoredTheme === 'theme-dark' ? toggle.dataset.lightLabel : toggle.dataset.darkLabel;
            });
          });
        });
      })();

      (function initCatalogModeSummary() {
        const form = document.getElementById('pathwayCatalogAssignForm');
        const summary = document.getElementById('catalogModeSummary');
        const sharedToggle = document.getElementById('pathwaysSharedSubject');
        if (!form || !summary || !sharedToggle) return;

        function buildSummaryText(sharedSubject, selectedCount) {
          const count = Math.max(1, Number(selectedCount || 0));
          if (sharedSubject) {
            return <%- JSON.stringify(buildCatalogModeSummary(true, '__COUNT__')) %>.replace('__COUNT__', String(count));
          }
          return <%- JSON.stringify(buildCatalogModeSummary(false, '__COUNT__')) %>.replace('__COUNT__', String(count));
        }

        function refreshSummary() {
          const selectedCount = form.querySelectorAll('input[name="target_course_ids"]:checked').length;
          summary.textContent = buildSummaryText(sharedToggle.checked, selectedCount);
        }

        sharedToggle.addEventListener('change', refreshSummary);
        form.querySelectorAll('input[name="target_course_ids"]').forEach((input) => {
          input.addEventListener('change', refreshSummary);
        });
        refreshSummary();
      })();
    </script>
      <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
