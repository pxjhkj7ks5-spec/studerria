  <body class="studerria-theme theme-dark page-admin-pathways page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', {
      role,
      username,
      t,
      activePage: 'admin-pathways',
      pageTitle: ui.pageTitle,
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>
    <%- include('partials/desktop-menu-drawer', {
      role,
      t,
      activePage: 'admin-pathways',
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>

    <main class="container shell">
      <% if (error) { %>
        <div class="alert flash-alert alert-danger mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert flash-alert alert-success mb-3"><%= success %></div>
      <% } %>

      <section class="glass hero hero-stage mb-3" id="pathways-top">
        <div class="hero-stage__content">
          <div class="hero-stage__copy">
            <span class="hero-kicker"><%= ui.heroKicker %></span>
            <h1 class="hero-title"><%= ui.heroTitle %></h1>
            <p class="hero-subtitle"><%= ui.heroSubtitle %></p>
            <div class="chip-row">
              <span class="chip"><%= ui.programsChip %>: <%= (programs || []).length %></span>
              <span class="chip"><%= ui.admissionsChip %>: <%= (admissions || []).length %></span>
              <span class="chip"><%= ui.mappedCoursesChip %>: <%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %> / <%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
              <span class="chip"><%= ui.visibleSubjectsChip %>: <%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %> / <%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
            </div>
            <div class="hero-focus-strip">
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.courseScope %></span>
                <strong><%= selectedCourseLabel || ui.noCourseSelected %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.trackFilter %></span>
                <strong><%= activeTrackLabel %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label"><%= ui.focusedCohort %></span>
                <strong><%= cohortFocusLabel %></strong>
              </div>
            </div>
          </div>
          <aside class="hero-health <%= cohortHealth ? `is-${cohortHealth.status_tone}` : 'is-muted' %>">
            <div class="hero-health__topline">
              <span class="status-pill status-pill--<%= cohortHealth ? cohortHealth.status_tone : 'muted' %>">
                <%= cohortHealth ? cohortHealth.status_label : ui.pickCohort %>
              </span>
              <span class="hero-health__caption"><%= cohortHealth ? ui.selectedAdmissionHealth : ui.focusMode %></span>
            </div>
            <% if (cohortHealth) { %>
              <div class="hero-health__title">
                <strong><%= cohortHealth.program_name %></strong>
                <span>
                  <%= cohortHealth.program_code ? `${cohortHealth.program_code} · ` : '' %><%= cohortHealth.admission_year %><%= cohortHealth.admission_label ? ` · ${cohortHealth.admission_label}` : '' %>
                </span>
              </div>
              <div class="hero-health__meta">
                <span class="chip"><%= trackLabels[String(cohortHealth.track_key)] || cohortHealth.track_key %></span>
                <span class="chip"><%= cohortHealth.course_label %></span>
              </div>
              <div class="hero-health__grid">
                <% (cohortHealth.signals || []).forEach((signal) => { %>
                  <a class="health-signal-card is-<%= signal.tone || 'muted' %>" href="<%= signal.href %>">
                    <span class="health-signal-card__label"><%= signal.label %></span>
                    <strong class="health-signal-card__value"><%= signal.value %></strong>
                    <span class="health-signal-card__meta"><%= signal.meta %></span>
                  </a>
                <% }) %>
              </div>
              <% if (cohortAlertsList.length && cohortAlertsList[0] && cohortAlertsList[0].target) { %>
                <div class="mt-3 d-grid">
                  <a class="btn btn-soft btn-pill" href="#<%= cohortAlertsList[0].target %>"><%= cohortAlertsList[0].action_label || ui.openSection %></a>
                </div>
              <% } %>
            <% } else { %>
              <div class="hero-health__empty"><%= ui.heroHealthEmpty %></div>
            <% } %>
          </aside>
        </div>
      </section>

      <nav class="glass focus-nav mb-3" aria-label="<%= ui.navAria %>">
        <div class="focus-nav__links">
          <% sectionLinks.forEach((item) => { %>
            <a class="focus-nav__link" href="<%= item.href %>"><%= item.label %></a>
          <% }) %>
        </div>
        <div class="focus-nav__meta">
          <span class="focus-nav__meta-label"><%= ui.navFocus %></span>
          <strong class="focus-nav__meta-value"><%= cohortFocusLabel %></strong>
        </div>
      </nav>

      <% if (cohortAlertsList.length) { %>
        <section class="pathways-alert-stack mb-3">
          <% cohortAlertsList.forEach((alert) => { %>
            <article class="glass pathways-alert pathways-alert--<%= alert.tone || 'info' %>">
              <div class="pathways-alert__body">
                <strong class="pathways-alert__title"><%= alert.title %></strong>
                <p class="pathways-alert__text"><%= alert.body %></p>
              </div>
              <% if (alert.target) { %>
                <a class="btn btn-soft btn-pill pathways-alert__action" href="#<%= alert.target %>"><%= alert.action_label || ui.openSection %></a>
              <% } %>
            </article>
          <% }) %>
        </section>
      <% } %>

      <section class="glass section mb-3" id="pathways-registration-impact">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= isUk ? 'Вплив на реєстрацію' : 'Registration impact' %></h2>
            <p class="section-subtitle"><%= isUk ? 'Панель коротко показує, що саме зараз побачить студент у вибраній когорті: чи відкриється курс, чи буде список предметів і чи не ламається маршрут кампусом.' : 'This panel shows what students see in the selected cohort right now: whether the course route opens, whether subjects are visible, and whether campus routing stays stable.' %></p>
          </div>
          <span class="chip"><%= selectedAdmissionValue > 0 ? (registrationExperience ? registrationExperience.title : (isUk ? 'Немає даних' : 'No data')) : ui.selectAdmissionFirst %></span>
        </div>
        <% if (selectedAdmissionValue > 0 && registrationExperience) { %>
          <div class="pathways-banner pathways-banner--<%= registrationExperience.tone || 'muted' %>">
            <strong><%= registrationExperience.title %></strong>
            <span><%= registrationExperience.body %></span>
          </div>
          <% if (Array.isArray(registrationExperience.stages) && registrationExperience.stages.length) { %>
            <div class="scope-summary-grid mt-3">
              <% registrationExperience.stages.forEach((stage) => { %>
                <div class="scope-summary-card">
                  <span class="scope-summary-card__label"><%= stage.label %></span>
                  <strong><%= stage.value %></strong>
                  <% if (stage.hint) { %>
                    <span class="catalog-subject-meta d-block mt-1"><%= stage.hint %></span>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
        <% } else { %>
          <div class="soft-panel muted"><%= ui.selectAdmissionFirst %></div>
        <% } %>
      </section>

      <section class="glass section mb-3" id="pathways-scope">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.scopeTitle %></h2>
            <p class="section-subtitle"><%= ui.scopeSubtitle %></p>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="chip"><%= activeTrackLabel %></span>
            <% if (selectedProgramValue > 0 || selectedAdmissionValue > 0) { %>
              <a class="btn btn-soft btn-sm btn-pill" href="<%= buildPathwaysUrl({ program_id: null, admission_id: null }) %>"><%= ui.clearFocus %></a>
            <% } %>
          </div>
        </div>
        <form method="GET" action="/admin/pathways" class="row g-2 mt-1">
          <div class="col-12 col-md-6 col-xl-4">
            <label class="form-label small" for="pathwayCourseSelect"><%= ui.courseScope %></label>
            <select id="pathwayCourseSelect" class="form-select compact-select" name="course">
              <% (courses || []).forEach((course) => { %>
                <option value="<%= course.id %>" <%= Number(course.id) === Number(selectedCourseValue) ? 'selected' : '' %>>
                  <%= buildCourseLabel(course) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <label class="form-label small" for="pathwayTrackSelect"><%= ui.trackFilter %></label>
            <select id="pathwayTrackSelect" class="form-select compact-select" name="track">
              <% (trackFilterOptions || []).forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>>
                  <%= trackLabels[String(item.key)] || item.label %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-xl-2 align-self-end d-grid">
            <button type="submit" class="btn btn-primary btn-pill"><%= ui.applyScope %></button>
          </div>
          <% if (selectedProgramValue > 0) { %>
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
          <% } %>
          <% if (selectedAdmissionValue > 0) { %>
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
          <% } %>
        </form>
        <div class="scope-summary-grid">
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.courseScope %></span>
            <strong><%= selectedCourseLabel || ui.noCourseSelected %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.programFocus %></span>
            <strong><%= selectedProgram ? selectedProgram.name : ui.noProgramSelected %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label"><%= ui.admissionFocus %></span>
            <strong><%= selectedAdmission ? `${selectedAdmission.admission_year}${selectedAdmission.label ? ` · ${selectedAdmission.label}` : ''}` : ui.noAdmissionSelected %></strong>
          </div>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-programs">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.programsTitle %></h2>
            <p class="section-subtitle"><%= ui.programsSubtitle %></p>
          </div>
        </div>

        <form method="POST" action="/admin/pathways/programs/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
          <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.track %></label>
            <select name="track_key" class="form-select compact-select" required>
              <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>><%= trackLabels[String(item.key)] || item.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.code %></label>
            <input class="form-control compact-input" type="text" name="code" maxlength="40" placeholder="BSC-AI" />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.programName %></label>
            <input class="form-control compact-input" type="text" name="name" maxlength="140" required placeholder="Bachelor AI" />
          </div>
          <div class="col-8 col-md-1">
            <label class="form-label small"><%= ui.sort %></label>
            <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="100" />
          </div>
          <div class="col-4 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit"><%= ui.add %></button>
          </div>
        </form>

        <div class="program-grid">
          <% (filteredPrograms || []).forEach((program) => { %>
            <form method="POST" action="/admin/pathways/programs/<%= program.id %>/update" class="soft-panel program-card <%= Number(program.id) === Number(selectedProgramValue) ? 'is-selected' : '' %>">
              <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
              <input type="hidden" name="track" value="<%= activeTrack %>" />
              <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
              <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
              <div class="program-card__header">
                <div>
                  <div class="program-card__eyebrow"><%= ui.programEyebrow %> #<%= program.id %></div>
                  <div class="row-label"><%= program.name %></div>
                </div>
                <div class="program-card__actions">
                  <% if (program.code) { %>
                    <span class="chip"><%= program.code %></span>
                  <% } %>
                  <a class="btn btn-soft btn-sm btn-pill" href="<%= buildPathwaysUrl({ program_id: program.id, admission_id: null }) %>"><%= ui.open %></a>
                </div>
              </div>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small"><%= ui.track %></label>
                  <select class="form-select compact-select" name="track_key" required>
                    <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                      <option value="<%= item.key %>" <%= item.key === program.track_key ? 'selected' : '' %>><%= trackLabels[String(item.key)] || item.label %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-sm-3">
                  <label class="form-label small"><%= ui.code %></label>
                  <input class="form-control compact-input" type="text" name="code" maxlength="40" value="<%= program.code || '' %>" />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small"><%= ui.programName %></label>
                  <input class="form-control compact-input" type="text" name="name" maxlength="140" required value="<%= program.name %>" />
                </div>
                <div class="col-7 col-sm-3">
                  <label class="form-label small"><%= ui.sort %></label>
                  <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="<%= program.sort_order %>" />
                </div>
                <div class="col-5 col-sm-4 align-self-end">
                  <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="program_active_<%= program.id %>" name="is_active" value="1" <%= program.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="program_active_<%= program.id %>"><%= ui.activeToggle %></label>
                  </div>
                </div>
                <div class="col-12 col-sm-5 align-self-end d-grid">
                  <button class="btn btn-primary btn-pill" type="submit"><%= ui.save %></button>
                </div>
              </div>
              <div class="program-card__footer muted"><%= ui.admissionsInProgram %>: <%= Number(program.admissions_count || 0) %></div>
            </form>
          <% }) %>
          <% if (!(filteredPrograms || []).length) { %>
            <div class="soft-panel">
              <div class="muted"><%= ui.noPrograms %></div>
            </div>
          <% } %>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-admissions">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= ui.admissionsTitle %></h2>
            <p class="section-subtitle"><%= ui.admissionsSubtitle %></p>
          </div>
          <% if (selectedProgram) { %>
            <span class="chip"><%= selectedProgram.name %></span>
          <% } %>
        </div>

        <form method="POST" action="/admin/pathways/admissions/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
          <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.programLabel %></label>
            <select class="form-select compact-select" name="program_id" required>
              <option value=""><%= ui.selectProgram %></option>
              <% (filteredPrograms || []).forEach((program) => { %>
                <option value="<%= program.id %>" <%= Number(program.id) === Number(selectedProgramValue) ? 'selected' : '' %>>
                  <%= program.name %> (<%= trackLabels[String(program.track_key)] || program.track_key %>)
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small"><%= ui.admissionYear %></label>
            <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= new Date().getUTCFullYear() %>" required />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small"><%= ui.label %></label>
            <input class="form-control compact-input" type="text" name="label" maxlength="120" placeholder="<%= ui.cohortPlaceholder %>" />
          </div>
          <div class="col-12 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit"><%= ui.add %></button>
          </div>
        </form>

        <div class="admission-grid">
          <% admissionCards.forEach((admission) => { %>
            <form class="soft-panel admission-card <%= admission.is_selected ? 'is-selected' : '' %>" method="POST" action="/admin/pathways/admissions/<%= admission.id %>/update">
              <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
              <input type="hidden" name="track" value="<%= activeTrack %>" />
              <input type="hidden" name="program_id" value="<%= admission.program_id %>" />
              <input type="hidden" name="focus_program_id" value="<%= selectedProgramValue %>" />
              <input type="hidden" name="focus_admission_id" value="<%= selectedAdmissionValue %>" />
              <div class="admission-card__head">
                <div>
                  <div class="admission-card__eyebrow"><%= ui.admissionEyebrow %></div>
                  <div class="admission-card__title"><%= admission.admission_year %><%= admission.label ? ` · ${admission.label}` : '' %></div>
                </div>
                <div class="admission-card__status">
                  <span class="status-pill status-pill--<%= admission.status_tone %>"><%= admission.status_label %></span>
                  <% if (admission.is_selected) { %>
                    <span class="status-pill status-pill--focus"><%= ui.focusedPill %></span>
                  <% } %>
                </div>
              </div>
              <div class="admission-card__metrics">
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.coursesShort %></span>
                  <strong class="mini-stat__value"><%= admission.mapping_visible_count %>/<%= admission.mapping_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.subjectsShort %></span>
                  <strong class="mini-stat__value"><%= admission.subject_visible_count %>/<%= admission.subject_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.campusesShort %></span>
                  <strong class="mini-stat__value"><%= formatCampusStatus(admission.campus_ambiguous_count, admission.campus_ready_count) %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label"><%= ui.usersShort %></span>
                  <strong class="mini-stat__value"><%= admission.users_count %></strong>
                </div>
              </div>
              <% if ((admission.status_notes || []).length) { %>
                <div class="admission-card__notes">
                  <% (admission.status_notes || []).forEach((note) => { %>
                    <span class="chip"><%= note %></span>
                  <% }) %>
                </div>
              <% } %>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small"><%= ui.year %></label>
                  <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= admission.admission_year %>" required />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small"><%= ui.label %></label>
                  <input class="form-control compact-input" type="text" name="label" maxlength="120" value="<%= admission.label || '' %>" />
                </div>
                <div class="col-12 col-sm-3 align-self-end">
                  <div class="form-check admission-card__check">
                    <input class="form-check-input" type="checkbox" id="adm_active_<%= admission.id %>" name="is_active" value="1" <%= admission.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="adm_active_<%= admission.id %>"><%= ui.activeToggle %></label>
                  </div>
                </div>
              </div>
              <div class="admission-card__footer">
                <a class="btn btn-soft btn-pill" href="<%= buildPathwaysUrl({ program_id: admission.program_id, admission_id: admission.id }) %>"><%= ui.focusCohort %></a>
                <button class="btn btn-primary btn-pill" type="submit"><%= ui.save %></button>
              </div>
            </form>
          <% }) %>
          <% if (!admissionCards.length) { %>
            <div class="soft-panel muted">
              <%= ui.manageProgramAdmissions %>
            </div>
          <% } %>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-5">
          <article class="glass section h-100" id="pathways-mapping">
            <div class="section-header">
              <div>
                <h2 class="section-title"><%= ui.mappingTitle %></h2>
                <p class="section-subtitle"><%= ui.mappingSubtitle %></p>
              </div>
              <span class="chip"><%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %>/<%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
            </div>
            <% if (selectedAdmissionValue > 0) { %>
              <div class="pathways-banner pathways-banner--<%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1 ? 'danger' : (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) ? 'warning' : 'success') %>">
                <strong><%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1 ? ui.mappingEmptyTitle : ui.mappingCoverageTitle %></strong>
                <span>
                  <% if (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1) { %>
                    <%= ui.mappingEmptyHelp %>
                  <% } else if (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0)) { %>
                    <%= ui.mappingPartialHelp %>
                  <% } else { %>
                    <%= ui.mappingReadyHelp %>
                  <% } %>
                </span>
              </div>
              <% if (legacyAdmissionOrdinal > 0 || activeTrack === 'teacher') { %>
                <div class="soft-panel mb-3">
                  <div class="row-label mb-1"><%= ui.legacyTitle %></div>
                  <div class="muted">
                    <% if (activeTrack === 'teacher') { %>
                      <%= ui.legacyTeacherHelp %>
                    <% } else { %>
                      <%= ui.legacyYearPrefix %> <%= Number(selectedAdmission && selectedAdmission.admission_year ? selectedAdmission.admission_year : 0) %> <%= ui.legacyYearMiddle %> <%= legacyAdmissionOrdinal %>. <%= ui.matchingCoursesFound %>: <%= legacySuggestedCount %>.
                    <% } %>
                  </div>
                  <form class="mt-2" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/legacy-map">
                    <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                    <input type="hidden" name="track" value="<%= activeTrack %>" />
                    <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                    <button class="btn btn-soft btn-pill" type="submit"><%= activeTrack === 'teacher' ? ui.mapTeacherCourses : ui.applyLegacyMapping %></button>
                  </form>
                </div>
              <% } %>
              <form id="pathwayCourseMappingForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/save">
                <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                <input type="hidden" name="track" value="<%= activeTrack %>" />
                <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                  <span class="muted"><%= ui.bulkActions %></span>
                  <span
                    data-react-island="checklist-toolbar"
                    data-island-props='<%- courseChecklistPropsJson %>'
                  ></span>
                </div>
                <div id="pathwayCourseMappingList" class="d-grid gap-2 mb-3">
                  <% (courseMappings || []).forEach((item) => { %>
                    <label
                      class="subject-row"
                      data-checklist-row
                      data-checklist-text="<%= `${item.course_name} ${formatCampusLabel(item.course_location || 'kyiv')} ${item.is_teacher_course ? ui.teacherSearch : ui.regularSearch}` %>"
                    >
                      <span>
                        <span class="row-label"><%= item.course_name %></span>
                        <span class="muted d-block"><%= buildCourseMetaLine(item) %></span>
                      </span>
                      <input class="form-check-input" type="checkbox" name="course_<%= item.course_id %>" value="1" <%= item.is_visible ? 'checked' : '' %> />
                    </label>
                  <% }) %>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <button class="btn btn-primary btn-pill" type="submit"><%= ui.saveMapping %></button>
                  <span class="muted"><%= ui.visibleLabel %>: <%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %>/<%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
                </div>
              </form>
              <% if ((copyAdmissions || []).length) { %>
                <form class="soft-panel mt-3" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/copy">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-8">
                      <label class="form-label small"><%= ui.copyMappingFromAdmission %></label>
                      <select class="form-select compact-select" name="source_admission_id" required>
                        <option value=""><%= ui.selectSourceAdmission %></option>
                        <% (copyAdmissions || []).forEach((option) => { %>
                          <option value="<%= option.id %>">
                            <%= option.admission_year %><%= option.label ? (' • ' + option.label) : '' %> · <%= formatCourseOptionSummary(option.course_visible_count, option.course_total_count) %>
                          </option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-4 d-grid">
                      <button class="btn btn-soft btn-pill" type="submit"><%= ui.copyMappingFromAdmission %></button>
                    </div>
                  </div>
                </form>
              <% } %>
            <% } else { %>
              <div class="soft-panel muted"><%= ui.selectAdmissionFirst %></div>
            <% } %>
          </article>
        </div>
        <div class="col-12 col-xl-7">
          <article class="glass section h-100" id="pathways-subjects">
            <div class="section-header">
              <div>
                <h2 class="section-title"><%= ui.subjectsTitle %></h2>
                <p class="section-subtitle"><%= ui.subjectsSubtitle %></p>
              </div>
              <span class="chip"><%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %>/<%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
            </div>
            <% if (selectedAdmissionValue > 0) { %>
              <div class="pathways-banner pathways-banner--<%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0 ? 'danger' : (Number(hiddenSubjectCount || 0) > 0 ? 'warning' : 'success') %>">
                <strong><%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0 ? ui.noVisibleSubjectsTitle : ui.visibilityCoverageTitle %></strong>
                <span>
                  <% if (Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0) { %>
                    <%= ui.emptySubjectPickerHelp %>
                  <% } else if (Number(hiddenSubjectCount || 0) > 0) { %>
                    <%= hiddenSubjectCount %> <%= ui.hiddenBaseHelpSuffix %>
                  <% } else { %>
                    <%= ui.visibilityReadyHelp %>
                  <% } %>
                </span>
              </div>
              <form id="pathwaySubjectVisibilityForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/subjects/save">
                <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                <input type="hidden" name="track" value="<%= activeTrack %>" />
                <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                  <span class="muted"><%= ui.bulkActions %></span>
                  <span
                    data-react-island="checklist-toolbar"
                    data-island-props='<%- subjectChecklistPropsJson %>'
                  ></span>
                </div>
                <div id="pathwaySubjectVisibilityList" class="subject-list d-grid gap-2 mb-3">
                  <% (subjectVisibilityItems || []).forEach((subject) => { %>
                    <label
                      class="subject-row"
                      data-checklist-row
                      data-checklist-text="<%= `${subject.name} ${ui.groups.toLowerCase()} ${Number(subject.group_count || 1)}` %>"
                    >
                      <span>
                        <span class="row-label"><%= subject.name %></span>
                        <span class="muted d-block"><%= ui.groups %>: <%= Number(subject.group_count || 1) %></span>
                      </span>
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="subject_<%= subject.id %>"
                        value="1"
                        <%= subject.effective_visible ? 'checked' : '' %>
                      />
                    </label>
                  <% }) %>
                  <% if (!(subjectVisibilityItems || []).length) { %>
                    <div class="soft-panel muted"><%= ui.noVisibleSubjectsInCourse %></div>
                  <% } %>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <button class="btn btn-primary btn-pill" type="submit"><%= ui.saveVisibility %></button>
                  <span class="muted"><%= ui.visibleLabel %>: <%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %>/<%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
                </div>
              </form>
              <% if ((copyAdmissions || []).length) { %>
                <form class="soft-panel mt-3" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/subjects/copy">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-8">
                      <label class="form-label small"><%= ui.copyVisibilityFromAdmission %></label>
                      <select class="form-select compact-select" name="source_admission_id" required>
                        <option value=""><%= ui.selectSourceAdmission %></option>
                        <% (copyAdmissions || []).forEach((option) => { %>
                          <option value="<%= option.id %>">
                            <%= option.admission_year %><%= option.label ? (' • ' + option.label) : '' %> · <%= formatVisibilityOptionSummary(option.subject_visible_count, option.subject_total_count) %>
                          </option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-4 d-grid">
                      <button class="btn btn-soft btn-pill" type="submit"><%= ui.copyVisibilityFromAdmission %></button>
                    </div>
                  </div>
                </form>
              <% } %>
            <% } else { %>
              <div class="soft-panel muted"><%= ui.selectAdmissionFirst %></div>
            <% } %>
          </article>
        </div>
      </section>

      <section class="glass section mb-3">
        <div class="row g-3">
          <div class="col-12 col-xl-5">
            <div id="pathways-campuses">
              <div class="section-header">
                <div>
                  <h2 class="section-title"><%= ui.campusesTitle %></h2>
                  <p class="section-subtitle"><%= ui.campusesSubtitle %></p>
                </div>
                <span class="chip"><%= formatCampusStatus(ambiguousCampusList.length, campusBindingList.length) %></span>
              </div>
              <% if (selectedAdmissionValue > 0) { %>
                <div class="pathways-banner pathways-banner--<%= ambiguousCampusList.length ? 'danger' : (campusBindingList.length ? 'success' : 'warning') %>">
                  <strong><%= ambiguousCampusList.length ? ui.campusConflictTitle : (campusBindingList.length ? ui.campusReadyTitle : ui.noCampusRoutingTitle) %></strong>
                  <span>
                    <% if (ambiguousCampusList.length) { %>
                      <%= ui.campusConflictHelp %>
                    <% } else if (campusBindingList.length) { %>
                      <%= ui.campusReadyHelp %>
                    <% } else { %>
                      <%= ui.campusEmptyHelp %>
                    <% } %>
                  </span>
                </div>
                <div class="d-grid gap-2 mt-3">
                  <% (campusBindingList || []).forEach((binding) => { %>
                    <div class="soft-panel campus-binding-card <%= binding.is_ambiguous ? 'is-ambiguous' : 'is-ready' %>">
                      <div class="campus-binding-card__top">
                        <div>
                          <div class="row-label"><%= binding.campus_label %></div>
                          <div class="muted"><%= formatLinkedCourseCount(binding.course_count) %></div>
                        </div>
                        <span class="status-pill status-pill--<%= binding.is_ambiguous ? 'danger' : 'success' %>"><%= binding.is_ambiguous ? ui.fixMapping : ui.readyShort %></span>
                      </div>
                      <% if ((binding.course_labels || []).length) { %>
                        <div class="campus-binding-card__chips">
                          <% (binding.course_labels || []).forEach((label) => { %>
                            <span class="chip"><%= label %></span>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  <% }) %>
                  <% if (!(campusBindingList || []).length) { %>
                    <div class="soft-panel muted"><%= ui.noCampusBindings %></div>
                  <% } %>
                </div>
              <% } else { %>
                <div class="soft-panel muted mt-3"><%= ui.selectAdmissionFirst %></div>
              <% } %>
            </div>
          </div>

          <div class="col-12 col-xl-7">
            <div id="pathways-migration">
              <div class="section-header">
                <div>
                  <h2 class="section-title"><%= ui.migrationTitle %></h2>
                  <p class="section-subtitle"><%= ui.migrationSubtitle %></p>
                </div>
                <span class="chip"><%= migrationSummaryValue.pending_users %> <%= ui.pendingShort %></span>
              </div>
              <% if (selectedAdmissionValue > 0 && selectedProgramValue > 0) { %>
                <div class="migration-summary-grid">
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.sourceCourses %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.total_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.mappedCourses %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.mapped_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.candidateUsers %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.candidate_users %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.alreadyAligned %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.already_assigned %></strong>
                  </div>
                </div>
                <div class="pathways-banner pathways-banner--<%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? 'warning' : 'success') : 'muted' %>">
                  <strong><%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? ui.migrationBacklogTitle : ui.migrationAlignedTitle) : ui.noSourceCoursesTitle %></strong>
                  <span>
                    <% if (migrationSummaryValue.total_courses) { %>
                      <%= ui.migrationSafeModeHelp %>
                    <% } else { %>
                      <%= ui.migrationEmptyHelp %>
                    <% } %>
                  </span>
                </div>
                <form id="pathwayUserMigrationForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/users/migrate" class="mt-3">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <span class="muted"><%= ui.bulkActions %></span>
                    <span
                      data-react-island="checklist-toolbar"
                      data-island-props='<%- migrationChecklistPropsJson %>'
                    ></span>
                  </div>
                  <div class="d-grid gap-2 mb-3">
                    <% (migrationCourseList || []).forEach((course) => { %>
                      <label
                        class="subject-row"
                        data-checklist-row
                        data-checklist-text="<%= `${course.course_name} ${formatCampusLabel(course.course_location || 'kyiv')} ${ui.usersPrefix.toLowerCase()} ${Number(course.users_count || 0)}` %>"
                      >
                        <span>
                          <span class="row-label"><%= buildCourseLabel(course) %></span>
                          <span class="muted d-block">
                            <%= ui.usersPrefix %>: <%= Number(course.users_count || 0) %> / <%= ui.alreadyAssignedPrefix %>: <%= Number(course.assigned_count || 0) %><%= course.is_mapped ? ` / ${ui.mappedToAdmissionSuffix}` : '' %>
                          </span>
                        </span>
                        <input class="form-check-input" type="checkbox" name="source_course_ids[]" value="<%= course.course_id %>" />
                      </label>
                    <% }) %>
                    <% if (!(migrationCourseList || []).length) { %>
                      <div class="soft-panel muted"><%= ui.noCompatibleSourceCourses %></div>
                    <% } %>
                  </div>
                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    <button class="btn btn-primary btn-pill" type="submit"><%= ui.assignUsersToAdmission %></button>
                    <span class="muted"><%= ui.migrationSafeModeCaption %></span>
                  </div>
                </form>
              <% } else { %>
                <div class="soft-panel muted mt-3"><%= ui.selectProgramAndAdmissionFirst %></div>
              <% } %>
            </div>
          </div>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-catalog">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h2 class="section-title"><%= ui.catalogTitle %></h2>
            <p class="section-subtitle"><%= ui.catalogSubtitle %></p>
          </div>
          <span class="chip"><%= ui.catalogEntriesCount %>: <%= subjectCatalogList.length %></span>
        </div>

        <% if (catalogSummary && catalogSummaryMetrics) { %>
          <div class="pathways-banner pathways-banner--<%= catalogSummary.tone || 'muted' %>">
            <strong><%= catalogSummary.title %></strong>
            <span><%= catalogSummary.body %></span>
          </div>
          <div class="scope-summary-grid mt-3 mb-3">
            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Shared інстанси' : 'Shared instances' %></span>
              <strong><%= Number(catalogSummaryMetrics.shared_instances || 0) %></strong>
            </div>
            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Separate інстанси' : 'Separate instances' %></span>
              <strong><%= Number(catalogSummaryMetrics.separate_instances || 0) %></strong>
            </div>
            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Мультикурсові зв’язки' : 'Multi-course bindings' %></span>
              <strong><%= Number(catalogSummaryMetrics.multi_course_instances || 0) %></strong>
            </div>
            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Непризначені бази' : 'Unassigned base subjects' %></span>
              <strong><%= Number(catalogSummaryMetrics.unassigned_entries || 0) %></strong>
            </div>
          </div>
        <% } %>

        <div class="catalog-forms mb-3">
          <form class="soft-panel h-100" method="POST" action="/admin/pathways/catalog/add">
            <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
            <input type="hidden" name="track" value="<%= activeTrack %>" />
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
            <div class="section-header mb-2">
              <div>
                <h3 class="section-title h5 mb-1"><%= ui.catalogCreateTitle %></h3>
                <p class="section-subtitle mb-0"><%= ui.catalogCreateSubtitle %></p>
              </div>
            </div>
            <div class="row g-2 align-items-end">
              <div class="col-12">
                <label class="form-label small"><%= ui.catalogName %></label>
                <input class="form-control compact-input" type="text" name="catalog_name" maxlength="140" placeholder="Data Science" required />
              </div>
              <div class="col-12 d-grid">
                <button class="btn btn-primary btn-pill" type="submit"><%= ui.catalogCreateAction %></button>
              </div>
            </div>
          </form>

          <form id="pathwayCatalogAssignForm" class="soft-panel h-100" method="POST" action="/admin/pathways/catalog/assign">
            <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
            <input type="hidden" name="source_course_id" value="<%= selectedCourseValue %>" />
            <input type="hidden" name="track" value="<%= activeTrack %>" />
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
            <input type="hidden" name="sync_pathways" value="1" />
            <div class="section-header mb-2">
              <div>
                <h3 class="section-title h5 mb-1"><%= ui.catalogAssignTitle %></h3>
                <p class="section-subtitle mb-0"><%= ui.catalogAssignSubtitle %></p>
              </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
              <span class="muted"><%= ui.bulkActions %></span>
              <span
                data-react-island="checklist-toolbar"
                data-island-props='<%- catalogChecklistPropsJson %>'
              ></span>
            </div>

            <div class="catalog-settings-grid mb-3">
              <div>
                <label class="form-label small"><%= ui.groups %></label>
                <select class="form-select compact-select" name="group_count">
                  <option value="1" selected>1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                </select>
              </div>
              <div>
                <label class="form-label small"><%= ui.defaultGroup || 'Default group' %></label>
                <select class="form-select compact-select" name="default_group">
                  <option value="1" selected>1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                </select>
              </div>
              <div>
                <label class="form-label small">Teamwork</label>
                <select class="form-select compact-select" name="show_in_teamwork">
                  <option value="1" selected><%= ui.yes %></option>
                  <option value="0"><%= ui.no %></option>
                </select>
              </div>
              <div>
                <label class="form-label small"><%= ui.visibleLabel %></label>
                <select class="form-select compact-select" name="visible">
                  <option value="1" selected><%= ui.yes %></option>
                  <option value="0"><%= ui.no %></option>
                </select>
              </div>
              <div>
                <label class="form-label small">Required</label>
                <select class="form-select compact-select" name="is_required">
                  <option value="1" selected><%= ui.yes %></option>
                  <option value="0"><%= ui.no %></option>
                </select>
              </div>
              <div>
                <label class="form-label small">General</label>
                <select class="form-select compact-select" name="is_general">
                  <option value="1" selected><%= ui.yes %></option>
                  <option value="0"><%= ui.no %></option>
                </select>
              </div>
            </div>

            <div class="soft-panel mb-3">
              <div class="form-check mb-1">
                <input class="form-check-input" type="checkbox" id="pathwaysSharedSubject" name="shared_subject" value="1" />
                <label class="form-check-label" for="pathwaysSharedSubject"><%= ui.sharedSubject %></label>
              </div>
              <div class="catalog-shared-note muted"><%= ui.sharedSubjectHint %></div>
              <div class="catalog-shared-note muted mt-1"><%= ui.separateSubjectHint %></div>
              <div
                class="catalog-mode-summary"
                id="catalogModeSummary"
                data-summary-shared="<%= buildCatalogModeSummary(true, 1) %>"
                data-summary-separate="<%= buildCatalogModeSummary(false, 1) %>"
              ><%= buildCatalogModeSummary(false, 1) %></div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
              <span class="muted"><%= ui.targetCourses %></span>
              <span
                data-react-island="checklist-toolbar"
                data-island-props='<%- catalogCourseChecklistPropsJson %>'
              ></span>
            </div>
            <% if (selectedAdmissionValue > 0) { %>
              <div class="pathways-banner pathways-banner--<%= catalogReadyTargetCount > 0 ? (catalogBlockedTargetCount > 0 ? 'warning' : 'success') : 'danger' %> mb-3">
                <strong>
                  <% if (catalogReadyTargetCount > 0) { %>
                    <%= isUk ? `Готові курси: ${catalogReadyTargetCount}` : `Ready courses: ${catalogReadyTargetCount}` %>
                  <% } else { %>
                    <%= isUk ? 'Ще немає жодного готового курсу для призначення' : 'No target courses are ready for assignment yet' %>
                  <% } %>
                </strong>
                <span>
                  <% if (catalogReadyTargetCount > 0 && catalogBlockedTargetCount > 0) { %>
                    <%= isUk ? `${catalogBlockedTargetCount} курс(ів) залишаються заблокованими, доки не стануть visible в mapping цієї когорти.` : `${catalogBlockedTargetCount} course(s) are still blocked until they become visible in this cohort mapping.` %>
                  <% } else if (catalogReadyTargetCount > 0) { %>
                    <%= isUk ? 'У focused cohort mode призначення піде тільки по замаплених курсах нижче.' : 'In focused cohort mode, assignment stays scoped to the mapped courses below.' %>
                  <% } else { %>
                    <%= isUk ? 'Спершу завершіть course mapping для цієї когорти, і тоді призначення з каталогу розблокується.' : 'Finish course mapping for this cohort first, then catalog assignment will unlock.' %>
                  <% } %>
                </span>
              </div>
            <% } %>
            <div class="catalog-target-list mb-3">
              <% (catalogTargetList || []).forEach((course) => { %>
                <label class="catalog-target-row <%= course.is_available ? '' : 'is-disabled' %>" data-catalog-course-row data-catalog-course-text="<%= `${course.name || ''} ${course.course_id || ''} ${course.is_available ? catalogTargetReadyLabel : catalogTargetBlockedLabel}` %>">
                  <span data-catalog-course-text>
                    <span class="row-label"><%= buildCourseLabel(course) %></span>
                    <span class="catalog-subject-meta d-block">#<%= course.course_id %><%= course.location ? ` · ${formatCampusLabel(course.location)}` : '' %><%= selectedAdmissionValue > 0 ? ` · ${course.is_available ? catalogTargetReadyLabel : catalogTargetBlockedLabel}` : '' %></span>
                  </span>
                  <input class="form-check-input" type="checkbox" name="target_course_ids" value="<%= course.course_id %>" <%= course.is_available ? '' : 'disabled' %> />
                </label>
              <% }) %>
            </div>

            <div class="catalog-subject-meta mb-3"><%= ui.sourceCourse %>: <%= selectedCourseLabel || ui.noCourseSelected %></div>
            <div class="d-grid">
              <button class="btn btn-primary btn-pill" type="submit"><%= ui.assignToCourses %></button>
            </div>
          </form>
        </div>

        <div class="catalog-grid">
          <% (subjectCatalogList || []).forEach((catalogEntry) => { %>
            <article class="soft-panel catalog-card">
              <div class="catalog-card-header">
                <label class="catalog-select-row flex-grow-1" data-catalog-row data-catalog-text="<%= `${catalogEntry.name || ''} ${(catalogEntry.instances || []).map((instance) => instance.course_names || '').join(' ')}` %>">
                  <input class="form-check-input mt-1" type="checkbox" name="catalog_ids" value="<%= catalogEntry.id %>" form="pathwayCatalogAssignForm" />
                  <span class="catalog-select-copy" data-catalog-text>
                    <span class="row-label"><%= catalogEntry.name %></span>
                    <span class="catalog-subject-meta">
                      <%= ui.instancesCount %>: <%= Number(catalogEntry.total_instances || 0) %> · <%= ui.coursesCount %>: <%= Number(catalogEntry.total_courses || 0) %>
                    </span>
                  </span>
                </label>
                <div class="catalog-chip-group">
                  <span class="chip catalog-count"><%= Number(catalogEntry.total_instances || 0) %> <%= ui.instancesCount.toLowerCase() %></span>
                  <span class="chip catalog-count"><%= Number(catalogEntry.total_courses || 0) %> <%= ui.coursesCount.toLowerCase() %></span>
                </div>
              </div>
              <div class="catalog-subject-list">
                <% (catalogEntry.instances || []).forEach((subject) => { %>
                  <div class="catalog-instance-row <%= subject.is_visible ? '' : 'is-hidden' %>">
                    <div class="catalog-instance-head">
                      <div>
                        <div class="row-label">
                          <%= subject.is_shared ? ui.catalogInstanceShared : ui.catalogInstanceSeparate %> · #<%= subject.id %>
                        </div>
                        <div class="catalog-subject-meta">
                          <%= ui.groups %>: <%= Number(subject.group_count || 1) %> ·
                          <%= ui.defaultGroup || 'Default group' %>: <%= Number(subject.default_group || 1) %> ·
                          Teamwork: <%= subject.show_in_teamwork ? ui.yes : ui.no %> ·
                          <%= subject.is_visible ? ui.catalogVisibleShown : ui.catalogVisibleHidden %>
                        </div>
                      </div>
                      <span class="status-pill status-pill--<%= subject.is_shared ? 'focus' : 'info' %>">
                        <%= subject.is_shared ? ui.catalogInstanceShared : ui.catalogInstanceSeparate %>
                      </span>
                    </div>
                    <div>
                      <div class="catalog-subject-meta">
                        <%= ui.catalogOwnerCourse %>:
                        <%= ((subject.course_labels || []).find((label) => Number(label.id) === Number(subject.owner_course_id || 0)) || {}).name || ('#' + Number(subject.owner_course_id || 0)) %>
                      </div>
                      <% if (subject.binding_description) { %>
                        <div class="catalog-subject-meta"><%= subject.binding_description %></div>
                      <% } %>
                    </div>
                    <div class="catalog-course-chip-wrap">
                      <% (subject.course_labels || []).forEach((courseLabel) => { %>
                        <form method="POST" action="/admin/pathways/subjects/<%= subject.id %>/course/<%= courseLabel.id %>/remove">
                          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                          <input type="hidden" name="track" value="<%= activeTrack %>" />
                          <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                          <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
                          <button class="catalog-course-chip" type="submit">
                            <span><%= courseLabel.name %></span>
                            <span class="catalog-course-chip-remove" aria-hidden="true">×</span>
                          </button>
                        </form>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
                <% if (!(catalogEntry.instances || []).length) { %>
                  <div class="soft-panel muted catalog-empty"><%= ui.catalogNoInstances %></div>
                <% } %>
              </div>
            </article>
          <% }) %>
          <% if (!subjectCatalogList.length) { %>
