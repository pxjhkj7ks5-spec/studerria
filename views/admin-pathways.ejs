    assignUsersToAdmission: 'Assign users to this admission',
    migrationSafeModeCaption: 'Safe mode: only track, program, and admission are updated. The existing course binding is preserved.',
    selectProgramAndAdmissionFirst: 'Select program and admission year first.',
    catalogTitle: 'Global subject base',
    catalogSubtitle: 'Create base subjects once and then assign them to one or many courses. When shared subject is enabled, one instance shares schedule, homework, materials, teachers, and settings across all selected courses.',
    catalogCreateTitle: 'New base subject',
