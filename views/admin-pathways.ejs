              <div class="soft-panel muted">
                <div><%= ui.selectAdmissionFirst %></div>
                <div class="mt-2">
                  <a class="btn btn-soft btn-pill" href="<%= selectedProgramValue > 0 ? '#pathways-admissions' : '#pathways-programs' %>"><%= selectedProgramValue > 0 ? ui.openAdmissions : ui.openPrograms %></a>
