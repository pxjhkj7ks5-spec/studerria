    pushField('presetId', state.presetId);
    pushField('moderationStatus', state.moderationStatus, true);
    return fields.join('\n');
  };

  const buildPathwaysUrl = (overrides) => {
    const params = new URLSearchParams();
    const rawOverrides = overrides || {};
    const next = buildPathwaysFocusState(rawOverrides);
    const hasStudyContextOverride = Object.prototype.hasOwnProperty.call(rawOverrides, 'studyContextId')
      || Object.prototype.hasOwnProperty.call(rawOverrides, 'study_context_id');
    const hasProgramOverride = Object.prototype.hasOwnProperty.call(rawOverrides, 'programId')
      || Object.prototype.hasOwnProperty.call(rawOverrides, 'program_id');
    const hasAdmissionOverride = Object.prototype.hasOwnProperty.call(rawOverrides, 'admissionId')
      || Object.prototype.hasOwnProperty.call(rawOverrides, 'admission_id');
    const hasPresetOverride = Object.prototype.hasOwnProperty.call(rawOverrides, 'presetId')
      || Object.prototype.hasOwnProperty.call(rawOverrides, 'preset_id');
    if (!hasStudyContextOverride) {
      const programChanged = hasProgramOverride && Number(next.programId || 0) !== Number(selectedProgramValue || 0);
      const admissionChanged = hasAdmissionOverride && Number(next.admissionId || 0) !== Number(selectedAdmissionValue || 0);
      if (programChanged || admissionChanged || !next.programId || !next.admissionId) {
        next.studyContextId = null;
      }
    }
    if (!hasPresetOverride) {
      const programChanged = hasProgramOverride && Number(next.programId || 0) !== Number(selectedProgramValue || 0);
      if (programChanged || !next.programId) {
        next.presetId = null;
      }
    }

    if (next.courseId) params.set('course', String(next.courseId));
    if (next.track && next.track !== 'all') params.set('track', String(next.track));
    if (next.programId) params.set('program_id', String(next.programId));
    if (next.admissionId) params.set('admission_id', String(next.admissionId));
    if (next.studyContextId) params.set('study_context_id', String(next.studyContextId));
    if (next.presetId) params.set('preset_id', String(next.presetId));
    if (next.moderationStatus && next.moderationStatus !== 'open') params.set('moderation_status', String(next.moderationStatus));

    const query = params.toString();
    return `/admin/pathways${query ? `?${query}` : ''}`;
  };

  const buildAdminScopeUrl = (context, tab) => {
    const params = new URLSearchParams();
    const contextId = Number(context && context.id ? context.id : 0) || 0;
    const courseId = Number(context && context.course_id ? context.course_id : selectedCourseValue) || 0;
    const trackValue = String((context && context.track_key) || activeTrack || '').trim();
    const programValue = Number((context && context.program_id) || selectedProgramValue || 0) || 0;
    const admissionValue = Number((context && context.admission_id) || selectedAdmissionValue || 0) || 0;
    const stageValue = Number((context && context.stage) || 0) || 0;
    const campusValue = String((context && context.campus_key) || '').trim();
    if (tab) params.set('tab', String(tab));
    if (courseId) params.set('course', String(courseId));
    if (trackValue) params.set('track', trackValue);
    if (programValue) params.set('program_id', String(programValue));
    if (admissionValue) params.set('admission_id', String(admissionValue));
    if (stageValue) params.set('stage', String(stageValue));
    if (campusValue) params.set('campus', campusValue);
    if (contextId) params.set('study_context_id', String(contextId));
    return `/admin?${params.toString()}`;
  };
  const formatCampusLabel = (location) => String(location || 'kyiv').trim().toLowerCase() === 'munich' ? ui.campusMunich : ui.campusKyiv;
  const isTeacherCourse = (course) => course && (course.is_teacher_course === true || Number(course.is_teacher_course) === 1);
  const buildCourseLabel = (course) => {
    const name = String(course && (course.name || course.course_name) || '').trim();
    const campus = formatCampusLabel(course && (course.location || course.course_location));
    return isTeacherCourse(course) ? `${name} / ${campus} / ${ui.teacherBadge}` : `${name} / ${campus}`;
  };
  const buildCourseMetaLine = (course) => {
    const campus = `${formatCampusLabel(course && (course.location || course.course_location))} ${ui.campusSuffix}`;
    return isTeacherCourse(course) ? `${campus} / ${ui.teacherCourse}` : `${campus} / ${ui.studentCourse}`;
  };
