    allVisible: 'All visible',
    hideAll: 'Hide all',
    findCourse: 'Find course',
    findSourceCourse: 'Find source course',
    findSubject: 'Find subject',
    trackAll: 'All tracks',
    trackBachelor: 'Bachelor',
    trackMaster: 'Master',
    trackTeacher: 'Teacher',
    campusKyiv: 'Kyiv',
    campusMunich: 'Munich',
    campusSuffix: 'campus',
    teacherCourse: 'Teacher course',
    studentCourse: 'Student course',
    teacherBadge: 'Teacher',
    teacherSearch: 'teacher',
    regularSearch: 'regular',
  };
  const trackLabels = {
    all: ui.trackAll,
    bachelor: ui.trackBachelor,
    master: ui.trackMaster,
    teacher: ui.trackTeacher,
  };
  const activeTrackLabel = trackLabels[String(activeTrack)] || String(activeTrack || ui.trackAll);
  const cohortFocusLabel = cohortHealth
    ? `${cohortHealth.program_code ? `${cohortHealth.program_code} · ` : ''}${cohortHealth.admission_year || ui.admissionYear}${cohortHealth.admission_label ? ` · ${cohortHealth.admission_label}` : ''}`
    : ui.noCohortSelected;
  const sectionLinks = [
    { href: '#pathways-scope', label: ui.navScope },
    { href: '#pathways-programs', label: ui.navPrograms },
    { href: '#pathways-admissions', label: ui.navAdmissions },
    { href: '#pathways-mapping', label: ui.navMapping },
    { href: '#pathways-subjects', label: ui.navSubjects },
    { href: '#pathways-campuses', label: ui.navCampuses },
    { href: '#pathways-migration', label: ui.navMigration },
    { href: '#pathways-catalog', label: ui.navCatalog },
  ];
  const courseChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwayCourseMappingForm',
    checkboxSelector: 'input[type="checkbox"][name^="course_"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: ui.findCourse,
    labels: {
      all: ui.all,
      none: ui.none,
      invert: ui.invert,
      selected: ui.selected,
    },
  }).replace(/'/g, '&#39;');
  const migrationChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwayUserMigrationForm',
    checkboxSelector: 'input[type="checkbox"][name="source_course_ids[]"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: ui.findSourceCourse,
    labels: {
      all: ui.all,
      none: ui.none,
      invert: ui.invert,
      selected: ui.selected,
    },
  }).replace(/'/g, '&#39;');
  const subjectChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwaySubjectVisibilityForm',
    checkboxSelector: 'input[type="checkbox"][name^="subject_"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: ui.findSubject,
    labels: {
      all: ui.allVisible,
      none: ui.hideAll,
      invert: ui.invert,
      selected: ui.selected,
    },
  }).replace(/'/g, '&#39;');
  const formatCampusStatus = (blockedCount, readyCount) => Number(blockedCount || 0) > 0
    ? `${Number(blockedCount || 0)} ${ui.blockedShort}`
    : `${Number(readyCount || 0)} ${ui.readyShort}`;
  const formatLinkedCourseCount = (count) => Number(count || 0) === 1
    ? ui.linkedCourseSingle
    : `${Number(count || 0)} ${ui.linkedCoursePlural}`;
  const formatCourseOptionSummary = (visibleCount, totalCount) =>
    `${Number(visibleCount || 0)}/${Number(totalCount || 0)} ${ui.coursesShort.toLowerCase()}`;
  const formatVisibilityOptionSummary = (visibleCount, totalCount) =>
    `${Number(visibleCount || 0)}/${Number(totalCount || 0)} ${ui.visibleShort}`;

  const buildPathwaysUrl = (overrides) => {
    const params = new URLSearchParams();
    const next = Object.assign({}, {
      course: selectedCourseValue,
      track: activeTrack,
      program_id: selectedProgramValue,
      admission_id: selectedAdmissionValue,
    }, overrides || {});

    Object.keys(next).forEach((key) => {
      const value = next[key];
      if (value === null || typeof value === 'undefined') return;
      if (String(value) === '' || String(value) === '0') return;
      if (key === 'track' && String(value) === 'all') return;
      params.set(key, String(value));
    });

    const query = params.toString();
    return `/admin/pathways${query ? `?${query}` : ''}`;
  };
  const formatCampusLabel = (location) => String(location || 'kyiv').trim().toLowerCase() === 'munich' ? ui.campusMunich : ui.campusKyiv;
  const isTeacherCourse = (course) => course && (course.is_teacher_course === true || Number(course.is_teacher_course) === 1);
  const buildCourseLabel = (course) => {
    const name = String(course && (course.name || course.course_name) || '').trim();
    const campus = formatCampusLabel(course && (course.location || course.course_location));
    return isTeacherCourse(course) ? `${name} / ${campus} / ${ui.teacherBadge}` : `${name} / ${campus}`;
  };
  const buildCourseMetaLine = (course) => {
    const campus = `${formatCampusLabel(course && (course.location || course.course_location))} ${ui.campusSuffix}`;
    return isTeacherCourse(course) ? `${campus} / ${ui.teacherCourse}` : `${campus} / ${ui.studentCourse}`;
  };
%>
