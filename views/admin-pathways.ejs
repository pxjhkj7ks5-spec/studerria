            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Мультикурсові зв’язки' : 'Multi-course bindings' %></span>
              <strong><%= Number(catalogSummaryMetrics.multi_course_instances || 0) %></strong>
            </div>
            <div class="scope-summary-card">
              <span class="scope-summary-card__label"><%= isUk ? 'Непризначені бази' : 'Unassigned base subjects' %></span>
              <strong><%= Number(catalogSummaryMetrics.unassigned_entries || 0) %></strong>
            </div>
          </div>
        <% } %>

        <div class="catalog-forms mb-3">
          <form id="pathwaysCatalogCreateForm" class="soft-panel h-100" method="POST" action="/admin/pathways/catalog/add">
            <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
            <input type="hidden" name="track" value="<%= activeTrack %>" />
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
            <div class="section-header mb-2">
              <div>
                <h3 class="section-title h5 mb-1"><%= ui.catalogCreateTitle %></h3>
                <p class="section-subtitle mb-0"><%= ui.catalogCreateSubtitle %></p>
              </div>
            </div>
            <div class="row g-2 align-items-end">
              <div class="col-12">
                <label class="form-label small"><%= ui.catalogName %></label>
                <input class="form-control compact-input" type="text" name="catalog_name" maxlength="140" placeholder="Data Science" required />
              </div>
              <div class="col-12 d-grid">
                <button class="btn btn-primary btn-pill" type="submit"><%= ui.catalogCreateAction %></button>
              </div>
            </div>
          </form>

