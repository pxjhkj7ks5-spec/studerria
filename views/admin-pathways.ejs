      <section class="compatibility-shell__panel mb-3">
        <div class="section-header mb-3">
          <div>
            <h2 class="section-title"><%= isUk ? 'Bridge operations' : 'Bridge operations' %></h2>
            <p class="section-subtitle"><%= isUk ? 'Сюди винесені тільки campus routing, migration backlog і legacy bridge-операції, які ще не варто тримати у primary setup flow.' : 'Only campus routing, migration backlog, and remaining legacy bridge operations live here now so they do not dominate the primary setup flow.' %></p>
          </div>
          <span class="chip"><%= isUk ? 'Legacy' : 'Legacy' %></span>
        </div>
        <div class="row g-3">
          <div class="col-12 col-xl-5">
            <div id="pathways-campuses">
              <div class="section-header">
                <div>
                  <h2 class="section-title"><%= ui.campusesTitle %></h2>
                  <p class="section-subtitle"><%= ui.campusesSubtitle %></p>
                </div>
                <span class="chip"><%= formatCampusStatus(ambiguousCampusList.length, campusBindingList.length) %></span>
              </div>
              <% if (selectedAdmissionValue > 0) { %>
                <div class="pathways-banner pathways-banner--<%= ambiguousCampusList.length ? 'danger' : (campusBindingList.length ? 'success' : 'warning') %>">
                  <strong><%= ambiguousCampusList.length ? ui.campusConflictTitle : (campusBindingList.length ? ui.campusReadyTitle : ui.noCampusRoutingTitle) %></strong>
                  <span>
                    <% if (ambiguousCampusList.length) { %>
                      <%= ui.campusConflictHelp %>
                    <% } else if (campusBindingList.length) { %>
                      <%= ui.campusReadyHelp %>
                    <% } else { %>
                      <%= ui.campusEmptyHelp %>
                    <% } %>
                  </span>
                </div>
                <div class="d-grid gap-2 mt-3">
                  <% (campusBindingList || []).forEach((binding) => { %>
                    <div class="soft-panel campus-binding-card <%= binding.is_ambiguous ? 'is-ambiguous' : 'is-ready' %>">
                      <div class="campus-binding-card__top">
                        <div>
                          <div class="row-label"><%= binding.campus_label %></div>
                          <div class="muted"><%= formatLinkedCourseCount(binding.course_count) %></div>
                        </div>
                        <span class="status-pill status-pill--<%= binding.is_ambiguous ? 'danger' : 'success' %>"><%= binding.is_ambiguous ? ui.fixMapping : ui.readyShort %></span>
                      </div>
                      <% if ((binding.course_labels || []).length) { %>
                        <div class="campus-binding-card__chips">
                          <% (binding.course_labels || []).forEach((label) => { %>
                            <span class="chip"><%= label %></span>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  <% }) %>
                  <% if (!(campusBindingList || []).length) { %>
                    <div class="soft-panel muted">
                      <div><%= ui.noCampusBindings %></div>
                      <div class="mt-2">
                        <a class="btn btn-soft btn-pill" href="#pathways-compatibility"><%= ui.reviewMapping %></a>
                      </div>
                    </div>
                  <% } %>
                </div>
              <% } else { %>
                <div class="soft-panel muted mt-3">
                  <div><%= ui.selectAdmissionFirst %></div>
                  <div class="mt-2">
                    <a class="btn btn-soft btn-pill" href="<%= selectedProgramValue > 0 ? '#pathways-admissions' : '#pathways-programs' %>"><%= selectedProgramValue > 0 ? ui.openAdmissions : ui.openPrograms %></a>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          <div class="col-12 col-xl-7">
            <div id="pathways-migration">
              <div class="section-header">
                <div>
                  <h2 class="section-title"><%= ui.migrationTitle %></h2>
                  <p class="section-subtitle"><%= ui.migrationSubtitle %></p>
                </div>
                <span class="chip"><%= migrationSummaryValue.pending_users %> <%= ui.pendingShort %></span>
              </div>
              <% if (selectedAdmissionValue > 0 && selectedProgramValue > 0) { %>
                <div class="migration-summary-grid">
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.sourceCourses %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.total_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.mappedCourses %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.mapped_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.candidateUsers %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.candidate_users %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label"><%= ui.alreadyAligned %></span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.already_assigned %></strong>
                  </div>
                </div>
                <div class="pathways-banner pathways-banner--<%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? 'warning' : 'success') : 'muted' %>">
                  <strong><%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? ui.migrationBacklogTitle : ui.migrationAlignedTitle) : ui.noSourceCoursesTitle %></strong>
                  <span>
                    <% if (migrationSummaryValue.total_courses) { %>
                      <%= ui.migrationSafeModeHelp %>
                    <% } else { %>
                      <%= ui.migrationEmptyHelp %>
                    <% } %>
                  </span>
                </div>
                <form id="pathwayUserMigrationForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/users/migrate" class="mt-3">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <span class="muted"><%= ui.bulkActions %></span>
                    <span
                      data-react-island="checklist-toolbar"
                      data-island-props='<%- migrationChecklistPropsJson %>'
                    ></span>
                  </div>
                  <div class="d-grid gap-2 mb-3">
                    <% (migrationCourseRows || []).forEach((course) => { %>
                      <label
                        class="subject-row <%= course.is_actionable ? '' : 'is-disabled' %>"
                        data-checklist-row
                        data-checklist-text="<%= `${course.course_name} ${formatCampusLabel(course.course_location || 'kyiv')} ${ui.usersPrefix.toLowerCase()} ${Number(course.users_count || 0)} ${course.is_actionable ? `${course.pending_users} ${ui.pendingShort}` : (Number(course.users_count || 0) > 0 ? ui.alreadyAligned : ui.noMigrationCandidates)}` %>"
                      >
                        <span>
                          <span class="row-label"><%= buildCourseLabel(course) %></span>
                          <span class="muted d-block">
                            <%= ui.usersPrefix %>: <%= Number(course.users_count || 0) %> / <%= ui.alreadyAssignedPrefix %>: <%= Number(course.assigned_count || 0) %> / <%= course.is_actionable ? `${course.pending_users} ${ui.pendingShort}` : (Number(course.users_count || 0) > 0 ? ui.alreadyAligned : ui.noMigrationCandidates) %><%= course.is_mapped ? ` / ${ui.mappedToAdmissionSuffix}` : '' %>
                          </span>
                        </span>
                        <input class="form-check-input" type="checkbox" name="source_course_ids[]" value="<%= course.course_id %>" <%= course.is_actionable ? '' : 'disabled' %> />
                      </label>
                    <% }) %>
                    <% if (!(migrationCourseList || []).length) { %>
                      <div class="soft-panel muted">
                        <div><%= ui.noCompatibleSourceCourses %></div>
                        <div class="mt-2">
                          <a class="btn btn-soft btn-pill" href="#pathways-scope"><%= ui.reviewScope %></a>
                        </div>
                      </div>
                    <% } %>
                  </div>
                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    <button class="btn btn-primary btn-pill" type="submit" <%= actionableMigrationCourseCount > 0 ? '' : 'disabled' %>><%= ui.assignUsersToAdmission %></button>
                    <span class="muted"><%= ui.migrationSafeModeCaption %></span>
                  </div>
                  <% if ((migrationCourseRows || []).length && actionableMigrationCourseCount < 1) { %>
                    <div class="soft-panel muted mt-3"><%= ui.allMigrationCoursesAligned %></div>
                  <% } %>
                </form>
                <div class="soft-panel mt-3">
                  <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                      <strong><%= isUk ? 'Підвищення когорти' : 'Cohort promotion' %></strong>
                      <div class="muted mt-1">
                        <%= isUk
                          ? 'Переводить користувачів у наступний study context цього ж року вступу, якщо для нього вже існує stage +1.'
                          : 'Moves users into the next study context of the same admission year when a stage +1 context already exists.' %>
                      </div>
                    </div>
                    <form method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/promote" class="d-flex flex-wrap align-items-center gap-2">
                      <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                      <input type="hidden" name="track" value="<%= activeTrack %>" />
                      <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                      <input type="hidden" name="preset_id" value="<%= selectedProgramPresetValue %>" />
                      <button class="btn btn-soft btn-pill" type="submit"><%= isUk ? 'Підвищити курс +1' : 'Promote stage +1' %></button>
                    </form>
                  </div>
                </div>
              <% } else { %>
                <div class="soft-panel muted mt-3">
                  <div><%= ui.selectProgramAndAdmissionFirst %></div>
                  <div class="mt-2">
                    <a class="btn btn-soft btn-pill" href="<%= selectedProgramValue > 0 ? '#pathways-admissions' : '#pathways-programs' %>"><%= selectedProgramValue > 0 ? ui.openAdmissions : ui.openPrograms %></a>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </section>
        </div>
      </details>

      <section class="glass section mb-3" id="pathways-moderation">
        <div class="section-header">
          <div>
            <h2 class="section-title"><%= setupUi.moderationTitle %></h2>
            <p class="section-subtitle"><%= setupUi.moderationSubtitle %></p>
          </div>
          <span class="chip"><%= moderationQueueList.length %></span>
        </div>
        <div class="d-flex flex-wrap gap-2 mb-3">
          <% [
            { key: 'open', label: setupUi.moderationOpen },
            { key: 'reviewing', label: setupUi.moderationReviewing },
            { key: 'resolved', label: setupUi.moderationResolved },
            { key: 'ignored', label: setupUi.moderationIgnored },
          ].forEach((statusItem) => { %>
            <a class="btn <%= moderationStatusValue === statusItem.key ? 'btn-primary' : 'btn-soft' %> btn-pill" href="<%= buildPathwaysUrl({ moderation_status: statusItem.key }) %>"><%= statusItem.label %></a>
          <% }) %>
        </div>
        <% if (moderationQueueList.length) { %>
          <div class="d-grid gap-3">
            <% moderationQueueList.forEach((item) => { %>
              <article class="soft-panel">
                <div class="section-header mb-2">
                  <div>
                    <h3 class="section-title h5 mb-1"><%= item.title || `Queue #${item.id}` %></h3>
                    <p class="section-subtitle mb-0"><%= item.summary || '' %></p>
                  </div>
                  <div class="d-flex flex-wrap gap-2">
                    <span class="chip"><%= item.severity || 'medium' %></span>
                    <span class="chip"><%= item.status || moderationStatusValue %></span>
                  </div>
                </div>
                <div class="catalog-subject-meta mb-2"><%= setupUi.moderationSource %>: <%= item.source_kind || '—' %>#<%= item.source_id || '—' %> / <%= setupUi.moderationIssue %>: <%= item.issue_code || '—' %></div>
                <% if (item.payload && Object.keys(item.payload).length) { %>
                  <pre class="soft-panel mb-3" style="white-space: pre-wrap;"><%= JSON.stringify(item.payload, null, 2) %></pre>
                <% } %>
                <div class="d-flex flex-wrap gap-2">
                  <% if (item.payload && item.payload.study_context_id) { %>
                    <a class="btn btn-soft btn-pill" href="<%= buildPathwaysUrl({ study_context_id: item.payload.study_context_id }) %>"><%= isUk ? 'Відкрити context' : 'Open context' %></a>
                  <% } %>
                  <form method="POST" action="/admin/pathways/moderation/<%= item.id %>/resolve" class="d-flex flex-wrap gap-2 align-items-center">
                    <%- renderPathwaysFocusFields({}, { exclude: ['studyContextId'] }) %>
                    <select class="form-select compact-select" name="study_context_id">
                      <option value=""><%= setupUi.moderationAssignContext %></option>
                      <% studyContextList.forEach((context) => { %>
                        <option value="<%= context.id %>"><%= context.label %></option>
                      <% }) %>
                    </select>
                    <input type="hidden" name="action" value="assign_context" />
                    <button class="btn btn-primary btn-pill" type="submit"><%= setupUi.moderationAssignContext %></button>
                  </form>
                  <form method="POST" action="/admin/pathways/moderation/<%= item.id %>/resolve">
                    <%- renderPathwaysFocusFields() %>
                    <input type="hidden" name="action" value="mark_resolved" />
                    <button class="btn btn-soft btn-pill" type="submit"><%= setupUi.moderationResolve %></button>
                  </form>
                  <form method="POST" action="/admin/pathways/moderation/<%= item.id %>/resolve">
                    <%- renderPathwaysFocusFields() %>
                    <input type="hidden" name="action" value="ignore" />
                    <button class="btn btn-soft btn-pill" type="submit"><%= setupUi.moderationIgnore %></button>
                  </form>
                  <% if ((item.status || moderationStatusValue) === 'resolved' || (item.status || moderationStatusValue) === 'ignored') { %>
                    <form method="POST" action="/admin/pathways/moderation/<%= item.id %>/resolve">
                      <%- renderPathwaysFocusFields() %>
                      <input type="hidden" name="action" value="reopen" />
                      <button class="btn btn-soft btn-pill" type="submit"><%= isUk ? 'Відкрити знову' : 'Reopen' %></button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/admin/pathways/moderation/<%= item.id %>/resolve">
                      <%- renderPathwaysFocusFields() %>
                      <input type="hidden" name="action" value="mark_reviewing" />
                      <button class="btn btn-soft btn-pill" type="submit"><%= isUk ? 'Позначити reviewing' : 'Mark reviewing' %></button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="soft-panel muted"><%= setupUi.moderationEmpty %></div>
        <% } %>
      </section>

      <section class="glass section mb-3" id="pathways-catalog">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h2 class="section-title"><%= ui.catalogTitle %></h2>
