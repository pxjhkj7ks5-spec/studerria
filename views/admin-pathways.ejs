                <a class="btn btn-soft btn-pill" href="<%= selectedAdmissionValue > 0 ? '#pathways-admissions' : (selectedProgramValue > 0 ? '#pathways-intake' : '#pathways-programs') %>"><%= isUk ? 'Відкрити cohort setup' : 'Open cohort setup' %></a>
              </div>
            </div>
          <% } %>
        <% } else { %>
          <div class="soft-panel muted">
            <div><%= ui.selectAdmissionFirst %></div>
            <div class="mt-2">
              <a class="btn btn-soft btn-pill" href="<%= selectedProgramValue > 0 ? '#pathways-admissions' : '#pathways-programs' %>"><%= selectedProgramValue > 0 ? ui.openAdmissions : ui.openPrograms %></a>
            </div>
          </div>
