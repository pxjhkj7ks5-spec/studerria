                                        <input class="form-check-input" type="checkbox" name="target_context_ids" value="<%= context.id %>" <%= (offering.target_context_ids || []).includes(Number(context.id || 0)) || Number(context.id || 0) === Number(selectedStudyContextValue || 0) ? 'checked' : '' %> />
