<%
  const selectedCourseValue = Number(selectedCourseId || 0);
  const activeTrack = trackFilter || 'all';
  const selectedProgramValue = Number(selectedProgramId || 0);
  const selectedAdmissionValue = Number(selectedAdmissionId || 0);
  const selectedProgram = (programs || []).find((item) => Number(item.id) === selectedProgramValue) || null;
  const selectedAdmission = (admissions || []).find((item) => Number(item.id) === selectedAdmissionValue) || null;
  const copyAdmissions = Array.isArray(admissionCopyOptions) ? admissionCopyOptions : [];
  const subjectCatalogList = Array.isArray(subjectCatalogCourses) ? subjectCatalogCourses : [];
  const campusBindingList = Array.isArray(registrationCampusBindings) ? registrationCampusBindings : [];
  const ambiguousCampusList = Array.isArray(ambiguousCampusBindings) ? ambiguousCampusBindings : [];
  const migrationCourseList = Array.isArray(migrationCourseOptions) ? migrationCourseOptions : [];
  const admissionCards = Array.isArray(admissionHealthCards) ? admissionHealthCards : [];
  const cohortHealth = selectedCohortHealth || null;
  const cohortAlertsList = Array.isArray(cohortAlerts) ? cohortAlerts : [];
  const migrationSummaryValue = migrationSummary || {
    total_courses: 0,
    mapped_courses: 0,
    candidate_users: 0,
    already_assigned: 0,
    pending_users: 0,
  };
  const legacyAdmissionOrdinal = Number(selectedAdmissionLegacyOrdinal || 0);
  const legacySuggestedCount = Number(legacySuggestedCourseCount || 0);
  const trackLabels = {
    all: 'All tracks',
    bachelor: 'Bachelor',
    master: 'Master',
    teacher: 'Teacher',
  };
  const activeTrackLabel = trackLabels[String(activeTrack)] || String(activeTrack || 'All tracks');
  const cohortFocusLabel = cohortHealth
    ? `${cohortHealth.program_code ? `${cohortHealth.program_code} · ` : ''}${cohortHealth.admission_year || 'Admission'}${cohortHealth.admission_label ? ` · ${cohortHealth.admission_label}` : ''}`
    : 'No cohort selected';
  const sectionLinks = [
    { href: '#pathways-scope', label: 'Scope' },
    { href: '#pathways-programs', label: 'Programs' },
    { href: '#pathways-admissions', label: 'Admissions' },
    { href: '#pathways-mapping', label: 'Mapping' },
    { href: '#pathways-subjects', label: 'Subjects' },
    { href: '#pathways-campuses', label: 'Campuses' },
    { href: '#pathways-migration', label: 'Migration' },
    { href: '#pathways-catalog', label: 'Catalog' },
  ];
  const courseChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwayCourseMappingForm',
    checkboxSelector: 'input[type="checkbox"][name^="course_"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: 'Find course',
    labels: {
      all: 'All',
      none: 'None',
      invert: 'Invert',
      selected: 'Selected',
    },
  }).replace(/'/g, '&#39;');
  const migrationChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwayUserMigrationForm',
    checkboxSelector: 'input[type="checkbox"][name="source_course_ids[]"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: 'Find source course',
    labels: {
      all: 'All',
      none: 'None',
      invert: 'Invert',
      selected: 'Selected',
    },
  }).replace(/'/g, '&#39;');
  const subjectChecklistPropsJson = JSON.stringify({
    targetSelector: '#pathwaySubjectVisibilityForm',
    checkboxSelector: 'input[type="checkbox"][name^="subject_"]',
    rowSelector: '[data-checklist-row]',
    rowTextSelector: '[data-checklist-text]',
    searchEnabled: true,
    searchPlaceholder: 'Find subject',
    labels: {
      all: 'All visible',
      none: 'Hide all',
      invert: 'Invert',
      selected: 'Selected',
    },
  }).replace(/'/g, '&#39;');

  const buildPathwaysUrl = (overrides) => {
    const params = new URLSearchParams();
    const next = Object.assign({}, {
      course: selectedCourseValue,
      track: activeTrack,
      program_id: selectedProgramValue,
      admission_id: selectedAdmissionValue,
    }, overrides || {});

    Object.keys(next).forEach((key) => {
      const value = next[key];
      if (value === null || typeof value === 'undefined') return;
      if (String(value) === '' || String(value) === '0') return;
      if (key === 'track' && String(value) === 'all') return;
      params.set(key, String(value));
    });

    const query = params.toString();
    return `/admin/pathways${query ? `?${query}` : ''}`;
  };
  const formatCampusLabel = (location) => String(location || 'kyiv').trim().toLowerCase() === 'munich' ? 'Munich' : 'Kyiv';
  const isTeacherCourse = (course) => course && (course.is_teacher_course === true || Number(course.is_teacher_course) === 1);
  const buildCourseLabel = (course) => {
    const name = String(course && (course.name || course.course_name) || '').trim();
    const campus = formatCampusLabel(course && (course.location || course.course_location));
    return isTeacherCourse(course) ? `${name} / ${campus} / Teacher` : `${name} / ${campus}`;
  };
  const buildCourseMetaLine = (course) => {
    const campus = `${formatCampusLabel(course && (course.location || course.course_location))} campus`;
    return isTeacherCourse(course) ? `${campus} / Teacher course` : `${campus} / Student course`;
  };
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title>Admin pathways</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/design-system.css" />
    <style>
      :root {
        --pathways-border-dark: rgba(255, 255, 255, 0.14);
        --pathways-border-light: rgba(15, 23, 42, 0.12);
        --pathways-bg-dark: rgba(255, 255, 255, 0.06);
        --pathways-bg-light: rgba(255, 255, 255, 0.74);
      }
      body {
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
      }
      body.theme-dark {
        background:
          radial-gradient(1200px 760px at 12% 4%, rgba(56, 189, 248, 0.18), transparent 64%),
          radial-gradient(1000px 720px at 84% 18%, rgba(129, 140, 248, 0.2), transparent 62%),
          linear-gradient(148deg, #071122 0%, #101b31 50%, #14243d 100%);
        color: #f8fafc;
      }
      body.theme-light {
        background:
          radial-gradient(1200px 760px at 14% 6%, rgba(186, 230, 253, 0.5), transparent 64%),
          radial-gradient(1000px 720px at 84% 18%, rgba(221, 214, 254, 0.54), transparent 62%),
          linear-gradient(128deg, #e9eff8 0%, #eff5ff 50%, #f7f9ff 100%);
        color: #0f172a;
      }
      .shell {
        padding-top: 24px;
        padding-bottom: 48px;
      }
      .glass {
        border-radius: 22px;
        backdrop-filter: blur(18px);
      }
      body.theme-dark .glass {
        border: 1px solid var(--pathways-border-dark);
        background: var(--pathways-bg-dark);
        box-shadow: 0 18px 46px rgba(2, 6, 23, 0.5);
      }
      body.theme-light .glass {
        border: 1px solid var(--pathways-border-light);
        background: var(--pathways-bg-light);
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
      }
      .flash-alert {
        border-radius: 14px;
        padding: 0.5rem 0.9rem;
        font-size: 0.9rem;
        border: 1px solid rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.35);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.12);
        backdrop-filter: blur(10px);
      }
      body.theme-dark .flash-alert {
        background: rgba(17, 17, 30, 0.7);
        border-color: rgba(255, 255, 255, 0.12);
        color: #f8fafc;
      }
      .flash-alert.alert-danger {
        border-color: rgba(239, 68, 68, 0.45);
        color: #b91c1c;
      }
      body.theme-dark .flash-alert.alert-danger {
        color: #fca5a5;
      }
      .flash-alert.alert-success {
        border-color: rgba(34, 197, 94, 0.45);
        color: #166534;
      }
      body.theme-dark .flash-alert.alert-success {
        color: #86efac;
      }
      .hero {
        padding: 24px;
      }
      .hero-title {
        margin: 0;
        font-size: clamp(1.75rem, 2.8vw, 2.45rem);
        font-weight: 700;
      }
      .hero-subtitle {
        margin-top: 10px;
        max-width: 860px;
        color: rgba(226, 232, 240, 0.82);
      }
      body.theme-light .hero-subtitle {
        color: rgba(15, 23, 42, 0.64);
      }
      .chip-row {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .chip {
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.34);
        background: rgba(15, 23, 42, 0.32);
        padding: 5px 12px;
        font-size: 0.82rem;
      }
      body.theme-light .chip {
        border-color: rgba(15, 23, 42, 0.14);
        background: rgba(255, 255, 255, 0.9);
      }
      .section {
        padding: 20px;
      }
      .section-title {
        margin: 0;
        font-size: 1.08rem;
        font-weight: 650;
      }
      .section-subtitle {
        margin: 8px 0 0;
        font-size: 0.84rem;
        color: rgba(203, 213, 225, 0.76);
      }
      body.theme-light .section-subtitle {
        color: rgba(15, 23, 42, 0.62);
      }
      .soft-panel {
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.26);
        padding: 14px;
      }
      body.theme-light .soft-panel {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.88);
      }
      .compact-input,
      .compact-select {
        min-height: 40px;
        border-radius: 11px;
        border: 1px solid rgba(148, 163, 184, 0.34);
      }
      body.theme-dark .compact-input,
      body.theme-dark .compact-select {
        background: rgba(255, 255, 255, 0.06);
        color: #f8fafc;
        border-color: rgba(148, 163, 184, 0.28);
      }
      body.theme-light .compact-input,
      body.theme-light .compact-select {
        background: rgba(255, 255, 255, 0.92);
      }
      .program-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: 12px;
      }
      .form-check-input {
        width: 1.05rem;
        height: 1.05rem;
      }
      .subject-list {
        max-height: 440px;
        overflow: auto;
        padding-right: 4px;
      }
      .subject-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.28);
      }
      body.theme-light .subject-row {
        background: rgba(255, 255, 255, 0.92);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .admission-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        padding: 10px 12px;
        background: rgba(15, 23, 42, 0.28);
      }
      body.theme-light .admission-row {
        background: rgba(255, 255, 255, 0.9);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .row-label {
        font-weight: 600;
      }
      .muted {
        font-size: 0.82rem;
        color: rgba(203, 213, 225, 0.74);
      }
      body.theme-light .muted {
        color: rgba(15, 23, 42, 0.6);
      }
      .btn-pill {
        border-radius: 999px;
      }
      .btn-soft {
        border: 1px solid rgba(148, 163, 184, 0.3);
        background: rgba(255, 255, 255, 0.1);
        color: inherit;
      }
      body.theme-light .btn-soft {
        background: rgba(255, 255, 255, 0.9);
      }
      .btn-soft:hover {
        border-color: rgba(125, 211, 252, 0.52);
      }
      .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 12px;
      }
      .catalog-card {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .catalog-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
      }
      .catalog-subject-list {
        display: grid;
        gap: 8px;
        max-height: 320px;
        overflow: auto;
        padding-right: 4px;
      }
      .catalog-subject-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: center;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.28);
        padding: 10px 12px;
      }
      .catalog-subject-row.is-hidden {
        opacity: 0.64;
      }
      body.theme-light .catalog-subject-row {
        background: rgba(255, 255, 255, 0.92);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .catalog-subject-meta {
        font-size: 0.79rem;
        color: rgba(203, 213, 225, 0.76);
      }
      body.theme-light .catalog-subject-meta {
        color: rgba(15, 23, 42, 0.6);
      }
      .catalog-count {
        white-space: nowrap;
      }
    </style>
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/pages/admin-pathways.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-dark page-admin-pathways page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', {
      role,
      username,
      t,
      activePage: 'admin-pathways',
      pageTitle: 'Admin pathways',
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>
    <%- include('partials/desktop-menu-drawer', {
      role,
      t,
      activePage: 'admin-pathways',
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>

    <main class="container shell">
      <% if (error) { %>
        <div class="alert flash-alert alert-danger mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert flash-alert alert-success mb-3"><%= success %></div>
      <% } %>

      <section class="glass hero hero-stage mb-3" id="pathways-top">
        <div class="hero-stage__content">
          <div class="hero-stage__copy">
            <span class="hero-kicker">Pathways control center</span>
            <h1 class="hero-title">Academic pathways workspace</h1>
            <p class="hero-subtitle">
              Керуйте треками, програмами, роками вступу та видимістю предметів для кожної когорти. Тепер сторінка одразу показує, чи готова обрана когорта до реєстрації, чи ще зависла на mapping, campuses або user migration.
            </p>
            <div class="chip-row">
              <span class="chip">Programs: <%= (programs || []).length %></span>
              <span class="chip">Admissions: <%= (admissions || []).length %></span>
              <span class="chip">Mapped courses: <%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %> / <%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
              <span class="chip">Visible subjects: <%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %> / <%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
            </div>
            <div class="hero-focus-strip">
              <div class="hero-focus-item">
                <span class="hero-focus-label">Course scope</span>
                <strong><%= selectedCourseLabel || 'No course selected' %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label">Track filter</span>
                <strong><%= activeTrackLabel %></strong>
              </div>
              <div class="hero-focus-item">
                <span class="hero-focus-label">Focused cohort</span>
                <strong><%= cohortFocusLabel %></strong>
              </div>
            </div>
          </div>
          <aside class="hero-health <%= cohortHealth ? `is-${cohortHealth.status_tone}` : 'is-muted' %>">
            <div class="hero-health__topline">
              <span class="status-pill status-pill--<%= cohortHealth ? cohortHealth.status_tone : 'muted' %>">
                <%= cohortHealth ? cohortHealth.status_label : 'Pick a cohort' %>
              </span>
              <span class="hero-health__caption"><%= cohortHealth ? 'Selected admission health' : 'Focus mode' %></span>
            </div>
            <% if (cohortHealth) { %>
              <div class="hero-health__title">
                <strong><%= cohortHealth.program_name %></strong>
                <span>
                  <%= cohortHealth.program_code ? `${cohortHealth.program_code} · ` : '' %><%= cohortHealth.admission_year %><%= cohortHealth.admission_label ? ` · ${cohortHealth.admission_label}` : '' %>
                </span>
              </div>
              <div class="hero-health__meta">
                <span class="chip"><%= trackLabels[String(cohortHealth.track_key)] || cohortHealth.track_key %></span>
                <span class="chip"><%= cohortHealth.course_label %></span>
              </div>
              <div class="hero-health__grid">
                <% (cohortHealth.signals || []).forEach((signal) => { %>
                  <a class="health-signal-card is-<%= signal.tone || 'muted' %>" href="<%= signal.href %>">
                    <span class="health-signal-card__label"><%= signal.label %></span>
                    <strong class="health-signal-card__value"><%= signal.value %></strong>
                    <span class="health-signal-card__meta"><%= signal.meta %></span>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="hero-health__empty">
                Pick an admission year to see cohort readiness, campus conflicts, and migration pressure in one place.
              </div>
            <% } %>
          </aside>
        </div>
      </section>

      <nav class="glass focus-nav mb-3" aria-label="Pathways sections">
        <div class="focus-nav__links">
          <% sectionLinks.forEach((item) => { %>
            <a class="focus-nav__link" href="<%= item.href %>"><%= item.label %></a>
          <% }) %>
        </div>
        <div class="focus-nav__meta">
          <span class="focus-nav__meta-label">Focus</span>
          <strong class="focus-nav__meta-value"><%= cohortFocusLabel %></strong>
        </div>
      </nav>

      <% if (cohortAlertsList.length) { %>
        <section class="pathways-alert-stack mb-3">
          <% cohortAlertsList.forEach((alert) => { %>
            <article class="glass pathways-alert pathways-alert--<%= alert.tone || 'info' %>">
              <div class="pathways-alert__body">
                <strong class="pathways-alert__title"><%= alert.title %></strong>
                <p class="pathways-alert__text"><%= alert.body %></p>
              </div>
              <% if (alert.target) { %>
                <a class="btn btn-soft btn-pill pathways-alert__action" href="#<%= alert.target %>"><%= alert.action_label || 'Open section' %></a>
              <% } %>
            </article>
          <% }) %>
        </section>
      <% } %>

      <section class="glass section mb-3" id="pathways-scope">
        <div class="section-header">
          <div>
            <h2 class="section-title">Scope</h2>
            <p class="section-subtitle">Виберіть курс і трек для фокусного редагування. Поточний focus зберігає program і admission, якщо вони ще валідні в новому scope.</p>
          </div>
          <span class="chip"><%= activeTrackLabel %></span>
        </div>
        <form method="GET" action="/admin/pathways" class="row g-2 mt-1">
          <div class="col-12 col-md-6 col-xl-4">
            <label class="form-label small" for="pathwayCourseSelect">Course</label>
            <select id="pathwayCourseSelect" class="form-select compact-select" name="course">
              <% (courses || []).forEach((course) => { %>
                <option value="<%= course.id %>" <%= Number(course.id) === Number(selectedCourseValue) ? 'selected' : '' %>>
                  <%= buildCourseLabel(course) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-6 col-xl-3">
            <label class="form-label small" for="pathwayTrackSelect">Track filter</label>
            <select id="pathwayTrackSelect" class="form-select compact-select" name="track">
              <% (trackFilterOptions || []).forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>>
                  <%= item.label %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-xl-2 align-self-end d-grid">
            <button type="submit" class="btn btn-primary btn-pill">Apply scope</button>
          </div>
          <% if (selectedProgramValue > 0) { %>
            <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
          <% } %>
          <% if (selectedAdmissionValue > 0) { %>
            <input type="hidden" name="admission_id" value="<%= selectedAdmissionValue %>" />
          <% } %>
        </form>
        <div class="scope-summary-grid">
          <div class="scope-summary-card">
            <span class="scope-summary-card__label">Course scope</span>
            <strong><%= selectedCourseLabel || 'No course selected' %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label">Program focus</span>
            <strong><%= selectedProgram ? selectedProgram.name : 'No program selected' %></strong>
          </div>
          <div class="scope-summary-card">
            <span class="scope-summary-card__label">Admission focus</span>
            <strong><%= selectedAdmission ? `${selectedAdmission.admission_year}${selectedAdmission.label ? ` · ${selectedAdmission.label}` : ''}` : 'No admission selected' %></strong>
          </div>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-programs">
        <div class="section-header">
          <div>
            <h2 class="section-title">Programs</h2>
            <p class="section-subtitle">Створіть нову програму або оновіть існуючі параметри треку. Program cards тепер працюють як стартова точка для focus flow.</p>
          </div>
        </div>

        <form method="POST" action="/admin/pathways/programs/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <div class="col-12 col-md-3">
            <label class="form-label small">Track</label>
            <select name="track_key" class="form-select compact-select" required>
              <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                <option value="<%= item.key %>" <%= String(item.key) === String(activeTrack) ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small">Code</label>
            <input class="form-control compact-input" type="text" name="code" maxlength="40" placeholder="BSC-AI" />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small">Program name</label>
            <input class="form-control compact-input" type="text" name="name" maxlength="140" required placeholder="Bachelor AI" />
          </div>
          <div class="col-8 col-md-1">
            <label class="form-label small">Sort</label>
            <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="100" />
          </div>
          <div class="col-4 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit">Add</button>
          </div>
        </form>

        <div class="program-grid">
          <% (filteredPrograms || []).forEach((program) => { %>
            <form method="POST" action="/admin/pathways/programs/<%= program.id %>/update" class="soft-panel program-card <%= Number(program.id) === Number(selectedProgramValue) ? 'is-selected' : '' %>">
              <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
              <input type="hidden" name="track" value="<%= activeTrack %>" />
              <div class="program-card__header">
                <div>
                  <div class="program-card__eyebrow">Program #<%= program.id %></div>
                  <div class="row-label"><%= program.name %></div>
                </div>
                <div class="program-card__actions">
                  <% if (program.code) { %>
                    <span class="chip"><%= program.code %></span>
                  <% } %>
                  <a class="btn btn-soft btn-sm btn-pill" href="<%= buildPathwaysUrl({ program_id: program.id, admission_id: null }) %>">Open</a>
                </div>
              </div>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small">Track</label>
                  <select class="form-select compact-select" name="track_key" required>
                    <% (trackFilterOptions || []).filter((item) => item.key !== 'all').forEach((item) => { %>
                      <option value="<%= item.key %>" <%= item.key === program.track_key ? 'selected' : '' %>><%= item.label %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-sm-3">
                  <label class="form-label small">Code</label>
                  <input class="form-control compact-input" type="text" name="code" maxlength="40" value="<%= program.code || '' %>" />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small">Name</label>
                  <input class="form-control compact-input" type="text" name="name" maxlength="140" required value="<%= program.name %>" />
                </div>
                <div class="col-7 col-sm-3">
                  <label class="form-label small">Sort</label>
                  <input class="form-control compact-input" type="number" name="sort_order" min="1" max="9999" value="<%= program.sort_order %>" />
                </div>
                <div class="col-5 col-sm-4 align-self-end">
                  <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="program_active_<%= program.id %>" name="is_active" value="1" <%= program.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="program_active_<%= program.id %>">Active</label>
                  </div>
                </div>
                <div class="col-12 col-sm-5 align-self-end d-grid">
                  <button class="btn btn-primary btn-pill" type="submit">Save</button>
                </div>
              </div>
              <div class="program-card__footer muted">Admissions in program: <%= Number(program.admissions_count || 0) %></div>
            </form>
          <% }) %>
          <% if (!(filteredPrograms || []).length) { %>
            <div class="soft-panel">
              <div class="muted">No programs in this filter yet.</div>
            </div>
          <% } %>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-admissions">
        <div class="section-header">
          <div>
            <h2 class="section-title">Admission years</h2>
            <p class="section-subtitle">Налаштуйте когорти для обраної програми. Cards нижче одразу показують readiness без відкривання mapping чи campus секцій навмання.</p>
          </div>
          <% if (selectedProgram) { %>
            <span class="chip"><%= selectedProgram.name %></span>
          <% } %>
        </div>

        <form method="POST" action="/admin/pathways/admissions/add" class="soft-panel row g-2 mb-3">
          <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
          <input type="hidden" name="track" value="<%= activeTrack %>" />
          <div class="col-12 col-md-4">
            <label class="form-label small">Program</label>
            <select class="form-select compact-select" name="program_id" required>
              <option value="">Select program</option>
              <% (filteredPrograms || []).forEach((program) => { %>
                <option value="<%= program.id %>" <%= Number(program.id) === Number(selectedProgramValue) ? 'selected' : '' %>>
                  <%= program.name %> (<%= program.track_key %>)
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small">Admission year</label>
            <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= new Date().getUTCFullYear() %>" required />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label small">Label</label>
            <input class="form-control compact-input" type="text" name="label" maxlength="120" placeholder="Cohort 2026" />
          </div>
          <div class="col-12 col-md-1 align-self-end d-grid">
            <button class="btn btn-primary btn-pill" type="submit">Add</button>
          </div>
        </form>

        <div class="admission-grid">
          <% admissionCards.forEach((admission) => { %>
            <form class="soft-panel admission-card <%= admission.is_selected ? 'is-selected' : '' %>" method="POST" action="/admin/pathways/admissions/<%= admission.id %>/update">
              <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
              <input type="hidden" name="track" value="<%= activeTrack %>" />
              <input type="hidden" name="program_id" value="<%= admission.program_id %>" />
              <div class="admission-card__head">
                <div>
                  <div class="admission-card__eyebrow">Admission year</div>
                  <div class="admission-card__title"><%= admission.admission_year %><%= admission.label ? ` · ${admission.label}` : '' %></div>
                </div>
                <div class="admission-card__status">
                  <span class="status-pill status-pill--<%= admission.status_tone %>"><%= admission.status_label %></span>
                  <% if (admission.is_selected) { %>
                    <span class="status-pill status-pill--focus">Focused</span>
                  <% } %>
                </div>
              </div>
              <div class="admission-card__metrics">
                <div class="mini-stat">
                  <span class="mini-stat__label">Courses</span>
                  <strong class="mini-stat__value"><%= admission.mapping_visible_count %>/<%= admission.mapping_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label">Subjects</span>
                  <strong class="mini-stat__value"><%= admission.subject_visible_count %>/<%= admission.subject_total_count %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label">Campuses</span>
                  <strong class="mini-stat__value"><%= admission.campus_ambiguous_count ? `${admission.campus_ambiguous_count} blocked` : `${admission.campus_ready_count} ready` %></strong>
                </div>
                <div class="mini-stat">
                  <span class="mini-stat__label">Users</span>
                  <strong class="mini-stat__value"><%= admission.users_count %></strong>
                </div>
              </div>
              <% if ((admission.status_notes || []).length) { %>
                <div class="admission-card__notes">
                  <% (admission.status_notes || []).forEach((note) => { %>
                    <span class="chip"><%= note %></span>
                  <% }) %>
                </div>
              <% } %>
              <div class="row g-2">
                <div class="col-12 col-sm-4">
                  <label class="form-label small">Year</label>
                  <input class="form-control compact-input" type="number" name="admission_year" min="2000" max="2100" value="<%= admission.admission_year %>" required />
                </div>
                <div class="col-12 col-sm-5">
                  <label class="form-label small">Label</label>
                  <input class="form-control compact-input" type="text" name="label" maxlength="120" value="<%= admission.label || '' %>" />
                </div>
                <div class="col-12 col-sm-3 align-self-end">
                  <div class="form-check admission-card__check">
                    <input class="form-check-input" type="checkbox" id="adm_active_<%= admission.id %>" name="is_active" value="1" <%= admission.is_active ? 'checked' : '' %> />
                    <label class="form-check-label" for="adm_active_<%= admission.id %>">Active</label>
                  </div>
                </div>
              </div>
              <div class="admission-card__footer">
                <a class="btn btn-soft btn-pill" href="<%= buildPathwaysUrl({ program_id: admission.program_id, admission_id: admission.id }) %>">Focus cohort</a>
                <button class="btn btn-primary btn-pill" type="submit">Save</button>
              </div>
            </form>
          <% }) %>
          <% if (!admissionCards.length) { %>
            <div class="soft-panel muted">
              Select program to manage its admission years.
            </div>
          <% } %>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-5">
          <article class="glass section h-100" id="pathways-mapping">
            <div class="section-header">
              <div>
                <h2 class="section-title">Course mapping</h2>
                <p class="section-subtitle">Курси, для яких admission доступний на етапі реєстрації. Це перша критична умова для працездатного onboarding flow.</p>
              </div>
              <span class="chip"><%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %>/<%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
            </div>
            <% if (selectedAdmissionValue > 0) { %>
              <div class="pathways-banner pathways-banner--<%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1 ? 'danger' : (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) ? 'warning' : 'success') %>">
                <strong><%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1 ? 'No course mapping yet' : 'Mapping coverage' %></strong>
                <span>
                  <% if (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < 1) { %>
                    Registration cannot resolve a course for this cohort until at least one linked course is visible.
                  <% } else if (Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) < Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0)) { %>
                    Cohort is partially mapped. Keep only the intended courses visible for registration.
                  <% } else { %>
                    Mapping is filled. Now verify campus routing and subjects.
                  <% } %>
                </span>
              </div>
              <% if (legacyAdmissionOrdinal > 0 || activeTrack === 'teacher') { %>
                <div class="soft-panel mb-3">
                  <div class="row-label mb-1">Legacy quick map</div>
                  <div class="muted">
                    <% if (activeTrack === 'teacher') { %>
                      Teacher track can map every teacher course at once.
                    <% } else { %>
                      Admission year <%= Number(selectedAdmission && selectedAdmission.admission_year ? selectedAdmission.admission_year : 0) %> is treated as legacy year <%= legacyAdmissionOrdinal %>. Matching courses found: <%= legacySuggestedCount %>.
                    <% } %>
                  </div>
                  <form class="mt-2" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/legacy-map">
                    <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                    <input type="hidden" name="track" value="<%= activeTrack %>" />
                    <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                    <button class="btn btn-soft btn-pill" type="submit"><%= activeTrack === 'teacher' ? 'Map teacher courses' : 'Apply legacy year mapping' %></button>
                  </form>
                </div>
              <% } %>
              <form id="pathwayCourseMappingForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/save">
                <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                <input type="hidden" name="track" value="<%= activeTrack %>" />
                <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                  <span class="muted">Bulk actions</span>
                  <span
                    data-react-island="checklist-toolbar"
                    data-island-props='<%- courseChecklistPropsJson %>'
                  ></span>
                </div>
                <div id="pathwayCourseMappingList" class="d-grid gap-2 mb-3">
                  <% (courseMappings || []).forEach((item) => { %>
                    <label
                      class="subject-row"
                      data-checklist-row
                      data-checklist-text="<%= `${item.course_name} ${item.course_location || 'kyiv'} ${item.is_teacher_course ? 'teacher' : 'regular'}` %>"
                    >
                      <span>
                        <span class="row-label"><%= item.course_name %></span>
                        <span class="muted d-block"><%= buildCourseMetaLine(item) %></span>
                      </span>
                      <input class="form-check-input" type="checkbox" name="course_<%= item.course_id %>" value="1" <%= item.is_visible ? 'checked' : '' %> />
                    </label>
                  <% }) %>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <button class="btn btn-primary btn-pill" type="submit">Save mapping</button>
                  <span class="muted">Visible: <%= Number(mappingSummary && mappingSummary.visible ? mappingSummary.visible : 0) %>/<%= Number(mappingSummary && mappingSummary.total ? mappingSummary.total : 0) %></span>
                </div>
              </form>
              <% if ((copyAdmissions || []).length) { %>
                <form class="soft-panel mt-3" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/courses/copy">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-8">
                      <label class="form-label small">Copy mapping from admission</label>
                      <select class="form-select compact-select" name="source_admission_id" required>
                        <option value="">Select source admission</option>
                        <% (copyAdmissions || []).forEach((option) => { %>
                          <option value="<%= option.id %>">
                            <%= option.admission_year %><%= option.label ? (' • ' + option.label) : '' %> · <%= Number(option.course_visible_count || 0) %>/<%= Number(option.course_total_count || 0) %> courses
                          </option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-4 d-grid">
                      <button class="btn btn-soft btn-pill" type="submit">Copy mapping</button>
                    </div>
                  </div>
                </form>
              <% } %>
            <% } else { %>
              <div class="soft-panel muted">Select admission year first.</div>
            <% } %>
          </article>
        </div>
        <div class="col-12 col-xl-7">
          <article class="glass section h-100" id="pathways-subjects">
            <div class="section-header">
              <div>
                <h2 class="section-title">Subject visibility</h2>
                <p class="section-subtitle">Предмети, які бачать студенти під час реєстрації для вибраної когорти. Тут тепер видно, коли cohort technically exists, але subject list фактично порожній.</p>
              </div>
              <span class="chip"><%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %>/<%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
            </div>
            <% if (selectedAdmissionValue > 0) { %>
              <div class="pathways-banner pathways-banner--<%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0 ? 'danger' : (Number(hiddenSubjectCount || 0) > 0 ? 'warning' : 'success') %>">
                <strong><%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0 ? 'No visible subjects' : 'Visibility coverage' %></strong>
                <span>
                  <% if (Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) < 1 && Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) > 0) { %>
                    Students would land on an empty subject picker in this course scope.
                  <% } else if (Number(hiddenSubjectCount || 0) > 0) { %>
                    <%= hiddenSubjectCount %> subjects are hidden globally in the base course and cannot be re-exposed here.
                  <% } else { %>
                    Subject visibility is aligned for the selected course scope.
                  <% } %>
                </span>
              </div>
              <form id="pathwaySubjectVisibilityForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/subjects/save">
                <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                <input type="hidden" name="track" value="<%= activeTrack %>" />
                <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                  <span class="muted">Bulk actions</span>
                  <span
                    data-react-island="checklist-toolbar"
                    data-island-props='<%- subjectChecklistPropsJson %>'
                  ></span>
                </div>
                <div id="pathwaySubjectVisibilityList" class="subject-list d-grid gap-2 mb-3">
                  <% (subjectVisibilityItems || []).forEach((subject) => { %>
                    <label
                      class="subject-row"
                      data-checklist-row
                      data-checklist-text="<%= `${subject.name} groups ${Number(subject.group_count || 1)}` %>"
                    >
                      <span>
                        <span class="row-label"><%= subject.name %></span>
                        <span class="muted d-block">Groups: <%= Number(subject.group_count || 1) %></span>
                      </span>
                      <input
                        class="form-check-input"
                        type="checkbox"
                        name="subject_<%= subject.id %>"
                        value="1"
                        <%= subject.effective_visible ? 'checked' : '' %>
                      />
                    </label>
                  <% }) %>
                  <% if (!(subjectVisibilityItems || []).length) { %>
                    <div class="soft-panel muted">No visible subjects in selected course.</div>
                  <% } %>
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                  <button class="btn btn-primary btn-pill" type="submit">Save visibility</button>
                  <span class="muted">Visible: <%= Number(visibilitySummary && visibilitySummary.visible ? visibilitySummary.visible : 0) %>/<%= Number(visibilitySummary && visibilitySummary.total ? visibilitySummary.total : 0) %></span>
                </div>
              </form>
              <% if ((copyAdmissions || []).length) { %>
                <form class="soft-panel mt-3" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/subjects/copy">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-8">
                      <label class="form-label small">Copy visibility from admission</label>
                      <select class="form-select compact-select" name="source_admission_id" required>
                        <option value="">Select source admission</option>
                        <% (copyAdmissions || []).forEach((option) => { %>
                          <option value="<%= option.id %>">
                            <%= option.admission_year %><%= option.label ? (' • ' + option.label) : '' %> · <%= Number(option.subject_visible_count || 0) %>/<%= Number(option.subject_total_count || 0) %> visible
                          </option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-4 d-grid">
                      <button class="btn btn-soft btn-pill" type="submit">Copy visibility</button>
                    </div>
                  </div>
                </form>
              <% } %>
            <% } else { %>
              <div class="soft-panel muted">Select admission year first.</div>
            <% } %>
          </article>
        </div>
      </section>

      <section class="glass section mb-3">
        <div class="row g-3">
          <div class="col-12 col-xl-5">
            <div id="pathways-campuses">
              <div class="section-header">
                <div>
                  <h2 class="section-title">Registration campuses</h2>
                  <p class="section-subtitle">Registration resolves one hidden course per campus. This block now surfaces ambiguity as a first-class readiness error, not just a side note.</p>
                </div>
                <span class="chip"><%= ambiguousCampusList.length ? `${ambiguousCampusList.length} blocked` : `${campusBindingList.length} ready` %></span>
              </div>
              <% if (selectedAdmissionValue > 0) { %>
                <div class="pathways-banner pathways-banner--<%= ambiguousCampusList.length ? 'danger' : (campusBindingList.length ? 'success' : 'warning') %>">
                  <strong><%= ambiguousCampusList.length ? 'Campus routing conflict' : (campusBindingList.length ? 'Campus routing ready' : 'No campus routing yet') %></strong>
                  <span>
                    <% if (ambiguousCampusList.length) { %>
                      Registration stays blocked until each campus resolves to exactly one visible linked course.
                    <% } else if (campusBindingList.length) { %>
                      Every available campus has a single registration route.
                    <% } else { %>
                      Map at least one visible course before campus routing can be derived.
                    <% } %>
                  </span>
                </div>
                <div class="d-grid gap-2 mt-3">
                  <% (campusBindingList || []).forEach((binding) => { %>
                    <div class="soft-panel campus-binding-card <%= binding.is_ambiguous ? 'is-ambiguous' : 'is-ready' %>">
                      <div class="campus-binding-card__top">
                        <div>
                          <div class="row-label"><%= binding.campus_label %></div>
                          <div class="muted"><%= binding.is_ambiguous ? `${binding.course_count} linked courses` : '1 linked course' %></div>
                        </div>
                        <span class="status-pill status-pill--<%= binding.is_ambiguous ? 'danger' : 'success' %>"><%= binding.is_ambiguous ? 'Fix mapping' : 'Ready' %></span>
                      </div>
                      <% if ((binding.course_labels || []).length) { %>
                        <div class="campus-binding-card__chips">
                          <% (binding.course_labels || []).forEach((label) => { %>
                            <span class="chip"><%= label %></span>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  <% }) %>
                  <% if (!(campusBindingList || []).length) { %>
                    <div class="soft-panel muted">No campus bindings yet. Map at least one course to this admission year first.</div>
                  <% } %>
                </div>
              <% } else { %>
                <div class="soft-panel muted mt-3">Select admission year first.</div>
              <% } %>
            </div>
          </div>

          <div class="col-12 col-xl-7">
            <div id="pathways-migration">
              <div class="section-header">
                <div>
                  <h2 class="section-title">Existing user migration</h2>
                  <p class="section-subtitle">Stamp current users with the selected track, program, and admission year without forcing re-registration. The panel now shows whether migration is already mostly aligned or still backlog-heavy.</p>
                </div>
                <span class="chip"><%= migrationSummaryValue.pending_users %> pending</span>
              </div>
              <% if (selectedAdmissionValue > 0 && selectedProgramValue > 0) { %>
                <div class="migration-summary-grid">
                  <div class="mini-stat">
                    <span class="mini-stat__label">Source courses</span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.total_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label">Mapped courses</span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.mapped_courses %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label">Candidate users</span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.candidate_users %></strong>
                  </div>
                  <div class="mini-stat">
                    <span class="mini-stat__label">Already aligned</span>
                    <strong class="mini-stat__value"><%= migrationSummaryValue.already_assigned %></strong>
                  </div>
                </div>
                <div class="pathways-banner pathways-banner--<%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? 'warning' : 'success') : 'muted' %>">
                  <strong><%= migrationSummaryValue.total_courses ? (migrationSummaryValue.pending_users > 0 ? 'Migration backlog still exists' : 'Migration is aligned') : 'No source courses yet' %></strong>
                  <span>
                    <% if (migrationSummaryValue.total_courses) { %>
                      Safe mode only updates track, program, and admission. Existing course bindings are preserved.
                    <% } else { %>
                      Pick compatible source courses to start cohort stamping for existing users.
                    <% } %>
                  </span>
                </div>
                <form id="pathwayUserMigrationForm" method="POST" action="/admin/pathways/admissions/<%= selectedAdmissionValue %>/users/migrate" class="mt-3">
                  <input type="hidden" name="course_id" value="<%= selectedCourseValue %>" />
                  <input type="hidden" name="track" value="<%= activeTrack %>" />
                  <input type="hidden" name="program_id" value="<%= selectedProgramValue %>" />
                  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <span class="muted">Bulk actions</span>
                    <span
                      data-react-island="checklist-toolbar"
                      data-island-props='<%- migrationChecklistPropsJson %>'
                    ></span>
                  </div>
                  <div class="d-grid gap-2 mb-3">
                    <% (migrationCourseList || []).forEach((course) => { %>
                      <label
                        class="subject-row"
                        data-checklist-row
                        data-checklist-text="<%= `${course.course_name} ${course.course_location} users ${Number(course.users_count || 0)}` %>"
                      >
                        <span>
                          <span class="row-label"><%= buildCourseLabel(course) %></span>
                          <span class="muted d-block">
                            Users: <%= Number(course.users_count || 0) %> / Already assigned: <%= Number(course.assigned_count || 0) %><%= course.is_mapped ? ' / Mapped to this admission' : '' %>
                          </span>
                        </span>
                        <input class="form-check-input" type="checkbox" name="source_course_ids[]" value="<%= course.course_id %>" />
                      </label>
                    <% }) %>
                    <% if (!(migrationCourseList || []).length) { %>
                      <div class="soft-panel muted">No compatible source courses found for this track yet.</div>
                    <% } %>
                  </div>
                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    <button class="btn btn-primary btn-pill" type="submit">Assign users to this admission</button>
                    <span class="muted">Safe mode: only track/program/admission are updated. The existing course binding is preserved.</span>
                  </div>
                </form>
              <% } else { %>
                <div class="soft-panel muted mt-3">Select program and admission year first.</div>
              <% } %>
            </div>
          </div>
        </div>
      </section>

      <section class="glass section mb-3" id="pathways-catalog">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h2 class="section-title">Subject catalog</h2>
            <p class="section-subtitle">Read-only list of all subjects across every course. This remains the long-tail reference view for debugging scope mismatches.</p>
          </div>
          <span class="chip">Courses with subjects: <%= subjectCatalogList.length %></span>
        </div>
        <div class="catalog-grid">
          <% (subjectCatalogList || []).forEach((course) => { %>
            <article class="soft-panel catalog-card">
              <div class="catalog-card-header">
                <div>
                  <div class="row-label"><%= buildCourseLabel(course) %></div>
                  <div class="muted"><%= buildCourseMetaLine(course) %></div>
                </div>
                <span class="chip catalog-count"><%= Number((course.subjects || []).length) %> subjects</span>
              </div>
              <div class="catalog-subject-list">
                <% (course.subjects || []).forEach((subject) => { %>
                  <div class="catalog-subject-row <%= subject.is_visible ? '' : 'is-hidden' %>">
                    <div>
                      <div class="row-label"><%= subject.name %></div>
                      <div class="catalog-subject-meta">
                        Groups: <%= Number(subject.group_count || 1) %><%= subject.is_visible ? '' : ' / Hidden in base course' %>
                      </div>
                    </div>
                    <span class="chip">#<%= subject.id %></span>
                  </div>
                <% }) %>
              </div>
            </article>
          <% }) %>
          <% if (!subjectCatalogList.length) { %>
            <div class="soft-panel muted">No subjects found yet.</div>
          <% } %>
        </div>
      </section>

      <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/changelog-modal') %>
    <%- include('partials/mobile-menu-modal', {
      role,
      t,
      activePage: 'admin-pathways',
      settings: settings,
      canManagePathways: true,
      pathwaysPanelHref: '/admin/pathways',
    }) %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script src="/js/design-system.js" defer></script>
    <script>
      (function initThemeToggles() {
        function applyStandaloneTheme(rawTheme) {
          const theme = rawTheme === 'theme-light' || rawTheme === 'light' ? 'light' : 'dark';
          const storedTheme = theme === 'light' ? 'theme-light' : 'theme-dark';
          document.documentElement.setAttribute('data-theme', theme);
          document.body.setAttribute('data-theme', theme);
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(storedTheme);
          localStorage.setItem('ui-theme', storedTheme);
          return storedTheme;
        }

        const themeToggles = document.querySelectorAll('.theme-toggle');
        const activeTheme = applyStandaloneTheme(localStorage.getItem('ui-theme') || 'theme-dark');

        themeToggles.forEach((btn) => {
          btn.textContent = activeTheme === 'theme-dark' ? btn.dataset.lightLabel : btn.dataset.darkLabel;
          btn.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
            const nextStoredTheme = applyStandaloneTheme(next);
            themeToggles.forEach((toggle) => {
              toggle.textContent = nextStoredTheme === 'theme-dark' ? toggle.dataset.lightLabel : toggle.dataset.darkLabel;
            });
          });
        });
      })();
    </script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
</html>
