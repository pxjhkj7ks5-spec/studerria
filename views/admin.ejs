      const escapeAuditText = (value) =>
        String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      const formatAuditDate = (value) => {
        if (!value) return '—';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return escapeAuditText(value);
        return parsed.toLocaleString('uk-UA');
      };
      const renderAuditTable = (containerEl, entries, rollbackAction, confirmMessage) => {
        if (!containerEl) return;
        if (!Array.isArray(entries) || !entries.length) {
          containerEl.innerHTML = '<div class="small text-muted py-2">Ще немає змін.</div>';
          return;
        }
        const rowsHtml = entries.map((entry) => {
          const summary = escapeAuditText(entry.summary || 'Оновлення');
          const actor = escapeAuditText(entry.created_by_name || '—');
          const createdAt = formatAuditDate(entry.created_at);
          const target = [entry.target_type, entry.target_key].filter(Boolean).join(': ');
          const targetText = target ? escapeAuditText(target) : '—';
          const rolledBack = entry.is_rolled_back;
          const rolledMeta = rolledBack
            ? `${formatAuditDate(entry.rolled_back_at)}${entry.rolled_back_by_name ? ` · ${escapeAuditText(entry.rolled_back_by_name)}` : ''}`
            : '';
          const canRollback = !rolledBack && entry.can_rollback;
          const rollbackButton = canRollback
            ? `
              <form method="POST" action="${rollbackAction}" class="d-inline">
                <input type="hidden" name="audit_id" value="${Number(entry.id)}" />
                <button
                  class="btn btn-sm btn-outline-warning"
                  type="submit"
                  data-confirm="${escapeAuditText(confirmMessage)}"
                  data-confirm-level="warning"
                >
                  Rollback
                </button>
              </form>
            `
            : `<span class="badge text-bg-${rolledBack ? 'secondary' : 'light'}">${rolledBack ? 'Rolled back' : 'No rollback'}</span>`;
          return `
            <tr>
              <td>#${Number(entry.id)}</td>
              <td>${summary}</td>
              <td>${targetText}</td>
              <td>${actor}</td>
              <td>${createdAt}</td>
              <td>${rolledBack ? rolledMeta : '—'}</td>
              <td>${rollbackButton}</td>
            </tr>
          `;
        }).join('');
        containerEl.innerHTML = `
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>ID</th>
                <th>Подія</th>
                <th>Target</th>
                <th>Хто</th>
                <th>Коли</th>
                <th>Rollback</th>
                <th></th>
              </tr>
            </thead>
            <tbody>${rowsHtml}</tbody>
          </table>
        `;
      };
      const loadSettingsAudit = async () => {
        const container = document.getElementById('settingsAuditList');
        if (!container) return;
        container.innerHTML = '<div class="small text-muted py-2">Loading…</div>';
        try {
          const response = await fetch('/admin/audit/settings.json', {
            headers: { Accept: 'application/json' },
