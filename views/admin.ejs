                      <option value="1">Active</option>
                      <option value="0" selected>Inactive</option>
                    </select>
                  </div>
                  <div class="col-12 col-md-2 d-grid">
                    <button class="btn btn-primary" type="submit">Create</button>
                  </div>
                </div>
              </form>
            </div>
          </div>

          <div class="card mb-4">
