                            <td><%= row.active_semester_title || '—' %></td>
                            <td><%= Number(row.subjects_total || 0) %></td>
                            <td><%= Number(row.subjects_closed || 0) %> (<%= Number(row.subjects_closed_share || 0) %>%)</td>
                            <td><%= Number(row.columns_locked || 0) %> / <%= Number(row.columns_total || 0) %></td>
                            <td><%= Number(row.schedule_total || 0) %></td>
                            <td><%= Number(row.homework_total || 0) %></td>
