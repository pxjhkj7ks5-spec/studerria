      const uaRiskStatusInput = document.getElementById('uaRiskStatus');
      const uaRiskScoreInput = document.getElementById('uaRiskScore');
      const uaRiskReasonInput = document.getElementById('uaRiskReason');
      const uaRiskResolutionInput = document.getElementById('uaRiskResolution');
      const uaRiskCaseMeta = document.getElementById('uaRiskCaseMeta');
      const uaRiskRefreshBtn = document.getElementById('uaRiskRefreshBtn');
      const uaRiskSaveBtn = document.getElementById('uaRiskSaveBtn');
      const uaRiskConfirmBtn = document.getElementById('uaRiskConfirmBtn');
      const uaRiskCloseBtn = document.getElementById('uaRiskCloseBtn');
