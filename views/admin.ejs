                    </select>
                  </div>
                  <div class="col-12 col-md-2">
                    <label class="form-label"><%= t('admin.group') %></label>
                    <input class="form-control" type="number" min="1" max="3" name="group_number" id="messageGroupInput" placeholder="1-3" />
                  </div>
                  <div class="col-12 col-md-2 d-grid">
                    <button class="btn btn-primary" type="submit"><%= t('admin.send') %></button>
                  </div>
                </div>
                <div class="row g-2 mt-2">
                  <div class="col-12 col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="status" id="messageStatusSelect">
                      <option value="published" selected>Publish now</option>
                      <option value="scheduled">Schedule</option>
                      <option value="draft">Draft</option>
                    </select>
                  </div>
                  <div class="col-12 col-md-4">
                    <label class="form-label">Publish at</label>
                    <input class="form-control" type="datetime-local" name="scheduled_at" id="messageScheduledAt" />
                  </div>
                </div>
                <div class="row g-2 mt-2">
                  <div class="col-12">
                    <label class="form-label">Specific users</label>
                    <select class="form-select" name="user_ids" id="messageUsersSelect" multiple size="5">
                      <% (users || []).filter(function(u) {
                        const keys = Array.isArray(u.role_keys) && u.role_keys.length
                          ? u.role_keys
                          : [u.primary_role || u.role || 'student'];
                        return keys.includes('student');
                      }).forEach(function(u) { %>
                        <option value="<%= u.id %>"><%= u.full_name %></option>
                      <% }); %>
                    </select>
                  </div>
                </div>
              </form>
            </div>
          </div>

          <div class="card mb-4">
            <div class="card-body">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <h5 class="card-title mb-0">Existing messages</h5>
                <div class="d-flex flex-wrap gap-2">
                  <a class="btn btn-sm btn-outline-secondary" href="<%= messagesPanelHref %>">Refresh</a>
                  <form method="POST" action="/admin/messages/clear" class="m-0">
                    <button
                      class="btn btn-sm btn-outline-danger"
                      type="submit"
                      data-confirm="Clear all messages visible in this tab? This also removes all-course broadcasts shown here."
                      data-confirm-level="danger"
                      data-confirm-typed="CLEAR"
                    >
                      Clear visible
                    </button>
                  </form>
                  <% if (role === 'admin') { %>
                    <form method="POST" action="/admin/messages/clear-all" class="m-0">
                      <button
                        class="btn btn-sm btn-danger"
                        type="submit"
                        data-confirm="Delete every message in the system across all courses and semesters?"
                        data-confirm-level="danger"
                        data-confirm-typed="DELETE ALL"
                      >
                        Clear all
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
              <div class="text-muted small mb-3">
                Use Refresh to reload the current message scope, Clear visible to wipe the current list, or Clear all to nuke the entire message archive.
              </div>
              <div class="table-responsive">
                <table class="table table-striped align-middle">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Body</th>
                      <th>Target</th>
                      <th>Created</th>
                      <th>Status</th>
                      <th>Schedule</th>
                      <th>Reads</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (adminMessages || []).forEach(function(m) { %>
                      <tr>
                        <td><%= m.id %></td>
                        <td><%= m.body %></td>
                        <td>
                          <% if (m.target_all === 1) { %>
                            <%= m.course_id ? t('admin.targetAllCurrentCourse') : t('admin.targetAllCourses') %>
                          <% } else if (m.subject_name) { %>
                            <%= m.subject_name %> · Group <%= m.group_number %>
                          <% } else { %>
                            <%= t('admin.targetUsers') %>
                          <% } %>
                        </td>
                        <td><%= m.created_at %></td>
                        <td>
                          <span class="badge <%= m.status === 'draft' ? 'bg-secondary' : (m.status === 'scheduled' ? 'bg-warning text-dark' : 'bg-success') %>">
                            <%= m.status || 'published' %>
                          </span>
                        </td>
                        <td><%= m.scheduled_at || '—' %></td>
                        <td>
                          <% if (typeof m.target_count !== 'undefined' && m.target_count > 0) { %>
                            <button class="btn btn-sm btn-outline-primary message-reads-btn" type="button" data-message-id="<%= m.id %>">
                              <%= m.read_count || 0 %>/<%= m.target_count %>
                            </button>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td>
                          <form method="POST" action="/admin/messages/delete/<%= m.id %>">
                            <button
                              class="btn btn-sm btn-outline-danger"
                              type="submit"
                              data-confirm="Delete this message?"
                              data-confirm-level="danger"
                            >
                              Delete
                            </button>
                          </form>
                        </td>
                      </tr>
                    <% }); %>
                    <% if (!(adminMessages || []).length) { %>
                      <tr>
                        <td colspan="8" class="text-muted">No messages yet.</td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>
      <% } %>

        <% if (sectionAllowed('admin-support') && supportSectionVisible) { %>
        <div id="admin-support" class="admin-panel" data-admin-title="Communications / Support">
          <%
            const supportLocale = lang === 'uk' ? 'uk-UA' : 'en-US';
            const formatSupportStamp = (value) => {
              if (!value) return '—';
              const date = new Date(value);
              if (Number.isNaN(date.getTime())) return value;
              return date.toLocaleString(supportLocale, {
                dateStyle: 'medium',
                timeStyle: 'short',
              });
            };
            const supportThread = selectedSupportRequest || null;
            const supportMessages = supportThread && Array.isArray(supportThread.messages) ? supportThread.messages : [];
            const activeSupportId = supportThread ? Number(supportThread.id || 0) : 0;
            const supportBaseHref = `/admin?tab=admin-support&course=${encodeURIComponent(String(selectedCourseId || ''))}`;
            const supportStatusClass = (status) => (
              status === 'resolved'
                ? 'bg-success'
                : (status === 'in_progress' ? 'bg-info text-dark' : 'bg-warning text-dark')
            );
            const supportPreviewText = (request) => {
              const raw = String((request.admin_note && String(request.admin_note).trim()) || request.body || '')
                .replace(/\s+/g, ' ')
                .trim();
              if (!raw) return '—';
              return raw.length > 120 ? `${raw.slice(0, 117)}...` : raw;
            };
            const supportMessageAuthor = (message) => {
              const fallback = message.author_role === 'admin'
                ? t('admin.supportAuthorAdmin')
                : t('admin.supportAuthorUser');
              return message.author_name || fallback;
            };
          %>
          <div class="card mb-4">
            <div class="card-body">
              <div class="support-chat-head mb-4">
                <div>
                  <h5 class="card-title mb-1"><%= t('admin.supportSectionTitle') %></h5>
                  <p class="support-chat-copy mb-0"><%= t('admin.supportSectionSubtitle') %></p>
                </div>
                <span class="badge bg-primary-subtle text-primary-emphasis rounded-pill"><%= (supportRequests || []).length %></span>
              </div>

              <div class="support-hub">
                <div>
                  <% if ((supportRequests || []).length) { %>
                    <div class="support-thread-list">
                      <% (supportRequests || []).forEach(function(request) { %>
                        <a
                          class="support-thread-link <%= Number(request.id || 0) === activeSupportId ? 'active' : '' %>"
                          href="<%= `${supportBaseHref}&support_request=${encodeURIComponent(String(request.id || ''))}` %>"
                        >
                          <div class="support-thread-head">
                            <span class="badge <%= supportStatusClass(request.status) %>">
                              <%= t(`help.status.${request.status === 'in_progress' ? 'inProgress' : request.status}`) %>
                            </span>
                            <span class="small text-muted"><%= formatSupportStamp(request.updated_at || request.created_at) %></span>
                          </div>
                          <h6 class="support-thread-title"><%= request.subject %></h6>
                          <div class="support-thread-user"><%= request.user_name %> · <%= t(`help.topic.${request.category}`) %></div>
                          <p class="support-thread-preview"><%= supportPreviewText(request) %></p>
                        </a>
                      <% }); %>
                    </div>
                  <% } else { %>
                    <div class="support-chat-empty">
                      <div>
                        <h5 class="mb-2"><%= t('admin.supportSectionEmpty') %></h5>
                        <p class="mb-0"><%= t('admin.supportSectionEmptyCopy') %></p>
                      </div>
                    </div>
                  <% } %>
                </div>

                <div>
                  <% if (supportThread) { %>
                    <div class="support-chat-shell">
                      <div class="support-chat-head">
                        <div>
                          <div class="d-flex flex-wrap gap-2 mb-2">
                            <span class="badge <%= supportStatusClass(supportThread.status) %>">
                              <%= t(`help.status.${supportThread.status === 'in_progress' ? 'inProgress' : supportThread.status}`) %>
                            </span>
                            <span class="badge bg-secondary-subtle text-secondary-emphasis">
                              <%= t(`help.topic.${supportThread.category}`) %>
                            </span>
                          </div>
                          <h2 class="support-chat-subject"><%= supportThread.subject %></h2>
                          <p class="support-chat-copy mb-0">
                            <strong><%= t('admin.supportTicketUser') %>:</strong> <%= supportThread.user_name %>
                            ·
                            <strong><%= t('admin.supportTicketUpdated') %>:</strong> <%= formatSupportStamp(supportThread.updated_at || supportThread.created_at) %>
                          </p>
                        </div>
                        <div class="support-chat-head-actions">
                          <% if (supportThread.status !== 'resolved') { %>
                            <form method="POST" action="/admin/support-requests/<%= supportThread.id %>/update">
                              <input type="hidden" name="status" value="resolved" />
                              <button
                                class="btn btn-outline-secondary glass btn-sm"
                                type="submit"
                                onclick="return confirm('<%= t('admin.supportCloseConfirm') %>')"
                              >
                                <%= t('admin.supportClose') %>
                              </button>
                            </form>
                          <% } else { %>
                            <form method="POST" action="/admin/support-requests/<%= supportThread.id %>/update">
                              <input type="hidden" name="status" value="in_progress" />
                              <button
                                class="btn btn-outline-secondary glass btn-sm"
                                type="submit"
                                onclick="return confirm('<%= t('admin.supportReopenConfirm') %>')"
                              >
                                <%= t('admin.supportReopen') %>
                              </button>
                            </form>
                          <% } %>
                        </div>
                      </div>

                      <div class="support-chat-scroll">
                        <% supportMessages.forEach(function(message) { %>
                          <article class="support-message support-message--<%= message.author_role === 'admin' ? 'admin' : 'user' %>">
                            <div class="support-message-meta">
                              <span><%= supportMessageAuthor(message) %></span>
                              <span><%= formatSupportStamp(message.created_at) %></span>
                            </div>
                            <p class="support-message-body"><%= message.body %></p>
                          </article>
                        <% }); %>
                      </div>

                      <div class="card support-chat-reply">
                        <div class="card-body">
                          <form method="POST" action="/admin/support-requests/<%= supportThread.id %>/update" class="row g-3 align-items-start">
                            <div class="col-12 col-lg-3">
                              <label class="form-label"><%= t('admin.supportTicketStatus') %></label>
                              <select class="form-select" name="status">
                                <option value="new" <%= supportThread.status === 'new' ? 'selected' : '' %>><%= t('help.status.new') %></option>
                                <option value="in_progress" <%= supportThread.status === 'in_progress' ? 'selected' : '' %>><%= t('help.status.inProgress') %></option>
                                <option value="resolved" <%= supportThread.status === 'resolved' ? 'selected' : '' %>><%= t('help.status.resolved') %></option>
                              </select>
                            </div>
                            <div class="col-12 col-lg-9">
                              <label class="form-label"><%= t('admin.supportReplyLabel') %></label>
                              <textarea
                                class="form-control"
                                name="reply_body"
                                rows="5"
                                maxlength="1000"
                                placeholder="<%= t('admin.supportReplyPlaceholder') %>"
                              ></textarea>
                            </div>
                            <div class="col-12 support-chat-actions">
                              <button class="btn btn-primary" type="submit"><%= t('admin.supportReplySend') %></button>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% } else { %>
                    <div class="support-chat-empty">
                      <div>
                        <h5 class="mb-2"><%= t('admin.supportSectionSelectTitle') %></h5>
                        <p class="mb-0"><%= t('admin.supportSectionSelectCopy') %></p>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% } %>
        </div>
      </div>
    </main>
    <%- include('partials/app-footer') %>
    <% if (!isLimitedView && role === 'admin') { %>
      <div class="modal fade admin-preview-modal" id="adminPreviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Тестовий перегляд</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
