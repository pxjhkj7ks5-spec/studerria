          renderAuditTable(container, data.entries || [], '/admin/settings/rollback', 'Rollback this settings change?');
        } catch (err) {
          container.innerHTML = `<div class="small text-danger py-2">${escapeAuditText(err.message || 'Failed to load settings audit')}</div>`;
        }
      };
      const loadRoleStudioAudit = async () => {
        const container = document.getElementById('roleStudioAuditList');
        if (!container) return;
        container.innerHTML = '<div class="small text-muted py-2">Loading…</div>';
        try {
          const response = await fetch('/admin/audit/role-studio.json', {
