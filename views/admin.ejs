      const setRiskCaseMeta = (caseRow) => {
        if (!uaRiskCaseMeta) return;
        if (!caseRow) {
          uaRiskCaseMeta.textContent = 'No case data yet';
          return;
        }
        const status = String(caseRow.status || 'open');
        const updatedAt = caseRow.updated_at ? new Date(caseRow.updated_at) : null;
        const updatedText = updatedAt && !Number.isNaN(updatedAt.getTime())
          ? updatedAt.toLocaleString('uk-UA')
          : '—';
        const confirmedBy = caseRow.confirmed_by_name ? String(caseRow.confirmed_by_name) : '';
        const closedBy = caseRow.closed_by_name ? String(caseRow.closed_by_name) : '';
        const tail = [];
        if (confirmedBy) tail.push(`confirmed: ${confirmedBy}`);
        if (closedBy) tail.push(`closed: ${closedBy}`);
        if (caseRow.auto_quarantined) tail.push('auto-quarantined');
        uaRiskCaseMeta.textContent = `Status: ${status} · updated: ${updatedText}${tail.length ? ` · ${tail.join(' · ')}` : ''}`;
      };

      const applyRiskCaseInputs = (caseRow, fallbackRisk = null) => {
        const risk = fallbackRisk && typeof fallbackRisk === 'object' ? fallbackRisk : {};
        if (uaRiskLevelInput) {
          uaRiskLevelInput.value = String(caseRow && caseRow.risk_level ? caseRow.risk_level : (risk.level || 'normal'));
        }
        if (uaRiskStatusInput) {
          uaRiskStatusInput.value = String(caseRow && caseRow.status ? caseRow.status : 'open');
        }
        if (uaRiskScoreInput) {
          const score = Number(caseRow && caseRow.risk_score ? caseRow.risk_score : (risk.score || 0));
          uaRiskScoreInput.value = Number.isFinite(score) ? String(Math.max(0, Math.round(score))) : '0';
        }
        if (uaRiskReasonInput) {
          uaRiskReasonInput.value = String(caseRow && caseRow.reason ? caseRow.reason : '');
        }
        if (uaRiskResolutionInput) {
          uaRiskResolutionInput.value = String(caseRow && caseRow.resolution_note ? caseRow.resolution_note : '');
        }
        setRiskCaseMeta(caseRow);
      };

      const renderForensicsGraph = (graph) => {
        if (!uaForensicsGraphMeta || !uaForensicsGraphNodes || !uaForensicsGraphEdges) return;
        const nodes = Array.isArray(graph && graph.nodes) ? graph.nodes : [];
        const edges = Array.isArray(graph && graph.edges) ? graph.edges : [];
        uaForensicsGraphMeta.textContent = `Nodes: ${nodes.length} · Links: ${edges.length}`;
        if (!nodes.length) {
          uaForensicsGraphNodes.innerHTML = '<div class="small text-muted">No graph nodes</div>';
          uaForensicsGraphEdges.innerHTML = '<div class="small text-muted">No graph links</div>';
          return;
        }
        uaForensicsGraphNodes.innerHTML = `
          <div class="d-flex flex-wrap gap-1">
            ${nodes.slice(0, 20).map((node) => {
              const type = String(node.type || '').toLowerCase();
              const badgeClass = type === 'user'
                ? 'text-bg-primary'
                : (type === 'ip'
                  ? 'text-bg-danger'
                  : (type === 'session' ? 'text-bg-warning' : 'text-bg-info'));
              return `<span class="badge ${badgeClass}">${escapeHtml(node.label || node.id || 'node')}</span>`;
            }).join('')}
          </div>
        `;
        uaForensicsGraphEdges.innerHTML = edges.length
          ? `<div class="small">${edges.slice(0, 16).map((edge) => {
            const left = String(edge.from || '').replace(/^.*:/, '');
            const right = String(edge.to || '').replace(/^.*:/, '');
            return `${escapeHtml(left)} → ${escapeHtml(right)}`;
          }).join(' · ')}</div>`
          : '<div class="small text-muted">No graph links</div>';
      };

      async function loadUserSessions(userId) {
        if (!uaSessionsList) return;
        uaSessionsList.innerHTML = '<li class="list-group-item text-muted">Loading…</li>';
        try {
          const res = await fetch(`/admin/users/${encodeURIComponent(userId)}/sessions.json`, {
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          const data = await res.json();
          if (!res.ok || !data.ok) {
            throw new Error(data && data.error ? data.error : 'sessions_load_failed');
          }
          const rows = Array.isArray(data.sessions) ? data.sessions : [];
          if (!rows.length) {
            uaSessionsList.innerHTML = '<li class="list-group-item text-muted">No active sessions</li>';
            return;
          }
          uaSessionsList.innerHTML = rows.map((row) => {
            const lastSeen = row.last_seen_at ? new Date(row.last_seen_at) : null;
            const lastSeenText = lastSeen && !Number.isNaN(lastSeen.getTime())
              ? lastSeen.toLocaleString('uk-UA')
              : '—';
            const route = row.last_seen_route ? String(row.last_seen_route) : '/';
            const ip = row.ip ? String(row.ip) : '—';
            const marker = row.is_current ? '<span class="badge text-bg-success ms-1">current</span>' : '';
            return `
              <li class="list-group-item">
                <div class="fw-semibold">${escapeHtml(route)}${marker}</div>
                <div class="small text-muted">${escapeHtml(lastSeenText)} · ${escapeHtml(ip)}</div>
              </li>
            `;
          }).join('');
        } catch (err) {
          uaSessionsList.innerHTML = '<li class="list-group-item text-muted">Failed to load sessions</li>';
        }
      }

      async function updateUserRiskCase(action = 'save') {
        const userId = Number(uaRiskUserIdInput && uaRiskUserIdInput.value ? uaRiskUserIdInput.value : 0);
        if (!Number.isFinite(userId) || userId < 1) return;
        const body = new URLSearchParams();
        body.set('action', action);
        body.set('risk_level', uaRiskLevelInput ? uaRiskLevelInput.value : 'normal');
        body.set('status', uaRiskStatusInput ? uaRiskStatusInput.value : 'open');
        body.set('risk_score', uaRiskScoreInput ? uaRiskScoreInput.value : '0');
        body.set('reason', uaRiskReasonInput ? uaRiskReasonInput.value : '');
        body.set('resolution_note', uaRiskResolutionInput ? uaRiskResolutionInput.value : '');
        try {
          const res = await fetch(`/admin/users/${encodeURIComponent(userId)}/risk-case`, {
            method: 'POST',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            },
            body: body.toString(),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) {
            throw new Error(data && data.error ? data.error : 'risk_case_update_failed');
          }
          applyRiskCaseInputs(data.case || null, {
            level: data.level,
            score: data.score,
          });
          if (action !== 'refresh') {
            showToast('success', 'Risk case updated.');
          }
          refreshUsers();
          if (visitAnalyticsPanel && isVisitAnalyticsVisible()) {
            loadSecurityDashboard();
          }
        } catch (err) {
          showToast('error', err.message || 'Failed to update risk case');
        }
      }

      async function loadUserForensics(userId) {
        const matchesList = document.getElementById('uaForensicsMatches');
        const meta = document.getElementById('uaForensicsMeta');
        const riskEl = document.getElementById('uaForensicsRisk');
        const guess = document.getElementById('uaForensicsGuess');
        if (!matchesList || !meta || !guess || !riskEl) return;
        meta.textContent = 'Loading forensics…';
        riskEl.innerHTML = '';
        guess.innerHTML = '';
        matchesList.innerHTML = '<li class="list-group-item text-muted">Loading…</li>';
        try {
          const res = await fetch(`/admin/users/${encodeURIComponent(userId)}/forensics.json`);
          if (!res.ok) {
            throw new Error('forensics_load_failed');
          }
          const data = await res.json();
          const evidence = data.evidence || {};
          const sourceLabel = getForensicsSourceLabel(evidence.source);
          const ipCount = Array.isArray(evidence.ips) ? evidence.ips.length : 0;
          const ignoredIpCount = Array.isArray(evidence.ignored_ips) ? evidence.ignored_ips.length : 0;
          const sessionCount = Array.isArray(evidence.session_ids) ? evidence.session_ids.length : 0;
          const agentCount = Array.isArray(evidence.user_agents) ? evidence.user_agents.length : 0;
          meta.textContent = `${sourceLabel} · IP: ${ipCount} · Ignored IP: ${ignoredIpCount} · Session: ${sessionCount} · Device: ${agentCount}`;

          const risk = data.risk || {};
          const riskBadgeClass = getForensicsRiskClass(String(risk.level || 'clear'));
          const riskLabel = String(risk.label || 'Ознак ризику не виявлено');
          const riskScore = Number(risk.score || 0);
          const riskReasons = Array.isArray(risk.reasons) ? risk.reasons.slice(0, 3) : [];
          const riskAlerts = Number(risk.recent_alerts_count || 0);
          riskEl.innerHTML = `
            <div class="small d-flex flex-wrap align-items-center gap-2">
              <span>Risk:</span>
              <span class="badge ${riskBadgeClass}">${escapeHtml(riskLabel)} · ${riskScore}</span>
              ${riskAlerts > 0 ? `<span class="badge text-bg-danger">Alerts ${riskAlerts}</span>` : ''}
              ${risk.allowlisted ? '<span class="badge text-bg-success">Allowlist active</span>' : ''}
            </div>
            ${riskReasons.length ? `<div class="small text-muted mt-1">${riskReasons.map((v) => escapeHtml(v)).join(' · ')}</div>` : ''}
          `;
          applyRiskCaseInputs(data.security_case || null, risk);
          renderForensicsGraph(data.graph || null);

          const registerEvent = evidence.register_event || null;
          const inferredEvents = Array.isArray(evidence.inferred_register_events) ? evidence.inferred_register_events : [];
          const inferredFirst = inferredEvents.length ? inferredEvents[0] : null;
          const fallbackIp = registerEvent?.ip || inferredFirst?.ip || (Array.isArray(evidence.ips) ? evidence.ips[0] : null);
          const fallbackAgent = registerEvent?.user_agent
            || inferredFirst?.user_agent
            || (Array.isArray(evidence.user_agents) ? evidence.user_agents[0] : null);
          const fallbackSeenAt = registerEvent?.created_at || inferredFirst?.last_seen_at || inferredFirst?.first_seen_at;

          const uaIp = document.getElementById('uaIp');
          const uaAgent = document.getElementById('uaAgent');
          const uaLoginAt = document.getElementById('uaLoginAt');
          const isMissing = (value) => !value || value === '-';
          if (uaIp && isMissing(uaIp.textContent) && fallbackIp) {
            uaIp.textContent = String(fallbackIp);
          }
          if (uaAgent && isMissing(uaAgent.textContent) && fallbackAgent) {
            uaAgent.textContent = String(fallbackAgent);
          }
          if (uaLoginAt && isMissing(uaLoginAt.textContent) && fallbackSeenAt) {
            uaLoginAt.textContent = `${fallbackSeenAt} (register)`;
          }

          if (data.suspected_owner) {
            const owner = data.suspected_owner;
            const ownerRole = getRoleLabel(normalizeRoleKeyClient(owner.role || 'student'));
            const confidenceClass = getForensicsConfidenceClass(owner.confidence);
            guess.innerHTML = `
              <div class="alert alert-warning py-2 px-3 mb-0">
                Можливий власник: <strong>${escapeHtml(owner.full_name || '')}</strong>
                <span class="badge ms-2 ${confidenceClass}">${escapeHtml(owner.confidence_label || '')} (${Number(owner.score || 0)})</span>
                <div class="small mt-1 text-muted">${escapeHtml(ownerRole)}</div>
              </div>
            `;
          } else {
            guess.innerHTML = '<div class="small text-muted">Чіткого кандидата поки не знайдено.</div>';
          }

          if (!Array.isArray(data.matches) || !data.matches.length) {
            matchesList.innerHTML = '<li class="list-group-item text-muted">No matches yet</li>';
          } else {
            matchesList.innerHTML = data.matches
              .map((match) => {
                const roleLabel = getRoleLabel(normalizeRoleKeyClient(match.role || 'student'));
                const confidenceClass = getForensicsConfidenceClass(match.confidence);
                const ipHits = Array.isArray(match.ip_hits) && match.ip_hits.length
                  ? `IP: ${match.ip_hits.map((v) => escapeHtml(v)).join(', ')}`
                  : '';
                const sessionHits = Array.isArray(match.session_hits) && match.session_hits.length
                  ? `Session: ${match.session_hits.map((v) => escapeHtml(v)).join(', ')}`
                  : '';
                const reasons = Array.isArray(match.reasons) ? match.reasons.slice(0, 4) : [];
                const details = [ipHits, sessionHits].filter(Boolean).join(' · ');
                return `
                  <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                      <div>
                        <div class="fw-semibold">${escapeHtml(match.full_name || '')}</div>
                        <div class="small text-muted">${escapeHtml(roleLabel)}</div>
                      </div>
                      <span class="badge ${confidenceClass}">${escapeHtml(match.confidence_label || '')} · ${Number(match.score || 0)}</span>
                    </div>
                    ${details ? `<div class="small text-muted mt-1">${details}</div>` : ''}
                    ${reasons.length ? `<div class="small mt-1">${reasons.map((v) => escapeHtml(v)).join(' · ')}</div>` : ''}
                  </li>
                `;
              })
              .join('');
          }
          loadUserSessions(userId);
        } catch (err) {
          meta.textContent = 'Failed to load forensics';
          riskEl.innerHTML = '';
          guess.innerHTML = '';
          matchesList.innerHTML = '<li class="list-group-item text-muted">Failed to load</li>';
          setRiskCaseMeta(null);
          renderForensicsGraph(null);
        }
      }

