        }
      };

      const renderSystemHealth = (payload) => {
        const data = payload && typeof payload === 'object' ? payload : null;
        const status = data ? String(data.status || '') : '';
        if (systemHealthStatusBadge) {
          systemHealthStatusBadge.className = `badge ${healthBadgeClass(status)}`;
          systemHealthStatusBadge.textContent = prettyHealthStatus(status || 'unknown');
        }
        if (systemHealthRuntime) {
          const runtime = data && data.runtime ? data.runtime : {};
          const version = runtime.version ? `v${runtime.version}` : 'v—';
          const uptime = Number(runtime.uptime_seconds || 0);
          const uptimeHours = uptime > 0 ? `${Math.round((uptime / 3600) * 10) / 10}h` : '—';
          systemHealthRuntime.textContent = `${version} · ${uptimeHours}`;
        }
        if (systemHealthDb) {
          const dbStatus = data && data.health ? String(data.health.db_status || '') : '';
          systemHealthDb.textContent = prettyHealthStatus(dbStatus || 'unknown');
        }
        if (systemHealthSession) {
          const sessionStatus = data && data.health ? String(data.health.session_status || '') : '';
          const failures = Number(data && data.session ? data.session.failures : 0);
          systemHealthSession.textContent = `${prettyHealthStatus(sessionStatus || 'unknown')} · fail ${formatVisitNumber(failures)}`;
        }
        if (systemHealthScheduler) {
          const schedulerStatus = data && data.health ? String(data.health.scheduler_status || '') : '';
          const scheduler = data && data.scheduler ? data.scheduler : {};
          const runCount = Number(scheduler.run_count || 0);
          systemHealthScheduler.textContent = `${prettyHealthStatus(schedulerStatus || 'unknown')} · runs ${formatVisitNumber(runCount)}`;
        }
        if (systemHealthGeneratedAt) {
          const generatedAt = data && data.generated_at ? new Date(data.generated_at) : null;
          systemHealthGeneratedAt.textContent = generatedAt && !Number.isNaN(generatedAt.getTime())
            ? `Оновлено: ${generatedAt.toLocaleString('uk-UA')}`
            : 'Оновлено: —';
        }
        if (systemHealthMigrationsBody) {
          const migrations = data && data.migrations ? data.migrations : {};
          const pendingIds = Array.isArray(migrations.pending_ids) ? migrations.pending_ids : [];
          const pendingText = pendingIds.length ? pendingIds.join(', ') : 'Немає';
          const lastApplied = migrations.last_applied_at ? new Date(migrations.last_applied_at) : null;
          const lastAppliedText = lastApplied && !Number.isNaN(lastApplied.getTime())
            ? lastApplied.toLocaleString('uk-UA')
            : '—';
          systemHealthMigrationsBody.innerHTML = `
            <tr><td>Доступно</td><td>${formatVisitNumber(migrations.total_available)}</td></tr>
            <tr><td>Застосовано</td><td>${formatVisitNumber(migrations.applied_count)}</td></tr>
            <tr><td>Pending</td><td>${formatVisitNumber(migrations.pending_count)}</td></tr>
            <tr><td>Остання міграція</td><td>${escapeHtml(lastAppliedText)}</td></tr>
            <tr><td>Pending IDs</td><td>${escapeHtml(pendingText)}</td></tr>
          `;
        }
        if (systemHealthErrorsBody) {
          const errors = data && data.errors ? data.errors : {};
          const top = Array.isArray(errors.top_labels) ? errors.top_labels : [];
          if (!top.length) {
            systemHealthErrorsBody.innerHTML = '<tr><td colspan="2" class="text-muted">Помилок за вікно немає.</td></tr>';
          } else {
            systemHealthErrorsBody.innerHTML = top.map((row) => `
              <tr>
                <td>${escapeHtml(`${row.kind || 'unknown'} / ${row.label || 'unknown'}`)}</td>
                <td>${formatVisitNumber(row.count)}</td>
              </tr>
            `).join('');
          }
        }
        if (systemHealthRecentErrorsList) {
          const errors = data && data.errors ? data.errors : {};
          const recent = Array.isArray(errors.recent) ? errors.recent.slice(0, 3) : [];
          if (!recent.length) {
            systemHealthRecentErrorsList.textContent = 'Останні помилки: немає';
          } else {
            const text = recent.map((row) => {
              const at = row.created_at ? new Date(row.created_at).toLocaleTimeString('uk-UA') : '--:--';
              return `${at} ${row.kind || 'unknown'}:${row.label || 'unknown'} — ${row.message || ''}`;
            }).join(' | ');
            systemHealthRecentErrorsList.textContent = `Останні помилки: ${text}`;
          }
        }
        const incidents = data && data.incidents ? data.incidents : {};
        const bySeverity = incidents && incidents.by_severity ? incidents.by_severity : {};
        if (systemIncidentOpen) {
          systemIncidentOpen.textContent = formatVisitNumber(incidents.open_incidents);
        }
        if (systemIncidentCritical) {
          systemIncidentCritical.textContent = formatVisitNumber(bySeverity.critical);
        }
        if (systemIncidentHigh) {
          systemIncidentHigh.textContent = formatVisitNumber(bySeverity.high);
        }
        if (systemIncidentUnique) {
          systemIncidentUnique.textContent = formatVisitNumber(incidents.unique_incidents);
        }
        if (systemIncidentBody) {
          const rows = Array.isArray(incidents.items) ? incidents.items : [];
          if (!rows.length) {
            systemIncidentBody.innerHTML = '<tr><td colspan="5" class="text-muted">Інцидентів за вікно немає.</td></tr>';
          } else {
            systemIncidentBody.innerHTML = rows.map((row) => {
              const lastSeen = row.last_seen_at ? new Date(row.last_seen_at) : null;
              const lastSeenText = lastSeen && !Number.isNaN(lastSeen.getTime())
                ? lastSeen.toLocaleString('uk-UA')
                : '—';
              return `
                <tr>
                  <td><span class="badge ${incidentSeverityClass(row.severity)}">${escapeHtml(String(row.severity || 'low').toUpperCase())}</span></td>
                  <td>${escapeHtml(`${row.kind || 'unknown'} / ${row.label || 'unknown'}`)}</td>
                  <td>${escapeHtml(lastSeenText)}</td>
                  <td>${formatVisitNumber(row.count)}</td>
                  <td>${escapeHtml(row.message || '')}</td>
                </tr>
              `;
            }).join('');
          }
        }
      };

      const loadSystemHealth = async () => {
        if (!visitAnalyticsPanel || systemHealthLoading) return;
        setSystemHealthLoading(true);
        try {
          const res = await fetch('/admin/system-health.json', {
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          if (!res.ok) {
            throw new Error(`System health ${res.status}`);
          }
          const data = await res.json();
          if (!data || !data.ok) {
            throw new Error('System health payload invalid');
          }
          renderSystemHealth(data);
        } catch (err) {
          renderSystemHealth(null);
        } finally {
          setSystemHealthLoading(false);
        }
      };

      const setDataQualityLoading = (loading) => {
        dataQualityLoading = !!loading;
        if (dataQualityRefreshBtn) {
          dataQualityRefreshBtn.disabled = dataQualityLoading;
          dataQualityRefreshBtn.textContent = dataQualityLoading ? 'Оновлення…' : 'Оновити quality';
        }
      };

      const renderDataQuality = (payload) => {
        const data = payload && typeof payload === 'object' ? payload : null;
        if (!data) {
          if (dataQualityMetricIssues) dataQualityMetricIssues.textContent = '—';
          if (dataQualityMetricChecks) dataQualityMetricChecks.textContent = '—';
          if (dataQualityMetricCritical) dataQualityMetricCritical.textContent = '—';
          if (dataQualityMetricSubjects) dataQualityMetricSubjects.textContent = '—';
          if (dataQualityStatusBadge) {
            dataQualityStatusBadge.className = 'badge text-bg-secondary';
            dataQualityStatusBadge.textContent = 'Unavailable';
          }
          if (dataQualityGeneratedAt) {
            dataQualityGeneratedAt.textContent = 'Оновлено: —';
          }
          if (dataQualityBody) {
            dataQualityBody.innerHTML = '<tr><td colspan="4" class="text-muted">Не вдалось завантажити data quality.</td></tr>';
          }
          return;
        }
        if (data.available === false) {
          if (dataQualityMetricIssues) dataQualityMetricIssues.textContent = '—';
          if (dataQualityMetricChecks) dataQualityMetricChecks.textContent = '—';
          if (dataQualityMetricCritical) dataQualityMetricCritical.textContent = '—';
          if (dataQualityMetricSubjects) dataQualityMetricSubjects.textContent = '—';
          if (dataQualityStatusBadge) {
            dataQualityStatusBadge.className = 'badge text-bg-secondary';
            dataQualityStatusBadge.textContent = 'Unavailable';
          }
          if (dataQualityGeneratedAt) {
            const generatedAt = data && data.generated_at ? new Date(data.generated_at) : null;
            dataQualityGeneratedAt.textContent = generatedAt && !Number.isNaN(generatedAt.getTime())
              ? `Оновлено: ${generatedAt.toLocaleString('uk-UA')}`
              : 'Оновлено: —';
          }
          if (dataQualityBody) {
            dataQualityBody.innerHTML = '<tr><td colspan="4" class="text-muted">Data quality недоступний для поточної схеми БД.</td></tr>';
          }
          return;
        }
        const summary = data && data.summary ? data.summary : {};
        const totalIssues = Number(summary.total_issues || 0);
        const criticalRows = Number(summary && summary.severity_rows ? summary.severity_rows.critical : 0);
        const checksWithIssues = Number(summary.checks_with_issues || 0);
        const checksTotal = Number(summary.checks_total || 0);
        const hasPartialData = data.partial === true;

        if (dataQualityMetricIssues) {
          dataQualityMetricIssues.textContent = formatVisitNumber(totalIssues);
        }
        if (dataQualityMetricChecks) {
          dataQualityMetricChecks.textContent = `${formatVisitNumber(checksWithIssues)} / ${formatVisitNumber(checksTotal)}`;
        }
        if (dataQualityMetricCritical) {
          dataQualityMetricCritical.textContent = formatVisitNumber(criticalRows);
        }
        if (dataQualityMetricSubjects) {
          dataQualityMetricSubjects.textContent = formatVisitNumber(summary.affected_subjects);
        }

        if (dataQualityStatusBadge) {
          const badgeClass = criticalRows > 0
            ? 'text-bg-danger'
            : (totalIssues > 0 ? 'text-bg-warning' : (hasPartialData ? 'text-bg-secondary' : 'text-bg-success'));
          const badgeLabel = criticalRows > 0
            ? 'Critical issues'
            : (totalIssues > 0 ? 'Warnings' : (hasPartialData ? 'Partial' : 'Clean'));
          dataQualityStatusBadge.className = `badge ${badgeClass}`;
          dataQualityStatusBadge.textContent = badgeLabel;
        }

        if (dataQualityGeneratedAt) {
          const generatedAt = data && data.generated_at ? new Date(data.generated_at) : null;
          dataQualityGeneratedAt.textContent = generatedAt && !Number.isNaN(generatedAt.getTime())
            ? `Оновлено: ${generatedAt.toLocaleString('uk-UA')}`
            : 'Оновлено: —';
        }

        if (!dataQualityBody) return;
        const rows = Array.isArray(data && data.items) ? data.items : [];
        if (!rows.length) {
          dataQualityBody.innerHTML = '<tr><td colspan="4" class="text-muted">Перевірки недоступні.</td></tr>';
          return;
        }
        dataQualityBody.innerHTML = rows.map((row) => {
          const count = Number(row && row.count ? row.count : 0);
          const isInfoNote = count <= 0 && String(row && row.severity ? row.severity : '').toLowerCase() === 'info';
          const statusClass = count > 0
            ? dataQualitySeverityBadgeClass(row.severity)
            : (isInfoNote ? 'text-bg-secondary' : 'text-bg-success');
          const statusLabel = count > 0
            ? String(row.severity || 'warning').toUpperCase()
            : (isInfoNote ? 'INFO' : 'OK');
          const description = row && row.description ? String(row.description) : '';
          const examples = Array.isArray(row && row.examples ? row.examples : [])
            .slice(0, 2)
            .map((item) => `<div class="data-quality-sample">${escapeHtml(String(item || ''))}</div>`)
            .join('');
          return `
            <tr>
              <td><span class="badge ${statusClass}">${escapeHtml(statusLabel)}</span></td>
              <td>
                <div class="fw-semibold">${escapeHtml(row && row.title ? String(row.title) : 'Check')}</div>
                <div class="small text-muted">${escapeHtml(description || '—')}</div>
              </td>
              <td>${formatVisitNumber(count)}</td>
              <td>${examples || '<span class="text-muted">—</span>'}</td>
            </tr>
          `;
        }).join('');
      };

      const buildUnavailableDataQualityPayload = () => ({
        ok: true,
        generated_at: new Date().toISOString(),
        available: false,
        partial: false,
        summary: {
          checks_total: 0,
          checks_with_issues: 0,
          total_issues: 0,
          affected_subjects: 0,
          severity_rows: {
            critical: 0,
            warning: 0,
            info: 0,
          },
          severity_checks: {
            critical: 0,
            warning: 0,
            info: 0,
          },
        },
        items: [],
      });

      const loadDataQuality = async () => {
        if (!visitAnalyticsPanel || dataQualityLoading) return;
        setDataQualityLoading(true);
        try {
          const res = await fetch('/admin/data-quality.json', {
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          let data = null;
          const contentType = String(res.headers.get('content-type') || '').toLowerCase();
          if (contentType.includes('application/json')) {
            data = await res.json();
          } else {
            const raw = await res.text();
            try {
              data = JSON.parse(raw);
            } catch (_err) {
              data = null;
            }
          }
          if (!res.ok || !data || typeof data !== 'object' || data.ok !== true) {
            data = buildUnavailableDataQualityPayload();
          }
          renderDataQuality(data);
        } catch (err) {
          renderDataQuality(buildUnavailableDataQualityPayload());
        } finally {
          setDataQualityLoading(false);
        }
      };

      const setSecurityDashboardLoading = (loading) => {
        securityDashboardLoading = !!loading;
        if (securityDashboardRefreshBtn) {
          securityDashboardRefreshBtn.disabled = securityDashboardLoading || securityScanLoading;
          securityDashboardRefreshBtn.textContent = securityDashboardLoading ? 'Оновлення…' : 'Оновити security';
        }
        if (securityDashboardScanBtn) {
          securityDashboardScanBtn.disabled = securityDashboardLoading || securityScanLoading;
        }
      };

      const setSecurityScanLoading = (loading) => {
        securityScanLoading = !!loading;
        if (securityDashboardScanBtn) {
          securityDashboardScanBtn.disabled = securityDashboardLoading || securityScanLoading;
          securityDashboardScanBtn.textContent = securityScanLoading ? 'Сканування…' : 'Скан ризиків';
        }
        if (securityDashboardRefreshBtn) {
          securityDashboardRefreshBtn.disabled = securityDashboardLoading || securityScanLoading;
        }
      };

      const formatSecurityAutoRefreshLabel = (seconds) => {
        const safeSeconds = Number(seconds || 0);
        const minutes = Math.max(1, Math.round(safeSeconds / 60));
        return `${minutes} хв`;
      };

      const updateSecurityAutoRefreshUi = () => {
        if (securityAutoRefreshIntervalSelect) {
          securityAutoRefreshIntervalSelect.value = String(securityAutoRefreshSeconds);
        }
        if (securityAutoRefreshToggleBtn) {
          securityAutoRefreshToggleBtn.textContent = securityAutoRefreshEnabled ? 'Авто: ON' : 'Авто: OFF';
          securityAutoRefreshToggleBtn.classList.toggle('btn-outline-success', securityAutoRefreshEnabled);
          securityAutoRefreshToggleBtn.classList.toggle('btn-outline-secondary', !securityAutoRefreshEnabled);
        }
        if (securityAutoRefreshStatus) {
          const statusParts = [];
          if (securityAutoRefreshEnabled) {
            statusParts.push(`Автооновлення кожні ${formatSecurityAutoRefreshLabel(securityAutoRefreshSeconds)}`);
          } else {
            statusParts.push('Автооновлення вимкнено');
          }
          if (securityAutoRefreshLastRunAt && !Number.isNaN(securityAutoRefreshLastRunAt.getTime())) {
            statusParts.push(`останній скан ${securityAutoRefreshLastRunAt.toLocaleTimeString('uk-UA')}`);
          }
          if (securityAutoRefreshSummary) {
            const highRisk = Number(securityAutoRefreshSummary.high_risk_total || 0);
            const watch = Number(securityAutoRefreshSummary.watch_total || 0);
            const suspicious = Number(securityAutoRefreshSummary.suspicious_total || (highRisk + watch));
            statusParts.push(`підозрілих ${formatVisitNumber(suspicious)} (high ${formatVisitNumber(highRisk)}, watch ${formatVisitNumber(watch)})`);
          }
          securityAutoRefreshStatus.textContent = statusParts.join(' · ');
        }
      };

      const clearSecurityAutoRefreshTimer = () => {
        if (securityAutoRefreshTimer) {
          window.clearInterval(securityAutoRefreshTimer);
          securityAutoRefreshTimer = null;
        }
      };

      const getSecurityRiskBadgeClass = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'high-risk') return 'text-bg-danger';
        if (key === 'watch') return 'text-bg-warning';
        return 'text-bg-secondary';
      };

      const getSecurityStatusBadgeClass = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'confirmed') return 'text-bg-warning';
        if (key === 'closed') return 'text-bg-success';
        return 'text-bg-secondary';
      };

      const formatSecurityRiskLabel = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'high-risk') return 'High-risk';
        if (key === 'watch') return 'Watch';
        return 'Normal';
      };

      const renderSecurityDashboard = (payload) => {
        const data = payload && typeof payload === 'object' ? payload : null;
        if (!data) {
          if (securityDashboardStatusBadge) {
            securityDashboardStatusBadge.className = 'badge text-bg-secondary';
            securityDashboardStatusBadge.textContent = 'Unavailable';
          }
          if (securityMetricOpenCases) securityMetricOpenCases.textContent = '—';
          if (securityMetricHighRisk) securityMetricHighRisk.textContent = '—';
          if (securityMetricWatch) securityMetricWatch.textContent = '—';
          if (securityMetricOverdue72h) securityMetricOverdue72h.textContent = '—';
          if (securityDashboardGeneratedAt) securityDashboardGeneratedAt.textContent = 'Оновлено: —';
          securityAutoRefreshSummary = null;
          updateSecurityAutoRefreshUi();
          if (securityRiskyBody) securityRiskyBody.innerHTML = '<tr><td colspan="4" class="text-muted">Не вдалось завантажити кейси.</td></tr>';
          if (securityAlertsBody) securityAlertsBody.innerHTML = '<tr><td colspan="4" class="text-muted">Не вдалось завантажити алерти.</td></tr>';
          if (securityIpsBody) securityIpsBody.innerHTML = '<tr><td colspan="3" class="text-muted">Не вдалось завантажити IP.</td></tr>';
          if (securityDevicesBody) securityDevicesBody.innerHTML = '<tr><td colspan="3" class="text-muted">Не вдалось завантажити devices.</td></tr>';
          return;
        }

        const summary = data.summary || {};
        const highRiskTotal = Number(summary.high_risk_total || 0);
        const watchTotal = Number(summary.watch_total || 0);
        const openCases = Number(summary.open_cases || 0);
        const overdue72h = Number(summary.overdue_72h || 0);
        securityAutoRefreshSummary = {
          high_risk_total: highRiskTotal,
          watch_total: watchTotal,
          suspicious_total: highRiskTotal + watchTotal,
        };
        updateSecurityAutoRefreshUi();

        if (securityDashboardStatusBadge) {
          const badgeClass = highRiskTotal > 0
            ? 'text-bg-danger'
            : (openCases > 0 ? 'text-bg-warning' : 'text-bg-success');
          const badgeLabel = highRiskTotal > 0
            ? 'High-risk present'
            : (openCases > 0 ? 'Open cases' : 'Stable');
          securityDashboardStatusBadge.className = `badge ${badgeClass}`;
          securityDashboardStatusBadge.textContent = badgeLabel;
        }
        if (securityMetricOpenCases) securityMetricOpenCases.textContent = formatVisitNumber(openCases);
        if (securityMetricHighRisk) securityMetricHighRisk.textContent = formatVisitNumber(highRiskTotal);
        if (securityMetricWatch) securityMetricWatch.textContent = formatVisitNumber(watchTotal);
        if (securityMetricOverdue72h) securityMetricOverdue72h.textContent = formatVisitNumber(overdue72h);

        if (securityDashboardGeneratedAt) {
          const generatedAt = data.generated_at ? new Date(data.generated_at) : null;
          securityDashboardGeneratedAt.textContent = generatedAt && !Number.isNaN(generatedAt.getTime())
            ? `Оновлено: ${generatedAt.toLocaleString('uk-UA')}`
            : 'Оновлено: —';
        }

        if (securityRiskyBody) {
          const rows = Array.isArray(data.risky_accounts) ? data.risky_accounts.slice(0, 10) : [];
          if (!rows.length) {
            securityRiskyBody.innerHTML = '<tr><td colspan="4" class="text-muted">Ризикових кейсів немає.</td></tr>';
          } else {
            securityRiskyBody.innerHTML = rows.map((row) => {
              const level = String(row && row.risk_level ? row.risk_level : '').trim().toLowerCase();
              const rowClass = level === 'high-risk'
                ? 'security-risk-row-high'
                : (level === 'watch' ? 'security-risk-row-watch' : '');
              return `
              <tr class="${rowClass}">
                <td>${escapeHtml(row.full_name || '-')}</td>
                <td><span class="badge ${getSecurityRiskBadgeClass(row.risk_level)}">${escapeHtml(formatSecurityRiskLabel(row.risk_level))}</span></td>
                <td><span class="badge ${getSecurityStatusBadgeClass(row.status)}">${escapeHtml(String(row.status || 'open'))}</span></td>
                <td>${formatVisitNumber(row.risk_score)}</td>
              </tr>
            `;
            }).join('');
          }
        }

        if (securityAlertsBody) {
          const rows = Array.isArray(data.open_alerts) ? data.open_alerts.slice(0, 10) : [];
          if (!rows.length) {
            securityAlertsBody.innerHTML = '<tr><td colspan="4" class="text-muted">Активних алертів немає.</td></tr>';
          } else {
            securityAlertsBody.innerHTML = rows.map((row) => {
              const at = row.created_at ? new Date(row.created_at) : null;
              const atText = at && !Number.isNaN(at.getTime()) ? at.toLocaleString('uk-UA') : '—';
              return `
                <tr>
                  <td><span class="badge ${incidentSeverityClass(row.severity)}">${escapeHtml(String(row.severity || '').toUpperCase())}</span></td>
                  <td>${escapeHtml(row.title || row.alert_key || 'Alert')}</td>
                  <td>${escapeHtml(row.user_name || '—')}</td>
                  <td>${escapeHtml(atText)}</td>
                </tr>
              `;
            }).join('');
          }
        }

        if (securityIpsBody) {
          const rows = Array.isArray(data.top_ips) ? data.top_ips.slice(0, 10) : [];
          if (!rows.length) {
            securityIpsBody.innerHTML = '<tr><td colspan="3" class="text-muted">Підозрілих IP за період немає.</td></tr>';
          } else {
            securityIpsBody.innerHTML = rows.map((row) => `
              <tr>
                <td>${escapeHtml(row.ip || '—')}</td>
                <td>${formatVisitNumber(row.users_count)}</td>
                <td>${formatVisitNumber(row.events_count)}</td>
              </tr>
            `).join('');
          }
        }

        if (securityDevicesBody) {
          const rows = Array.isArray(data.top_devices) ? data.top_devices.slice(0, 10) : [];
          if (!rows.length) {
            securityDevicesBody.innerHTML = '<tr><td colspan="3" class="text-muted">Підозрілих девайсів за період немає.</td></tr>';
          } else {
            securityDevicesBody.innerHTML = rows.map((row) => `
              <tr>
                <td>${escapeHtml(row.sample_label || row.device_key || 'device')}</td>
                <td>${formatVisitNumber(row.users_count)}</td>
                <td>${formatVisitNumber(row.events_count)}</td>
              </tr>
            `).join('');
          }
        }
      };

      const loadSecurityDashboard = async ({ silent = false } = {}) => {
        if (!visitAnalyticsPanel || securityDashboardLoading) return;
        setSecurityDashboardLoading(true);
        try {
          const res = await fetch('/admin/security-dashboard.json', {
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          if (!res.ok) {
            throw new Error(`Security dashboard ${res.status}`);
          }
          const data = await res.json();
          if (!data || !data.ok) {
            throw new Error('Security dashboard payload invalid');
          }
          renderSecurityDashboard(data);
        } catch (err) {
          renderSecurityDashboard(null);
          if (!silent) {
            showToast('error', 'Не вдалось завантажити security dashboard.');
          }
        } finally {
          setSecurityDashboardLoading(false);
        }
      };

      const runSecurityDashboardScan = async ({ silent = false } = {}) => {
        if (!visitAnalyticsPanel || securityScanLoading) return;
        setSecurityScanLoading(true);
        try {
          const res = await fetch('/admin/security-dashboard/recompute', {
            method: 'POST',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ limit: 220 }),
          });
          if (!res.ok) {
            throw new Error(`Security scan ${res.status}`);
          }
          const payload = await res.json();
          if (!payload || !payload.ok) {
            throw new Error('Security scan payload invalid');
          }
          securityAutoRefreshLastRunAt = payload.generated_at ? new Date(payload.generated_at) : new Date();
          securityAutoRefreshSummary = payload.summary || null;
          updateSecurityAutoRefreshUi();
          await loadSecurityDashboard({ silent: true });
          if (!silent) {
            const suspiciousTotal = Number(payload.summary && payload.summary.suspicious_total ? payload.summary.suspicious_total : 0);
            showToast('success', `Скан завершено: підозрілих акаунтів ${formatVisitNumber(suspiciousTotal)}.`);
          }
        } catch (err) {
          if (!silent) {
            showToast('error', 'Не вдалось виконати скан ризиків.');
          }
        } finally {
          setSecurityScanLoading(false);
        }
      };

      const restartSecurityAutoRefresh = () => {
        clearSecurityAutoRefreshTimer();
        if (!securityAutoRefreshEnabled) {
          updateSecurityAutoRefreshUi();
          return;
        }
        securityAutoRefreshTimer = window.setInterval(() => {
          if (!visitAnalyticsPanel) return;
          if (!isVisitAnalyticsVisible()) return;
          runSecurityDashboardScan({ silent: true });
        }, Math.max(30000, securityAutoRefreshSeconds * 1000));
        updateSecurityAutoRefreshUi();
      };

      const renderVisitChart = (dailyRows) => {
        if (!visitChartCanvas || !visitChartCtor) return;
        const labels = (dailyRows || []).map((row) => row.day || row.date || row.label || '');
        const visits = (dailyRows || []).map((row) => Number(row.visits ?? row.total_visits ?? row.count ?? 0));
        const unique = (dailyRows || []).map((row) => Number(row.unique_visitors ?? row.unique ?? 0));
        if (visitChart) {
          visitChart.destroy();
          visitChart = null;
        }
        visitChart = new visitChartCtor(visitChartCanvas, {
          type: 'line',
          data: {
            labels,
            datasets: [
              {
                label: 'Візити',
                data: visits,
                borderColor: '#60a5fa',
                backgroundColor: 'rgba(96, 165, 250, 0.22)',
                fill: true,
                tension: 0.32,
                pointRadius: 2.5,
              },
              {
                label: 'Унікальні',
                data: unique,
                borderColor: '#34d399',
                backgroundColor: 'rgba(52, 211, 153, 0.16)',
                fill: false,
                tension: 0.32,
                pointRadius: 2.5,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            scales: {
              x: {
                grid: { color: 'rgba(148, 163, 184, 0.16)' },
                ticks: { color: getComputedStyle(document.body).getPropertyValue('--text-muted') || '#94a3b8' },
              },
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(148, 163, 184, 0.12)' },
                ticks: { color: getComputedStyle(document.body).getPropertyValue('--text-muted') || '#94a3b8' },
              },
            },
            plugins: {
              legend: {
                labels: {
                  color: getComputedStyle(document.body).getPropertyValue('--text-primary') || '#e2e8f0',
                },
              },
            },
          },
        });
      };

      const loadVisitAnalytics = async () => {
        if (!visitAnalyticsPanel || visitAnalyticsLoading) return;
        const days = visitDaysSelect ? Number(visitDaysSelect.value || 14) : 14;
        const excludeAdmin = visitExcludeAdminToggle ? (visitExcludeAdminToggle.checked ? 1 : 0) : 1;
        setVisitAnalyticsLoading(true);
        try {
          const res = await fetch(`/admin/visit-analytics.json?days=${encodeURIComponent(days)}&exclude_admin=${encodeURIComponent(String(excludeAdmin))}`, {
            headers: { Accept: 'application/json' },
            cache: 'no-store',
          });
          if (!res.ok) {
            throw new Error(`Analytics ${res.status}`);
          }
          const data = await res.json();
          if (!data || !data.ok) {
            throw new Error('Analytics payload invalid');
          }
          const useAnalyticsFallback = Boolean(
            data.exclude_admin
            && data.analytics_used_fallback
            && data.summary_fallback
            && Number(data.summary_fallback.total_visits || 0) > 0
          );
          const summarySource = useAnalyticsFallback ? (data.summary_fallback || {}) : (data.summary || {});
          const dailySource = useAnalyticsFallback ? (data.daily_fallback || []) : (data.daily || []);
          const topPagesSource = useAnalyticsFallback ? (data.top_pages_fallback || []) : (data.top_pages || []);
          const rolesSource = useAnalyticsFallback ? (data.roles_fallback || []) : (data.roles || []);

          if (visitMetricTotal) visitMetricTotal.textContent = formatVisitNumber(summarySource.total_visits);
          if (visitMetricUnique) visitMetricUnique.textContent = formatVisitNumber(summarySource.unique_visitors);
          if (visitMetricSigned) visitMetricSigned.textContent = formatVisitNumber(summarySource.signed_users);
          if (visitMetricDays) visitMetricDays.textContent = formatVisitNumber(summarySource.active_days);
          renderVisitChart(dailySource);
          renderVisitTopPages(topPagesSource);
          renderVisitRoles(rolesSource);
          const recentFilteredRows = Array.isArray(data.recent) ? data.recent : [];
          const recentFallbackRows = Array.isArray(data.recent_fallback) ? data.recent_fallback : [];
          if (useAnalyticsFallback && recentFallbackRows.length) {
            setVisitRecentHint('Без адмінів порожньо, показано статистику і останні візити з адмінами.');
            renderVisitRecent(recentFallbackRows);
          } else if (!recentFilteredRows.length && data.recent_is_fallback && recentFallbackRows.length) {
            setVisitRecentHint('Без адмінів порожньо, показано останні візити з адмінами.');
            renderVisitRecent(recentFallbackRows);
          } else {
            setVisitRecentHint('');
            renderVisitRecent(recentFilteredRows);
          }
          try {
            renderHomeworkSla(data.homework_sla || null);
          } catch (_err) {
            renderHomeworkSla(null);
          }
        } catch (err) {
          renderVisitTopPages([]);
          renderVisitRoles([]);
          setVisitRecentHint('');
          renderVisitRecent([]);
          renderHomeworkSla(null);
          if (visitMetricTotal) visitMetricTotal.textContent = '—';
          if (visitMetricUnique) visitMetricUnique.textContent = '—';
          if (visitMetricSigned) visitMetricSigned.textContent = '—';
          if (visitMetricDays) visitMetricDays.textContent = '—';
          showToast('error', 'Не вдалось завантажити аналітику відвідування.');
        } finally {
          setVisitAnalyticsLoading(false);
        }
      };

      const isVisitAnalyticsVisible = () => {
        if (!visitAnalyticsPanel) return false;
        const style = window.getComputedStyle(visitAnalyticsPanel);
        return style.display !== 'none' && style.visibility !== 'hidden';
      };

      const refreshVisitAnalyticsOnOpen = () => {
        if (!visitAnalyticsPanel) return;
        if (!isVisitAnalyticsVisible()) return;
        if (visitChart && typeof visitChart.resize === 'function') {
          visitChart.resize();
        }
        loadVisitAnalytics();
        loadSystemHealth();
        loadDataQuality();
        loadSecurityDashboard({ silent: true });
        restartSecurityAutoRefresh();
      };

      if (visitAnalyticsPanel) {
        updateSecurityAutoRefreshUi();
        if (visitRefreshBtn) {
          visitRefreshBtn.addEventListener('click', () => {
            loadVisitAnalytics();
            loadSystemHealth();
            loadDataQuality();
            loadSecurityDashboard({ silent: true });
          });
        }
        if (visitDaysSelect) {
          visitDaysSelect.addEventListener('change', loadVisitAnalytics);
        }
        if (visitExcludeAdminToggle) {
          visitExcludeAdminToggle.addEventListener('change', loadVisitAnalytics);
        }
        if (systemHealthRefreshBtn) {
          systemHealthRefreshBtn.addEventListener('click', loadSystemHealth);
        }
        if (dataQualityRefreshBtn) {
          dataQualityRefreshBtn.addEventListener('click', loadDataQuality);
        }
        if (securityDashboardRefreshBtn) {
          securityDashboardRefreshBtn.addEventListener('click', () => loadSecurityDashboard({ silent: false }));
        }
        if (securityDashboardScanBtn) {
          securityDashboardScanBtn.addEventListener('click', () => runSecurityDashboardScan({ silent: false }));
        }
        if (securityAutoRefreshIntervalSelect) {
          securityAutoRefreshIntervalSelect.value = String(securityAutoRefreshSeconds);
          securityAutoRefreshIntervalSelect.addEventListener('change', () => {
            const nextValue = Number(securityAutoRefreshIntervalSelect.value || securityAutoRefreshSeconds);
            if (securityAutoRefreshAllowedSeconds.includes(nextValue)) {
              securityAutoRefreshSeconds = nextValue;
              safeStorageSet('admin:security:auto-refresh-seconds', String(nextValue));
            }
            restartSecurityAutoRefresh();
          });
        }
        if (securityAutoRefreshToggleBtn) {
          securityAutoRefreshToggleBtn.addEventListener('click', () => {
            securityAutoRefreshEnabled = !securityAutoRefreshEnabled;
            safeStorageSet('admin:security:auto-refresh-enabled', securityAutoRefreshEnabled ? '1' : '0');
            restartSecurityAutoRefresh();
            if (securityAutoRefreshEnabled && isVisitAnalyticsVisible()) {
              runSecurityDashboardScan({ silent: true });
            }
          });
        }
        window.addEventListener('admin:visit-analytics-opened', refreshVisitAnalyticsOnOpen);
        if (isVisitAnalyticsVisible()) {
          loadVisitAnalytics();
          loadSystemHealth();
          loadDataQuality();
          loadSecurityDashboard({ silent: true });
          restartSecurityAutoRefresh();
        }
      }

      window.addEventListener('beforeunload', () => {
        clearSecurityAutoRefreshTimer();
      });

      document.addEventListener('click', async (event) => {
        const trigger = event.target.closest('[data-confirm]');
        if (!trigger) return;
        const formId = trigger.getAttribute('form');
        const form = formId ? document.getElementById(formId) : trigger.closest('form');
        if (!form) return;
        event.preventDefault();
        const message = trigger.dataset.confirm || 'Are you sure?';
        const level = trigger.dataset.confirmLevel || 'danger';
        const typed = trigger.dataset.confirmTyped || '';
        const ok = await openConfirmModal({ message, level, typed });
        if (!ok) return;
        if (typed) {
          let confirmPhraseInput = form.querySelector('input[name="confirm_phrase"]');
          if (!confirmPhraseInput) {
            confirmPhraseInput = document.createElement('input');
            confirmPhraseInput.type = 'hidden';
            confirmPhraseInput.name = 'confirm_phrase';
            form.appendChild(confirmPhraseInput);
          }
          confirmPhraseInput.value = typed;
          const stepupInput = form.querySelector('input[name="stepup_code"]');
          if (stepupInput && !String(stepupInput.value || '').trim()) {
            stepupInput.value = typed;
          }
        }
        form.submit();
      });

      const importScopeData = {
        courses: <%- JSON.stringify(courses || []) %>,
        semestersByCourse: <%- JSON.stringify(semestersByCourseMap || {}) %>,
      };
      const roleLabelMap = <%- JSON.stringify(roleLabelMapData || {}) %>;
      const roleCatalogBootstrap = <%- JSON.stringify((rbacRolesList || []).map((roleRow) => ({
        key: roleRow.key,
        label: roleRow.label || roleRow.key,
        is_active: roleRow.is_active !== false && Number(roleRow.is_active) !== 0,
      }))) %>;
      const normalizeRoleKeyClient = (value) => String(value || '').trim().toLowerCase();
      const getRoleLabel = (roleKey) => roleLabelMap[normalizeRoleKeyClient(roleKey)] || String(roleKey || 'student');
      const parseRoleKeys = (value, fallback = ['student']) => {
        const input = Array.isArray(value) ? value : (typeof value === 'string' ? value.split(',') : []);
        const seen = new Set();
        const keys = [];
        input.forEach((item) => {
          const normalized = normalizeRoleKeyClient(item);
          if (!normalized || seen.has(normalized)) return;
          seen.add(normalized);
          keys.push(normalized);
        });
        return keys.length ? keys : fallback;
      };
      const mapRoleKeysToLabels = (roleKeys) =>
        parseRoleKeys(roleKeys).map((key) => getRoleLabel(key)).join(', ');
      const getPrimaryRoleClass = (primaryRole) => (
        primaryRole === 'admin'
          ? 'primary'
          : (primaryRole === 'starosta'
            ? 'warning'
            : (primaryRole === 'deanery' ? 'info' : 'secondary'))
      );
      const getSelectedRoleKeys = () => {
        const rolesSelect = document.getElementById('uaRolesSelect');
        if (!rolesSelect) return [];
        return Array.from(rolesSelect.selectedOptions || [])
          .map((opt) => normalizeRoleKeyClient(opt.value))
          .filter(Boolean);
      };
      const setPrimaryRoleOptions = (roleKeys, preferredPrimary = '') => {
        const primarySelect = document.getElementById('uaPrimaryRole');
        if (!primarySelect) return;
        const keys = parseRoleKeys(roleKeys, []);
        if (!keys.length) {
          primarySelect.innerHTML = '';
          return;
        }
        primarySelect.innerHTML = keys
          .map((key) => `<option value="${escapeHtml(key)}">${escapeHtml(getRoleLabel(key))}</option>`)
          .join('');
        const normalizedPreferred = normalizeRoleKeyClient(preferredPrimary);
        primarySelect.value = keys.includes(normalizedPreferred) ? normalizedPreferred : keys[0];
      };
      const populateRoleEditor = (roleCatalog, roleKeys, preferredPrimary = '') => {
        const rolesSelect = document.getElementById('uaRolesSelect');
        if (!rolesSelect) return;
        const selectedKeys = parseRoleKeys(roleKeys, ['student']);
        const catalogRows = Array.isArray(roleCatalog) ? roleCatalog : [];
        const byKey = new Map();
        catalogRows.forEach((row) => {
          const key = normalizeRoleKeyClient(row && row.key);
          if (!key || byKey.has(key)) return;
          byKey.set(key, {
            key,
            label: row && row.label ? String(row.label) : getRoleLabel(key),
            is_active: row ? (row.is_active !== false && Number(row.is_active) !== 0) : true,
          });
        });
        selectedKeys.forEach((key) => {
          if (!byKey.has(key)) {
            byKey.set(key, { key, label: getRoleLabel(key), is_active: true });
          }
        });
        const options = Array.from(byKey.values())
          .filter((row) => row.is_active || selectedKeys.includes(row.key) || row.key === 'admin')
          .sort((a, b) => a.label.localeCompare(b.label, 'uk'));
        rolesSelect.innerHTML = options
          .map((row) => {
            const suffix = row.is_active ? '' : ' (inactive)';
            const selected = selectedKeys.includes(row.key) ? ' selected' : '';
            return `<option value="${escapeHtml(row.key)}"${selected}>${escapeHtml(`${row.label}${suffix}`)}</option>`;
          })
          .join('');
        setPrimaryRoleOptions(selectedKeys, preferredPrimary);
      };
      let userRolesModalRequestToken = 0;
      const hydrateUserRoleEditor = async (userId, fallbackRoleKeys, fallbackPrimaryRole) => {
        const token = ++userRolesModalRequestToken;
        try {
          const res = await fetch(`/admin/users/${encodeURIComponent(userId)}/roles.json`, {
            headers: { Accept: 'application/json' },
          });
          if (!res.ok) return;
          const data = await res.json();
          if (token !== userRolesModalRequestToken) return;
          const roleCatalog = Array.isArray(data.roles) && data.roles.length
            ? data.roles.map((row) => ({
                key: row.key,
                label: row.label || row.key,
                is_active: row.is_active !== false && Number(row.is_active) !== 0,
              }))
            : roleCatalogBootstrap;
          roleCatalog.forEach((row) => {
            const key = normalizeRoleKeyClient(row && row.key);
            if (!key) return;
            roleLabelMap[key] = row && row.label ? String(row.label) : key;
          });
          const roleKeys = parseRoleKeys(data.role_keys, fallbackRoleKeys);
          const primaryRole = normalizeRoleKeyClient(data.primary_role || fallbackPrimaryRole || roleKeys[0] || 'student');
          populateRoleEditor(roleCatalog, roleKeys, primaryRole);
          document.getElementById('uaRole').textContent = getRoleLabel(primaryRole);
          document.getElementById('uaRoles').textContent = mapRoleKeysToLabels(roleKeys);
        } catch (err) {
          // keep fallback role data
        }
      };
      const importCourseMap = new Map(
        (importScopeData.courses || []).map((course) => [String(course.id), course])
      );
      const importSemestersByCourse = importScopeData.semestersByCourse || {};
      const getCampusLabel = (course) => {
        if (!course) return '';
        return String(course.location || 'kyiv').toLowerCase() === 'munich' ? 'Munich' : 'Kyiv';
      };
      const updateScopeSummary = (scopeSummary, courseId, semesterId) => {
        if (!scopeSummary) return;
        const course = importCourseMap.get(String(courseId || ''));
        const campusLabel = getCampusLabel(course);
        const parts = [];
        if (course) parts.push(course.name);
        if (campusLabel) parts.push(campusLabel);
        if (semesterId) {
          const list = importSemestersByCourse[String(courseId)] || [];
          const sem = list.find((item) => String(item.id) === String(semesterId));
          if (sem) parts.push(`Semester=${sem.title}`);
        }
        scopeSummary.textContent = parts.length ? `Import into: ${parts.join(' · ')}` : 'Select scope to validate.';
      };

      document.querySelectorAll('.import-card').forEach((card) => {
        const type = card.dataset.importType;
        const form = card.querySelector('form.import-form');
        const fileInput = form ? form.querySelector('input[type="file"]') : null;
        const createEl = card.querySelector('[data-import-create]');
        const updateEl = card.querySelector('[data-import-update]');
        const skipEl = card.querySelector('[data-import-skip]');
        const errorEl = card.querySelector('[data-import-error]');
        const errorsContainer = card.querySelector('[data-import-errors]');
        const downloadBtn = card.querySelector('[data-import-error-download]');
        const confirmCheck = card.querySelector('[data-import-confirm-check]');
        const confirmButton = form ? form.querySelector('button[type="submit"]') : null;
        const confirmRequiredInput = card.querySelector('[data-import-confirm-required]');
        const typedConfirmWrap = card.querySelector('[data-import-typed-confirm]');
        const typedConfirmInput = card.querySelector('[data-import-confirm-phrase]');
        const templateBtn = card.querySelector('[data-template]');
        const scopeCourseSelect = card.querySelector('[data-import-scope-course]');
        const scopeSemesterSelect = card.querySelector('[data-import-scope-semester]');
        const scopeSummary = card.querySelector('[data-import-scope-summary]');
        let operationId = '';
        let validationBlocked = false;
        let hasValidated = false;

        const syncSummary = ({ create = 0, update = 0, skip = 0, errors = 0 } = {}) => {
          if (createEl) createEl.textContent = create;
          if (updateEl) updateEl.textContent = update;
          if (skipEl) skipEl.textContent = skip;
          if (errorEl) errorEl.textContent = errors;
        };
        const setLoading = (loading) => {
          card.classList.toggle('is-loading', loading);
        };
        const scopeReady = () => {
          if (!scopeCourseSelect || !scopeCourseSelect.value) return false;
          if (scopeSemesterSelect && !scopeSemesterSelect.value) return false;
          return true;
        };
        const updateConfirmState = () => {
          if (!confirmButton) return;
          const requiresTyped = confirmRequiredInput && confirmRequiredInput.value === '1';
          const typedOk = !requiresTyped || (typedConfirmInput && typedConfirmInput.value.trim().toUpperCase() === 'IMPORT');
          const checked = confirmCheck ? confirmCheck.checked : true;
          const ready = hasValidated && !validationBlocked && scopeReady() && checked && typedOk;
          confirmButton.disabled = !ready;
        };
        const refreshSemesterOptions = () => {
          if (!scopeSemesterSelect || !scopeCourseSelect) return;
          const list = importSemestersByCourse[String(scopeCourseSelect.value)] || [];
          const selected = scopeSemesterSelect.value;
          scopeSemesterSelect.innerHTML = list.length
            ? list.map((sem) => `<option value="${sem.id}" ${String(sem.id) === String(selected) ? 'selected' : ''}>${sem.title} · ${sem.weeks_count} тижнів</option>`).join('')
            : '<option value="">Немає семестрів</option>';
