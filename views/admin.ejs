      const renderHomeworkSla = (sla) => {
        const data = sla && typeof sla === 'object' ? sla : null;
        const thresholdHours = Number(data && data.threshold_hours ? data.threshold_hours : 48);
        if (homeworkSlaThresholdLabel) {
          homeworkSlaThresholdLabel.textContent = `(>${formatVisitNumber(thresholdHours)} год)`;
        }
        if (visitSlaMetricOverdue) {
          visitSlaMetricOverdue.textContent = formatVisitNumber(data && data.overdue_ungraded_total);
        }
        if (visitSlaMetricUngraded) {
          visitSlaMetricUngraded.textContent = formatVisitNumber(data && data.ungraded_total);
        }
        if (visitSlaMetricSubjects) {
          visitSlaMetricSubjects.textContent = formatVisitNumber(data && data.subjects_at_risk);
        }
        if (visitSlaMetricMaxWait) {
          visitSlaMetricMaxWait.textContent = formatSlaWait(data && data.max_wait_hours);
        }
        if (!homeworkSlaBody) return;
        const rows = (Array.isArray(data && data.by_subject) ? data.by_subject : [])
          .filter((row) => Number(row && row.ungraded_total || 0) > 0 || Number(row && row.overdue_ungraded_total || 0) > 0);
        if (!rows.length) {
          homeworkSlaBody.innerHTML = '<tr><td colspan="5" class="text-muted">Неперевірених робіт понад SLA немає.</td></tr>';
          return;
