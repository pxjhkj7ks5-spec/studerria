                  <td>${log.action}</td>
                  <td>${log.details || '-'}</td>
                  <td>${log.created_at}</td>
                </tr>
              `
            )
            .join('');
        } catch (err) {
          return;
        }
      }

      function getForensicsConfidenceClass(level) {
        if (level === 'high') return 'text-bg-danger';
        if (level === 'medium') return 'text-bg-warning';
        if (level === 'low') return 'text-bg-info';
        return 'text-bg-secondary';
      }

      function getForensicsRiskClass(level) {
        if (level === 'high' || level === 'high-risk') return 'text-bg-danger';
        if (level === 'watch') return 'text-bg-warning';
        if (level === 'low') return 'text-bg-info';
        if (level === 'suppressed') return 'text-bg-success';
        return 'text-bg-secondary';
      }

      function getForensicsSourceLabel(source) {
        if (source === 'registration_event') return 'Registration event';
        if (source === 'inferred_site_visits') return 'Inferred from register visits';
        if (source === 'login_only') return 'Login history only';
        return 'Unknown source';
      }

      const uaRiskUserIdInput = document.getElementById('uaRiskUserId');
