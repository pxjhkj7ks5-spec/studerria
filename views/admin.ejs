      const formatVisitNumber = (value) => {
        const n = Number(value || 0);
        return new Intl.NumberFormat('uk-UA').format(Number.isFinite(n) ? n : 0);
      };
      const formatSlaWait = (value) => {
        const hours = Number(value || 0);
        if (!Number.isFinite(hours) || hours <= 0) return '—';
        if (hours >= 72) {
          return `${(hours / 24).toFixed(1)} дн`;
        }
        if (hours >= 24) {
          return `${Math.round(hours / 24)} дн`;
        }
        return `${Math.round(hours)} год`;
      };
      const prettyHealthStatus = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'ok') return 'OK';
        if (key === 'starting') return 'Starting';
        if (key === 'running') return 'Running';
        if (key === 'disabled') return 'Disabled';
        if (key === 'degraded') return 'Degraded';
        if (key === 'critical' || key === 'fail') return 'Critical';
        return key || 'unknown';
      };
      const healthBadgeClass = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'ok' || key === 'running') return 'text-bg-success';
        if (key === 'starting' || key === 'disabled') return 'text-bg-secondary';
        if (key === 'degraded') return 'text-bg-warning';
        if (key === 'critical' || key === 'fail') return 'text-bg-danger';
        return 'text-bg-secondary';
      };
      const incidentSeverityClass = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'critical') return 'text-bg-danger';
        if (key === 'high') return 'text-bg-warning';
        if (key === 'medium') return 'text-bg-info';
        return 'text-bg-secondary';
      };
      const dataQualitySeverityBadgeClass = (value) => {
        const key = String(value || '').trim().toLowerCase();
        if (key === 'critical') return 'text-bg-danger';
        if (key === 'warning') return 'text-bg-warning';
        return 'text-bg-secondary';
      };

      const prettyVisitPageLabel = (key) => {
        const labels = {
          login: 'Логін',
          register: 'Реєстрація',
          schedule: 'Розклад',
          'my-day': 'My Day',
          teamwork: 'Teamwork',
          profile: 'Профіль',
          admin: 'Адмінка',
          deanery: 'Деканат',
          starosta: 'Староста',
          teacher: 'Викладач',
          subjects: 'Предмети',
        };
        const normalized = String(key || '').trim().toLowerCase();
        return labels[normalized] || normalized || 'unknown';
      };

      const prettyVisitRoleLabel = (key) => {
        const labels = {
          admin: 'Адмін',
          deanery: 'Деканат',
          starosta: 'Староста',
          teacher: 'Викладач',
          student: 'Студент',
          guest: 'Гість',
        };
        const normalized = String(key || '').trim().toLowerCase();
        return labels[normalized] || normalized || 'guest';
