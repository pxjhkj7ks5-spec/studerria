          renderAuditTable(container, data.entries || [], '/admin/role-studio/rollback', 'Rollback this Role Studio change?');
        } catch (err) {
          container.innerHTML = `<div class="small text-danger py-2">${escapeAuditText(err.message || 'Failed to load Role Studio audit')}</div>`;
