                      <option value="" disabled selected>Subject</option>
                      <% (subjects || []).forEach(function(s) { %>
                        <option value="<%= s.id %>" data-group-count="<%= s.group_count %>" data-is-general="<%= s.is_general ? '1' : '0' %>"><%= s.name %> (1–<%= s.group_count %>)</option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="col-12 col-md-2">
