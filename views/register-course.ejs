<%
  const scopeMatrix = registrationScopeMatrix || {
    tracks: [],
    programs: [],
    cohortsByProgram: {},
    campusesByCohort: {},
    teacherCampusesByProgram: {},
    initialSelection: {},
  };
  const trackDiagnostics = registrationTrackDiagnostics || {};
  const initialSelection = scopeMatrix.initialSelection || {};
  const selectedTrackValue = typeof initialSelection.trackKey === 'string' && initialSelection.trackKey
    ? initialSelection.trackKey
    : (typeof selectedTrack === 'string' && selectedTrack ? selectedTrack : 'bachelor');
  const formatTrackLabel = (trackKey, fallback) => {
    const normalized = String(trackKey || '').trim().toLowerCase();
    if (normalized === 'bachelor') return lang === 'en' ? 'Bachelor' : 'Бакалаврат';
    if (normalized === 'master') return lang === 'en' ? "Master's" : 'Магістратура';
    if (normalized === 'teacher') return lang === 'en' ? 'Teaching' : 'Викладацький';
    return fallback || normalized;
  };
  const registerCourseText = lang === 'en'
    ? {
        themeToggleAria: 'Change theme',
        introTitle: 'Course registration',
        stepTrack: 'Level',
        stepTrackCopy: 'Choose bachelor, master, or teaching registration.',
        stepProgram: 'Program',
        stepProgramCopy: 'Program defines the next available steps.',
        programStaticBadge: 'Selected',
        singleProgramCopy: 'This level has one available program.',
        stepCohort: 'Admission year',
        stepCohortCopy: 'Pick the admission year you want to join.',
        stepCampus: 'Location',
        stepCampusCopyStudent: 'Choose the location that matches your registration.',
        stepCampusCopyTeacher: 'Choose the location that matches your teaching route.',
        chooseProgram: 'Choose a program',
        chooseProgramFirst: 'Choose a program first to see the next available steps.',
        chooseProgramForCampusTeacher: 'Choose a program first to see available locations.',
        noPrograms: 'This route is not open for registration yet.',
        noCohorts: 'No admission year is available for this program yet.',
        noReadyCohorts: 'Admission years for this program are still being prepared.',
        chooseCohortFirst: 'Choose an admission year to review available locations.',
        chooseCohortOption: 'Choose admission year',
        noCampuses: 'No locations are available for this route yet.',
        noReadyCampuses: 'This route has no ready location for registration yet.',
        chooseCampus: 'Choose a location to continue.',
        ready: 'Ready',
        blocked: 'Unavailable',
        needsSetup: 'Needs attention',
        cohortLabel: 'Admission year',
        admissionYearLabel: 'Admission year',
        campusLabel: 'Location',
        campusKyiv: 'Kyiv',
        campusMunich: 'Munich',
        scopeProgram: 'Program',
        scopeCohort: 'Admission year',
        scopeRoute: 'Level',
        scopeGroup: 'Academic group',
        continueLockedStudent: 'Choose admission year and location before continuing.',
        continueLockedTeacher: 'Choose a program and location before continuing.',
      }
    : {
        themeToggleAria: 'Змінити тему',
        introTitle: 'Реєстрація курсу',
        stepTrack: 'Рівень',
        stepTrackCopy: 'Оберіть бакалаврат, магістратуру або викладацький трек.',
        stepProgram: 'Програма',
        stepProgramCopy: 'Програма визначає наступні доступні кроки.',
        programStaticBadge: 'Вибрано',
        singleProgramCopy: 'Для цього рівня доступна одна програма.',
        stepCohort: 'Рік вступу',
        stepCohortCopy: 'Оберіть рік вступу, до якого хочете приєднатись.',
        stepCampus: 'Локація',
        stepCampusCopyStudent: 'Оберіть локацію, яка відповідає вашій реєстрації.',
        stepCampusCopyTeacher: 'Оберіть локацію, яка відповідає викладацькому маршруту.',
        chooseProgram: 'Оберіть програму',
        chooseProgramFirst: 'Спершу оберіть програму, щоб побачити доступні варіанти далі.',
        chooseProgramForCampusTeacher: 'Спершу оберіть програму, щоб побачити доступні локації.',
        noPrograms: 'Цей маршрут поки не відкритий для реєстрації.',
        noCohorts: 'Для цієї програми поки немає жодного року вступу.',
        noReadyCohorts: 'Роки вступу для цієї програми ще готуються до реєстрації.',
        chooseCohortFirst: 'Оберіть рік вступу, щоб переглянути доступні локації.',
        chooseCohortOption: 'Оберіть рік вступу',
        noCampuses: 'Для цього маршруту поки немає доступних локацій.',
        noReadyCampuses: 'Для цього маршруту поки немає готової локації для реєстрації.',
        chooseCampus: 'Оберіть локацію, щоб продовжити реєстрацію.',
        ready: 'Готово',
        blocked: 'Недоступно',
        needsSetup: 'Потребує уваги',
        cohortLabel: 'Рік вступу',
        admissionYearLabel: 'Рік вступу',
        campusLabel: 'Локація',
        campusKyiv: 'Київ',
        campusMunich: 'Мюнхен',
        scopeProgram: 'Програма',
        scopeCohort: 'Рік вступу',
        scopeRoute: 'Рівень',
        scopeGroup: 'Академічна група',
        continueLockedStudent: 'Оберіть рік вступу і локацію перед продовженням.',
        continueLockedTeacher: 'Оберіть програму і локацію перед продовженням.',
      };
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title><%= t('registerCourse.title') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --accent: #2583ff;
        --accent-strong: #1068de;
        --accent-soft: rgba(37, 131, 255, 0.14);
        --success: #118a56;
        --warning: #b86b00;
        --danger: #cf3c44;
        --card-radius: 28px;
        --registration-text: #0f172a;
        --registration-heading: #0f172a;
        --registration-muted: rgba(51, 65, 85, 0.78);
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
        min-height: 100vh;
      }
      body.theme-light {
        background:
          radial-gradient(1200px 900px at 10% 10%, rgba(96, 165, 250, 0.28), transparent 60%),
          radial-gradient(1000px 800px at 92% 12%, rgba(34, 211, 238, 0.2), transparent 58%),
          linear-gradient(160deg, #eef6ff 0%, #f7fbff 54%, #f6f7fb 100%);
        color: #0f172a;
      }
      body.theme-dark {
        --registration-text: rgba(241, 245, 249, 0.96);
        --registration-heading: #f8fafc;
        --registration-muted: rgba(226, 232, 240, 0.78);
        background:
          radial-gradient(1200px 900px at 8% 10%, rgba(32, 124, 229, 0.28), transparent 62%),
          radial-gradient(1000px 780px at 88% 10%, rgba(14, 165, 233, 0.16), transparent 60%),
          linear-gradient(180deg, #07111d 0%, #0a1727 48%, #0d1d31 100%);
        color: #f8fafc;
      }
      .glass {
        position: relative;
        isolation: isolate;
        overflow: clip;
        background-clip: padding-box;
        border-radius: var(--card-radius);
        backdrop-filter: blur(22px) saturate(160%);
        -webkit-backdrop-filter: blur(22px) saturate(160%);
        transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease, transform 180ms ease;
      }
      body.theme-light .glass {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(244, 249, 255, 0.78));
        border: 1px solid rgba(148, 163, 184, 0.16);
        box-shadow: 0 28px 64px rgba(15, 23, 42, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.85);
      }
      body.theme-dark .glass {
        background: linear-gradient(180deg, rgba(16, 29, 46, 0.78), rgba(13, 25, 42, 0.72));
        border: 1px solid rgba(148, 191, 255, 0.14);
        box-shadow: 0 34px 72px rgba(1, 8, 20, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }
      body.page-register-course .auth-card {
        border-radius: 34px;
        overflow: hidden;
      }
      body.page-register-course .auth-card .card-body {
        padding: 1.2rem 1.05rem !important;
      }
      body.page-register-course .auth-card h1 {
        margin: 0;
        font-size: clamp(1.18rem, 2.4vw, 1.48rem);
        line-height: 1.08;
        letter-spacing: -0.04em;
        font-weight: 760;
      }
      .registration-titlebar {
        margin-bottom: 0.65rem;
        padding: 0.2rem 0.15rem 0.45rem;
      }
      .registration-step {
        padding: 0.72rem 0 0.78rem;
        border-top: 1px solid rgba(148, 163, 184, 0.14);
      }
      .registration-step:first-of-type {
        border-top: 0;
        padding-top: 0.1rem;
      }
      .registration-step-header {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        margin-bottom: 0.45rem;
      }
      .registration-step-index {
        flex: 0 0 auto;
        width: 1.55rem;
        height: 1.55rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
      }
      body.theme-light .registration-step-index {
        background: rgba(37, 131, 255, 0.09);
        color: rgba(17, 76, 149, 0.9);
      }
      body.theme-dark .registration-step-index {
        background: rgba(96, 165, 250, 0.12);
        color: rgba(191, 219, 254, 0.92);
      }
      .registration-step-title {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .registration-step-copy {
        margin: 0.14rem 0 0;
        font-size: 0.74rem;
        line-height: 1.35;
      }
      body.theme-light .registration-step-copy {
        color: rgba(51, 65, 85, 0.78);
      }
      body.theme-dark .registration-step-copy {
        color: rgba(226, 232, 240, 0.72);
      }
      .track-grid,
      .scope-grid {
        display: grid;
        gap: 0.55rem;
      }
      .track-grid {
        grid-template-columns: repeat(auto-fit, minmax(118px, 1fr));
      }
      .scope-grid--cohorts {
        grid-template-columns: 1fr;
      }
      .scope-grid--campuses {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
      }
      .track-option,
      .scope-option,
      .registration-empty {
        position: relative;
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        color: var(--registration-text);
        transition: transform 150ms ease, border-color 150ms ease, box-shadow 150ms ease, background 150ms ease, opacity 150ms ease;
      }
      body.theme-light .track-option,
      body.theme-light .scope-option,
      body.theme-light .registration-empty {
        background: rgba(255, 255, 255, 0.58);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.76);
      }
      body.theme-dark .track-option,
      body.theme-dark .scope-option,
      body.theme-dark .registration-empty {
        background: rgba(255, 255, 255, 0.05);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }
      .track-option {
        padding: 0.62rem 0.75rem;
        text-align: center;
        cursor: pointer;
        font-weight: 700;
        font-size: 0.82rem;
      }
      .track-option input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      .track-option:hover,
      .scope-option:hover {
        transform: translateY(-1px);
      }
      .track-option.is-selected,
      .scope-option.is-selected {
        border-color: rgba(37, 131, 255, 0.58);
      }
      body.theme-light .track-option.is-selected,
      body.theme-light .scope-option.is-selected {
        background: linear-gradient(135deg, rgba(37, 131, 255, 0.14), rgba(78, 205, 196, 0.12));
        box-shadow: 0 18px 34px rgba(37, 131, 255, 0.12);
      }
      body.theme-dark .track-option.is-selected,
      body.theme-dark .scope-option.is-selected {
        background: linear-gradient(135deg, rgba(37, 131, 255, 0.18), rgba(18, 182, 201, 0.14));
        box-shadow: 0 18px 34px rgba(6, 20, 42, 0.26);
      }
      .track-option.is-disabled,
      .scope-option.is-disabled {
        cursor: not-allowed;
        opacity: 0.58;
      }
      .track-option.is-diagnostic {
        opacity: 0.78;
      }
      .scope-option {
        width: 100%;
        padding: 0.72rem 0.78rem;
        text-align: left;
        cursor: pointer;
        color: var(--registration-text);
        font: inherit;
        -webkit-appearance: none;
        appearance: none;
      }
      .scope-option[disabled] {
        cursor: not-allowed;
      }
      .scope-option-head,
      .scope-option-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.7rem;
      }
      .scope-option-head {
        margin-bottom: 0.35rem;
      }
      .scope-option-title {
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: -0.02em;
        color: var(--registration-heading);
      }
      .scope-option-subtitle {
        font-size: 0.72rem;
        line-height: 1.32;
        margin-top: 0.16rem;
      }
      body.theme-light .scope-option-subtitle,
      body.theme-light .registration-empty-copy,
      body.theme-light .registration-hint,
      body.theme-light .program-static-copy {
        color: var(--registration-muted);
      }
      body.theme-dark .scope-option-subtitle,
      body.theme-dark .registration-empty-copy,
      body.theme-dark .registration-hint,
      body.theme-dark .program-static-copy {
        color: var(--registration-muted);
      }
      .scope-option-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.42rem;
      }
      .scope-pill,
      .scope-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 1.45rem;
        padding: 0.14rem 0.52rem;
        border-radius: 999px;
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .scope-pill {
        border: 1px solid rgba(148, 163, 184, 0.22);
      }
      body.theme-light .scope-pill {
        background: rgba(255, 255, 255, 0.72);
        color: rgba(30, 41, 59, 0.76);
      }
      body.theme-dark .scope-pill {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(226, 232, 240, 0.84);
      }
      .scope-status--ready {
        color: var(--success);
        background: rgba(17, 138, 86, 0.12);
      }
      .scope-status--blocked {
        color: var(--danger);
        background: rgba(207, 60, 68, 0.12);
      }
      .scope-status--needs_setup {
        color: var(--warning);
        background: rgba(184, 107, 0, 0.14);
      }
      .scope-status--repair {
        color: #8a5a00;
        background: rgba(246, 173, 85, 0.2);
      }
      body.theme-dark .scope-status--ready {
        color: #86efac;
        background: rgba(17, 138, 86, 0.16);
      }
      body.theme-dark .scope-status--blocked {
        color: #fda4af;
        background: rgba(207, 60, 68, 0.18);
      }
      body.theme-dark .scope-status--needs_setup {
        color: #fdba74;
        background: rgba(184, 107, 0, 0.18);
      }
      body.theme-dark .scope-status--repair {
        color: #fcd34d;
        background: rgba(217, 119, 6, 0.22);
      }
      .registration-empty {
        padding: 0.72rem 0.78rem;
      }
      .registration-empty-title {
        font-size: 0.82rem;
        font-weight: 700;
        line-height: 1.25;
        color: var(--registration-heading);
      }
      .registration-empty-copy {
        margin-top: 0.18rem;
        font-size: 0.72rem;
        line-height: 1.35;
      }
      .program-static {
        padding: 0.82rem 0.9rem;
        border-radius: 18px;
        border: 1px solid rgba(37, 131, 255, 0.28);
      }
      body.theme-light .program-static {
        background: linear-gradient(135deg, rgba(237, 246, 255, 0.92), rgba(248, 252, 255, 0.88));
        box-shadow: 0 18px 34px rgba(37, 131, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.84);
      }
      body.theme-dark .program-static {
        background: linear-gradient(135deg, rgba(25, 47, 74, 0.82), rgba(16, 33, 54, 0.8));
        box-shadow: 0 18px 34px rgba(4, 16, 32, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }
      .program-static-head {
        display: flex;
        justify-content: flex-start;
        margin-bottom: 0.45rem;
      }
      .program-static-badge {
        display: inline-flex;
        align-items: center;
        min-height: 1.5rem;
        padding: 0.12rem 0.58rem;
        border-radius: 999px;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }
      body.theme-light .program-static-badge {
        background: rgba(37, 131, 255, 0.12);
        color: rgba(17, 76, 149, 0.92);
      }
      body.theme-dark .program-static-badge {
        background: rgba(96, 165, 250, 0.14);
        color: rgba(191, 219, 254, 0.96);
      }
      .program-static-title {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--registration-heading);
      }
      .program-static-copy {
        margin-top: 0.22rem;
        font-size: 0.72rem;
      }
      .pathway-select {
        min-height: 40px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        font-weight: 650;
        font-size: 0.84rem;
        padding: 0.45rem 0.85rem;
      }
      body.theme-light .pathway-select {
        background: rgba(255, 255, 255, 0.76);
        color: #0f172a;
      }
      body.theme-dark .pathway-select {
        background: rgba(255, 255, 255, 0.08);
        color: #f8fafc;
      }
      body.page-register-course .pathway-select option {
        color: #0f172a;
        background: #ffffff;
      }
      body.theme-dark.page-register-course .pathway-select option {
        color: #f8fafc;
        background: #0f2238;
      }
      .registration-hint {
        margin: 0.36rem 0 0;
        font-size: 0.72rem;
        line-height: 1.35;
      }
      .registration-hint.is-error {
        color: var(--danger) !important;
      }
      .cohort-select-wrap {
        display: grid;
        gap: 0.42rem;
      }
      .auth-action-stack {
        margin-top: 0.8rem;
      }
      body.page-register-course .register-action-btn {
        height: 42px;
        border-radius: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 0.9rem;
        font-size: 0.84rem;
      }
      body.page-register-course .btn-primary.register-action-btn {
        background: linear-gradient(180deg, #2d8cff, #1973e8);
        border: 1px solid rgba(37, 131, 255, 0.52);
        box-shadow: 0 18px 34px rgba(37, 131, 255, 0.18);
      }
      body.page-register-course .btn-primary.register-action-btn:disabled {
        opacity: 0.58;
        box-shadow: none;
      }
      body.page-register-course .btn-outline-primary.register-action-btn {
        border-radius: 16px;
        color: var(--registration-heading);
        border-color: rgba(148, 163, 184, 0.26);
        background: rgba(255, 255, 255, 0.52);
      }
      body.theme-dark.page-register-course .btn-outline-primary.register-action-btn {
        color: #f8fafc;
        border-color: rgba(191, 219, 254, 0.22);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.05));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }
      body.theme-dark.page-register-course .btn-outline-primary.register-action-btn:hover {
        border-color: rgba(129, 150, 255, 0.46);
        background: linear-gradient(180deg, rgba(96, 165, 250, 0.16), rgba(59, 130, 246, 0.1));
      }
      body.page-register-course .alert {
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        backdrop-filter: blur(12px);
      }
      body.theme-dark.page-register-course .alert.alert-danger {
        color: #fecdd3;
        border-color: rgba(251, 113, 133, 0.18);
        background: linear-gradient(180deg, rgba(79, 24, 42, 0.88), rgba(57, 17, 33, 0.74));
      }
      .theme-toggle-floating {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 10;
      }
      .theme-toggle-min {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.22);
        background: rgba(255, 255, 255, 0.08);
        color: inherit;
        backdrop-filter: blur(12px);
      }
      body.theme-light .theme-toggle-min {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.74);
      }
      .btn {
        transition: transform 140ms ease, box-shadow 140ms ease;
      }
      .btn:hover:not(:disabled) {
        transform: translateY(-1px);
      }
      .btn:active:not(:disabled) {
        transform: translateY(0);
      }
      .app-footer {
        font-size: 0.8rem;
      }
      body.theme-dark .app-footer {
        color: rgba(255, 255, 255, 0.62);
      }
      body.theme-light .app-footer {
        color: rgba(15, 23, 42, 0.6);
      }
      @media (max-width: 767px) {
        body.page-register-course .auth-card .card-body {
          padding: 1rem 0.85rem !important;
        }
        .registration-step-header {
          gap: 0.55rem;
        }
        .scope-grid--cohorts {
          grid-template-columns: 1fr;
        }
      }
      .scope-option--campus {
        flex: 0 0 auto;
        width: auto;
        min-width: 124px;
        padding: 0.52rem 0.7rem;
        border-radius: 18px;
      }
      .scope-grid--campuses .registration-empty {
        flex: 1 1 100%;
      }
      .scope-option--campus .scope-option-head {
        margin-bottom: 0;
        align-items: center;
        gap: 0.55rem;
      }
      .scope-option--campus .scope-option-title {
        font-size: 0.84rem;
        font-weight: 700;
      }
      .scope-option--campus .scope-option-foot {
        justify-content: flex-start;
        margin-top: 0.22rem;
      }
      .scope-option--campus .scope-option-subtitle {
        margin-top: 0.18rem;
        font-size: 0.68rem;
      }
      .scope-option--campus .scope-status {
        min-height: 1.3rem;
        padding-inline: 0.44rem;
        font-size: 0.62rem;
      }
      .scope-option--campus .scope-pill {
        min-height: 1.28rem;
        padding-inline: 0.44rem;
        font-size: 0.62rem;
      }
      body.theme-light .scope-option--campus {
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.8);
      }
      body.theme-dark .scope-option--campus {
        background: rgba(255, 255, 255, 0.07);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }
      body.theme-light .scope-option--campus.is-selected {
        background: linear-gradient(135deg, rgba(37, 131, 255, 0.16), rgba(126, 200, 255, 0.16));
        box-shadow: 0 16px 30px rgba(37, 131, 255, 0.14);
      }
      body.theme-dark .scope-option--campus.is-selected {
        background: linear-gradient(135deg, rgba(37, 131, 255, 0.22), rgba(59, 130, 246, 0.14));
        box-shadow: 0 16px 30px rgba(4, 16, 32, 0.32);
      }
    </style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <link rel="stylesheet" href="/css/auth-actions.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-light page-register-course">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <div class="theme-toggle-floating">
      <button
        class="theme-toggle-min"
        type="button"
        id="themeToggle"
        aria-label="<%= registerCourseText.themeToggleAria %>"
        data-light-label="☀️"
        data-dark-label="🌙"
      >
        🌙
      </button>
    </div>
    <div class="container">
      <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-11 col-md-10 col-lg-8 col-xl-7">
            <div class="card auth-card glass">
            <div class="card-body">
              <div class="registration-titlebar">
                <h1><%= registerCourseText.introTitle %></h1>
              </div>
              <% if (error) { %>
              <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <form method="POST" action="/register/course" id="registerCourseForm">
                <section class="registration-step">
                  <div class="registration-step-header">
                    <span class="registration-step-index" id="trackStepIndex">1</span>
                    <div>
                      <h2 class="registration-step-title"><%= registerCourseText.stepTrack %></h2>
                      <p class="registration-step-copy"><%= registerCourseText.stepTrackCopy %></p>
                    </div>
                  </div>
                  <div class="track-grid" id="trackGrid">
                    <% (scopeMatrix.tracks || []).forEach((track) => { %>
                      <label class="track-option <%= track.enabled ? '' : 'is-diagnostic' %>" data-track-card="<%= track.key %>">
                        <input
                          type="radio"
                          name="study_track"
                          value="<%= track.key %>"
                          <%= selectedTrackValue === track.key ? 'checked' : '' %>
                          required
                        />
                        <span><%= formatTrackLabel(track.key, track.label) %></span>
                      </label>
                    <% }) %>
                  </div>
                </section>

                <section class="registration-step">
                  <div class="registration-step-header">
                    <span class="registration-step-index" id="programStepIndex">2</span>
                    <div>
                      <h2 class="registration-step-title"><%= registerCourseText.stepProgram %></h2>
                      <p class="registration-step-copy"><%= registerCourseText.stepProgramCopy %></p>
                    </div>
                  </div>
                  <div id="programField">
                    <label class="visually-hidden" for="studyProgramSelect"><%= registerCourseText.stepProgram %></label>
                    <select id="studyProgramSelect" name="program_id" class="form-select pathway-select"></select>
                  </div>
                  <div id="programStaticField" style="display:none;">
                    <div class="program-static">
                      <div class="program-static-head">
                        <span class="program-static-badge"><%= registerCourseText.programStaticBadge %></span>
                      </div>
                      <div class="program-static-title" id="programStaticLabel"></div>
                      <div class="program-static-copy" id="programStaticCopy"><%= registerCourseText.singleProgramCopy %></div>
                    </div>
                  </div>
                  <p class="registration-hint" id="programHint"></p>
                </section>

                <section class="registration-step" id="cohortStep">
                  <div class="registration-step-header">
                    <span class="registration-step-index" id="cohortStepIndex">3</span>
                    <div>
                      <h2 class="registration-step-title"><%= registerCourseText.stepCohort %></h2>
                      <p class="registration-step-copy"><%= registerCourseText.stepCohortCopy %></p>
                    </div>
                  </div>
                  <div class="cohort-select-wrap">
                    <label class="visually-hidden" for="cohortSelect"><%= registerCourseText.stepCohort %></label>
                    <select id="cohortSelect" name="cohort_id" class="form-select pathway-select"></select>
                  </div>
                  <p class="registration-hint" id="cohortHint"></p>
                </section>

                <section class="registration-step" id="campusStep">
                  <div class="registration-step-header">
                    <span class="registration-step-index" id="campusStepIndex">4</span>
                    <div>
                      <h2 class="registration-step-title"><%= registerCourseText.stepCampus %></h2>
                      <p class="registration-step-copy" id="campusStepCopy"><%= registerCourseText.stepCampusCopyStudent %></p>
                    </div>
                  </div>
                  <input type="hidden" name="group_id" id="selectedGroupInput" value="" />
                  <input type="hidden" name="campus" id="selectedCampusInput" value="" />
                  <div class="scope-grid scope-grid--campuses" id="campusOptions"></div>
                  <p class="registration-hint" id="campusHint"></p>
                </section>

                <div class="auth-action-stack auth-action-stack--grid">
                  <button type="submit" class="btn btn-primary register-action-btn auth-action-btn" id="registerContinueButton" disabled>
                    <%= t('registerCourse.continue') %>
                  </button>
                  <a href="/register" class="btn btn-outline-primary register-action-btn auth-action-btn"><%= t('registerCourse.backToRegister') %></a>
                </div>
              </form>
            </div>
          </div>
          <%- include('partials/app-footer') %>
        </div>
      </div>
    </div>
    <%- include('partials/changelog-modal') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const currentLang = <%- JSON.stringify(lang) %>;
      const registerCourseText = <%- JSON.stringify(registerCourseText) %>;
      const scopeMatrix = <%- JSON.stringify(scopeMatrix) %>;
      const trackDiagnostics = <%- JSON.stringify(trackDiagnostics) %>;
      const trackStepIndex = document.getElementById('trackStepIndex');
      const programStepIndex = document.getElementById('programStepIndex');
      const cohortStepIndex = document.getElementById('cohortStepIndex');
      const campusStepIndex = document.getElementById('campusStepIndex');
      const trackInputs = Array.from(document.querySelectorAll('input[name="study_track"]'));
      const programSelect = document.getElementById('studyProgramSelect');
      const programField = document.getElementById('programField');
      const programStaticField = document.getElementById('programStaticField');
      const programStaticLabel = document.getElementById('programStaticLabel');
      const programStaticCopy = document.getElementById('programStaticCopy');
      const programHint = document.getElementById('programHint');
      const cohortStep = document.getElementById('cohortStep');
      const cohortSelect = document.getElementById('cohortSelect');
      const cohortHint = document.getElementById('cohortHint');
      const campusStep = document.getElementById('campusStep');
      const campusStepCopy = document.getElementById('campusStepCopy');
      const campusOptions = document.getElementById('campusOptions');
      const campusHint = document.getElementById('campusHint');
      const groupInput = document.getElementById('selectedGroupInput');
      const campusInput = document.getElementById('selectedCampusInput');
      const continueButton = document.getElementById('registerContinueButton');
      const registerCourseForm = document.getElementById('registerCourseForm');

      const state = {
        trackKey: '',
        programId: null,
        cohortId: null,
        campusKey: '',
        groupId: null,
        studyContextId: null,
        courseId: null,
        cohortConfirmed: false,
        campusConfirmed: false,
      };

      function escapeHtml(rawValue) {
        return String(rawValue || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function normalizeTrackKey(rawValue) {
        const normalized = String(rawValue || '').trim().toLowerCase();
        if (normalized === 'master') return 'master';
        if (normalized === 'teacher') return 'teacher';
        return 'bachelor';
      }

      function normalizeCampusKey(rawValue) {
        return String(rawValue || '').trim().toLowerCase() === 'munich' ? 'munich' : 'kyiv';
      }

      function isTeacherTrack(trackKey) {
        return normalizeTrackKey(trackKey) === 'teacher';
      }

      function formatTrackLabelClient(trackKey) {
        const normalized = normalizeTrackKey(trackKey);
        if (normalized === 'master') return currentLang === 'en' ? "Master's" : 'Магістратура';
        if (normalized === 'teacher') return currentLang === 'en' ? 'Teaching' : 'Викладацький';
        return currentLang === 'en' ? 'Bachelor' : 'Бакалаврат';
      }

      function formatCampusLabelClient(campusKey) {
        return normalizeCampusKey(campusKey) === 'munich'
          ? registerCourseText.campusMunich
          : registerCourseText.campusKyiv;
      }

      function getTrackOptions() {
        return Array.isArray(scopeMatrix.tracks) ? scopeMatrix.tracks : [];
      }

      function getTrackDiagnostic(trackKey) {
        return (trackDiagnostics && trackDiagnostics[normalizeTrackKey(trackKey)]) || null;
      }

      function getProgramsForTrack(trackKey) {
        return (Array.isArray(scopeMatrix.programs) ? scopeMatrix.programs : [])
          .filter((program) => normalizeTrackKey(program && program.track_key) === normalizeTrackKey(trackKey));
      }

      function getProgramById(programId) {
        return (Array.isArray(scopeMatrix.programs) ? scopeMatrix.programs : [])
          .find((program) => Number(program.id || 0) === Number(programId || 0)) || null;
      }

      function getCohortsForProgram(programId) {
        return (scopeMatrix && scopeMatrix.cohortsByProgram && scopeMatrix.cohortsByProgram[String(programId)]) || [];
      }

      function getCampusesForCohort(cohortId) {
        return (scopeMatrix && scopeMatrix.campusesByCohort && scopeMatrix.campusesByCohort[String(cohortId)]) || [];
      }

      function getTeacherCampusesForProgram(programId) {
        return (scopeMatrix && scopeMatrix.teacherCampusesByProgram && scopeMatrix.teacherCampusesByProgram[String(programId)]) || [];
      }

      function resolveTrackKey(preferredTrack) {
        const normalizedPreferred = normalizeTrackKey(preferredTrack);
        const trackRows = getTrackOptions();
        if (trackRows.some((track) => track && normalizeTrackKey(track.key) === normalizedPreferred)) {
          return normalizedPreferred;
        }
        return normalizeTrackKey((trackRows.find((track) => track && track.enabled) || trackRows[0] || {}).key || 'bachelor');
      }

      function resolveProgramId(trackKey, preferredProgramId) {
        const programs = getProgramsForTrack(trackKey);
        if (programs.some((program) => Number(program.id || 0) === Number(preferredProgramId || 0))) {
          return Number(preferredProgramId || 0);
        }
        return programs[0] ? Number(programs[0].id || 0) : null;
      }

      function formatProgramLabel(program) {
        if (!program) return '';
        return program.code ? `${program.name} (${program.code})` : String(program.name || '').trim();
      }

      function setHint(target, message, isError = false) {
        if (!(target instanceof HTMLElement)) return;
        target.textContent = message || '';
        target.classList.toggle('is-error', Boolean(isError));
      }

      function clearSelectionBelowProgram() {
        state.cohortId = null;
        state.campusKey = '';
        state.groupId = null;
        state.studyContextId = null;
        state.courseId = null;
        state.cohortConfirmed = false;
        state.campusConfirmed = false;
      }

      function clearCampusSelection() {
        state.campusKey = '';
        state.groupId = null;
        state.studyContextId = null;
        state.courseId = null;
        state.campusConfirmed = false;
      }

      function isSelectionComplete() {
        if (isTeacherTrack(state.trackKey)) {
          return Boolean(state.programId && state.campusConfirmed && state.groupId);
        }
        return Boolean(state.programId && state.cohortConfirmed && state.campusConfirmed && state.groupId);
      }

      function syncStepIndices() {
        const teacherMode = isTeacherTrack(state.trackKey);
        if (trackStepIndex) trackStepIndex.textContent = '1';
        if (programStepIndex) programStepIndex.textContent = '2';
        if (cohortStepIndex) cohortStepIndex.textContent = '3';
        if (campusStepIndex) {
          campusStepIndex.textContent = teacherMode ? '3' : '4';
        }
      }

      function syncTrackCards() {
        document.querySelectorAll('[data-track-card]').forEach((card) => {
          const trackKey = normalizeTrackKey(card.dataset.trackCard);
          const selected = trackKey === normalizeTrackKey(state.trackKey);
          card.classList.toggle('is-selected', selected);
          const input = card.querySelector('input[name="study_track"]');
          if (input) {
            input.checked = selected;
          }
        });
      }

      function renderProgramField() {
        const programs = getProgramsForTrack(state.trackKey);
        const diagnostic = getTrackDiagnostic(state.trackKey);
        if (!programSelect || !programField || !programStaticField) return;
        const resolvedProgramId = resolveProgramId(state.trackKey, state.programId);
        if (Number(resolvedProgramId || 0) !== Number(state.programId || 0)) {
          state.programId = resolvedProgramId;
          clearSelectionBelowProgram();
        }
        if (!programs.length) {
          programField.style.display = '';
          programStaticField.style.display = 'none';
          programSelect.innerHTML = '';
          setHint(programHint, (diagnostic && diagnostic.message) || registerCourseText.noPrograms, true);
          return;
        }
        if (programs.length === 1) {
          const onlyProgram = programs[0];
          programSelect.innerHTML = '';
          const option = document.createElement('option');
          option.value = String(onlyProgram.id || '');
          option.textContent = formatProgramLabel(onlyProgram);
          option.selected = true;
          programSelect.appendChild(option);
          programField.style.display = 'none';
          programStaticField.style.display = '';
          if (programStaticLabel) {
            programStaticLabel.textContent = formatProgramLabel(onlyProgram);
          }
          if (programStaticCopy) {
            programStaticCopy.textContent = registerCourseText.singleProgramCopy;
          }
          state.programId = Number(onlyProgram.id || 0);
          setHint(programHint, '');
          return;
        }
        programField.style.display = '';
        programStaticField.style.display = 'none';
        programSelect.innerHTML = '';
        programs.forEach((program) => {
          const option = document.createElement('option');
          option.value = String(program.id || '');
          option.textContent = formatProgramLabel(program);
          if (Number(program.id || 0) === Number(state.programId || 0)) {
            option.selected = true;
          }
          programSelect.appendChild(option);
        });
        setHint(programHint, '');
      }

      function createEmptyCard(title, copy) {
        const empty = document.createElement('div');
        empty.className = 'registration-empty';
        empty.innerHTML = `
          <div class="registration-empty-title">${escapeHtml(title)}</div>
          ${copy ? `<div class="registration-empty-copy">${escapeHtml(copy)}</div>` : ''}
        `;
        return empty;
      }

      function renderCohorts() {
        if (!(cohortSelect instanceof HTMLSelectElement) || !(cohortStep instanceof HTMLElement)) return;
        const teacherMode = isTeacherTrack(state.trackKey);
        cohortStep.style.display = teacherMode ? 'none' : '';
        cohortSelect.innerHTML = '';
        if (teacherMode) {
          cohortSelect.disabled = true;
          setHint(cohortHint, '');
          return;
        }
        const cohorts = getCohortsForProgram(state.programId);
        if (!state.programId) {
          const option = document.createElement('option');
          option.value = '';
          option.textContent = registerCourseText.chooseProgram;
          option.selected = true;
          cohortSelect.appendChild(option);
          cohortSelect.disabled = true;
          setHint(cohortHint, registerCourseText.chooseProgramFirst);
          clearSelectionBelowProgram();
          return;
        }
        if (!cohorts.length) {
          const option = document.createElement('option');
          option.value = '';
          option.textContent = registerCourseText.noCohorts;
          option.selected = true;
          cohortSelect.appendChild(option);
          cohortSelect.disabled = true;
          setHint(cohortHint, registerCourseText.noReadyCohorts, true);
          clearSelectionBelowProgram();
          return;
        }
        cohortSelect.disabled = false;
        const placeholderOption = document.createElement('option');
        placeholderOption.value = '';
        placeholderOption.textContent = registerCourseText.chooseCohortOption;
        placeholderOption.selected = !state.cohortConfirmed || !state.cohortId;
        cohortSelect.appendChild(placeholderOption);
        const hasSelectableCohort = cohorts.some((cohort) => cohort && (cohort.is_selectable || cohort.is_ready));
        if (!hasSelectableCohort) {
          setHint(cohortHint, registerCourseText.noReadyCohorts, true);
        } else if (!state.cohortConfirmed) {
          setHint(cohortHint, registerCourseText.chooseCohortFirst);
        } else {
          setHint(cohortHint, '');
        }
        cohorts.forEach((cohort) => {
          const option = document.createElement('option');
          const isSelectable = Boolean(cohort && (cohort.is_selectable || cohort.is_ready));
          const cohortLabel = Number(cohort.admission_year || 0) > 0
            ? String(Number(cohort.admission_year || 0))
            : (String(cohort.label || '').trim() || registerCourseText.admissionYearLabel);
          const statusLabel = cohort.status_label || (isSelectable ? registerCourseText.ready : registerCourseText.needsSetup);
          option.value = String(cohort.id || '');
          option.textContent = `${cohortLabel} · ${statusLabel}`;
          option.disabled = !isSelectable;
          option.selected = state.cohortConfirmed && Number(cohort.id || 0) === Number(state.cohortId || 0);
          cohortSelect.appendChild(option);
        });
      }

      function applyTeacherDefaultCampus(campusChoices) {
        if (!isTeacherTrack(state.trackKey) || state.campusConfirmed) {
          return false;
        }
        const selectableChoices = Array.isArray(campusChoices)
          ? campusChoices.filter((choice) => choice && choice.is_selectable)
          : [];
        if (!selectableChoices.length) {
          return false;
        }
        const preferredChoice = selectableChoices.find((choice) => normalizeCampusKey(choice.campus_key) === 'kyiv')
          || selectableChoices[0];
        state.campusKey = normalizeCampusKey(preferredChoice.campus_key);
        state.groupId = Number(preferredChoice.group_id || 0) || null;
        state.studyContextId = Number(preferredChoice.study_context_id || preferredChoice.group_id || 0) || null;
        state.courseId = Number(preferredChoice.course_id || 0) || null;
        state.campusConfirmed = true;
        return true;
      }

      function renderCampuses() {
        if (!(campusOptions instanceof HTMLElement)) return;
        const teacherMode = isTeacherTrack(state.trackKey);
        campusOptions.innerHTML = '';
        if (campusStepCopy) {
          campusStepCopy.textContent = teacherMode
            ? registerCourseText.stepCampusCopyTeacher
            : registerCourseText.stepCampusCopyStudent;
        }
        if (teacherMode) {
          if (!state.programId) {
            campusOptions.appendChild(createEmptyCard(registerCourseText.chooseProgram, registerCourseText.chooseProgramForCampusTeacher));
            setHint(campusHint, registerCourseText.chooseProgramForCampusTeacher);
            clearCampusSelection();
            return;
          }
        } else if (!state.cohortConfirmed || !state.cohortId) {
          setHint(campusHint, '');
          clearCampusSelection();
          return;
        }

        const campusChoices = teacherMode
          ? getTeacherCampusesForProgram(state.programId)
          : getCampusesForCohort(state.cohortId);

        if (!campusChoices.length) {
          campusOptions.appendChild(createEmptyCard(registerCourseText.noCampuses, registerCourseText.noReadyCampuses));
          setHint(campusHint, registerCourseText.noReadyCampuses, true);
          clearCampusSelection();
          return;
        }

        if (teacherMode) {
          applyTeacherDefaultCampus(campusChoices);
        }

        const hasSelectableCampus = campusChoices.some((choice) => choice && choice.is_selectable);
        if (!hasSelectableCampus) {
          setHint(campusHint, registerCourseText.noReadyCampuses, true);
        } else if (!state.campusConfirmed) {
          setHint(campusHint, registerCourseText.chooseCampus);
        } else {
          setHint(campusHint, '');
        }

        campusChoices.forEach((choice) => {
          const button = document.createElement('button');
          const isSelectable = Boolean(choice && choice.is_selectable);
          const isSelected = state.campusConfirmed
            && normalizeCampusKey(choice.campus_key) === normalizeCampusKey(state.campusKey)
            && Number(choice.group_id || 0) === Number(state.groupId || 0);
          const statusClass = isSelectable
            ? (choice.reason_tone === 'repair' ? 'repair' : 'ready')
            : (choice.reason_tone === 'blocked' ? 'blocked' : 'needs_setup');
          const statusLabel = choice.reason_short
            || (isSelectable ? registerCourseText.ready : registerCourseText.needsSetup);
          button.type = 'button';
          button.className = `scope-option scope-option--campus ${isSelected ? 'is-selected' : ''} ${isSelectable ? '' : 'is-disabled'}`;
          button.disabled = !isSelectable;
          button.innerHTML = `
            <div class="scope-option-head">
              <div class="scope-option-title">${escapeHtml(choice.campus_label || formatCampusLabelClient(choice.campus_key))}</div>
              <span class="scope-status scope-status--${escapeHtml(statusClass)}">${escapeHtml(statusLabel)}</span>
            </div>
            ${(choice.group_label || choice.reason_copy)
              ? `<div class="scope-option-foot"><div class="scope-option-meta">${
                choice.group_label ? `<span class="scope-pill">${escapeHtml(choice.group_label)}</span>` : ''
              }</div></div>`
              : ''}
          `;
          if (isSelectable) {
            button.addEventListener('click', () => {
              state.campusKey = normalizeCampusKey(choice.campus_key);
              state.groupId = Number(choice.group_id || 0) || null;
              state.studyContextId = Number(choice.study_context_id || choice.group_id || 0) || null;
              state.courseId = Number(choice.course_id || 0) || null;
              if (!teacherMode) {
                state.cohortId = Number(choice.cohort_id || state.cohortId || 0) || state.cohortId;
                state.cohortConfirmed = true;
              }
              state.campusConfirmed = true;
              renderAll();
            });
          }
          campusOptions.appendChild(button);
        });
      }

      function syncFormFields() {
        if (cohortSelect) {
          cohortSelect.value = !isTeacherTrack(state.trackKey) && state.cohortConfirmed
            ? String(state.cohortId || '')
            : '';
        }
        if (groupInput) {
          groupInput.value = state.campusConfirmed ? String(state.groupId || '') : '';
        }
        if (campusInput) {
          campusInput.value = state.campusConfirmed ? String(state.campusKey || '') : '';
        }
        if (programSelect && programField.style.display !== 'none') {
          programSelect.value = state.programId ? String(state.programId) : '';
        }
        if (continueButton) {
          continueButton.disabled = !isSelectionComplete();
        }
      }

      function renderAll() {
        syncStepIndices();
        syncTrackCards();
        renderProgramField();
        renderCohorts();
        renderCampuses();
        syncFormFields();
      }

      function hydrateInitialState() {
        const initial = scopeMatrix && scopeMatrix.initialSelection ? scopeMatrix.initialSelection : {};
        state.trackKey = resolveTrackKey(initial.trackKey || selectedTrackValue);
        state.programId = resolveProgramId(state.trackKey, initial.programId);
        if (initial && initial.campusConfirmed && Number(initial.groupId || 0) > 0) {
          state.cohortId = Number(initial.cohortId || 0) || null;
          state.campusKey = normalizeCampusKey(initial.campusKey);
          state.groupId = Number(initial.groupId || 0) || null;
          state.studyContextId = Number(initial.studyContextId || initial.groupId || 0) || null;
          state.courseId = Number(initial.courseId || 0) || null;
          state.campusConfirmed = true;
          state.cohortConfirmed = !isTeacherTrack(state.trackKey);
          if (isTeacherTrack(state.trackKey)) {
            state.cohortConfirmed = false;
          }
        }
      }

      trackInputs.forEach((input) => {
        input.addEventListener('change', () => {
          const nextTrackKey = resolveTrackKey(input.value);
          if (normalizeTrackKey(nextTrackKey) === normalizeTrackKey(state.trackKey)) {
            return;
          }
          state.trackKey = nextTrackKey;
          state.programId = resolveProgramId(state.trackKey, null);
          clearSelectionBelowProgram();
          renderAll();
        });
      });

      if (programSelect) {
        programSelect.addEventListener('change', () => {
          const nextProgramId = Number(programSelect.value || 0) || null;
          if (Number(nextProgramId || 0) === Number(state.programId || 0)) {
            return;
          }
          state.programId = nextProgramId;
          clearSelectionBelowProgram();
          renderAll();
        });
      }

      if (cohortSelect) {
        cohortSelect.addEventListener('change', () => {
          const nextCohortId = Number(cohortSelect.value || 0) || null;
          if (!nextCohortId) {
            state.cohortId = null;
            state.cohortConfirmed = false;
            clearCampusSelection();
            renderAll();
            return;
          }
          if (Number(nextCohortId || 0) === Number(state.cohortId || 0) && state.cohortConfirmed) {
            return;
          }
          state.cohortId = nextCohortId;
          state.cohortConfirmed = true;
          clearCampusSelection();
          renderAll();
        });
      }

      if (registerCourseForm) {
        registerCourseForm.addEventListener('submit', (event) => {
          if (!isSelectionComplete()) {
            event.preventDefault();
            setHint(
              campusHint,
              isTeacherTrack(state.trackKey) ? registerCourseText.continueLockedTeacher : registerCourseText.continueLockedStudent,
              true
            );
          }
        });
      }

      hydrateInitialState();
      renderAll();

      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggle.textContent = savedTheme === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      themeToggle.addEventListener('click', () => {
        const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
        document.body.classList.remove('theme-light', 'theme-dark');
        document.body.classList.add(next);
        localStorage.setItem('ui-theme', next);
        themeToggle.textContent = next === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      });
    </script>
    <script src="/js/design-system.js" defer></script>
    <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
