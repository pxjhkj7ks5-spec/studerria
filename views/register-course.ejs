      }
      body.theme-dark.page-register-course .track-option:hover,
      body.theme-dark.page-register-course .course-option:hover {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.07));
        box-shadow: 0 14px 28px rgba(8, 12, 28, 0.24);
      }
      body.theme-dark.page-register-course .track-option.is-selected,
      body.theme-dark.page-register-course .course-option.is-selected {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.24), rgba(139, 92, 246, 0.28));
        border-color: rgba(96, 165, 250, 0.72);
        box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
      }
      body.theme-dark.page-register-course .track-option.is-selected span,
      body.theme-dark.page-register-course .course-option.is-selected span {
        color: #ffffff;
      }
      body.theme-light.page-register-course .pathway-select {
        background: rgba(255, 255, 255, 0.76);
        border-color: rgba(148, 163, 184, 0.26);
        color: #0f172a;
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
      }
      body.theme-dark.page-register-course .pathway-select {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.08));
        border-color: rgba(191, 219, 254, 0.16);
        color: #f8fafc;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 12px 26px rgba(5, 8, 24, 0.18);
      }
      body.page-register-course .pathway-select option {
        color: #0f172a;
        background: #ffffff;
      }
      body.theme-dark.page-register-course .pathway-select option {
        color: #f8fafc;
        background: #1b2342;
      }
      body.page-register-course .register-action-btn {
        height: 46px;
        border-radius: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1rem;
      }
      body.page-register-course .btn-primary.register-action-btn {
        background: #3b82f6;
        border: 1px solid rgba(59, 130, 246, 0.6);
      }
      body.page-register-course .btn-outline-primary.register-action-btn {
        border-radius: 14px;
      }
      .theme-toggle-floating {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 10;
      }
      .theme-toggle-min {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.08);
        color: inherit;
        backdrop-filter: blur(10px);
      }
      body.theme-light .theme-toggle-min {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.7);
      }
      .btn {
        transition: transform 140ms ease, box-shadow 140ms ease;
      }
      .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.12);
      }
      body.theme-dark .btn:hover {
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.4);
      }
      .btn:active {
        transform: translateY(0);
        box-shadow: none;
      }
      .app-footer {
        font-size: 0.8rem;
      }
      body.theme-dark .app-footer {
