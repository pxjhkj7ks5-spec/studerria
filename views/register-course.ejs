      <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-light page-register-course">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <div class="theme-toggle-floating">
      <button
        class="theme-toggle-min"
        type="button"
        id="themeToggle"
        aria-label="Toggle theme"
        data-light-label="☀️"
        data-dark-label="🌙"
      >
        🌙
      </button>
    </div>
    <div class="container">
      <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-11 col-sm-8 col-md-6 col-lg-4">
          <div class="card auth-card glass">
            <div class="card-body p-4">
              <h1 class="h4 mb-3 text-center"><%= t('registerCourse.title') %></h1>
              <% if (error) { %>
              <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <form method="POST" action="/register/course">
                <div class="mb-3">
                  <span class="pathway-label">Track</span>
                  <div class="pathway-grid" id="trackGrid">
                    <% (pathways.tracks || []).forEach((track) => { %>
                      <label
                        class="track-option <%= track.enabled ? '' : 'is-disabled' %>"
                        data-track-card="<%= track.key %>"
                      >
                        <input
                          type="radio"
                          name="study_track"
                          value="<%= track.key %>"
                          <%= selectedTrackValue === track.key ? 'checked' : '' %>
                          <%= track.enabled ? '' : 'disabled' %>
                          required
                        />
                        <span><%= track.label %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>

                <div class="mb-3">
                  <label class="pathway-label" for="studyProgramSelect">Program</label>
                  <select
                    id="studyProgramSelect"
                    name="study_program_id"
                    class="form-select pathway-select"
                    data-selected-program="<%= selectedProgramValue || '' %>"
                  >
                    <option value="">Select program</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label class="pathway-label" for="admissionSelect">Admission year</label>
                  <select
                    id="admissionSelect"
                    name="admission_id"
                    class="form-select pathway-select"
                    data-selected-admission="<%= selectedAdmissionValue || '' %>"
                  >
                    <option value="">Select admission year</option>
                  </select>
                </div>

                <div class="d-grid gap-2 mb-3">
                  <% courses.forEach((course) => { %>
                    <label
                      class="course-option d-flex align-items-center"
                      data-course-card="<%= course.id %>"
                      data-course-teacher="<%= (course.is_teacher_course === true || Number(course.is_teacher_course) === 1) ? '1' : '0' %>"
                    >
                      <input
                        type="radio"
                        name="course_id"
                        value="<%= course.id %>"
                        <%= Number(selectedCourseId) === Number(course.id) ? 'checked' : '' %>
                        required
                      />
                      <span class="course-option-content">
                        <span class="course-option-title"><%= course.name %></span>
                        <span class="course-option-meta">
                          <span class="course-option-pill"><%= formatCampusLabel(course.location) %></span>
                          <% if (isTeacherCourse(course)) { %>
                            <span class="course-option-pill">Teacher</span>
                          <% } %>
                        </span>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <p class="pathway-hint mb-3">Programs and admission years define which courses and subjects are visible.</p>
                <button type="submit" class="btn btn-primary w-100"><%= t('registerCourse.continue') %></button>
                <a href="/register" class="btn btn-outline-secondary w-100 mt-2"><%= t('registerCourse.backToRegister') %></a>
              </form>
            </div>
          </div>
          <%- include('partials/app-footer') %>
        </div>
      </div>
    </div>
    <%- include('partials/changelog-modal') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const pathwayPayload = <%- JSON.stringify(pathways) %>;
      const pathwayPrograms = Array.isArray(pathwayPayload.programs) ? pathwayPayload.programs : [];
      const pathwayAdmissions = Array.isArray(pathwayPayload.admissions) ? pathwayPayload.admissions : [];
      const pathwayLinks = Array.isArray(pathwayPayload.links) ? pathwayPayload.links : [];

      const trackInputs = Array.from(document.querySelectorAll('input[name="study_track"]'));
      const programSelect = document.getElementById('studyProgramSelect');
      const admissionSelect = document.getElementById('admissionSelect');
      const courseCards = Array.from(document.querySelectorAll('[data-course-card]'));
      const selectedProgramSeed = Number(programSelect?.dataset.selectedProgram || 0);
      const selectedAdmissionSeed = Number(admissionSelect?.dataset.selectedAdmission || 0);

      const admissionToCourseSet = new Map();
      pathwayLinks.forEach((link) => {
        const admissionId = Number(link.admission_id || 0);
        const courseId = Number(link.course_id || 0);
        if (!admissionToCourseSet.has(admissionId)) {
          admissionToCourseSet.set(admissionId, new Set());
        }
        if (courseId > 0) {
          admissionToCourseSet.get(admissionId).add(courseId);
        }
      });

      function getSelectedTrack() {
        const checked = trackInputs.find((input) => input.checked);
        if (checked) return checked.value;
        const firstEnabled = trackInputs.find((input) => !input.disabled);
        if (firstEnabled) {
          firstEnabled.checked = true;
          return firstEnabled.value;
        }
        return 'bachelor';
      }

      function syncTrackCards() {
        document.querySelectorAll('[data-track-card]').forEach((card) => {
          const key = card.dataset.trackCard;
          const input = card.querySelector(`input[name="study_track"][value="${key}"]`);
          card.classList.toggle('is-selected', Boolean(input && input.checked));
          card.classList.toggle('is-disabled', Boolean(input && input.disabled));
        });
      }

      function setOptions(selectEl, options, selectedValue, emptyLabel) {
        if (!selectEl) return;
        selectEl.innerHTML = '';
        const emptyOption = document.createElement('option');
        emptyOption.value = '';
        emptyOption.textContent = emptyLabel;
        selectEl.appendChild(emptyOption);
        options.forEach((option) => {
          const node = document.createElement('option');
          node.value = String(option.value);
          node.textContent = option.label;
          if (String(selectedValue || '') === String(option.value)) {
            node.selected = true;
          }
          selectEl.appendChild(node);
        });
      }

      function refreshProgramOptions() {
        const trackKey = getSelectedTrack();
        const programIdsByTrack = new Set(
          pathwayPrograms
            .filter((program) => program.track_key === trackKey)
            .map((program) => Number(program.id))
        );
        const options = pathwayPrograms
          .filter((program) => programIdsByTrack.has(Number(program.id)))
          .map((program) => ({
            value: Number(program.id),
            label: program.code ? `${program.name} (${program.code})` : program.name,
          }));
        const currentValue = Number(programSelect?.value || selectedProgramSeed || 0);
        const resolvedValue = options.some((option) => Number(option.value) === currentValue)
          ? currentValue
          : (options[0] ? Number(options[0].value) : null);
        setOptions(programSelect, options, resolvedValue, 'Select program');
      }

      function refreshAdmissionOptions() {
        const programId = Number(programSelect?.value || 0);
        const options = pathwayAdmissions
          .filter((admission) => Number(admission.program_id) === programId)
          .map((admission) => ({
            value: Number(admission.id),
            label: admission.label
              ? `${admission.admission_year || ''} - ${admission.label}`.trim()
              : String(admission.admission_year || 'Admission'),
          }));
        const currentValue = Number(admissionSelect?.value || selectedAdmissionSeed || 0);
        const resolvedValue = options.some((option) => Number(option.value) === currentValue)
          ? currentValue
          : (options[0] ? Number(options[0].value) : null);
        setOptions(admissionSelect, options, resolvedValue, 'Select admission year');
      }

      function getTrackCourseFilter(trackKey) {
        if (trackKey === 'teacher') {
          return (courseCard) => courseCard.dataset.courseTeacher === '1';
        }
        return (courseCard) => courseCard.dataset.courseTeacher !== '1';
      }

      function refreshCourseOptions() {
        const trackKey = getSelectedTrack();
        const admissionId = Number(admissionSelect?.value || 0);
        const mappedCourses = admissionToCourseSet.get(admissionId);
        const trackFilter = getTrackCourseFilter(trackKey);
        let anyVisible = false;
        let firstVisibleInput = null;

        courseCards.forEach((card) => {
          const input = card.querySelector('input[type="radio"][name="course_id"]');
          if (!input) return;
          const courseId = Number(input.value || 0);
          const mappedVisible = mappedCourses ? mappedCourses.has(courseId) : true;
          const trackVisible = trackFilter(card);
          const visible = mappedVisible && trackVisible;
          card.style.display = visible ? '' : 'none';
          input.disabled = !visible;
          if (!visible && input.checked) {
            input.checked = false;
            card.classList.remove('is-selected');
          }
          if (visible) {
            anyVisible = true;
            if (!firstVisibleInput) firstVisibleInput = input;
          }
        });

        const checkedVisible = courseCards.some((card) => {
          const input = card.querySelector('input[type="radio"][name="course_id"]');
          return Boolean(input && !input.disabled && input.checked);
        });

        if (!checkedVisible && firstVisibleInput) {
          firstVisibleInput.checked = true;
        }
        if (!anyVisible) {
          courseCards.forEach((card) => card.classList.remove('is-selected'));
        }
        syncCourseCards();
      }

      function syncCourseCards() {
        courseCards.forEach((card) => {
          const input = card.querySelector('input[type="radio"][name="course_id"]');
          card.classList.toggle('is-selected', Boolean(input && input.checked));
        });
      }

      function refreshPathwaySelections() {
        syncTrackCards();
        refreshProgramOptions();
        refreshAdmissionOptions();
        refreshCourseOptions();
      }

      trackInputs.forEach((input) => {
        input.addEventListener('change', refreshPathwaySelections);
      });

      if (programSelect) {
        programSelect.addEventListener('change', () => {
          refreshAdmissionOptions();
          refreshCourseOptions();
        });
      }

      if (admissionSelect) {
        admissionSelect.addEventListener('change', refreshCourseOptions);
      }

      courseCards.forEach((card) => {
        card.addEventListener('click', () => {
          const input = card.querySelector('input[type="radio"][name="course_id"]');
          if (!input || input.disabled) return;
          courseCards.forEach((item) => item.classList.remove('is-selected'));
          input.checked = true;
          card.classList.add('is-selected');
        });
      });

      refreshPathwaySelections();

      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggle.textContent = savedTheme === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      themeToggle.addEventListener('click', () => {
        const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
        document.body.classList.remove('theme-light', 'theme-dark');
        document.body.classList.add(next);
        localStorage.setItem('ui-theme', next);
        themeToggle.textContent = next === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      });
    </script>
      <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
</html>
