</style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <link rel="stylesheet" href="/css/auth-actions.css" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-light page-register-course">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <div class="theme-toggle-floating">
      <button
        class="theme-toggle-min"
        type="button"
        id="themeToggle"
        aria-label="<%= registerCourseText.themeToggleAria %>"
        data-light-label="☀️"
        data-dark-label="🌙"
      >
        🌙
      </button>
    </div>
    <div class="container">
      <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-11 col-sm-8 col-md-6 col-lg-4">
          <div class="card auth-card glass">
            <div class="card-body p-4">
              <h1 class="h4 mb-3 text-center"><%= t('registerCourse.title') %></h1>
              <% if (error) { %>
              <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <form method="POST" action="/register/course">
                <div class="mb-3">
                  <span class="pathway-label"><%= registerCourseText.level %></span>
                  <div class="pathway-grid" id="trackGrid">
                    <% (pathways.tracks || []).forEach((track) => { %>
                      <label
                        class="track-option <%= track.enabled ? '' : 'is-disabled' %>"
                        data-track-card="<%= track.key %>"
                      >
                        <input
                          type="radio"
                          name="study_track"
                          value="<%= track.key %>"
                          <%= selectedTrackValue === track.key ? 'checked' : '' %>
                          <%= track.enabled ? '' : 'disabled' %>
                          required
                        />
                        <span><%= formatTrackLabel(track.key, track.label) %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>

                <div class="mb-3" id="programField">
                  <label class="pathway-label" for="studyProgramSelect"><%= registerCourseText.program %></label>
                  <select
                    id="studyProgramSelect"
                    name="program_id"
                    class="form-select pathway-select"
                    data-selected-program="<%= selectedProgramValue || '' %>"
                  >
                    <option value=""><%= registerCourseText.chooseProgram %></option>
                  </select>
                </div>
                <div class="mb-3" id="programStaticField" style="display: none;">
                  <span class="pathway-label"><%= registerCourseText.program %></span>
                  <div class="track-option is-selected">
                    <span id="programStaticLabel"></span>
                  </div>
                </div>

                <div class="mb-3" id="admissionField">
                  <label class="pathway-label"><%= registerCourseText.admissionYear %></label>
                  <input type="hidden" name="cohort_id" id="selectedAdmissionInput" value="<%= selectedAdmissionValue || '' %>" />
                  <div class="pathway-grid" id="admissionOptions"></div>
                </div>

                <div class="mb-3">
                  <label class="pathway-label"><%= registerCourseText.campus %></label>
                  <input type="hidden" data-legacy-field="course_id" id="selectedCourseIdInput" value="<%= Number(selectedCourseId || 0) || '' %>" />
                  <input type="hidden" name="group_id" id="selectedStudyContextInput" value="<%= selectedStudyContextValue || '' %>" />
                  <input type="hidden" name="campus" id="selectedCampusInput" value="<%= selectedCampusValue %>" />
                  <div class="pathway-grid" id="campusOptions"></div>
                </div>
                <p class="pathway-hint mb-3" id="campusHint"><%= selectedTrackValue === 'teacher' ? registerCourseText.campusReadyTeacherHint : registerCourseText.campusReadyStudentHint %></p>
                <div class="glass mb-3 p-3" id="academicContextSummaryCard">
                  <div class="small text-muted mb-1"><%= registerCourseText.academicGroupPreview %></div>
                  <div class="fw-semibold" id="academicContextSummary"><%= selectedTrackValue === 'teacher' ? registerCourseText.summaryDefaultTeacher : registerCourseText.summaryDefaultStudent %></div>
                </div>
                <div class="auth-action-stack auth-action-stack--grid">
                  <button type="submit" class="btn btn-primary register-action-btn auth-action-btn"><%= t('registerCourse.continue') %></button>
                  <a href="/register" class="btn btn-outline-primary register-action-btn auth-action-btn"><%= t('registerCourse.backToRegister') %></a>
                </div>
              </form>
            </div>
          </div>
          <%- include('partials/app-footer') %>
        </div>
      </div>
    </div>
    <%- include('partials/changelog-modal') %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const isEnglishRegisterCourse = <%- JSON.stringify(lang === 'en') %>;
      const registerCourseText = <%- JSON.stringify(registerCourseText) %>;
      const academicStudentGroupSummaryDefault = registerCourseText.summaryDefaultStudent;
      const academicTeacherGroupSummaryDefault = registerCourseText.summaryDefaultTeacher;
      registerCourseText.campusReadyStudentHint = isEnglishRegisterCourse
        ? 'The admission year defines the cohort. Choosing a campus automatically selects the academic group.'
        : '\u0420\u0456\u043a \u0432\u0441\u0442\u0443\u043f\u0443 \u0432\u0438\u0437\u043d\u0430\u0447\u0430\u0454 \u043a\u043e\u0433\u043e\u0440\u0442\u0443. \u0412\u0438\u0431\u0456\u0440 \u043a\u0430\u043c\u043f\u0443\u0441\u0443 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u043e\u0431\u0438\u0440\u0430\u0454 \u043f\u043e\u0442\u0440\u0456\u0431\u043d\u0443 \u0430\u043a\u0430\u0434\u0435\u043c\u0456\u0447\u043d\u0443 \u0433\u0440\u0443\u043f\u0443.';
      registerCourseText.readyToRegister = isEnglishRegisterCourse
        ? 'Ready: Studerria can resolve one stable academic group for this campus.'
        : '\u0413\u043e\u0442\u043e\u0432\u043e: Studerria \u043c\u043e\u0436\u0435 \u0432\u0438\u0437\u043d\u0430\u0447\u0438\u0442\u0438 \u043e\u0434\u043d\u0443 \u0441\u0442\u0430\u0431\u0456\u043b\u044c\u043d\u0443 \u0430\u043a\u0430\u0434\u0435\u043c\u0456\u0447\u043d\u0443 \u0433\u0440\u0443\u043f\u0443 \u0434\u043b\u044f \u0446\u044c\u043e\u0433\u043e \u043a\u0430\u043c\u043f\u0443\u0441\u0443.';
      registerCourseText.chooseValidCampus = isEnglishRegisterCourse
        ? 'Choose a valid campus before continuing, otherwise Studerria cannot resolve the correct academic group.'
        : '\u041e\u0431\u0435\u0440\u0456\u0442\u044c \u043a\u043e\u0440\u0435\u043a\u0442\u043d\u0438\u0439 \u043a\u0430\u043c\u043f\u0443\u0441 \u043f\u0435\u0440\u0435\u0434 \u043f\u0440\u043e\u0434\u043e\u0432\u0436\u0435\u043d\u043d\u044f\u043c, \u0456\u043d\u0430\u043a\u0448\u0435 Studerria \u043d\u0435 \u0432\u0438\u0437\u043d\u0430\u0447\u0438\u0442\u044c \u043f\u043e\u0442\u0440\u0456\u0431\u043d\u0443 \u0430\u043a\u0430\u0434\u0435\u043c\u0456\u0447\u043d\u0443 \u0433\u0440\u0443\u043f\u0443.';
      const pathwayPayload = <%- JSON.stringify(pathways) %>;
      const pathwayPrograms = Array.isArray(pathwayPayload.programs) ? pathwayPayload.programs : [];
      const pathwayAdmissions = Array.isArray(pathwayPayload.admissions) ? pathwayPayload.admissions : [];
      const pathwayLinks = Array.isArray(pathwayPayload.links) ? pathwayPayload.links : [];
      const pathwayCourses = Array.isArray(pathwayPayload.courses) ? pathwayPayload.courses : [];
      const registrationContextPayload = <%- JSON.stringify(registrationContexts) %>;
      const registrationAuditIssuesPayload = <%- JSON.stringify(registrationAuditIssues || []) %>;
      const programById = new Map(pathwayPrograms.map((program) => [Number(program.id || 0), program]));
      const admissionById = new Map(pathwayAdmissions.map((admission) => [Number(admission.id || 0), admission]));
      const academicContextSummaryEl = document.getElementById('academicContextSummary');
      const trackInputs = Array.from(document.querySelectorAll('input[name="study_track"]'));
      const programSelect = document.getElementById('studyProgramSelect');
      const programField = document.getElementById('programField');
      const programStaticField = document.getElementById('programStaticField');
      const programStaticLabel = document.getElementById('programStaticLabel');
      const admissionField = document.getElementById('admissionField');
      const admissionInput = document.getElementById('selectedAdmissionInput');
      const admissionOptions = document.getElementById('admissionOptions');
      const courseIdInput = document.getElementById('selectedCourseIdInput');
      const studyContextInput = document.getElementById('selectedStudyContextInput');
      const campusInput = document.getElementById('selectedCampusInput');
      const campusOptions = document.getElementById('campusOptions');
      const campusHint = document.getElementById('campusHint');
      const registerCourseForm = document.querySelector('form[action="/register/course"]');
      const selectedProgramSeed = Number(programSelect?.dataset.selectedProgram || 0);
      const selectedAdmissionSeed = Number(admissionInput?.value || 0);
      const selectedCourseSeed = Number(courseIdInput?.value || 0);
      const selectedStudyContextSeed = Number(studyContextInput?.value || 0);
      const selectedCampusSeed = String(campusInput?.value || '').trim().toLowerCase();
      const courseById = new Map(
        pathwayCourses.map((course) => [Number(course.id || 0), course])
      );
      const contextById = new Map(
        (Array.isArray(registrationContextPayload) ? registrationContextPayload : []).map((context) => [Number(context.id || 0), context])
      );

      function formatLinkedCourseCount(count) {
        return Number(count || 0) === 1
          ? registerCourseText.oneLinkedCourse
          : `${count} ${registerCourseText.linkedCoursesSuffix}`;
      }

      function getSelectedTrack() {
        const checked = trackInputs.find((input) => input.checked);
        if (checked) return checked.value;
        const firstEnabled = trackInputs.find((input) => !input.disabled);
        if (firstEnabled) {
          firstEnabled.checked = true;
          return firstEnabled.value;
        }
        return 'bachelor';
      }

      function isTeacherCourseClient(course) {
        return Boolean(course) && (
          course.is_teacher_course === true
          || Number(course.is_teacher_course) === 1
        );
      }

      function normalizeCampusKey(rawValue) {
        return String(rawValue || '').trim().toLowerCase() === 'munich' ? 'munich' : 'kyiv';
      }

      function formatCampusLabelClient(location) {
        return normalizeCampusKey(location) === 'munich'
          ? registerCourseText.campusMunich
          : registerCourseText.campusKyiv;
      }

      function formatTrackLabelClient(trackKey) {
        const normalized = String(trackKey || '').trim().toLowerCase();
        if (normalized === 'bachelor') return registerCourseText.trackBachelor;
        if (normalized === 'master') return registerCourseText.trackMaster;
        if (normalized === 'teacher') return registerCourseText.trackTeacher;
        return trackKey || normalized;
      }

      function localizeAdmissionLabel(rawLabel) {
        const normalized = String(rawLabel || '').trim();
        if (isEnglishRegisterCourse) return normalized;
        return normalized
          .replace(/^Cohort\b/i, 'Когорта')
          .replace(/\bCohort\b/gi, 'Когорта');
      }

      function isTeacherTrack(trackKey) {
        return String(trackKey || '').trim().toLowerCase() === 'teacher';
      }

      function localizeAdmissionLabel(rawLabel) {
        const normalized = String(rawLabel || '').trim();
        if (isEnglishRegisterCourse) return normalized;
        return normalized
          .replace(/^Cohort\b/i, 'Когорта')
          .replace(/\bCohort\b/gi, 'Когорта');
      }

      function getCampusReadyHint(trackKey) {
        return isTeacherTrack(trackKey)
          ? registerCourseText.campusReadyTeacherHint
          : registerCourseText.campusReadyStudentHint;
      }

      function getAcademicSummaryDefault(trackKey) {
        return isTeacherTrack(trackKey)
          ? academicTeacherGroupSummaryDefault
          : academicStudentGroupSummaryDefault;
      }

      function updateAcademicContextSummary() {
        if (!academicContextSummaryEl) return;
        const trackKey = getSelectedTrack();
        const programId = Number(programSelect?.value || selectedProgramSeed || 0);
        const admissionId = Number(admissionInput?.value || selectedAdmissionSeed || 0);
        const studyContextId = Number(studyContextInput?.value || 0);
        const courseId = Number(courseIdInput?.value || 0);
        const program = programById.get(programId);
        const admission = admissionById.get(admissionId);
        const studyContext = contextById.get(studyContextId);
        const course = courseById.get(courseId);
        const parts = [];
        const isTeacher = isTeacherTrack(trackKey);
        parts.push(formatTrackLabelClient(trackKey));
        if (program) {
          parts.push(program.code ? `${program.name} (${program.code})` : program.name);
        }
        if (!isTeacher && admission) {
          parts.push(isEnglishRegisterCourse ? `Cohort ${admission.admission_year}` : `Когорта ${admission.admission_year}`);
        }
        if (studyContext) {
          const studyContextLabel = String(studyContext.label_uk || studyContext.label || '').trim();
          if (isTeacher) {
            parts.push(formatCampusLabelClient(studyContext.campus_key || campusInput?.value));
            if (studyContextLabel) {
              parts.push(studyContextLabel);
            }
          } else {
            parts.push(studyContextLabel || `${formatCampusLabelClient(studyContext.campus_key)} / Year ${Number(studyContext.stage || studyContext.stage_number || 1)}`);
          }
        } else if (course) {
          parts.push(`${course.name || 'Course'} / ${formatCampusLabelClient(course.location)}`);
        } else if (isTeacher && campusInput?.value) {
          parts.push(formatCampusLabelClient(campusInput.value));
        }
        academicContextSummaryEl.textContent = parts.filter(Boolean).join(' / ') || getAcademicSummaryDefault(trackKey);
      }

      function syncTrackCards() {
        document.querySelectorAll('[data-track-card]').forEach((card) => {
          const key = card.dataset.trackCard;
          const input = card.querySelector(`input[name="study_track"][value="${key}"]`);
          card.classList.toggle('is-selected', Boolean(input && input.checked));
          card.classList.toggle('is-disabled', Boolean(input && input.disabled));
        });
      }

      function setOptions(selectEl, options, selectedValue, emptyLabel) {
        if (!selectEl) return;
        selectEl.innerHTML = '';
        const emptyOption = document.createElement('option');
        emptyOption.value = '';
        emptyOption.textContent = emptyLabel;
        selectEl.appendChild(emptyOption);
        options.forEach((option) => {
          const node = document.createElement('option');
          node.value = String(option.value);
          node.textContent = option.label;
          if (String(selectedValue || '') === String(option.value)) {
            node.selected = true;
          }
          selectEl.appendChild(node);
        });
      }

      function refreshProgramOptions() {
        const trackKey = getSelectedTrack();
        const options = pathwayPrograms
          .filter((program) => program.track_key === trackKey)
          .map((program) => ({
            value: Number(program.id),
            label: program.code ? `${program.name} (${program.code})` : program.name,
          }));
        const currentValue = Number(programSelect?.value || selectedProgramSeed || 0);
        const resolvedValue = options.some((option) => Number(option.value) === currentValue)
          ? currentValue
          : (options[0] ? Number(options[0].value) : null);
        setOptions(programSelect, options, resolvedValue, registerCourseText.chooseProgram);
        if (programField && programStaticField && programStaticLabel) {
          if (options.length === 1) {
            programField.style.display = 'none';
            programStaticField.style.display = '';
            programStaticLabel.textContent = options[0].label;
          } else {
            programField.style.display = '';
            programStaticField.style.display = 'none';
            programStaticLabel.textContent = '';
          }
        }
      }

      function refreshAdmissionOptions() {
        const trackKey = getSelectedTrack();
        const programId = Number(programSelect?.value || 0);
        if (admissionField) {
          admissionField.style.display = isTeacherTrack(trackKey) ? 'none' : '';
        }
        if (isTeacherTrack(trackKey)) {
          if (admissionInput) {
            admissionInput.value = '';
          }
          if (admissionOptions) {
            admissionOptions.innerHTML = '';
          }
          return;
        }
        const options = pathwayAdmissions
          .filter((admission) => Number(admission.program_id) === programId)
          .map((admission) => ({
            value: Number(admission.id),
            title: String(admission.admission_year || registerCourseText.admissionYear),
            subtitle: localizeAdmissionLabel(admission.label),
          }));
        const currentValue = Number(admissionInput?.value || selectedAdmissionSeed || 0);
        const resolvedValue = options.some((option) => Number(option.value) === currentValue)
          ? currentValue
          : (options[0] ? Number(options[0].value) : null);
        if (admissionInput) {
          admissionInput.value = resolvedValue ? String(resolvedValue) : '';
        }
        if (!admissionOptions) return;
        admissionOptions.innerHTML = '';
        if (!programId) {
          const emptyState = document.createElement('div');
          emptyState.className = 'track-option admission-option is-disabled';
          emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.chooseProgramFirstTitle}</span><span class="course-option-subtitle">${registerCourseText.chooseProgramFirstSubtitle}</span></span>`;
          admissionOptions.appendChild(emptyState);
          return;
        }
        if (!options.length) {
          const emptyState = document.createElement('div');
          emptyState.className = 'track-option admission-option is-disabled';
          emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.noAdmissionYearsTitle}</span><span class="course-option-subtitle">${registerCourseText.noAdmissionYearsSubtitle}</span></span>`;
          admissionOptions.appendChild(emptyState);
          return;
        }

        options.forEach((option) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'course-option admission-option';
          if (Number(option.value) === Number(resolvedValue)) {
            button.classList.add('is-selected');
          }
          button.innerHTML = `
            <span class="course-option-content">
              <span class="course-option-title">${option.title}</span>
              ${option.subtitle ? `<span class="course-option-subtitle">${option.subtitle}</span>` : ''}
            </span>
          `;
          button.addEventListener('click', () => {
            admissionOptions.querySelectorAll('.admission-option').forEach((item) => item.classList.remove('is-selected'));
            button.classList.add('is-selected');
            if (admissionInput) {
              admissionInput.value = String(option.value);
            }
            renderCampusOptions();
          });
          admissionOptions.appendChild(button);
        });
      }

      function getAdmissionCourses(admissionId, trackKey) {
        const targetAdmissionId = Number(admissionId || 0);
        if (!targetAdmissionId) return [];
        const courseIds = [];
        pathwayLinks.forEach((link) => {
          const linkAdmissionId = Number(link.admission_id || 0);
          const courseId = Number(link.course_id || 0);
          if (linkAdmissionId !== targetAdmissionId || !courseId) return;
          if (!courseById.has(courseId)) return;
          if (!courseIds.includes(courseId)) {
            courseIds.push(courseId);
          }
        });

        return courseIds
          .map((courseId) => courseById.get(courseId))
          .filter((course) => {
            const teacherCourse = isTeacherCourseClient(course);
            return trackKey === 'teacher' ? teacherCourse : !teacherCourse;
          });
      }

      function getRegistrationContextsForAdmission(admissionId, programId, trackKey) {
        const targetAdmissionId = Number(admissionId || 0);
        const targetProgramId = Number(programId || 0);
        const normalizedTrack = String(trackKey || '').trim().toLowerCase();
        if (!targetAdmissionId || !targetProgramId) return [];
        return (Array.isArray(registrationContextPayload) ? registrationContextPayload : []).filter((context) => {
          const contextStage = Number(context.stage || context.stage_number || 0);
          const contextTrack = String(context.track_key || context.track || '').trim().toLowerCase();
          return Number(context.admission_id || 0) === targetAdmissionId
            && Number(context.program_id || 0) === targetProgramId
            && contextTrack === normalizedTrack
            && contextStage === 1;
        });
      }

      function getTeacherRegistrationContexts(programId) {
        const targetProgramId = Number(programId || 0);
        if (!targetProgramId) return [];
        return (Array.isArray(registrationContextPayload) ? registrationContextPayload : []).filter((context) => {
          const contextStage = Number(context.stage || context.stage_number || 0);
          const contextTrack = String(context.track_key || context.track || '').trim().toLowerCase();
          return Number(context.program_id || 0) === targetProgramId
            && contextTrack === 'teacher'
            && contextStage === 1;
        });
      }

      function getTeacherCampusIssuePriority(issueCode) {
        switch (String(issueCode || '').trim()) {
          case 'registration_teacher_multiple_defaults':
            return 40;
          case 'registration_teacher_default_required':
            return 30;
          case 'registration_group_missing_compat_bridge':
            return 20;
          case 'registration_group_missing_visible_subjects':
            return 10;
          default:
            return 0;
        }
      }

      function getTeacherCampusIssueCopy(issueCode) {
        switch (String(issueCode || '').trim()) {
          case 'registration_teacher_multiple_defaults':
            return {
              title: registerCourseText.teacherMultipleDefaultsTitle,
              subtitle: registerCourseText.teacherMultipleDefaultsSubtitle,
              hint: registerCourseText.teacherMultipleDefaultsHint,
            };
          case 'registration_teacher_default_required':
            return {
              title: registerCourseText.teacherDefaultRequiredTitle,
              subtitle: registerCourseText.teacherDefaultRequiredSubtitle,
              hint: registerCourseText.teacherDefaultRequiredHint,
            };
          default:
            return {
              title: registerCourseText.noTeacherPathTitle,
              subtitle: registerCourseText.noTeacherPathSubtitle,
              hint: registerCourseText.teacherPathRequiredHint,
            };
        }
      }

      function getTeacherRegistrationIssues(programId) {
        const targetProgramId = Number(programId || 0);
        if (!targetProgramId) return [];
        return (Array.isArray(registrationAuditIssuesPayload) ? registrationAuditIssuesPayload : []).filter((issue) => {
          const issueTrack = String(issue && issue.track_key || '').trim().toLowerCase();
          const issueStage = Number(issue && issue.stage_number || 0);
          return Number(issue && issue.program_id || 0) === targetProgramId
            && issueTrack === 'teacher'
            && issueStage === 1;
        });
      }

      function buildStudentCampusChoices(admissionId, programId, trackKey) {
        const contextRows = getRegistrationContextsForAdmission(admissionId, programId, trackKey);
        if (contextRows.length) {
          const campusMap = new Map();
          contextRows.forEach((context) => {
            const campusKey = normalizeCampusKey(context.campus_key || context.course_location || context.location);
            if (!campusMap.has(campusKey)) {
              campusMap.set(campusKey, {
                campusKey,
                campusLabel: formatCampusLabelClient(campusKey),
                contexts: [],
              });
            }
            campusMap.get(campusKey).contexts.push(context);
          });

          return ['kyiv', 'munich']
            .map((campusKey) => campusMap.get(campusKey))
            .filter(Boolean)
            .map((entry) => {
              const uniqueContexts = Array.from(new Map(
                (Array.isArray(entry.contexts) ? entry.contexts : [])
                  .map((context) => [Number(context && context.id || 0), context])
                  .filter(([contextId]) => contextId > 0)
              ).values());
              const chosenContext = uniqueContexts.length === 1 ? uniqueContexts[0] : null;
              return {
                campusKey: entry.campusKey,
                campusLabel: entry.campusLabel,
                courseCount: uniqueContexts.length,
                courseId: chosenContext ? (Number(chosenContext.course_id || 0) || null) : null,
                studyContextId: chosenContext ? (Number(chosenContext.id || 0) || null) : null,
                isAmbiguous: uniqueContexts.length !== 1,
              };
            });
        }

        const campusMap = new Map();
        getAdmissionCourses(admissionId, trackKey).forEach((course) => {
          const courseId = Number(course.id || 0);
          if (!courseId) return;
          const campusKey = normalizeCampusKey(course.location);
          if (!campusMap.has(campusKey)) {
            campusMap.set(campusKey, {
              campusKey,
              campusLabel: formatCampusLabelClient(campusKey),
              courseIds: [],
            });
          }
          campusMap.get(campusKey).courseIds.push(courseId);
        });

        return ['kyiv', 'munich']
          .map((campusKey) => campusMap.get(campusKey))
          .filter(Boolean)
          .map((entry) => {
            const uniqueIds = Array.from(new Set(entry.courseIds));
            return {
              campusKey: entry.campusKey,
              campusLabel: entry.campusLabel,
              courseCount: uniqueIds.length,
              courseId: uniqueIds.length === 1 ? uniqueIds[0] : null,
              studyContextId: null,
              isAmbiguous: uniqueIds.length !== 1,
            };
          });
      }

      function buildTeacherCampusChoices(programId) {
        const readyContexts = getTeacherRegistrationContexts(programId);
        const readyByCampus = new Map();
        readyContexts.forEach((context) => {
          const campusKey = normalizeCampusKey(context.campus_key || context.course_location || context.location);
          if (!readyByCampus.has(campusKey)) {
            readyByCampus.set(campusKey, {
              campusKey,
              campusLabel: formatCampusLabelClient(campusKey),
              contexts: [],
            });
          }
          readyByCampus.get(campusKey).contexts.push(context);
        });

        const issueByCampus = new Map();
        getTeacherRegistrationIssues(programId).forEach((issue) => {
          const campusKey = normalizeCampusKey(issue && issue.campus_key);
          const currentIssue = issueByCampus.get(campusKey);
          if (!currentIssue || getTeacherCampusIssuePriority(issue.issue_code) > getTeacherCampusIssuePriority(currentIssue.issue_code)) {
            issueByCampus.set(campusKey, issue);
          }
        });

        const campusKeys = Array.from(new Set([
          ...Array.from(readyByCampus.keys()),
          ...Array.from(issueByCampus.keys()),
        ])).sort((left, right) => {
          if (left === right) return 0;
          if (left === 'kyiv') return -1;
          if (right === 'kyiv') return 1;
          return String(left || '').localeCompare(String(right || ''));
        });

        return campusKeys.map((campusKey) => {
          const readyBucket = readyByCampus.get(campusKey);
          const issue = issueByCampus.get(campusKey) || null;
          if (readyBucket) {
            const uniqueContexts = Array.from(new Map(
              (Array.isArray(readyBucket.contexts) ? readyBucket.contexts : [])
                .map((context) => [Number(context && context.id || 0), context])
                .filter(([contextId]) => contextId > 0)
            ).values());
            const blockingIssueCode = issue
              && (
                String(issue.issue_code || '') === 'registration_teacher_multiple_defaults'
                || String(issue.issue_code || '') === 'registration_teacher_default_required'
              )
              ? String(issue.issue_code || '')
              : '';
            const defaultContexts = uniqueContexts.filter((context) => (
              context
              && (context.is_teacher_registration_default === true || Number(context.is_teacher_registration_default) === 1)
            ));
            let chosenContext = null;
            let resolvedIssueCode = blockingIssueCode;
            if (!resolvedIssueCode) {
              if (defaultContexts.length === 1) {
                chosenContext = defaultContexts[0];
              } else if (defaultContexts.length > 1) {
                resolvedIssueCode = 'registration_teacher_multiple_defaults';
              } else if (uniqueContexts.length === 1) {
                chosenContext = uniqueContexts[0];
              } else if (uniqueContexts.length > 1) {
                resolvedIssueCode = 'registration_teacher_default_required';
              }
            }
            if (resolvedIssueCode || !chosenContext) {
              const issueCopy = getTeacherCampusIssueCopy(resolvedIssueCode || 'registration_teacher_default_required');
              return {
                campusKey,
                campusLabel: readyBucket.campusLabel,
                courseCount: uniqueContexts.length,
                courseId: null,
                studyContextId: null,
                cohortId: null,
                groupLabel: '',
                isAmbiguous: true,
                issueCode: resolvedIssueCode || 'registration_teacher_default_required',
                issueTitle: issueCopy.title,
                issueSubtitle: issueCopy.subtitle,
                issueHint: issueCopy.hint,
              };
            }
            return {
              campusKey,
              campusLabel: readyBucket.campusLabel,
              courseCount: uniqueContexts.length,
              courseId: Number(chosenContext.course_id || 0) || null,
              studyContextId: Number(chosenContext.id || 0) || null,
              cohortId: Number(chosenContext.admission_id || 0) || null,
              groupLabel: String(chosenContext.label_uk || chosenContext.label || '').trim(),
              isAmbiguous: false,
              issueCode: '',
              issueTitle: '',
              issueSubtitle: '',
              issueHint: '',
            };
          }

          const issueCopy = getTeacherCampusIssueCopy(issue && issue.issue_code);
          return {
            campusKey,
            campusLabel: formatCampusLabelClient(campusKey),
            courseCount: Array.isArray(issue && issue.duplicate_group_ids) ? issue.duplicate_group_ids.length : 0,
            courseId: null,
            studyContextId: null,
            cohortId: null,
            groupLabel: '',
            isAmbiguous: true,
            issueCode: issue ? String(issue.issue_code || '') : 'registration_teacher_missing_path',
            issueTitle: issueCopy.title,
            issueSubtitle: issueCopy.subtitle,
            issueHint: issueCopy.hint,
          };
        });
      }

      function buildCampusChoices(admissionId, programId, trackKey) {
        if (isTeacherTrack(trackKey)) {
          return buildTeacherCampusChoices(programId);
        }
        return buildStudentCampusChoices(admissionId, programId, trackKey);
      }

      function getCampusChoiceSubtitle(choice, trackKey) {
        if (choice && choice.isAmbiguous) {
          if (isTeacherTrack(trackKey)) {
            return choice.issueSubtitle || registerCourseText.noTeacherPathSubtitle;
          }
          return `${formatLinkedCourseCount(choice.courseCount)}. ${registerCourseText.oneVisibleCourseNeeded}`;
        }
        if (isTeacherTrack(trackKey)) {
          return choice && choice.groupLabel
            ? `${choice.groupLabel}. ${registerCourseText.readyTeacherToRegister}`
            : registerCourseText.readyTeacherToRegister;
        }
        return `${formatLinkedCourseCount(choice && choice.courseCount)}. ${registerCourseText.readyToRegister}`;
      }

      function getCampusChoiceHint(choice, trackKey) {
        if (choice && choice.isAmbiguous) {
          if (isTeacherTrack(trackKey)) {
            return choice.issueHint || registerCourseText.teacherPathRequiredHint;
          }
          return registerCourseText.ambiguousCampusHint;
        }
        return getCampusReadyHint(trackKey);
      }

      function setCampusHint(message, isError = false) {
        if (!campusHint) return;
        campusHint.textContent = message;
        campusHint.style.color = isError ? '#dc2626' : '';
      }

      function renderCampusOptions() {
        if (!campusOptions || !courseIdInput || !campusInput) return;
        const trackKey = getSelectedTrack();
        const programId = Number(programSelect?.value || 0);
        const admissionId = Number(admissionInput?.value || 0);
        const campusChoices = buildCampusChoices(admissionId, programId, trackKey);
        const preferredCourse = courseById.get(selectedCourseSeed);
        const preferredCampus = selectedCampusSeed || (preferredCourse ? normalizeCampusKey(preferredCourse.location) : '');
        const activeCourseId = Number(courseIdInput.value || 0);
        const activeStudyContextId = Number(studyContextInput?.value || 0);
        const activeCampusKey = String(campusInput.value || preferredCampus || '').trim().toLowerCase();
        const isTeacher = isTeacherTrack(trackKey);

        campusOptions.innerHTML = '';
        courseIdInput.value = '';
        if (studyContextInput) {
          studyContextInput.value = '';
        }
        campusInput.value = '';
        if (isTeacher && admissionInput) {
          admissionInput.value = '';
        }

        if (isTeacher && !programId) {
          const emptyState = document.createElement('div');
          emptyState.className = 'track-option campus-option is-disabled';
          emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.chooseProgramFirstTitle}</span><span class="course-option-subtitle">${registerCourseText.chooseProgramFirstTeacherSubtitle}</span></span>`;
          campusOptions.appendChild(emptyState);
          setCampusHint(registerCourseText.chooseProgramFirstTeacherSubtitle, true);
          return;
        }

        if (!isTeacher && !admissionId) {
          const emptyState = document.createElement('div');
          emptyState.className = 'track-option campus-option is-disabled';
          if (!programId) {
            emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.chooseProgramFirstTitle}</span><span class="course-option-subtitle">${registerCourseText.chooseProgramFirstSubtitle}</span></span>`;
          } else {
            emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.noAvailableAdmissionTitle}</span><span class="course-option-subtitle">${registerCourseText.noAvailableAdmissionSubtitle}</span></span>`;
          }
          campusOptions.appendChild(emptyState);
          setCampusHint(getCampusReadyHint(trackKey));
          return;
        }

        if (!campusChoices.length) {
          const emptyState = document.createElement('div');
          emptyState.className = 'track-option campus-option is-disabled';
          emptyState.innerHTML = `<span class="course-option-content"><span class="course-option-title">${registerCourseText.noCampusesTitle}</span><span class="course-option-subtitle">${isTeacher ? registerCourseText.noCampusesTeacherSubtitle : registerCourseText.noCampusesStudentSubtitle}</span></span>`;
          campusOptions.appendChild(emptyState);
          setCampusHint(
            isTeacher
              ? registerCourseText.noCampusesTeacherHint
              : registerCourseText.noCampusesStudentHint,
            true
          );
          return;
        }

        let selectedChoice = campusChoices.find((choice) => Number(choice.studyContextId || 0) === activeStudyContextId)
          || campusChoices.find((choice) => choice.courseId === activeCourseId)
          || null;
        if (!selectedChoice && activeCampusKey) {
          selectedChoice = campusChoices.find((choice) => choice.campusKey === activeCampusKey && !choice.isAmbiguous) || null;
        }
        if (!selectedChoice && preferredCampus) {
          selectedChoice = campusChoices.find((choice) => choice.campusKey === preferredCampus && !choice.isAmbiguous) || null;
        }
        if (!selectedChoice) {
          selectedChoice = campusChoices.find((choice) => !choice.isAmbiguous) || null;
        }

        campusChoices.forEach((choice) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = `track-option campus-option ${choice.isAmbiguous ? 'is-disabled' : ''}`;
          if (selectedChoice && selectedChoice.campusKey === choice.campusKey && !choice.isAmbiguous) {
            button.classList.add('is-selected');
            courseIdInput.value = String(choice.courseId || '');
            if (studyContextInput) {
              studyContextInput.value = String(choice.studyContextId || '');
            }
            if (isTeacher && admissionInput) {
              admissionInput.value = String(choice.cohortId || '');
            }
            campusInput.value = choice.campusKey;
          }

          const subtitle = getCampusChoiceSubtitle(choice, trackKey);
          button.innerHTML = `
            <span class="course-option-content">
              <span class="course-option-title">${choice.campusLabel}</span>
              <span class="course-option-subtitle">${subtitle}</span>
            </span>
          `;

          if (!choice.isAmbiguous) {
            button.addEventListener('click', () => {
              campusOptions.querySelectorAll('.campus-option').forEach((item) => item.classList.remove('is-selected'));
              button.classList.add('is-selected');
              courseIdInput.value = String(choice.courseId || '');
              if (studyContextInput) {
                studyContextInput.value = String(choice.studyContextId || '');
              }
              if (isTeacher && admissionInput) {
                admissionInput.value = String(choice.cohortId || '');
              }
              campusInput.value = choice.campusKey;
              setCampusHint(getCampusReadyHint(trackKey));
            });
          }

          campusOptions.appendChild(button);
        });

        if (!campusInput.value || (studyContextInput && !studyContextInput.value)) {
          const issueChoice = campusChoices.find((choice) => choice.isAmbiguous) || null;
          setCampusHint(getCampusChoiceHint(issueChoice, trackKey), true);
        } else {
          setCampusHint(getCampusReadyHint(trackKey));
        }
        updateAcademicContextSummary();
      }

      function refreshPathwaySelections() {
        syncTrackCards();
        refreshProgramOptions();
        refreshAdmissionOptions();
        renderCampusOptions();
        updateAcademicContextSummary();
      }

      trackInputs.forEach((input) => {
        input.addEventListener('change', refreshPathwaySelections);
      });

      if (programSelect) {
        programSelect.addEventListener('change', () => {
          refreshAdmissionOptions();
          renderCampusOptions();
          updateAcademicContextSummary();
        });
      }

      if (registerCourseForm) {
        registerCourseForm.addEventListener('submit', (event) => {
          if ((studyContextInput && !studyContextInput.value) || (campusInput && !campusInput.value)) {
            event.preventDefault();
            setCampusHint(registerCourseText.chooseValidCampus, true);
          }
        });
      }

      updateAcademicContextSummary();

      refreshPathwaySelections();

      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggle.textContent = savedTheme === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      themeToggle.addEventListener('click', () => {
        const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
        document.body.classList.remove('theme-light', 'theme-dark');
        document.body.classList.add(next);
        localStorage.setItem('ui-theme', next);
        themeToggle.textContent = next === 'theme-dark' ? themeToggle.dataset.lightLabel : themeToggle.dataset.darkLabel;
      });
    </script>
      <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
