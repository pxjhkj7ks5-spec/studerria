<%
  const selectedCourseValue = Number(selectedCourseId || 0);
  const selectedSubjectValue = selectedSubject ? Number(selectedSubject.subject_id || 0) : 0;
  const selectedGroupValue = Number(selectedGroupNumber || 0);
  const selectedStudentValue = Number(selectedStudentId || 0);
  const periodValue = period || 'semester';
  const scopeValue = scopeType || 'subject';
  const isAllCoursesScope = scopeValue === 'all-courses';
  const isCourseAggregateScope = scopeValue === 'course' || isAllCoursesScope || scopeValue === 'student-course';
  const scopeCourseCountValue = Number(scopeCourseCount || 0);
  const exportQuery = new URLSearchParams();
  if (selectedCourseValue) exportQuery.set('course_id', String(selectedCourseValue));
  if (selectedSubjectValue) exportQuery.set('subject_id', String(selectedSubjectValue));
  if (scopeValue) exportQuery.set('scope_type', scopeValue);
  if (selectedGroupValue) exportQuery.set('group_number', String(selectedGroupValue));
  if (selectedStudentValue) exportQuery.set('student_id', String(selectedStudentValue));
  if (periodValue) exportQuery.set('period', periodValue);
  const exportCsvHref = `/journal/insights/export.csv${exportQuery.toString() ? `?${exportQuery.toString()}` : ''}`;
  const periodPresetPropsJson = JSON.stringify({
    formSelector: '#journalInsightsFiltersForm',
    selectSelector: '#insightsPeriod',
    options: (periodOptions || []).map((item) => ({
      key: String(item.key || ''),
      label: String(item.label || item.key || ''),
    })),
    active: periodValue,
    submitOnPick: true,
  }).replace(/'/g, '&#39;');
  const scopeLabelValue = scopeLabel || t('journalInsights.scope');
  const workflow = (workflowLinks && typeof workflowLinks === 'object') ? workflowLinks : {};
  const journalReturnContext = (typeof returnJournalContext === 'object' && returnJournalContext) ? returnJournalContext : {};
  const backToJournalHref = workflow.journalHref || `/journal${selectedSubjectValue ? `?subject_id=${selectedSubjectValue}` : ''}`;
  const scheduleHref = workflow.scheduleHref || '/schedule';
  const returnSubjectValue = Number(journalReturnContext.subjectId || 0);
  const returnAttendanceDateValue = String(journalReturnContext.attendanceDate || '').trim();
  const returnAttendanceClassValue = Number(journalReturnContext.attendanceClassNumber || 0);
  const returnAttendanceQuickValue = Number(journalReturnContext.attendanceQuick || 0) === 1 ? 1 : 0;
  const gradeTrend = (trends && Array.isArray(trends.grade)) ? trends.grade : [];
  const attendanceTrend = (trends && Array.isArray(trends.attendance)) ? trends.attendance : [];
  const gradeMax = Math.max(100, ...gradeTrend.map((item) => Number(item.avg_score_percent || 0)));
  const rankingRows = Array.isArray(rankingTop) ? rankingTop : [];
  const selectedSubjectHasStorage = Boolean(selectedJournalHasStorageBinding);
  const showNoStorageNotice = Boolean(!isCourseAggregateScope && selectedSubject && !selectedSubjectHasStorage);
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title><%= t('journalInsights.pageTitle') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <style>
      :root {
        --insights-border-dark: rgba(255, 255, 255, 0.14);
        --insights-border-light: rgba(15, 23, 42, 0.12);
        --insights-bg-dark: rgba(255, 255, 255, 0.06);
        --insights-bg-light: rgba(255, 255, 255, 0.74);
      }
      body {
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
      }
      body.theme-dark {
        background:
          radial-gradient(1200px 740px at 10% 6%, rgba(56, 189, 248, 0.18), transparent 64%),
          radial-gradient(1000px 700px at 84% 20%, rgba(99, 102, 241, 0.18), transparent 62%),
          linear-gradient(150deg, #071024 0%, #101a33 52%, #14253f 100%);
        color: #f8fafc;
      }
      body.theme-light {
        background:
          radial-gradient(1200px 740px at 12% 8%, rgba(186, 230, 253, 0.55), transparent 64%),
          radial-gradient(1000px 700px at 84% 20%, rgba(221, 214, 254, 0.56), transparent 62%),
          linear-gradient(126deg, #e8eff9 0%, #eef5ff 52%, #f6f9ff 100%);
        color: #0f172a;
      }
      .shell {
        padding-top: 24px;
        padding-bottom: 48px;
      }
      .glass {
        border-radius: 22px;
        backdrop-filter: blur(18px);
      }
      body.theme-dark .glass {
        border: 1px solid var(--insights-border-dark);
        background: var(--insights-bg-dark);
        box-shadow: 0 18px 46px rgba(2, 6, 23, 0.5);
      }
      body.theme-light .glass {
        border: 1px solid var(--insights-border-light);
        background: var(--insights-bg-light);
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
      }
      .hero {
        position: relative;
        overflow: hidden;
        padding: 28px;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(520px 220px at 0% 0%, rgba(125, 211, 252, 0.12), transparent 65%),
          radial-gradient(420px 260px at 100% 100%, rgba(167, 139, 250, 0.14), transparent 68%);
        pointer-events: none;
      }
      .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
        gap: 18px;
        align-items: start;
      }
      .hero-main {
        min-width: 0;
      }
      .hero-side {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }
      .hero-title {
        margin: 0;
        font-size: clamp(2.1rem, 3.3vw, 3.1rem);
        line-height: 0.98;
        letter-spacing: -0.04em;
        font-weight: 760;
      }
      .hero-subtitle {
        margin-top: 10px;
        max-width: 760px;
        font-size: 1rem;
        line-height: 1.62;
        color: rgba(226, 232, 240, 0.82);
      }
      body.theme-light .hero-subtitle {
        color: rgba(15, 23, 42, 0.62);
      }
      .hero-stat {
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(8, 15, 34, 0.34);
        padding: 14px 15px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      }
      body.theme-light .hero-stat {
        background: rgba(255, 255, 255, 0.68);
        border-color: rgba(15, 23, 42, 0.1);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
      }
      .hero-stat-label {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(226, 232, 240, 0.54);
      }
      body.theme-light .hero-stat-label {
        color: rgba(15, 23, 42, 0.46);
      }
      .hero-stat-value {
        margin-top: 8px;
        font-size: 1.5rem;
        font-weight: 720;
        line-height: 1.05;
      }
      .hero-stat-meta {
        margin-top: 4px;
        font-size: 0.82rem;
        color: rgba(226, 232, 240, 0.66);
      }
      body.theme-light .hero-stat-meta {
        color: rgba(15, 23, 42, 0.56);
      }
      .chip-row {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .chip {
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.32);
        background: rgba(15, 23, 42, 0.3);
        padding: 5px 12px;
        font-size: 0.82rem;
      }
      body.theme-light .chip {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.88);
      }
      .section {
        padding: 20px;
      }
      .section-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
      }
      .section-title {
        margin: 0;
        font-size: 1.08rem;
        font-weight: 650;
      }
      .section-subtitle {
        margin: 5px 0 0;
        font-size: 0.9rem;
        line-height: 1.5;
        color: rgba(226, 232, 240, 0.68);
      }
      body.theme-light .section-subtitle {
        color: rgba(15, 23, 42, 0.54);
      }
      .soft-panel {
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.26);
        padding: 14px;
      }
      body.theme-light .soft-panel {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.88);
      }
      .compact-select,
      .compact-input {
        min-height: 40px;
        border-radius: 11px;
        border: 1px solid rgba(148, 163, 184, 0.34);
      }
      body.theme-dark .compact-select,
      body.theme-dark .compact-input {
        background: rgba(255, 255, 255, 0.06);
        color: #f8fafc;
        border-color: rgba(148, 163, 184, 0.28);
      }
      body.theme-light .compact-select,
      body.theme-light .compact-input {
        background: rgba(255, 255, 255, 0.92);
      }
      .summary-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      }
      .summary-card {
        position: relative;
        overflow: hidden;
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.28);
        padding: 12px;
      }
      .summary-card::before {
        content: '';
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, rgba(125, 211, 252, 0.5), rgba(167, 139, 250, 0.2), transparent 90%);
      }
      body.theme-light .summary-card {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.9);
      }
      .summary-label {
        font-size: 0.78rem;
        color: rgba(203, 213, 225, 0.74);
      }
      body.theme-light .summary-label {
        color: rgba(15, 23, 42, 0.6);
      }
      .summary-value {
        margin-top: 4px;
        font-size: 1.42rem;
        font-weight: 700;
      }
      .table-shell {
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 14px;
        overflow: hidden;
        background: rgba(8, 15, 34, 0.24);
      }
      body.theme-light .table-shell {
        border-color: rgba(15, 23, 42, 0.1);
        background: rgba(255, 255, 255, 0.86);
      }
      .table-shell .table {
        margin-bottom: 0;
        --bs-table-bg: transparent;
        --bs-table-accent-bg: transparent;
        --bs-table-color: inherit;
        --bs-table-border-color: rgba(148, 163, 184, 0.16);
        color: inherit;
      }
      body.theme-light .table-shell .table {
        --bs-table-border-color: rgba(15, 23, 42, 0.08);
      }
      .insights-table thead th {
        padding: 0.9rem 1rem;
        font-size: 0.76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(226, 232, 240, 0.6);
        background: rgba(255, 255, 255, 0.04);
        border-bottom-width: 1px;
      }
      body.theme-light .insights-table thead th {
        color: rgba(15, 23, 42, 0.56);
        background: rgba(248, 250, 252, 0.92);
      }
      .insights-table tbody td {
        padding: 0.88rem 1rem;
        vertical-align: middle;
        background: transparent;
      }
      .insights-table tbody tr:nth-child(odd) td {
        background: rgba(255, 255, 255, 0.028);
      }
      body.theme-light .insights-table tbody tr:nth-child(odd) td {
        background: rgba(248, 250, 252, 0.72);
      }
      .insights-table tbody tr:hover td {
        background: rgba(99, 102, 241, 0.12);
      }
      body.theme-light .insights-table tbody tr:hover td {
        background: rgba(99, 102, 241, 0.08);
      }
      .empty-state {
        padding: 18px;
        color: rgba(226, 232, 240, 0.66);
      }
      body.theme-light .empty-state {
        color: rgba(15, 23, 42, 0.58);
      }
      .trend-grid {
        display: grid;
        gap: 8px;
      }
      .trend-row {
        display: grid;
        grid-template-columns: 120px 1fr auto;
        gap: 10px;
        align-items: center;
      }
      .trend-label {
        font-size: 0.82rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .trend-bar-track {
        border-radius: 999px;
        height: 10px;
        background: rgba(148, 163, 184, 0.24);
        overflow: hidden;
      }
      .trend-bar {
        height: 10px;
        width: var(--w, 0%);
        border-radius: 999px;
        background: linear-gradient(90deg, #38bdf8 0%, #818cf8 100%);
      }
      .trend-value {
        font-weight: 600;
        font-size: 0.82rem;
      }
      .filters-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 4px;
      }
      .publish-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        margin-bottom: 12px;
      }
      .publish-card {
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.22);
        padding: 14px;
      }
      body.theme-light .publish-card {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.9);
      }
      .publish-card__eyebrow {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(226, 232, 240, 0.56);
      }
      body.theme-light .publish-card__eyebrow {
        color: rgba(15, 23, 42, 0.48);
      }
      .publish-card__title {
        margin-top: 8px;
        font-size: 1.02rem;
        font-weight: 680;
      }
      .publish-card__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }
      .publish-card__note {
        margin: 10px 0 0;
        font-size: 0.88rem;
        line-height: 1.55;
        color: rgba(226, 232, 240, 0.72);
      }
      body.theme-light .publish-card__note {
        color: rgba(15, 23, 42, 0.58);
      }
      .publish-card__ranking {
        margin: 12px 0 0;
        padding-left: 1.05rem;
      }
      .publish-card__ranking li {
        margin-bottom: 0.28rem;
        font-size: 0.88rem;
      }
      .ranking-position {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        height: 34px;
        border-radius: 999px;
        font-weight: 700;
        background: rgba(59, 130, 246, 0.16);
        color: #bfdbfe;
      }
      body.theme-light .ranking-position {
        color: #1d4ed8;
        background: rgba(59, 130, 246, 0.12);
      }
      .ranking-name {
        font-weight: 650;
      }
      .ranking-subtext {
        display: block;
        margin-top: 2px;
        font-size: 0.78rem;
        color: rgba(226, 232, 240, 0.6);
      }
      body.theme-light .ranking-subtext {
        color: rgba(15, 23, 42, 0.54);
      }
      .insights-table tbody tr.ranking-row-top td {
        background: rgba(56, 189, 248, 0.12);
      }
      body.theme-light .insights-table tbody tr.ranking-row-top td {
        background: rgba(56, 189, 248, 0.08);
      }
      @media (max-width: 991px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 640px) {
        .hero {
          padding: 22px 20px;
        }
        .hero-side {
          grid-template-columns: 1fr;
        }
        .section-head {
          flex-direction: column;
        }
      }
    </style>
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/pages/journal-insights.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-journal-insights page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', { role, username, t, activePage: 'journal-insights', pageTitle: t('journalInsights.title'), settings: settings }) %>
    <%- include('partials/desktop-menu-drawer', { role, t, activePage: 'journal-insights', settings: settings }) %>

    <main class="container shell">
      <% if (error) { %>
        <div class="alert alert-danger glass mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success glass mb-3"><%= success %></div>
      <% } %>

      <section class="glass hero mb-3">
        <div class="hero-grid">
          <div class="hero-main">
            <h1 class="hero-title"><%= t('journalInsights.title') %></h1>
            <p class="hero-subtitle">
              <%= t('journalInsights.subtitle') %>
            </p>
            <div class="chip-row">
              <span class="chip"><%= scopeLabelValue %></span>
              <span class="chip"><%= t('journalInsights.period') %>: <%= periodLabel %></span>
              <span class="chip"><%= t('journalInsights.participants') %>: <%= Number(summary && summary.participants_count ? summary.participants_count : 0) %></span>
              <% if (isAllCoursesScope && scopeCourseCountValue > 0) { %>
                <span class="chip"><%= t('journalInsights.courses') %>: <%= scopeCourseCountValue %></span>
              <% } %>
              <% if (selectedSemester && selectedSemester.title) { %>
                <span class="chip"><%= selectedSemester.title %></span>
              <% } %>
            </div>
          </div>
          <div class="hero-side">
            <div class="hero-stat">
              <div class="hero-stat-label"><%= t('journalInsights.stat.average') %></div>
              <div class="hero-stat-value"><%= Number(summary && summary.average_score ? summary.average_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
              <div class="hero-stat-meta"><%= t('journalInsights.stat.median') %> <%= Number(summary && summary.median_score ? summary.median_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
            </div>
            <div class="hero-stat">
              <div class="hero-stat-label"><%= t('journalInsights.stat.attendanceReliability') %></div>
              <div class="hero-stat-value"><%= Number(summary && summary.attendance_reliability ? summary.attendance_reliability : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
              <div class="hero-stat-meta"><%= t('journalInsights.stat.absenceShare') %> <%= Number(summary && summary.attendance_absent_share ? summary.attendance_absent_share : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
            </div>
            <div class="hero-stat">
              <div class="hero-stat-label"><%= t('journalInsights.stat.atRisk') %></div>
              <div class="hero-stat-value"><%= Number(summary && summary.at_risk_count ? summary.at_risk_count : 0) %></div>
              <div class="hero-stat-meta"><%= t('journalInsights.stat.excellent') %> <%= Number(summary && summary.excellent_count ? summary.excellent_count : 0) %></div>
            </div>
            <div class="hero-stat">
              <div class="hero-stat-label"><%= t('journalInsights.stat.momentum') %></div>
              <div class="hero-stat-value"><%= Number(summary && summary.momentum_score ? summary.momentum_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
              <div class="hero-stat-meta"><%= t('journalInsights.stat.trendDelta') %> <%= Number(summary && summary.grade_delta ? summary.grade_delta : 0).toFixed(2).replace(/\.00$/, '') %></div>
            </div>
          </div>
        </div>
      </section>

      <section class="glass section mb-3">
        <div class="section-head">
          <div>
            <h2 class="section-title"><%= t('journalInsights.filtersTitle') %></h2>
            <p class="section-subtitle"><%= t('journalInsights.filtersSubtitle') %></p>
          </div>
        </div>
        <form id="journalInsightsFiltersForm" method="GET" action="/journal/insights" class="row g-2 mt-1">
          <input type="hidden" name="return_subject_id" value="<%= returnSubjectValue || '' %>" />
          <input type="hidden" name="return_attendance_date" value="<%= returnAttendanceDateValue %>" />
          <input type="hidden" name="return_attendance_class_number" value="<%= returnAttendanceClassValue || '' %>" />
          <input type="hidden" name="return_attendance_quick" value="<%= returnAttendanceQuickValue %>" />
          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsCourse"><%= t('journalInsights.course') %></label>
            <select id="insightsCourse" class="form-select compact-select" name="course_id" <%= isAllCoursesScope ? 'disabled' : '' %>>
              <% (courseOptions || []).forEach((course) => { %>
                <option value="<%= course.course_id %>" <%= Number(course.course_id) === selectedCourseValue ? 'selected' : '' %>><%= course.course_name %></option>
              <% }) %>
            </select>
            <% if (isAllCoursesScope) { %>
              <input type="hidden" name="course_id" value="<%= selectedCourseValue || '' %>" />
            <% } %>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsScope"><%= t('journalInsights.scope') %></label>
            <select id="insightsScope" class="form-select compact-select" name="scope_type">
              <% (scopeOptions || []).forEach((scope) => { %>
                <option value="<%= scope.key %>" <%= scope.key === scopeValue ? 'selected' : '' %>><%= scope.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsPeriod"><%= t('journalInsights.period') %></label>
            <select id="insightsPeriod" class="form-select compact-select" name="period">
              <% (periodOptions || []).forEach((item) => { %>
                <option value="<%= item.key %>" <%= item.key === periodValue ? 'selected' : '' %>><%= item.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-3 align-self-end d-grid">
            <button class="btn btn-primary" type="submit"><%= t('journalInsights.apply') %></button>
          </div>

          <div class="col-12">
            <span
              data-react-island="insights-period-preset"
              data-island-props='<%- periodPresetPropsJson %>'
            ></span>
          </div>

          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsSubject"><%= t('journalInsights.subject') %></label>
            <select id="insightsSubject" class="form-select compact-select" name="subject_id" <%= isCourseAggregateScope ? 'disabled' : '' %>>
              <% if (!(subjectOptions || []).length) { %>
                <option value=""><%= t('journalInsights.noSubjectAccess') %></option>
              <% } else { %>
                <% (subjectOptions || []).filter((subject) => Number(subject.course_id) === selectedCourseValue).forEach((subject) => { %>
                  <option value="<%= subject.subject_id %>" <%= Number(subject.subject_id) === selectedSubjectValue ? 'selected' : '' %>>
                    <%= subject.subject_name %> - <%= subject.group_label %>
                  </option>
                <% }) %>
              <% } %>
            </select>
            <% if (isCourseAggregateScope) { %>
              <input type="hidden" name="subject_id" value="<%= selectedSubjectValue %>" />
            <% } %>
          </div>

          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsGroup"><%= t('journalInsights.group') %></label>
            <select id="insightsGroup" class="form-select compact-select" name="group_number" <%= scopeValue === 'group' ? '' : 'disabled' %>>
              <option value=""><%= t('journalInsights.allGroups') %></option>
              <% (groupOptions || []).forEach((groupNumber) => { %>
                <option value="<%= groupNumber %>" <%= Number(groupNumber) === selectedGroupValue ? 'selected' : '' %>>
                  Group <%= groupNumber %>
                </option>
              <% }) %>
            </select>
            <% if (scopeValue !== 'group') { %>
              <input type="hidden" name="group_number" value="<%= selectedGroupValue || '' %>" />
            <% } %>
          </div>

          <div class="col-12 col-md-3">
            <label class="form-label small" for="insightsStudent"><%= t('journalInsights.student') %></label>
            <select id="insightsStudent" class="form-select compact-select" name="student_id" <%= (scopeValue === 'student' || scopeValue === 'student-course') ? '' : 'disabled' %>>
              <option value=""><%= t('journalInsights.selectStudent') %></option>
              <% (studentOptions || []).forEach((student) => { %>
                <option value="<%= student.id %>" <%= Number(student.id) === selectedStudentValue ? 'selected' : '' %>>
                  <%= student.full_name %> - <%= t('journalInsights.group') %> <%= Number(student.group_number || 0) %>
                </option>
              <% }) %>
            </select>
            <% if (scopeValue !== 'student' && scopeValue !== 'student-course') { %>
              <input type="hidden" name="student_id" value="<%= selectedStudentValue || '' %>" />
            <% } %>
          </div>

          <div class="col-12 filters-actions">
            <a class="btn btn-outline-primary" href="<%= exportCsvHref %>"><%= t('journalInsights.exportCsv') %></a>
            <a class="btn btn-outline-secondary" href="<%= backToJournalHref %>"><%= t('journalInsights.backToJournal') %></a>
          </div>
        </form>
      </section>

      <% if (showNoStorageNotice) { %>
        <section class="glass section mb-3">
          <div class="soft-panel">
            <div class="summary-label"><%= lang === 'en' ? 'Storage status' : 'Статус storage' %></div>
            <div class="summary-value fs-5"><%= lang === 'en' ? 'Insights are waiting for journal storage binding' : 'Інсайти очікують на прив’язку journal storage' %></div>
            <p class="section-subtitle mb-3">
              <%= lang === 'en'
                ? 'This subject exists in Academic V2, but analytics become available only after journal storage is linked.'
                : 'Цей предмет уже є в Academic V2, але аналітика доступна лише після прив’язки до journal storage.' %>
            </p>
            <div class="d-flex flex-wrap gap-2">
              <a class="btn btn-outline-secondary" href="<%= backToJournalHref %>"><%= t('journalInsights.backToJournal') %></a>
              <a class="btn btn-outline-secondary" href="<%= scheduleHref %>"><%= lang === 'en' ? 'Open schedule' : 'До розкладу' %></a>
            </div>
          </div>
        </section>
      <% } else { %>

      <section class="glass section mb-3">
        <div class="section-head">
          <div>
            <h2 class="section-title"><%= t('journalInsights.summaryTitle') %></h2>
            <p class="section-subtitle"><%= t('journalInsights.summarySubtitle') %></p>
          </div>
        </div>
        <div class="summary-grid mt-2">
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.averageScore') %></div>
            <div class="summary-value"><%= Number(summary && summary.average_score ? summary.average_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.median') %></div>
            <div class="summary-value"><%= Number(summary && summary.median_score ? summary.median_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.topScore') %></div>
            <div class="summary-value"><%= Number(summary && summary.top_score ? summary.top_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.atRisk') %></div>
            <div class="summary-value"><%= Number(summary && summary.at_risk_count ? summary.at_risk_count : 0) %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.excellent') %></div>
            <div class="summary-value"><%= Number(summary && summary.excellent_count ? summary.excellent_count : 0) %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.gradeTrendDelta') %></div>
            <div class="summary-value"><%= Number(summary && summary.grade_delta ? summary.grade_delta : 0).toFixed(2).replace(/\.00$/, '') %></div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.attendanceAbsentShare') %></div>
            <div class="summary-value"><%= Number(summary && summary.attendance_absent_share ? summary.attendance_absent_share : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.attendanceLateShare') %></div>
            <div class="summary-value"><%= Number(summary && summary.attendance_late_share ? summary.attendance_late_share : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.riskRate') %></div>
            <div class="summary-value"><%= Number(summary && summary.risk_rate ? summary.risk_rate : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.excellenceRate') %></div>
            <div class="summary-value"><%= Number(summary && summary.excellence_rate ? summary.excellence_rate : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.scoreConsistency') %></div>
            <div class="summary-value"><%= Number(summary && summary.score_consistency ? summary.score_consistency : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.attendanceReliability') %></div>
            <div class="summary-value"><%= Number(summary && summary.attendance_reliability ? summary.attendance_reliability : 0).toFixed(2).replace(/\.00$/, '') %>%</div>
          </div>
          <div class="summary-card">
            <div class="summary-label"><%= t('journalInsights.summary.momentumScore') %></div>
            <div class="summary-value"><%= Number(summary && summary.momentum_score ? summary.momentum_score : 0).toFixed(2).replace(/\.00$/, '') %></div>
          </div>
        </div>
      </section>

      <section class="row g-3 mb-3">
        <div class="col-12">
          <article class="glass section h-100">
            <div class="section-head">
              <div>
                <h2 class="section-title"><%= t('journalInsights.rankingTitle') %></h2>
                <p class="section-subtitle"><%= t('journalInsights.rankingSubtitle') %></p>
              </div>
            </div>
            <div class="table-shell mt-2">
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 insights-table">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th><%= t('journalInsights.table.student') %></th>
                      <th><%= t('journalInsights.table.group') %></th>
                      <th><%= t('journalInsights.table.score') %></th>
                      <th><%= t('journalInsights.table.subjects') %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!rankingRows.length) { %>
                      <tr>
                        <td colspan="5" class="empty-state"><%= t('journalInsights.empty.ranking') %></td>
                      </tr>
                    <% } %>
                    <% rankingRows.forEach((row) => { %>
                      <tr class="<%= Number(row.rank || 0) <= 3 ? 'ranking-row-top' : '' %>">
                        <td><span class="ranking-position"><%= row.rank %></span></td>
                        <td>
                          <span class="ranking-name"><%= row.full_name %></span>
                          <span class="ranking-subtext">
                            <%= lang === 'en' ? 'Group' : 'Група' %> <%= Number(row.group_number || 0) || '-' %>
                            · <%= Number(row.subjects_count || 1) %> <%= t('journalInsights.table.subjects').toLowerCase() %>
                          </span>
                        </td>
                        <td><%= Number(row.group_number || 0) || '-' %></td>
                        <td><strong><%= Number(row.final_score || 0).toFixed(2).replace(/\.00$/, '') %></strong></td>
                        <td><%= Number(row.subjects_count || 1) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-6">
          <article class="glass section h-100">
            <div class="section-head">
              <div>
                <h2 class="section-title"><%= t('journalInsights.gradeTrendTitle') %></h2>
                <p class="section-subtitle"><%= t('journalInsights.gradeTrendSubtitle') %></p>
              </div>
            </div>
            <div class="trend-grid mt-2">
              <% if (!gradeTrend.length) { %>
                <div class="empty-state"><%= t('journalInsights.empty.gradeTrend') %></div>
              <% } %>
              <% gradeTrend.forEach((item) => { %>
                <% const value = Number(item.avg_score_percent || 0); %>
                <div class="trend-row">
                  <div class="trend-label"><%= item.bucket %></div>
                  <div class="trend-bar-track">
                    <div class="trend-bar" style="--w: <%= Math.max(0, Math.min(100, (value / gradeMax) * 100)) %>%"></div>
                  </div>
                  <div class="trend-value"><%= value.toFixed(2).replace(/\.00$/, '') %>%</div>
                </div>
              <% }) %>
            </div>
          </article>
        </div>
        <div class="col-12 col-xl-6">
          <article class="glass section h-100">
            <div class="section-head">
              <div>
                <h2 class="section-title"><%= t('journalInsights.attendanceTrendTitle') %></h2>
                <p class="section-subtitle"><%= t('journalInsights.attendanceTrendSubtitle') %></p>
              </div>
            </div>
            <div class="trend-grid mt-2">
              <% if (!attendanceTrend.length) { %>
                <div class="empty-state"><%= t('journalInsights.empty.attendanceTrend') %></div>
              <% } %>
              <% attendanceTrend.forEach((item) => { %>
                <% const total = Number(item.total_count || 0); %>
                <% const absentShare = total > 0 ? (Number(item.absent_count || 0) / total) * 100 : 0; %>
                <div class="trend-row">
                  <div class="trend-label"><%= item.bucket %></div>
                  <div class="trend-bar-track">
                    <div class="trend-bar" style="--w: <%= Math.max(0, Math.min(100, absentShare)) %>%"></div>
                  </div>
                  <div class="trend-value"><%= absentShare.toFixed(2).replace(/\.00$/, '') %>% <%= t('journalInsights.trend.absent') %></div>
                </div>
              <% }) %>
            </div>
          </article>
        </div>
      </section>
      <% } %>

      <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/changelog-modal') %>
    <%- include('partials/mobile-menu-modal', { role, t, activePage: 'journal-insights', settings: settings }) %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script src="/js/design-system.js" defer></script>
    <script>
      (function initThemeToggles() {
        function applyStandaloneTheme(rawTheme) {
          const theme = rawTheme === 'theme-light' || rawTheme === 'light' ? 'light' : 'dark';
          const storedTheme = theme === 'light' ? 'theme-light' : 'theme-dark';
          document.documentElement.setAttribute('data-theme', theme);
          document.body.setAttribute('data-theme', theme);
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(storedTheme);
          localStorage.setItem('ui-theme', storedTheme);
          return storedTheme;
        }

        const themeToggles = document.querySelectorAll('.theme-toggle');
        const activeTheme = applyStandaloneTheme(localStorage.getItem('ui-theme') || 'theme-dark');

        themeToggles.forEach((btn) => {
          btn.textContent = activeTheme === 'theme-dark' ? btn.dataset.lightLabel : btn.dataset.darkLabel;
          btn.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
            const nextStoredTheme = applyStandaloneTheme(next);
            themeToggles.forEach((toggle) => {
              toggle.textContent = nextStoredTheme === 'theme-dark' ? toggle.dataset.lightLabel : toggle.dataset.darkLabel;
            });
          });
        });
      })();
    </script>
      <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
