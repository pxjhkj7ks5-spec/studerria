<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title>Studerria</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/pages/my-day.css" />    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-dark page-my-day page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%
      const cockpit = myDay || {};
      const brief = cockpit.brief || {};
      const briefReasons = Array.isArray(brief.reasons) ? brief.reasons : [];
      const deadlineItems = Array.isArray(cockpit.deadline_focus) ? cockpit.deadline_focus : [];
      const classItems = Array.isArray(cockpit.next_classes) ? cockpit.next_classes : [];
      const inboxItems = Array.isArray(cockpit.inbox_items) ? cockpit.inbox_items : [];
      const competencies = Array.isArray(cockpit.competencies) ? cockpit.competencies : [];
      const competencyManualTotalMarks = Number(cockpit.competency_manual_total_marks || 0);
      const competencyAutoTotalMarks = Number(cockpit.competency_auto_total_marks || 0);
      const activity = cockpit.activity_summary || {};
      const reminders = Array.isArray(cockpit.reminders) ? cockpit.reminders : [];
      const reviewQueue = cockpit.review_queue || {};
      const reviewQueueItems = Array.isArray(reviewQueue.items) ? reviewQueue.items : [];
      const reviewQueueTemplates = Array.isArray(reviewQueue.templates) ? reviewQueue.templates : [];
      const reviewQueueCounts = reviewQueue.counts || {};
      const hasReviewQueue = Boolean(reviewQueue.enabled);
      const progressDashboard = cockpit.progress_dashboard || {};
      const progressSubjects = Array.isArray(progressDashboard.subjects) ? progressDashboard.subjects : [];
      const hasProgressDashboard = Boolean(progressDashboard.enabled);
      const teacherCompetencyPicker = cockpit.teacher_competency_picker || {};
      const teacherCompetencySubjects = Array.isArray(teacherCompetencyPicker.subjects) ? teacherCompetencyPicker.subjects : [];
      const teacherSelectedCompetencySubjectId = Number(teacherCompetencyPicker.selected_subject_id || 0);
      const effectiveHomeViewRole = typeof homeViewRole === 'string' && homeViewRole ? homeViewRole : role;
      const isStudentLikeMyDayView = effectiveHomeViewRole === 'student'
        || effectiveHomeViewRole === 'admin'
        || effectiveHomeViewRole === 'starosta';
      const isTeacherMyDayView = effectiveHomeViewRole === 'teacher';
      const isDefaultStaffMyDayView = !isStudentLikeMyDayView && !isTeacherMyDayView;
      const whatIfSubjects = Array.isArray(cockpit.what_if_subjects) ? cockpit.what_if_subjects : [];
      const defaultWhatIfSubjectId = Number(cockpit.what_if_default_subject_id || 0);
      const briefToneClass = `brief-tone-${brief.tone || 'calm'}`;

      const formatShortDate = (value) => {
        if (!value) return '-';
        const parsed = new Date(`${value}T00:00:00`);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleDateString('uk-UA', { day: '2-digit', month: '2-digit' });
      };
      const formatReminderDate = (value) => {
        if (!value) return '-';
        const parsed = new Date(`${value}T00:00:00`);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleDateString('uk-UA');
      };
      const formatDateTime = (value) => {
        if (!value) return '-';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleString('uk-UA', {
          day: '2-digit',
          month: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        });
      };
      const getDeadlineStatus = (item) => {
        if (item && item.submission_status === 'submitted_on_time') {
          return { label: 'Р’С‡Р°СЃРЅРѕ', className: 'status-on-time' };
        }
        if (item && item.submission_status === 'submitted_late') {
          return { label: 'Р†Р· Р·Р°РїС–Р·РЅРµРЅРЅСЏРј', className: 'status-late' };
        }
        if (item && item.submission_status === 'overdue') {
          return { label: 'РџСЂРѕСЃС‚СЂРѕС‡РµРЅРѕ', className: 'status-overdue' };
        }
        return { label: 'Р’С–РґРєСЂРёС‚Рѕ', className: 'status-open' };
      };
      const getDayContext = (item) => (item && item.day_context === 'tomorrow' ? 'Р—Р°РІС‚СЂР°' : 'РЎСЊРѕРіРѕРґРЅС–');
      const getReviewQueueTypeMeta = (item) => {
        const queueType = String(item && item.queue_type ? item.queue_type : 'new');
        if (queueType === 'overdue') {
          return { label: 'РџСЂРѕСЃС‚СЂРѕС‡РµРЅС–', className: 'status-overdue' };
        }
        if (queueType === 'no_comment') {
          return { label: 'Р‘РµР· РєРѕРјРµРЅС‚Р°СЂСЏ', className: 'status-late' };
        }
        return { label: 'РќРѕРІС–', className: 'status-open' };
      };
      const getSubmissionStatusMeta = (item) => {
        const status = String(item && item.submission_status ? item.submission_status : '');
        if (status === 'late') return { label: 'Р—РґР°РЅРѕ РїС–Р·РЅРѕ', className: 'type-chip type-chip-warning' };
        if (status === 'on_time') return { label: 'Р’С‡Р°СЃРЅРѕ', className: 'type-chip type-chip-success' };
        if (status === 'manual') return { label: 'Р СѓС‡РЅР° РєРѕР»РѕРЅРєР°', className: 'type-chip' };
        return null;
      };
      const getProgressRiskMeta = (item) => {
        const level = String(item && item.risk_level ? item.risk_level : 'low');
        if (level === 'high') return { label: 'Р’РёСЃРѕРєРёР№ СЂРёР·РёРє', className: 'progress-risk-high' };
        if (level === 'medium') return { label: 'РџРѕРјС–СЂРЅРёР№ СЂРёР·РёРє', className: 'progress-risk-medium' };
        return { label: 'РЎС‚Р°Р±С–Р»СЊРЅРѕ', className: 'progress-risk-low' };
      };
    %>

    <%- include('partials/topbar', { role, username, t, activePage: 'my-day', pageTitle: 'Р“РѕР»РѕРІРЅР°' }) %>

    <main class="container cockpit-page py-4">
      <% if (okMessage) { %>
        <div class="alert alert-success cockpit-alert" role="alert"><%= okMessage %></div>
      <% } %>
      <% if (errMessage) { %>
        <div class="alert alert-danger cockpit-alert" role="alert"><%= errMessage %></div>
      <% } %>

      <section class="cockpit-card brief-card <%= briefToneClass %>">
        <div class="brief-head">
          <span class="brief-kicker">Leadership Brief</span>
          <span class="brief-meta">РўРёР¶РґРµРЅСЊ <%= cockpit.week_number || '-' %></span>
        </div>
        <h1 class="brief-title"><%= brief.title || 'РўРІС–Р№ РґРµРЅСЊ РїС–Рґ РєРѕРЅС‚СЂРѕР»РµРј' %></h1>
        <p class="brief-message"><%= brief.message || 'РљСЂРёС‚РёС‡РЅРёС… СЃРёРіРЅР°Р»С–РІ РЅРµ Р·РЅР°Р№РґРµРЅРѕ, С‚СЂРёРјР°Р№ С‚РµРјРї.' %></p>
        <div class="brief-actions">
          <a class="btn btn-glass" href="<%= brief.action_href || '/schedule' %>"><%= brief.action_label || 'Р’С–РґРєСЂРёС‚Рё СЂРѕР·РєР»Р°Рґ' %></a>
          <button type="button" class="btn btn-soft" id="briefWhyToggle">Р§РѕРјСѓ СЏ С†Рµ Р±Р°С‡Сѓ?</button>
        </div>
        <div class="brief-reasons d-none" id="briefWhyPanel">
          <% if (briefReasons.length) { %>
            <% briefReasons.forEach((reason) => { %>
              <div class="brief-reason-row"><%= reason %></div>
            <% }) %>
          <% } else { %>
            <div class="brief-reason-row">РЎРёРіРЅР°Р»Рё С‰Рµ РЅР°РєРѕРїРёС‡СѓСЋС‚СЊСЃСЏ.</div>
          <% } %>
        </div>
      </section>

      <section class="cockpit-grid">
        <% if (isStudentLikeMyDayView) { %>
          <article class="cockpit-card section-card order-1 dual-focus-card" id="deadlinesClassesBlock">
            <div class="section-head">
              <h2 class="section-title">РќР°Р№Р±Р»РёР¶С‡С– РґРµРґР»Р°Р№РЅРё С‚Р° РїР°СЂРё</h2>
              <span class="section-subtitle">РљР»СЋС‡РѕРІС– Р·Р°РґР°С‡С– С‚Р° РЅР°Р№Р±Р»РёР¶С‡С– Р·Р°РЅСЏС‚С‚СЏ</span>
            </div>

            <div class="dual-focus-grid">
              <section class="dual-focus-pane" aria-labelledby="deadlinesPaneTitle">
                <div class="dual-focus-pane-head">
                  <h3 class="dual-focus-pane-title" id="deadlinesPaneTitle">РќР°Р№Р±Р»РёР¶С‡С– РґРµРґР»Р°Р№РЅРё</h3>
                  <span class="dual-focus-pane-subtitle">2-3 Р·Р°РґР°С‡С– Р· РїСЂС–РѕСЂРёС‚РµС‚РѕРј</span>
                </div>
                <% if (!deadlineItems.length) { %>
                  <div class="empty-state compact">
                    <div class="empty-state-title">РљСЂРёС‚РёС‡РЅРёС… РґРµРґР»Р°Р№РЅС–РІ РЅРµ Р·РЅР°Р№РґРµРЅРѕ</div>
                    <div class="empty-state-subtitle">РЎРёСЃС‚РµРјР° РЅРµ Р±Р°С‡РёС‚СЊ РІС–РґРєСЂРёС‚РёС… СЂРёР·РёРєС–РІ РЅР° РЅР°Р№Р±Р»РёР¶С‡РёР№ РїРµСЂС–РѕРґ.</div>
                  </div>
                <% } else { %>
                  <div class="item-list">
                    <% deadlineItems.forEach((item) => {
                         const status = getDeadlineStatus(item);
                         const isHomework = item && item.type === 'homework';
                         const canSubmitNow = Boolean(isHomework && item.can_submit);
                         const hasSubmission = Boolean(isHomework && item.submission_id);
                         const creatorName = String(item && item.created_by ? item.created_by : '').trim();
                    %>
                      <div class="item-row deadline-row">
                        <div class="item-main">
                          <div class="item-title"><%= item.description || 'Р—Р°РІРґР°РЅРЅСЏ' %></div>
                          <div class="item-meta">
                            <span><%= item.subject_name || 'РџСЂРµРґРјРµС‚' %></span>
                            <span>РґРѕ <%= formatShortDate(item.deadline_date) %></span>
                            <% if (creatorName) { %><span>РґРѕРґР°РІ: <%= creatorName %></span><% } %>
                            <% if (item.is_control) { %><span class="type-chip">РљРѕРЅС‚СЂРѕР»СЊ</span><% } %>
                            <% if (item.is_credit) { %><span class="type-chip">Р—Р°Р»С–Рє</span><% } %>
                          </div>
                        </div>
                        <div class="item-side">
                          <span class="status-chip <%= status.className %>"><%= status.label %></span>
                          <% if (canSubmitNow) { %>
                            <button
                              type="button"
                              class="btn btn-submit-now"
                              data-submit-homework-id="<%= item.id %>"
                              data-submit-title="<%= item.description || 'Р—Р°РІРґР°РЅРЅСЏ' %>"
                              data-submit-mode="<%= hasSubmission ? 'update' : 'create' %>"
                            >
                              <%= hasSubmission ? 'РћРЅРѕРІРёС‚Рё Р·РґР°С‡Сѓ' : 'Р—РґР°С‚Рё' %>
                            </button>
                          <% } else if (isHomework && hasSubmission && item.submission_status === 'submitted_on_time') { %>
                            <span class="item-note">Р—РґР°РЅРѕ <%= item.submitted_date || '' %></span>
                          <% } else if (isHomework && hasSubmission && item.submission_status === 'submitted_late') { %>
                            <span class="item-note">Р—РґР°РЅРѕ С–Р· Р·Р°РїС–Р·РЅРµРЅРЅСЏРј</span>
                          <% } else if (item.type === 'teamwork') { %>
                            <a href="/teamwork" class="btn btn-inline-link">Р’С–РґРєСЂРёС‚Рё</a>
                          <% } else { %>
                            <a href="/schedule" class="btn btn-inline-link">Р’С–РґРєСЂРёС‚Рё</a>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
                <div class="section-footer-link dual-focus-footer">
                  <a href="/schedule">Р’С–РґРєСЂРёС‚Рё РїРѕРІРЅРёР№ СЃРїРёСЃРѕРє Сѓ СЂРѕР·РєР»Р°РґС–</a>
                </div>
              </section>

              <section class="dual-focus-pane" aria-labelledby="nextClassesPaneTitle">
                <div class="dual-focus-pane-head">
                  <h3 class="dual-focus-pane-title" id="nextClassesPaneTitle">РџР°СЂРё РЅР°Р№Р±Р»РёР¶С‡РёРј С‡Р°СЃРѕРј</h3>
                  <span class="dual-focus-pane-subtitle">РЎСЊРѕРіРѕРґРЅС– С‚Р° Р·Р°РІС‚СЂР°</span>
                </div>
                <% if (!classItems.length) { %>
                  <div class="empty-state compact">
                    <div class="empty-state-title">РќР°Р№Р±Р»РёР¶С‡РёС… РїР°СЂ РЅРµРјР°С”</div>
                    <div class="empty-state-subtitle">РџРµСЂРµРІС–СЂ СЂРѕР·РєР»Р°Рґ, СЏРєС‰Рѕ РѕС‡С–РєСѓС”С€ Р·РјС–РЅРё.</div>
                  </div>
                <% } else { %>
                  <div class="item-list">
                    <% classItems.forEach((item) => { %>
                      <div class="item-row class-row">
                        <div class="item-main">
                          <div class="item-title"><%= item.subject_name || 'РџСЂРµРґРјРµС‚' %></div>
                          <div class="item-meta">
                            <span class="type-chip"><%= getDayContext(item) %></span>
                            <span>РџР°СЂР° <%= item.class_number || '-' %></span>
                            <span><%= item.start || '--:--' %> - <%= item.end || '--:--' %></span>
                            <% if (item.group_number) { %><span>Р“СЂСѓРїР° <%= item.group_number %></span><% } %>
                          </div>
                        </div>
                        <div class="item-side">
                          <a href="/schedule" class="btn btn-inline-link">Р”Рѕ СЂРѕР·РєР»Р°РґСѓ</a>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </section>
            </div>
          </article>
        <% } %>

        <% if (isTeacherMyDayView) { %>
          <article class="cockpit-card section-card order-1 dual-focus-card teacher-focus-card" id="teacherClassesRemindersBlock">
            <div class="section-head">
              <h2 class="section-title">РџР°СЂРё РЅР°Р№Р±Р»РёР¶С‡РёРј С‡Р°СЃРѕРј</h2>
              <span class="section-subtitle">РЎСЊРѕРіРѕРґРЅС– С‚Р° Р·Р°РІС‚СЂР° + РѕСЃРѕР±РёСЃС‚С– РЅР°РіР°РґСѓРІР°РЅРЅСЏ</span>
            </div>

            <div class="dual-focus-grid dual-focus-grid-single">
              <section class="dual-focus-pane" aria-labelledby="teacherNextClassesPaneTitle">
                <div class="dual-focus-pane-head">
                  <h3 class="dual-focus-pane-title" id="teacherNextClassesPaneTitle">РџР°СЂРё РЅР°Р№Р±Р»РёР¶С‡РёРј С‡Р°СЃРѕРј</h3>
                  <span class="dual-focus-pane-subtitle">РЎСЊРѕРіРѕРґРЅС– С‚Р° Р·Р°РІС‚СЂР°</span>
                </div>
                <% if (!classItems.length) { %>
                  <div class="empty-state compact">
                    <div class="empty-state-title">РќР°Р№Р±Р»РёР¶С‡РёС… РїР°СЂ РЅРµРјР°С”</div>
                    <div class="empty-state-subtitle">РџРµСЂРµРІС–СЂ СЂРѕР·РєР»Р°Рґ, СЏРєС‰Рѕ РѕС‡С–РєСѓС”С€ Р·РјС–РЅРё.</div>
                  </div>
                <% } else { %>
                  <div class="item-list">
                    <% classItems.forEach((item) => { %>
                      <div class="item-row class-row">
                        <div class="item-main">
                          <div class="item-title"><%= item.subject_name || 'РџСЂРµРґРјРµС‚' %></div>
                          <div class="item-meta">
                            <span class="type-chip"><%= getDayContext(item) %></span>
                            <span>РџР°СЂР° <%= item.class_number || '-' %></span>
                            <span><%= item.start || '--:--' %> - <%= item.end || '--:--' %></span>
                            <% if (item.group_number) { %><span>Р“СЂСѓРїР° <%= item.group_number %></span><% } %>
                          </div>
                        </div>
                        <div class="item-side">
                          <a href="/schedule" class="btn btn-inline-link">Р”Рѕ СЂРѕР·РєР»Р°РґСѓ</a>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </section>
            </div>

            <div class="reminder-block teacher-inline-reminders">
              <div class="reminder-header">
                <h3>РќР°РіР°РґСѓРІР°РЅРЅСЏ</h3>
                <button type="button" class="btn btn-soft btn-sm" id="toggleReminderForm">Р”РѕРґР°С‚Рё</button>
              </div>
              <form id="reminderForm" class="reminder-form d-none">
                <input type="hidden" id="reminderEditId" value="" />
                <div class="reminder-row">
                  <input type="text" id="reminderTitle" class="form-control reminder-input" maxlength="160" placeholder="РќР°Р·РІР° РЅР°РіР°РґСѓРІР°РЅРЅСЏ" required />
                </div>
                <div class="reminder-row">
                  <textarea id="reminderNote" class="form-control reminder-input" rows="2" maxlength="500" placeholder="РќРѕС‚Р°С‚РєР° (РѕРїС†С–Р№РЅРѕ)"></textarea>
                </div>
                <div class="reminder-row reminder-row-split">
                  <input type="date" id="reminderDate" class="form-control reminder-input" required />
                  <input type="time" id="reminderTime" class="form-control reminder-input" />
                </div>
                <div class="reminder-actions">
                  <button type="submit" class="btn btn-glass btn-sm" id="reminderSubmit">Р”РѕРґР°С‚Рё</button>
                  <button type="button" class="btn btn-soft btn-sm" id="reminderCancel">РЎРєР°СЃСѓРІР°С‚Рё</button>
                </div>
              </form>
              <div id="reminderList" class="reminder-list">
                <% if (!reminders.length) { %>
                  <div class="empty-state compact">
                    <div class="empty-state-title">РќР°РіР°РґСѓРІР°РЅСЊ РЅРµРјР°С”</div>
                    <div class="empty-state-subtitle">Р”РѕРґР°Р№ РїРµСЂС€Рµ РЅР° РЅР°Р№Р±Р»РёР¶С‡РёР№ С‚РёР¶РґРµРЅСЊ.</div>
                  </div>
                <% } else { %>
                  <% reminders.forEach((reminder) => { %>
                    <div class="reminder-item">
                      <div class="reminder-main">
                        <div class="reminder-title <%= reminder.is_done ? 'done' : '' %>"><%= reminder.title %></div>
                        <div class="reminder-meta"><%= formatReminderDate(reminder.remind_date) %><%= reminder.remind_time ? ` В· ${reminder.remind_time}` : '' %></div>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          </article>
        <% } %>

        <% if (isDefaultStaffMyDayView) { %>
        <article class="cockpit-card section-card<%= isStudentLikeMyDayView ? ' order-1' : '' %>" id="deadlinesBlock">
          <div class="section-head">
            <h2 class="section-title">РќР°Р№Р±Р»РёР¶С‡С– РґРµРґР»Р°Р№РЅРё</h2>
            <span class="section-subtitle">2-3 Р·Р°РґР°С‡С– Р· РЅР°Р№РІРёС‰РёРј РїСЂС–РѕСЂРёС‚РµС‚РѕРј</span>
          </div>
          <% if (!deadlineItems.length) { %>
            <div class="empty-state">
              <div class="empty-state-title">РљСЂРёС‚РёС‡РЅРёС… РґРµРґР»Р°Р№РЅС–РІ РЅРµ Р·РЅР°Р№РґРµРЅРѕ</div>
              <div class="empty-state-subtitle">РЎРёСЃС‚РµРјР° РЅРµ Р±Р°С‡РёС‚СЊ РІС–РґРєСЂРёС‚РёС… СЂРёР·РёРєС–РІ РЅР° РЅР°Р№Р±Р»РёР¶С‡РёР№ РїРµСЂС–РѕРґ.</div>
            </div>
          <% } else { %>
            <div class="item-list">
              <% deadlineItems.forEach((item) => {
                   const status = getDeadlineStatus(item);
                   const isHomework = item && item.type === 'homework';
                   const canSubmitNow = Boolean(isHomework && item.can_submit);
                   const hasSubmission = Boolean(isHomework && item.submission_id);
                   const creatorName = String(item && item.created_by ? item.created_by : '').trim();
              %>
                <div class="item-row deadline-row">
                  <div class="item-main">
                    <div class="item-title"><%= item.description || 'Р—Р°РІРґР°РЅРЅСЏ' %></div>
                    <div class="item-meta">
