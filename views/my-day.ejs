            <div class="teacher-competency-subtitle"><%= t('myDay.competency.subjectLabel') %>: <%= teacherCompetencyPicker.selected_subject_name %></div>
          <% } %>
          <div class="competency-source-summary">
            <span><%= t('myDay.competency.manual') %>: <strong><%= competencyManualTotalMarks %></strong></span>
            <span><%= t('myDay.competency.auto') %>: <strong><%= competencyAutoTotalMarks %></strong></span>
