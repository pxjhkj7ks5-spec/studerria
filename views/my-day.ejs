<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title>Studerria</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/pages/my-day.css" />    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-my-day page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%
      const cockpit = myDay || {};
      const brief = cockpit.brief || {};
      const briefReasons = Array.isArray(brief.reasons) ? brief.reasons : [];
      const deadlineItems = Array.isArray(cockpit.deadline_focus) ? cockpit.deadline_focus : [];
      const classItems = Array.isArray(cockpit.next_classes) ? cockpit.next_classes : [];
      const inboxItems = Array.isArray(cockpit.inbox_items) ? cockpit.inbox_items : [];
      const competencies = Array.isArray(cockpit.competencies) ? cockpit.competencies : [];
      const competencyManualTotalMarks = Number(cockpit.competency_manual_total_marks || 0);
      const competencyAutoTotalMarks = Number(cockpit.competency_auto_total_marks || 0);
      const activity = cockpit.activity_summary || {};
      const reminders = Array.isArray(cockpit.reminders) ? cockpit.reminders : [];
      const reviewQueue = cockpit.review_queue || {};
      const reviewQueueItems = Array.isArray(reviewQueue.items) ? reviewQueue.items : [];
      const reviewQueueTemplates = Array.isArray(reviewQueue.templates) ? reviewQueue.templates : [];
      const reviewQueueCounts = reviewQueue.counts || {};
      const hasReviewQueue = Boolean(reviewQueue.enabled);
      const progressDashboard = cockpit.progress_dashboard || {};
      const progressSubjects = Array.isArray(progressDashboard.subjects) ? progressDashboard.subjects : [];
      const hasProgressDashboard = Boolean(progressDashboard.enabled);
      const teacherCompetencyPicker = cockpit.teacher_competency_picker || {};
      const teacherCompetencySubjects = Array.isArray(teacherCompetencyPicker.subjects) ? teacherCompetencyPicker.subjects : [];
      const teacherSelectedCompetencySubjectId = Number(teacherCompetencyPicker.selected_subject_id || 0);
      const attendanceHealth = cockpit.attendance_health || null;
      const latestRatingSnapshot = cockpit.latest_rating_snapshot || null;
      const inboxMessageSummary = cockpit.inbox_message_summary || cockpit.announcement_summary || null;
      const inboxMessageItems = Array.isArray(cockpit.inbox_message_items)
        ? cockpit.inbox_message_items
        : (Array.isArray(cockpit.announcement_items) ? cockpit.announcement_items : []);
      const supportSummary = cockpit.support_summary || null;
      const supportThreads = Array.isArray(cockpit.support_threads) ? cockpit.support_threads : [];
      const teacherQuickActions = Array.isArray(cockpit.teacher_quick_actions) ? cockpit.teacher_quick_actions : [];
      const effectiveHomeViewRole = typeof homeViewRole === 'string' && homeViewRole ? homeViewRole : role;
      const isStudentLikeMyDayView = effectiveHomeViewRole === 'student'
        || effectiveHomeViewRole === 'admin'
        || effectiveHomeViewRole === 'starosta';
      const isTeacherMyDayView = effectiveHomeViewRole === 'teacher';
      const isDefaultStaffMyDayView = !isStudentLikeMyDayView && !isTeacherMyDayView;
      const whatIfSubjects = Array.isArray(cockpit.what_if_subjects) ? cockpit.what_if_subjects : [];
      const defaultWhatIfSubjectId = Number(cockpit.what_if_default_subject_id || 0);
      const briefToneClass = `brief-tone-${brief.tone || 'calm'}`;
      const localeCode = lang === 'en' ? 'en-US' : 'uk-UA';
      const supportMissionSummary = supportSummary || { open: 0, resolved: 0, total: 0, response: '' };

      const formatShortDate = (value) => {
        if (!value) return '-';
        const normalizedValue = String(value);
        const parsed = /^\d{4}-\d{2}-\d{2}$/.test(normalizedValue)
          ? new Date(`${normalizedValue}T00:00:00`)
          : new Date(normalizedValue);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleDateString(localeCode, { day: '2-digit', month: 'short' });
      };
      const formatReminderDate = (value) => {
        if (!value) return '-';
        const parsed = new Date(`${value}T00:00:00`);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleDateString(localeCode);
      };
      const formatDateTime = (value) => {
        if (!value) return '-';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return value;
        return parsed.toLocaleString(localeCode, {
          day: '2-digit',
          month: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
        });
      };
      const getDeadlineStatus = (item) => {
        if (item && item.submission_status === 'submitted_on_time') {
          return { label: t('myDay.status.onTime'), className: 'status-on-time' };
        }
        if (item && item.submission_status === 'submitted_late') {
          return { label: t('myDay.status.late'), className: 'status-late' };
        }
        if (item && item.submission_status === 'overdue') {
          return { label: t('myDay.status.overdue'), className: 'status-overdue' };
        }
        return { label: t('myDay.status.open'), className: 'status-open' };
      };
      const getDayContext = (item) => (item && item.day_context === 'tomorrow'
        ? t('myDay.day.tomorrow')
        : t('myDay.day.today'));
      const getReviewQueueTypeMeta = (item) => {
        const queueType = String(item && item.queue_type ? item.queue_type : 'new');
        if (queueType === 'overdue') {
          return { label: t('myDay.reviewQueue.overdue'), className: 'status-overdue' };
        }
        if (queueType === 'no_comment') {
          return { label: t('myDay.reviewQueue.noComment'), className: 'status-late' };
        }
        return { label: t('myDay.reviewQueue.new'), className: 'status-open' };
      };
      const getSubmissionStatusMeta = (item) => {
        const status = String(item && item.submission_status ? item.submission_status : '');
        if (status === 'late') return { label: t('myDay.submissionStatus.late'), className: 'type-chip type-chip-warning' };
        if (status === 'on_time') return { label: t('myDay.submissionStatus.onTime'), className: 'type-chip type-chip-success' };
        if (status === 'manual') return { label: t('myDay.submissionStatus.manual'), className: 'type-chip' };
        return null;
      };
      const getProgressRiskMeta = (item) => {
        const level = String(item && item.risk_level ? item.risk_level : 'low');
        if (level === 'high') return { label: t('myDay.progressRisk.high'), className: 'progress-risk-high' };
        if (level === 'medium') return { label: t('myDay.progressRisk.medium'), className: 'progress-risk-medium' };
        return { label: t('myDay.progressRisk.stable'), className: 'progress-risk-low' };
      };
      const getAttendanceStatusLabel = (summary) => {
        const statusKey = String(summary && summary.status_key ? summary.status_key : 'stable');
        if (lang === 'en') {
          if (statusKey === 'attention') return 'Attention';
          if (statusKey === 'watch') return 'Watch';
          return 'Stable';
        }
        if (statusKey === 'attention') return 'Увага';
        if (statusKey === 'watch') return 'Контроль';
        return 'Стабільно';
      };
      const getAttendanceNote = (summary) => {
        const noteKey = String(summary && summary.note_key ? summary.note_key : '');
        if (lang === 'en') {
          if (noteKey === 'teacher_follow_up') return 'Absences are climbing. Open the journal and review the latest marks.';
          if (noteKey === 'teacher_watch') return 'There are enough late or missed marks to warrant a quick review.';
          if (noteKey === 'student_follow_up') return 'Absences are above the safe range. Check the journal and clarify missing reasons.';
          if (noteKey === 'student_watch') return 'A few recent misses or late arrivals need attention before they stack up.';
          if (noteKey === 'teacher_steady') return 'Attendance signal is calm across the current review window.';
          return 'Attendance looks steady right now.';
        }
        if (noteKey === 'teacher_follow_up') return 'Пропуски ростуть. Відкрий журнал і перевір останні відмітки.';
        if (noteKey === 'teacher_watch') return 'Є достатньо запізнень або пропусків, щоб швидко переглянути останні позначки.';
        if (noteKey === 'student_follow_up') return 'Рівень пропусків уже вийшов із безпечної зони. Перевір журнал і уточни причини.';
        if (noteKey === 'student_watch') return 'Останні пропуски або запізнення вже варто взяти під контроль, поки вони не накопичилися.';
        if (noteKey === 'teacher_steady') return 'Сигнал по відвідуваності зараз рівний у межах поточного вікна.';
        return 'Зараз відвідуваність виглядає стабільною.';
      };
      const getAttendanceWindowLabel = (summary) => {
        const primaryWindowDays = Number(summary && summary.primary_window_days ? summary.primary_window_days : 0);
        if (primaryWindowDays > 0) {
          return lang === 'en' ? `Window: last ${primaryWindowDays} days` : `Вікно: останні ${primaryWindowDays} днів`;
        }
        return lang === 'en' ? 'Window: current semester' : 'Вікно: поточний семестр';
      };
      const getAttendanceRecentLabel = (summary) => {
        const recent = summary && summary.recent && typeof summary.recent === 'object' ? summary.recent : null;
        const recentWindowDays = Number(summary && summary.recent_window_days ? summary.recent_window_days : 14) || 14;
        if (!recent || Number(recent.total || 0) < 1) {
          return lang === 'en' ? `Last ${recentWindowDays}d: no new marks` : `Останні ${recentWindowDays} дн.: без нових позначок`;
        }
        return lang === 'en'
          ? `Last ${recentWindowDays}d: absent ${Number(recent.absent || 0)}, late ${Number(recent.late || 0)}`
          : `Останні ${recentWindowDays} дн.: відсутність ${Number(recent.absent || 0)}, запізнення ${Number(recent.late || 0)}`;
      };
      const getInboxMessageTone = (summary) => {
        if (summary && Number(summary.fresh_unread || 0) > 0) return 'risk';
        if (summary && Number(summary.fresh || 0) > 0) return 'focus';
        return 'calm';
      };
      const getInboxMessageStatusLabel = (summary) => {
        if (lang === 'en') {
          if (summary && Number(summary.fresh_unread || 0) > 0) return 'Unread';
          if (summary && Number(summary.fresh || 0) > 0) return 'Recent';
          return 'Quiet';
        }
        if (summary && Number(summary.fresh_unread || 0) > 0) return 'Нове';
        if (summary && Number(summary.fresh || 0) > 0) return 'Свіже';
        return 'Спокійно';
      };
      const getInboxMessageKindLabel = (item) => {
        const kind = String(item && item.message_kind ? item.message_kind : 'broadcast');
        if (lang === 'en') {
          if (kind === 'broadcast') return 'All-course broadcast';
          if (kind === 'group') return 'Group update';
          if (kind === 'subject') return 'Subject update';
          if (kind === 'direct') return 'Direct update';
          return 'Inbox update';
        }
        if (kind === 'broadcast') return 'Загальне оголошення';
        if (kind === 'group') return 'Оновлення групи';
        if (kind === 'subject') return 'Оновлення предмета';
        if (kind === 'direct') return 'Адресне повідомлення';
        return 'Оновлення inbox';
      };
      const getInboxMessageCardTitle = (item) => {
        if (item && item.message_title) return item.message_title;
        if (item && item.body_preview) return item.body_preview;
        if (item && item.body) return item.body;
        return lang === 'en' ? 'Inbox update' : 'Оновлення inbox';
      };
      const getInboxMessageCardBody = (item) => {
        if (item && item.message_title) {
          return item.body_preview || item.body || '';
        }
        return '';
      };
      const getInboxMessageMeta = (item) => {
        const parts = [];
        if (item && item.message_scope_line) {
          parts.push(item.message_scope_line);
        } else {
          if (item && item.subject_name) parts.push(item.subject_name);
          if (item && Number(item.group_number || 0) > 0) {
            parts.push(`${lang === 'en' ? 'Group' : 'Група'} ${Number(item.group_number)}`);
          }
        }
        if (item && item.rating_snapshot_card && item.rating_snapshot_card.updated_label) {
          parts.push(item.rating_snapshot_card.updated_label);
        } else if (item && (item.published_at || item.created_at)) {
          parts.push(formatDateTime(item.published_at || item.created_at));
        }
        return parts.join(' · ');
      };
      const getSupportMissionStatusLabel = (summary) => {
        if (lang === 'en') {
          if (summary && Number(summary.open || 0) > 0) return 'Open';
          if (summary && Number(summary.total || 0) > 0) return 'Resolved';
          return 'Quiet';
        }
        if (summary && Number(summary.open || 0) > 0) return 'Відкрито';
        if (summary && Number(summary.total || 0) > 0) return 'Закрито';
        return 'Спокійно';
      };
      const getSupportMissionTone = (summary) => {
        if (summary && Number(summary.open || 0) > 0) return 'focus';
        return 'calm';
      };
      const getRatingMissionTone = (snapshot) => snapshot ? 'focus' : 'calm';
      const getRatingMissionStatusLabel = (snapshot) => {
        if (lang === 'en') {
          return snapshot ? 'Published' : 'Awaiting';
        }
        return snapshot ? 'Опубліковано' : 'Очікується';
      };
    %>

    <%- include('partials/topbar', { role, username, t, activePage: 'my-day', pageTitle: t('myDay.pageTitle') }) %>
    <aside class="schedule-drawer" id="scheduleActionDrawer" aria-hidden="true">
      <div class="drawer-head">
        <div class="drawer-title"><%= t('myDay.drawer.title') %></div>
        <button class="drawer-close" type="button" id="scheduleDrawerClose" aria-label="<%= t('navigation.closeMenu') %>">✕</button>
      </div>
      <div class="drawer-actions">
        <% if (role === 'admin') { %>
          <form method="POST" action="/admin/switch-to-admin" class="drawer-action-wrap">
            <button class="drawer-action" type="submit">🛠️ <%= t('schedule.backToAdmin') %></button>
          </form>
        <% } else if (hasCustomAdminPanelAccess) { %>
          <a class="drawer-action" href="<%= customAdminPanelHref || '/admin' %>">🛠️ <%= t('schedule.backToAdmin') %></a>
        <% } %>
        <% if (role === 'starosta') { %>
          <a class="drawer-action" href="/starosta">🧑‍🏫 <%= t('menu.starosta') %></a>
        <% } %>
        <% if (role === 'deanery') { %>
          <a class="drawer-action" href="/deanery">🏛️ <%= t('menu.deanery') %></a>
        <% } %>
        <a class="drawer-action" href="/schedule">📅 <%= t('myDay.drawer.schedule') %></a>
        <a class="drawer-action" href="/journal">📘 <%= t('myDay.drawer.journal') %></a>
        <a class="drawer-action" href="/teamwork">🤝 <%= t('menu.teamwork') %></a>
        <a class="drawer-action" href="/subjects">📚 <%= t('myDay.drawer.subjects') %></a>
        <% if (canUseCustomDeadlinesUi) { %>
          <a class="drawer-action" href="/schedule">🌀 <%= t('myDay.drawer.customDeadlines') %></a>
        <% } %>
        <% if (settings && settings.allow_messages) { %>
          <a class="drawer-action" href="/schedule">💬 <%= t('myDay.drawer.messages') %></a>
        <% } %>
        <a class="drawer-action" href="/profile">👤 <%= t('schedule.profile') %></a>
        <button
          class="drawer-action theme-toggle"
          type="button"
          data-light-label="☀️ <%= t('myDay.drawer.themeToggle') %>"
          data-dark-label="🌙 <%= t('myDay.drawer.themeToggle') %>"
        >
          🌙 <%= t('myDay.drawer.themeToggle') %>
        </button>
        <form method="POST" action="/logout" class="drawer-action-wrap">
          <button class="drawer-action" type="submit">🚪 <%= t('schedule.logout') %></button>
        </form>
      </div>
    </aside>

    <main class="container cockpit-page py-4">
      <% if (okMessage) { %>
        <div class="alert alert-success cockpit-alert" role="alert"><%= okMessage %></div>
      <% } %>
      <% if (errMessage) { %>
        <div class="alert alert-danger cockpit-alert" role="alert"><%= errMessage %></div>
      <% } %>

      <section class="cockpit-card brief-card <%= briefToneClass %>">
        <div class="brief-head">
          <span class="brief-kicker"><%= t('myDay.briefKicker') %></span>
          <span class="brief-meta"><%= t('myDay.briefWeek') %> <%= cockpit.week_number || '-' %></span>
        </div>
        <h1 class="brief-title"><%= brief.title || t('myDay.briefTitleFallback') %></h1>
        <p class="brief-message"><%= brief.message || t('myDay.briefMessageFallback') %></p>
        <div class="brief-actions">
          <a class="btn btn-glass" href="<%= brief.action_href || '/schedule' %>"><%= brief.action_label || t('myDay.briefOpenSchedule') %></a>
          <button type="button" class="btn btn-soft" id="briefWhyToggle"><%= t('myDay.briefWhy') %></button>
        </div>
        <div class="brief-reasons d-none" id="briefWhyPanel">
          <% if (briefReasons.length) { %>
            <% briefReasons.forEach((reason) => { %>
              <div class="brief-reason-row"><%= reason %></div>
            <% }) %>
          <% } else { %>
            <div class="brief-reason-row"><%= t('myDay.briefWhyEmpty') %></div>
          <% } %>
        </div>
      </section>

      <section class="mission-strip">
        <article class="cockpit-card mission-card mission-card-attendance<%= attendanceHealth ? ` is-${attendanceHealth.tone}` : '' %>">
          <div class="mission-card-kicker"><%= lang === 'en' ? 'Attendance' : 'Відвідуваність' %></div>
          <div class="mission-card-content">
            <div class="mission-card-topline">
              <div class="mission-card-value"><%= attendanceHealth && attendanceHealth.reliability !== null && typeof attendanceHealth.reliability !== 'undefined' ? `${attendanceHealth.reliability}%` : '-' %></div>
              <span class="mission-card-badge mission-card-badge-<%= attendanceHealth ? (attendanceHealth.tone || 'calm') : 'calm' %>"><%= attendanceHealth ? getAttendanceStatusLabel(attendanceHealth) : (lang === 'en' ? 'No data' : 'Немає даних') %></span>
            </div>
            <% if (attendanceHealth) { %>
              <div class="mission-card-meta">
                <span><%= lang === 'en' ? 'Present' : 'Присутність' %>: <%= Number(attendanceHealth.present || 0) %></span>
                <span><%= lang === 'en' ? 'Late' : 'Запізнення' %>: <%= Number(attendanceHealth.late || 0) %></span>
                <span><%= lang === 'en' ? 'Absent' : 'Відсутність' %>: <%= Number(attendanceHealth.absent || 0) %></span>
              </div>
              <div class="mission-card-foot">
                <span><%= lang === 'en' ? 'Flagged' : 'Ризикові' %>: <%= Number(attendanceHealth.flagged_total || 0) %></span>
                <span><%= getAttendanceWindowLabel(attendanceHealth) %></span>
                <% if (attendanceHealth.last_marked_at) { %>
                  <span><%= lang === 'en' ? 'Last mark' : 'Остання відмітка' %>: <%= formatShortDate(attendanceHealth.last_marked_at) %></span>
                <% } %>
              </div>
              <p class="mission-card-note"><%= getAttendanceNote(attendanceHealth) %></p>
              <div class="mission-card-foot">
                <span><%= getAttendanceRecentLabel(attendanceHealth) %></span>
              </div>
            <% } else { %>
              <div class="mission-card-empty"><%= lang === 'en' ? 'No attendance signal yet.' : 'Поки немає сигналу по відвідуваності.' %></div>
            <% } %>
          </div>
          <div class="mission-card-action">
            <a class="btn btn-inline-link" href="/journal"><%= lang === 'en' ? 'Open journal' : 'Відкрити журнал' %></a>
          </div>
        </article>
        <article class="cockpit-card mission-card">
          <div class="mission-card-kicker"><%= lang === 'en' ? 'Latest rating' : 'Останній рейтинг' %></div>
          <div class="mission-card-content">
            <div class="mission-card-topline">
              <div class="mission-card-value mission-card-value-wide"><%= latestRatingSnapshot ? (latestRatingSnapshot.scope_label || '-') : '—' %></div>
              <span class="mission-card-badge mission-card-badge-<%= getRatingMissionTone(latestRatingSnapshot) %>"><%= getRatingMissionStatusLabel(latestRatingSnapshot) %></span>
            </div>
            <% if (latestRatingSnapshot) { %>
              <div class="mission-card-meta">
                <% if (latestRatingSnapshot.target_label) { %>
                  <span><%= latestRatingSnapshot.target_label %></span>
                <% } %>
                <% if (latestRatingSnapshot.period_label) { %>
                  <span><%= latestRatingSnapshot.period_label %></span>
                <% } %>
                <% if (latestRatingSnapshot.updated_label) { %>
                  <span><%= latestRatingSnapshot.updated_label %></span>
                <% } %>
              </div>
              <% if (latestRatingSnapshot.top_entry) { %>
                <p class="mission-card-note">
                  <strong><%= lang === 'en' ? 'Leader' : 'Лідер' %></strong>: <%= latestRatingSnapshot.top_entry.full_name %><br />
                  <strong><%= lang === 'en' ? 'Top score' : 'Топ-оцінка' %></strong>:
                  <%= latestRatingSnapshot.top_entry.score_label || latestRatingSnapshot.top_entry.final_score || '' %>
                </p>
              <% } else { %>
                <p class="mission-card-note"><%= lang === 'en' ? 'The latest published snapshot is ready in Journal Insights.' : 'Останній опублікований snapshot вже доступний у Journal Insights.' %></p>
              <% } %>
            <% } else { %>
              <div class="mission-card-empty"><%= lang === 'en' ? 'No published rating yet.' : 'Опублікованого рейтингу ще немає.' %></div>
            <% } %>
          </div>
          <div class="mission-card-action">
            <a class="btn btn-inline-link" href="<%= latestRatingSnapshot && latestRatingSnapshot.action_href ? latestRatingSnapshot.action_href : '/journal/insights' %>"><%= lang === 'en' ? 'Open insights' : 'Відкрити insights' %></a>
          </div>
        </article>
        <article class="cockpit-card mission-card">
          <div class="mission-card-kicker"><%= lang === 'en' ? 'Support' : 'Підтримка' %></div>
          <div class="mission-card-content">
            <div class="mission-card-topline">
              <div class="mission-card-value"><%= Number(supportMissionSummary.open || 0) %></div>
              <span class="mission-card-badge mission-card-badge-<%= getSupportMissionTone(supportMissionSummary) %>"><%= getSupportMissionStatusLabel(supportMissionSummary) %></span>
            </div>
            <div class="mission-card-meta">
              <span><%= lang === 'en' ? 'Open threads' : 'Активні треди' %>: <%= Number(supportMissionSummary.open || 0) %></span>
              <span><%= lang === 'en' ? 'Resolved' : 'Закрито' %>: <%= Number(supportMissionSummary.resolved || 0) %></span>
              <% if (supportMissionSummary.response) { %>
                <span><%= lang === 'en' ? 'SLA' : 'SLA' %>: <%= supportMissionSummary.response %></span>
              <% } %>
            </div>
            <% if (supportThreads[0]) { %>
              <p class="mission-card-note"><strong><%= lang === 'en' ? 'Latest thread' : 'Останній тред' %></strong>: <%= supportThreads[0].subject %></p>
              <div class="mission-card-foot">
                <% if (supportThreads[0].last_message_at) { %>
                  <span><%= lang === 'en' ? 'Updated' : 'Оновлено' %>: <%= formatDateTime(supportThreads[0].last_message_at) %></span>
                <% } %>
              </div>
            <% } else { %>
