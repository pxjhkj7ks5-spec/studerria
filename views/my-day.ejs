                      type="button"
                      class="btn btn-soft btn-xs review-template-btn <%= index === 0 ? 'is-active' : '' %>"
                      data-template-text="<%= template.text %>"
                    >
                      <%= template.label %>
                    </button>
                  <% }) %>
                  <button type="button" class="btn btn-soft btn-xs review-template-btn" data-template-clear="1"><%= t('myDay.review.templateNone') %></button>
                </div>
              <% } %>
            </div>

            <% if (!reviewQueueItems.length) { %>
              <div class="empty-state compact">
                <div class="empty-state-title"><%= t('myDay.review.emptyTitle') %></div>
                <div class="empty-state-subtitle"><%= t('myDay.review.emptySubtitle') %></div>
              </div>
            <% } else { %>
              <div class="item-list review-queue-list">
                <% reviewQueueItems.forEach((item) => {
                     const queueMeta = getReviewQueueTypeMeta(item);
                     const submissionMeta = getSubmissionStatusMeta(item);
                     const hasScore = Number.isFinite(Number(item.score));
                %>
                  <div class="item-row review-row" data-queue-type="<%= item.queue_type || 'new' %>">
                    <div class="item-main">
                      <div class="item-title"><%= item.student_name || t('myDay.review.item.studentFallback') %></div>
                      <div class="item-meta">
                        <span><%= item.subject_name || t('myDay.item.subjectFallback') %></span>
                        <% if (item.student_group) { %><span><%= t('myDay.review.item.groupLabel') %> <%= item.student_group %></span><% } %>
                        <span><%= t('myDay.review.item.columnLabel') %>: <%= item.column_title || t('myDay.review.item.columnFallback') %></span>
                        <span><%= t('myDay.review.item.submittedLabel') %>: <%= formatDateTime(item.submitted_at) %></span>
                        <% if (item.due_date) { %><span><%= t('myDay.review.item.deadlineLabel') %>: <%= formatShortDate(item.due_date) %></span><% } %>
                        <% if (hasScore) { %><span><%= t('myDay.review.item.scoreLabel') %>: <%= String(item.score).replace(/\.00$/, '') %></span><% } %>
                      </div>
                    </div>
                    <div class="item-side">
                      <span class="status-chip <%= queueMeta.className %>"><%= queueMeta.label %></span>
                      <% if (submissionMeta) { %>
                        <span class="<%= submissionMeta.className %>"><%= submissionMeta.label %></span>
                      <% } %>
                      <a class="btn btn-inline-link review-open-link" href="<%= item.review_href %>"><%= t('myDay.review.open') %></a>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
            <% if (reviewQueue.truncated) { %>
              <div class="section-footer-link review-footer-note">
                <%= t('myDay.review.truncatedPrefix') %> <%= reviewQueueItems.length %> <%= t('myDay.review.truncatedSuffix') %>
              </div>
            <% } %>
            <div class="section-footer-link">
              <a href="/journal"><%= t('myDay.review.goJournal') %></a>
            </div>
          </article>
        <% } %>

