                  aria-label="РћР±СЂР°С‚Рё РїСЂРµРґРјРµС‚ РґР»СЏ РєРѕРјРїР°СЃР° РєРѕРјРїРµС‚РµРЅС‚РЅРѕСЃС‚РµР№"
                >
                  <% teacherCompetencySubjects.forEach((subject) => { %>
                    <option value="<%= subject.subject_id %>" <%= Number(subject.subject_id) === teacherSelectedCompetencySubjectId ? 'selected' : '' %>>
                      <%= subject.subject_name || 'РџСЂРµРґРјРµС‚' %>
