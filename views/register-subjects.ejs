<!doctype html>
<%
  const subjectRegistrationError = String(error || '').trim();
  const subjectRegistrationErrorText = (() => {
    if (!subjectRegistrationError) return '';
    if (subjectRegistrationError === 'missing-group' || subjectRegistrationError === 'Select group') {
      return t('registerSubjects.errorMissingGroup');
    }
    if (subjectRegistrationError === 'projection-incomplete') {
      return lang === 'en'
        ? 'Academic setup is still incomplete for your group. Review the warning and try again later.'
        : 'Академічне налаштування для вашої групи ще не завершене. Перегляньте попередження і спробуйте пізніше.';
    }
    if (subjectRegistrationError === 'db-error' || subjectRegistrationError === 'Database error') {
      return t('registerSubjects.errorDb');
    }
    return subjectRegistrationError;
  })();

  const subjectCards = Array.isArray(registerSubjectCards) ? registerSubjectCards : [];

  const selectableSubjects = subjectCards.filter((subject) => subject.interactive);
  const autoAssignedSubjects = subjectCards.filter((subject) => subject.autoAssigned);
  const renderedSubjectCards = subjectCards.filter((subject) => !subject.autoAssigned);
  const activeSelectableSubjects = selectableSubjects.filter((subject) => !subject.optedOut);
  const pendingSelectableSubjects = activeSelectableSubjects.filter((subject) => !subject.selectedGroup);
  const totalVisibleCount = subjectCards.length;
  const configuredSubjectCount = subjectCards.filter((subject) => subject.ready).length;
  const autoAssignedCount = subjectCards.filter((subject) => subject.autoAssigned).length;
  const manualMultiGroupSubjects = activeSelectableSubjects.filter((subject) => subject.groupCount > 1);
  const hasPendingSelections = pendingSelectableSubjects.length > 0;
  const progressPercent = totalVisibleCount ? Math.round((configuredSubjectCount / totalVisibleCount) * 100) : 100;
  const summarizeSubjectNames = (list) => {
    const names = list.map((subject) => String(subject.name || '').trim()).filter(Boolean);
    if (!names.length) return '';
    if (names.length <= 3) return names.join(', ');
    return `${names.slice(0, 3).join(', ')} +${names.length - 3}`;
  };
  const pendingSubjectSummary = summarizeSubjectNames(pendingSelectableSubjects);
  const remainingText = hasPendingSelections
    ? `${t('registerSubjects.remaining')}: ${pendingSelectableSubjects.length}`
    : t('registerSubjects.allSet');
  const missingSummaryText = hasPendingSelections && pendingSubjectSummary
    ? `${t('registerSubjects.missingHintPrefix')}: ${pendingSubjectSummary}`
    : '';
  const submitHintText = hasPendingSelections ? t('registerSubjects.submitHintIncomplete') : '';
  const quickGroupMax = manualMultiGroupSubjects.length
    ? Math.min(3, Math.min(...manualMultiGroupSubjects.map((subject) => subject.groupCount)))
    : 0;
  const hasQuickSelect = manualMultiGroupSubjects.length > 1 && quickGroupMax > 1;
  const quickGroupOptions = hasQuickSelect
    ? Array.from({ length: quickGroupMax }, (_value, index) => index + 1)
    : [];
  const quickSelectedGroup = (() => {
    if (!hasQuickSelect || !manualMultiGroupSubjects.length) return null;
    const [firstSubject] = manualMultiGroupSubjects;
    if (!firstSubject || !firstSubject.selectedGroup) return null;
    return manualMultiGroupSubjects.every((subject) => subject.selectedGroup === firstSubject.selectedGroup)
      ? firstSubject.selectedGroup
      : null;
  })();
  const showNoSubjectsNotice = !subjectCards.length;
  const showAutoAssignedNotice = !showNoSubjectsNotice && !selectableSubjects.length;
  const registerGroupsUi = {
    statusSelected: t('registerSubjects.statusSelected'),
    statusPending: t('registerSubjects.statusPending'),
    statusSkipped: t('registerSubjects.statusSkipped'),
    statusReady: lang === 'en' ? 'Ready' : 'Готово',
    remaining: t('registerSubjects.remaining'),
    allSet: t('registerSubjects.allSet'),
    submitHintIncomplete: t('registerSubjects.submitHintIncomplete'),
    missingHintPrefix: t('registerSubjects.missingHintPrefix'),
    filterEmpty: t('registerSubjects.filterEmpty'),
    selectedSuffix: t('registerSubjects.selectedSuffix'),
    baselineSelectedCount: autoAssignedCount,
    baselineTotalCount: autoAssignedCount,
  };
%>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title><%= t('registerSubjects.title') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --accent: #5e7cff;
        --accent-strong: #3f67ec;
        --page-radius: 28px;
        --page-text: #0f172a;
        --page-muted: rgba(15, 23, 42, 0.68);
        --glass-light: rgba(255, 255, 255, 0.72);
        --glass-dark: rgba(20, 24, 34, 0.5);
        --glass-border-light: rgba(15, 23, 42, 0.08);
        --glass-border-dark: rgba(255, 255, 255, 0.12);
      }

      body {
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", Helvetica, Arial, sans-serif;
        color: var(--page-text);
        transition: background 220ms ease, color 220ms ease;
      }

      body.theme-light {
        --page-text: #0f172a;
        --page-muted: rgba(15, 23, 42, 0.68);
        background:
          radial-gradient(1200px 760px at 18% 10%, rgba(147, 197, 253, 0.3), transparent 60%),
          radial-gradient(920px 640px at 88% 12%, rgba(196, 181, 253, 0.28), transparent 58%),
          linear-gradient(135deg, #eef2ff 0%, #f0f7ff 48%, #f9fbff 100%);
      }

      body.theme-dark {
        --page-text: #f8fafc;
        --page-muted: rgba(226, 232, 240, 0.72);
        background:
          radial-gradient(1200px 780px at 12% 10%, rgba(88, 99, 230, 0.28), transparent 62%),
          radial-gradient(940px 700px at 86% 12%, rgba(152, 93, 255, 0.28), transparent 58%),
          linear-gradient(160deg, #15184b 0%, #1a2266 44%, #231a6a 100%);
      }

      .glass {
        position: relative;
        overflow: clip;
        border-radius: var(--page-radius);
        -webkit-backdrop-filter: blur(22px) saturate(1.08);
        backdrop-filter: blur(22px) saturate(1.08);
        transition: background 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
      }

      body.theme-light .glass {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.54));
        border: 1px solid var(--glass-border-light);
        box-shadow: 0 28px 70px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.72);
      }

      body.theme-dark .glass {
        background: linear-gradient(180deg, rgba(22, 28, 40, 0.74), rgba(15, 20, 32, 0.58));
        border: 1px solid var(--glass-border-dark);
        box-shadow: 0 30px 72px rgba(2, 6, 23, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.03);
      }

      .auth-card {
        border: 0;
        overflow: visible;
      }

      .container {
        position: relative;
        z-index: 1;
      }

      .text-muted {
        color: var(--page-muted) !important;
      }

      .theme-toggle-floating {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 20;
      }

      .theme-toggle-min {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        padding: 0;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.14);
        color: inherit;
        font-size: 1rem;
        line-height: 1;
        -webkit-backdrop-filter: blur(14px);
        backdrop-filter: blur(14px);
      }

      body.theme-light .theme-toggle-min {
        border-color: rgba(15, 23, 42, 0.08);
        background: rgba(255, 255, 255, 0.76);
      }

      .btn {
        transition: transform 140ms ease, box-shadow 140ms ease, opacity 140ms ease;
      }

      .btn:hover:not(:disabled) {
        transform: translateY(-1px);
      }

      .btn-primary {
        border: 0;
        border-radius: 16px;
        padding: 0.82rem 1.15rem;
        font-weight: 650;
        background: linear-gradient(180deg, var(--accent) 0%, var(--accent-strong) 100%);
        box-shadow: 0 16px 28px rgba(79, 108, 236, 0.28);
      }

      .btn-primary:disabled {
        opacity: 0.56;
        box-shadow: none;
        transform: none;
      }

      .flash-alert {
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
        padding: 0.95rem 1rem;
        border-radius: 20px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.46));
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.1);
        -webkit-backdrop-filter: blur(14px);
        backdrop-filter: blur(14px);
      }

      .flash-alert__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.8rem;
        height: 1.8rem;
        flex: 0 0 1.8rem;
        border-radius: 999px;
        font-size: 0.86rem;
        font-weight: 700;
      }

      .flash-alert__body {
        min-width: 0;
      }

      .flash-alert__title {
        display: block;
        margin-bottom: 0.18rem;
        font-size: 0.92rem;
        font-weight: 650;
      }

      .flash-alert__text {
        margin: 0;
        font-size: 0.89rem;
        line-height: 1.5;
      }

      .flash-alert.alert-danger {
        color: #8b1d32;
        border-color: rgba(225, 29, 72, 0.18);
        background: linear-gradient(180deg, rgba(255, 241, 242, 0.96), rgba(255, 228, 230, 0.8));
      }

      .flash-alert.alert-danger .flash-alert__icon {
        background: rgba(225, 29, 72, 0.12);
        color: #be123c;
      }

      .flash-alert.alert-info {
        color: #1d4ed8;
        border-color: rgba(96, 165, 250, 0.16);
        background: linear-gradient(180deg, rgba(239, 246, 255, 0.96), rgba(219, 234, 254, 0.78));
      }

      .flash-alert.alert-info .flash-alert__icon {
        background: rgba(59, 130, 246, 0.12);
        color: #2563eb;
      }

      body.theme-dark .flash-alert {
        color: #e2e8f0;
        border-color: rgba(191, 219, 254, 0.12);
        background: linear-gradient(180deg, rgba(21, 28, 40, 0.86), rgba(18, 24, 37, 0.72));
        box-shadow: 0 24px 42px rgba(2, 6, 23, 0.32);
      }

      body.theme-dark .flash-alert.alert-danger {
        color: #fecdd3;
        border-color: rgba(251, 113, 133, 0.18);
        background: linear-gradient(180deg, rgba(79, 24, 42, 0.9), rgba(57, 17, 33, 0.74));
      }

      body.theme-dark .flash-alert.alert-danger .flash-alert__icon {
        background: rgba(251, 113, 133, 0.16);
        color: #fda4af;
      }

      body.theme-dark .flash-alert.alert-info {
        color: #dbeafe;
        border-color: rgba(96, 165, 250, 0.18);
        background: linear-gradient(180deg, rgba(26, 40, 70, 0.86), rgba(20, 30, 56, 0.74));
      }

      body.theme-dark .flash-alert.alert-info .flash-alert__icon {
        background: rgba(96, 165, 250, 0.16);
        color: #bfdbfe;
      }

      .app-footer {
        font-size: 0.8rem;
      }

      @media (max-width: 767.98px) {
        .theme-toggle-floating {
          top: 12px;
          right: 12px;
        }

        .theme-toggle-min {
          height: 40px;
        }

      }
    </style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
    <link rel="stylesheet" href="/css/auth-actions.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/register-groups.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-light page-register-subjects">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>

    <div class="theme-toggle-floating">
      <button
        class="theme-toggle-min"
        type="button"
        id="themeToggle"
        aria-label="Змінити тему"
        data-light-label="☀️"
        data-dark-label="🌙"
      >
        🌙
      </button>
    </div>

    <div class="container py-4">
      <div class="row justify-content-center">
        <div class="col-11 col-sm-10 col-md-9 col-lg-8 col-xl-7">
          <div class="card auth-card glass reg-groups-card">
            <div class="card-body p-4 p-lg-5">
              <div class="reg-groups-hero">
                <div>
                  <h1 class="h4 mb-2"><%= t('registerSubjects.title') %></h1>
                  <p class="text-muted reg-groups-subtitle mb-0"><%= t('registerSubjects.subtitle') %></p>
                </div>
              </div>

              <% if (subjectRegistrationErrorText) { %>
                <div class="alert alert-danger flash-alert mb-3" role="alert">
                  <span class="flash-alert__icon" aria-hidden="true">!</span>
                  <div class="flash-alert__body">
                    <span class="flash-alert__title"><%= t('registerSubjects.alertTitleAction') %></span>
                    <p class="flash-alert__text"><%= subjectRegistrationErrorText %></p>
                  </div>
                </div>
              <% } %>

              <% if (projectionAlert && projectionAlert.body) { %>
                <div class="alert alert-warning flash-alert mb-3" role="alert">
                  <span class="flash-alert__icon" aria-hidden="true">!</span>
                  <div class="flash-alert__body">
                    <span class="flash-alert__title"><%= projectionAlert.title %></span>
                    <p class="flash-alert__text"><%= projectionAlert.body %></p>
                  </div>
                </div>
              <% } %>

              <form method="POST" action="/register/subjects" id="registerGroupsForm" data-reg-groups-form novalidate>
                <% subjectCards.forEach(function(subject) { %>
                  <% if (subject.autoAssigned) { %>
                    <input type="hidden" name="subject_<%= subject.id %>" value="<%= subject.selectedGroup || 1 %>" />
                  <% } %>
                <% }); %>

                <% if (showNoSubjectsNotice) { %>
                  <div class="alert alert-info flash-alert mb-3" role="status">
                    <span class="flash-alert__icon" aria-hidden="true">i</span>
                    <div class="flash-alert__body">
                      <span class="flash-alert__title"><%= t('registerSubjects.noSubjectsTitle') %></span>
                      <p class="flash-alert__text"><%= t('registerSubjects.noSubjects') %></p>
                    </div>
                  </div>
                <% } else if (showAutoAssignedNotice) { %>
                  <div class="alert alert-info flash-alert mb-3" role="status">
                    <span class="flash-alert__icon" aria-hidden="true">i</span>
                    <div class="flash-alert__body">
                      <span class="flash-alert__title"><%= t('registerSubjects.autoAssignedTitle') %></span>
                      <p class="flash-alert__text"><%= t('registerSubjects.autoAssignedText') %></p>
                    </div>
                  </div>
                <% } %>

                <% if (showNoSubjectsNotice || showAutoAssignedNotice) { %>
                  <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <% if (showAutoAssignedNotice) { %>
                      <button type="submit" class="btn btn-primary"><%= t('registerSubjects.finish') %></button>
                      <span class="text-muted small">
                        <%= lang === 'en'
                          ? 'Required disciplines are already assigned. Finish registration to open Home and Schedule.'
                          : 'Обов’язкові дисципліни вже призначені. Завершіть реєстрацію, щоб відкрити Home і розклад.' %>
                      </span>
                    <% } else { %>
                      <a class="btn btn-outline-secondary" href="/register/course">
                        <%= lang === 'en' ? 'Back to course step' : 'Назад до вибору курсу' %>
                      </a>
                      <span class="text-muted small">
                        <%= lang === 'en'
                          ? 'This pathway currently exposes no disciplines, so the student would enter Home with an empty study route until an administrator fixes the cohort mapping.'
                          : 'Цей pathway зараз не відкриває жодної дисципліни, тому студент потрапить на Home з порожнім навчальним маршрутом, доки адміністратор не виправить мапінг когорти.' %>
                      </span>
                    <% } %>
                  </div>
                <% } %>

                <% if (hasQuickSelect) { %>
                  <section class="reg-groups-surface reg-groups-quick-panel" aria-labelledby="quickSelectHeading">
                    <div class="reg-groups-quick-panel__copy">
                      <span class="reg-groups-kicker" id="quickSelectHeading"><%= t('registerSubjects.quickTitle') %></span>
                      <p class="mb-0 text-muted"><%= t('registerSubjects.quickText') %></p>
                    </div>
                    <div class="reg-groups-quick-panel__actions" role="group" aria-label="<%= t('registerSubjects.quickTitle') %>">
                      <% quickGroupOptions.forEach((g) => { %>
                        <button
                          type="button"
                          class="reg-groups-quick-pill <%= quickSelectedGroup === g ? 'is-active' : '' %>"
                          data-reg-groups-quick-group="<%= g %>"
                          aria-pressed="<%= quickSelectedGroup === g ? 'true' : 'false' %>"
                        >
                          <%= t('registerSubjects.group') %> <%= g %>
                        </button>
                      <% }) %>
                      <button type="button" class="reg-groups-reset" data-reg-groups-reset>
                        <%= t('registerSubjects.resetSelection') %>
                      </button>
                    </div>
                  </section>
                <% } %>

                <% if (subjectCards.length) { %>
                  <section class="reg-groups-surface reg-groups-list-panel">
                    <div class="reg-groups-list-head">
                      <div>
                        <span class="reg-groups-kicker"><%= lang === 'en' ? 'Registration catalog' : 'Каталог реєстрації' %></span>
                        <p class="reg-groups-list-head__copy mb-0">
                          <%= lang === 'en'
                            ? `${totalVisibleCount} disciplines are visible in this route.`
                            : `У цьому маршруті видно ${totalVisibleCount} дисциплін.` %>
                        </p>
                      </div>
                      <div class="reg-groups-list-head__meta" aria-label="<%= lang === 'en' ? 'Catalog summary' : 'Підсумок каталогу' %>">
                        <% if (autoAssignedCount) { %>
                          <span class="reg-groups-list-head__pill"><%= autoAssignedCount %> <%= lang === 'en' ? 'auto-ready' : 'авто-готово' %></span>
                        <% } %>
                        <% if (pendingSelectableSubjects.length) { %>
                          <span class="reg-groups-list-head__pill is-pending"><%= pendingSelectableSubjects.length %> <%= lang === 'en' ? 'need your choice' : 'потребують вибору' %></span>
                        <% } %>
                      </div>
                    </div>

                    <div class="reg-groups-list" data-reg-groups-list>
                      <% renderedSubjectCards.forEach(function(subject) { %>
                        <% const subjectStatusText = subject.optedOut
                          ? t('registerSubjects.statusSkipped')
                          : (subject.autoAssigned
                            ? (lang === 'en' ? 'Ready' : 'Готово')
                            : (subject.selectedGroup ? t('registerSubjects.statusSelected') : t('registerSubjects.statusPending'))); %>
                        <div
                          class="reg-groups-row<%= subject.pending ? ' is-pending' : '' %><%= subject.optedOut ? ' is-opted-out' : '' %><%= subject.autoAssigned ? ' is-auto-assigned' : '' %>"
                          data-reg-groups-row
                          data-subject-id="<%= subject.id %>"
                          data-subject-name="<%= subject.name %>"
                          data-group-count="<%= subject.groupCount %>"
                          data-opted-out="<%= subject.optedOut ? '1' : '0' %>"
                          data-required="<%= subject.requiredFlag ? '1' : '0' %>"
                          data-allow-not-taught="<%= subject.allowNotTaught ? '1' : '0' %>"
                          data-manual-selectable="<%= subject.interactive ? '1' : '0' %>"
                          data-auto-assigned="<%= subject.autoAssigned ? '1' : '0' %>"
                        >
                          <div class="reg-groups-row__heading">
                            <div class="reg-groups-row__title-stack">
                              <div class="reg-groups-row__title-line">
                                <span class="reg-groups-row__title"><%= subject.name %></span>
                                <span class="reg-groups-row__chip">
                                  <%= subject.requiredFlag ? t('registerSubjects.required') : t('registerSubjects.optional') %>
                                </span>
                              </div>
                            </div>

                            <span class="reg-groups-row__status" data-reg-groups-status>
                              <span class="reg-groups-row__status-dot" aria-hidden="true"></span>
                              <span data-reg-groups-status-label><%= subjectStatusText %></span>
                            </span>
                          </div>

                          <div
                            class="reg-groups-row__actions<%= subject.allowNotTaught ? ' reg-groups-row__actions--stacked' : '' %>"
                            role="group"
                            aria-label="<%= subject.name %>"
                          >
                            <div class="reg-groups-row__group-buttons">
                              <% for (let g = 1; g <= subject.groupCount; g += 1) { %>
                                <button
                                  type="button"
                                  class="reg-groups-pill <%= subject.selectedGroup === g ? 'is-active' : '' %>"
                                  data-reg-groups-group="<%= g %>"
                                  aria-pressed="<%= subject.selectedGroup === g ? 'true' : 'false' %>"
                                >
                                  <%= t('registerSubjects.group') %> <%= g %>
                                </button>
                              <% } %>
                            </div>
                            <% if (subject.allowNotTaught) { %>
                              <div class="reg-groups-row__optout">
                                <button
                                  type="button"
                                  class="reg-groups-pill reg-groups-pill--optout <%= subject.optedOut ? 'is-active' : '' %>"
                                  data-reg-groups-optout-btn
                                  aria-pressed="<%= subject.optedOut ? 'true' : 'false' %>"
                                >
                                  <%= t('registerSubjects.optout') %>
                                </button>
                              </div>
                            <% } %>
                          </div>

                          <input
                            type="hidden"
                            name="subject_<%= subject.id %>"
                            value="<%= subject.selectedGroup || '' %>"
                            data-reg-groups-input
                          />
                          <% if (subject.allowNotTaught) { %>
                            <input
                              type="hidden"
                              name="optout_<%= subject.id %>"
                              value="<%= subject.optedOut ? '1' : '0' %>"
                              data-reg-groups-optout
                            />
                          <% } %>
                        </div>
                      <% }); %>

                      <% if (autoAssignedSubjects.length) { %>
                        <div class="reg-groups-list-section">
                          <div class="reg-groups-list-section__head">
                            <span class="reg-groups-kicker"><%= t('registerSubjects.autoAssignedSectionTitle') %></span>
                            <p class="reg-groups-list-section__copy mb-0"><%= t('registerSubjects.autoAssignedSectionText') %></p>
                          </div>

                          <div class="reg-groups-list reg-groups-list--static">
                            <% autoAssignedSubjects.forEach(function(subject) { %>
                              <div class="reg-groups-row is-auto-assigned">
                                <div class="reg-groups-row__heading">
                                  <div class="reg-groups-row__title-stack">
                                    <div class="reg-groups-row__title-line">
                                      <span class="reg-groups-row__title"><%= subject.name %></span>
                                      <span class="reg-groups-row__chip"><%= t('registerSubjects.required') %></span>
                                    </div>
                                  </div>

                                  <span class="reg-groups-row__status">
                                    <span class="reg-groups-row__status-dot" aria-hidden="true"></span>
                                    <span><%= lang === 'en' ? 'Ready' : 'Готово' %></span>
                                  </span>
                                </div>

                                <div class="reg-groups-row__actions reg-groups-row__actions--static" aria-hidden="true">
                                  <span class="reg-groups-pill reg-groups-pill--static is-active">
                                    <%= t('registerSubjects.group') %> <%= subject.selectedGroup || 1 %>
                                  </span>
                                </div>
                              </div>
                            <% }); %>
                          </div>
                        </div>
                      <% } %>
                    </div>

                    <% if (renderedSubjectCards.length) { %>
                      <p class="reg-groups-filter-empty" data-reg-groups-empty hidden><%= t('registerSubjects.filterEmpty') %></p>
                    <% } %>
                  </section>
                <% } %>
              </form>
            </div>
          </div>

          <% if (selectableSubjects.length) { %>
            <div class="reg-groups-sticky-shell">
              <div class="reg-groups-sticky glass">
                <div class="reg-groups-sticky__meta">
                  <div class="reg-groups-sticky__summary">
                    <div class="reg-groups-sticky__count">
                      <strong><span data-reg-groups-selected><%= configuredSubjectCount %></span>/<span data-reg-groups-total><%= totalVisibleCount %></span></strong>
                      <span><%= t('registerSubjects.selectedSuffix') %></span>
                    </div>
                    <p class="reg-groups-sticky__remaining mb-0" data-reg-groups-remaining role="status" aria-live="polite">
                      <%= remainingText %>
                    </p>
                    <p
                      class="reg-groups-sticky__missing mb-0"
                      data-reg-groups-missing
                      role="status"
                      aria-live="polite"
                      <%= missingSummaryText ? '' : 'hidden' %>
                    >
                      <%= missingSummaryText %>
                    </p>
                    <div
                      class="reg-groups-progress-bar reg-groups-sticky__progress"
                      role="progressbar"
                      aria-label="<%= t('registerSubjects.progressSelected') %>"
                      aria-valuemin="0"
                      aria-valuemax="<%= totalVisibleCount %>"
                      aria-valuenow="<%= configuredSubjectCount %>"
                      data-reg-groups-progress
                    >
                      <span style="width: <%= progressPercent %>%;" data-reg-groups-progress-bar></span>
                    </div>
                  </div>

                  <label class="reg-groups-filter reg-groups-filter--sticky">
                    <input type="checkbox" data-reg-groups-filter />
                    <span><%= t('registerSubjects.filterUnselected') %></span>
                  </label>
                </div>

                <div class="reg-groups-sticky__actions">
                  <p
                    class="reg-groups-sticky__hint mb-0"
                    data-reg-groups-submit-hint
                    <%= submitHintText ? '' : 'hidden' %>
                  ><%= submitHintText %></p>
                  <button
                    type="submit"
                    form="registerGroupsForm"
                    class="btn btn-primary reg-groups-submit-btn"
                    data-reg-groups-submit
                    <%= hasPendingSelections ? 'disabled' : '' %>
                  >
                    <%= t('registerSubjects.finish') %>
                  </button>
                </div>
              </div>
            </div>
          <% } %>

          <%- include('partials/app-footer') %>
        </div>
      </div>
    </div>

    <%- include('partials/changelog-modal') %>

    <script>
      window.__registerGroupsConfig = <%- JSON.stringify(registerGroupsUi) %>;
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';

      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);

      if (themeToggle) {
        themeToggle.textContent = savedTheme === 'theme-dark'
          ? themeToggle.dataset.lightLabel
          : themeToggle.dataset.darkLabel;

        themeToggle.addEventListener('click', () => {
          const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(next);
          localStorage.setItem('ui-theme', next);
          themeToggle.textContent = next === 'theme-dark'
            ? themeToggle.dataset.lightLabel
            : themeToggle.dataset.darkLabel;
        });
      }
    </script>
    <script src="/js/register-groups.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
    <script src="/js/design-system.js" defer></script>
    <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
