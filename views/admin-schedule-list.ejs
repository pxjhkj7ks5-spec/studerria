<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Розклад · список</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --accent: #3b82f6;
        --accent-dark: #2563eb;
        --radius: 16px;
        --glass-border-dark: rgba(255, 255, 255, 0.14);
        --glass-border-light: rgba(15, 23, 42, 0.12);
        --glass-bg-dark: rgba(255, 255, 255, 0.06);
        --glass-bg-light: rgba(255, 255, 255, 0.35);
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", "Inter", Arial, sans-serif;
        min-height: 100vh;
      }
      body.theme-light {
        background: radial-gradient(1200px 800px at 20% 10%, rgba(147, 197, 253, 0.22), transparent 60%),
          radial-gradient(1000px 700px at 90% 20%, rgba(196, 181, 253, 0.22), transparent 60%),
          linear-gradient(135deg, #e6eef8 0%, #e9f0fb 45%, #eef2ff 100%);
        color: #0f172a;
      }
      body.theme-dark {
        background: radial-gradient(1200px 800px at 15% 10%, rgba(59, 130, 246, 0.22), transparent 60%),
          radial-gradient(1000px 700px at 80% 20%, rgba(14, 165, 233, 0.18), transparent 60%),
          linear-gradient(160deg, #0b0f1a 0%, #141b30 100%);
        color: #f8fafc;
      }
      body.theme-dark .text-dark {
        color: #f8fafc !important;
      }
      .admin-nav {
        backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      body.theme-light .admin-nav {
        background: rgba(255, 255, 255, 0.8);
        border-bottom-color: rgba(15, 23, 42, 0.12);
      }
      body.theme-dark .admin-nav {
        background: rgba(10, 10, 20, 0.6);
      }
      .card {
        position: relative;
        isolation: isolate;
        overflow: clip;
        background-clip: padding-box;
        border-radius: var(--radius);
        backdrop-filter: blur(20px);
        transition: background 220ms ease, border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
      }
      body.theme-dark .card {
        background: rgba(18, 24, 40, 0.72);
        color: #f8fafc;
        border-color: rgba(255, 255, 255, 0.08);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45);
      }
      body.theme-light .card {
        background: rgba(255, 255, 255, 0.72);
        border-color: var(--glass-border-light);
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.14), 0 0 0 1px rgba(255, 255, 255, 0.4) inset;
      }
      .windows-modal .modal-content {
        border-radius: 18px;
        background: rgba(15, 23, 42, 0.88);
        border: 1px solid rgba(148, 163, 184, 0.25);
        color: #f8fafc;
      }
      body.theme-light .windows-modal .modal-content {
        background: rgba(255, 255, 255, 0.96);
        color: #0f172a;
        border-color: rgba(15, 23, 42, 0.12);
      }
      .windows-modal .modal-header {
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      }
      body.theme-light .windows-modal .modal-header {
        border-bottom: 1px solid rgba(15, 23, 42, 0.12);
      }
      .windows-note {
        font-size: 0.85rem;
        color: rgba(148, 163, 184, 0.8);
      }
      body.theme-light .windows-note {
        color: rgba(15, 23, 42, 0.6);
      }
      .windows-course-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 8px 12px;
      }
      .windows-day {
        padding: 10px 12px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
      }
      body.theme-light .windows-day {
        background: rgba(15, 23, 42, 0.04);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .windows-day-title {
        font-weight: 600;
        margin-bottom: 6px;
      }
      .window-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        background: rgba(59, 130, 246, 0.18);
        border: 1px solid rgba(59, 130, 246, 0.35);
        color: #e0f2fe;
      }
      body.theme-light .window-chip {
        color: #1e3a8a;
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(59, 130, 246, 0.22);
      }
      .windows-empty {
        font-size: 0.9rem;
        color: rgba(148, 163, 184, 0.8);
      }
      body.theme-light .windows-empty {
        color: rgba(15, 23, 42, 0.6);
      }
    </style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
      <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-light schedule-list-page">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand">Розклад (список)</span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted">
            <%= role === 'admin' ? t('role.admin') : (role === 'deanery' ? t('role.deanery') : (role === 'starosta' ? t('role.starosta') : t('role.user'))) %>: <%= username %>
          </span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="Toggle theme"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-primary btn-sm me-2" href="<%= adminHomeHref || '/admin' %>">Назад в адмінку</a>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h1 class="h3 mb-0">Список пар</h1>
        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#courseWindowsModal">
            Спільні вікна
          </button>
          <a class="btn btn-outline-secondary btn-sm" href="/admin/schedule-summary">Сводка семестру</a>
          <div class="text-muted">Показуємо по <%= perPage %> записів</div>
        </div>
      </div>

      <% if (allowCourseSelect) { %>
        <form class="mb-3" method="GET" action="/admin/schedule-list">
          <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0"><%= t('admin.course') %></label>
            <select name="course" class="form-select w-auto" onchange="this.form.submit()">
              <% (courses || []).forEach(function(c) { %>
                <option value="<%= c.id %>" <%= Number(selectedCourseId) === Number(c.id) ? 'selected' : '' %>>
                  <%= c.name %>
                </option>
              <% }); %>
            </select>
          </div>
        </form>
      <% } %>

      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3"><%= t('admin.filters') %></h5>
          <form method="GET" action="/admin/schedule-list">
            <input type="hidden" name="course" value="<%= selectedCourseId %>" />
            <div class="row g-2">
              <div class="col-12 col-md-3">
                <input class="form-control" name="group_number" placeholder="Group number" value="<%= (filters && filters.group_number) || '' %>" />
              </div>
              <div class="col-12 col-md-3">
                <select class="form-select" name="day">
                  <option value="">All days</option>
                  <% (activeScheduleDays || ['Monday','Tuesday','Wednesday','Thursday','Friday']).forEach(function(d) { %>
                    <option value="<%= d %>" <%= filters && filters.day === d ? 'selected' : '' %>><%= d %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-12 col-md-3">
                <input class="form-control" name="subject" placeholder="Subject" value="<%= (filters && filters.subject) || '' %>" />
              </div>
              <div class="col-12 col-md-3">
                <input class="form-control" type="date" name="schedule_date" value="<%= (filters && filters.schedule_date) || '' %>" />
              </div>
            </div>
            <div class="row g-2 mt-2">
              <div class="col-12 col-md-3 d-grid">
                <button class="btn btn-outline-primary" type="submit"><%= t('admin.apply') %></button>
              </div>
              <div class="col-12 col-md-3">
                <select class="form-select" name="sort_schedule">
                  <option value=""><%= t('admin.sortSchedule') %></option>
                  <option value="group" <%= sorts && sorts.schedule === 'group' ? 'selected' : '' %>><%= t('admin.sortGroup') %></option>
                  <option value="day" <%= sorts && sorts.schedule === 'day' ? 'selected' : '' %>><%= t('admin.sortDay') %></option>
                  <option value="time" <%= sorts && sorts.schedule === 'time' ? 'selected' : '' %>><%= t('admin.sortTime') %></option>
                </select>
              </div>
              <div class="col-12 col-md-3 d-grid">
                <button class="btn btn-outline-secondary" type="submit"><%= t('admin.applySort') %></button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <div class="d-flex flex-wrap gap-2 mb-2">
            <button class="btn btn-outline-danger btn-sm" type="submit" form="deleteScheduleForm">Delete Selected</button>
            <form id="clearScheduleForm" method="POST" action="/admin/schedule/clear-all">
              <button
                class="btn btn-danger btn-sm"
                type="submit"
                onclick="return confirm('Clear ALL schedule entries?');"
              >
                Clear All
              </button>
            </form>
          </div>
          <div class="table-responsive">
            <table class="table table-striped align-middle">
              <thead>
                <tr>
                  <th><input type="checkbox" id="selectAllSchedule" /></th>
                  <th>ID</th>
                  <th>Subject</th>
                  <th>Type</th>
                  <th>Group #</th>
                  <th>Day</th>
                  <th>Semester</th>
                  <th>Class #</th>
                  <th>Week</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% (schedule || []).forEach(function(item) { %>
                  <tr>
                    <td><input type="checkbox" name="delete_ids" value="<%= item.id %>" form="deleteScheduleForm" /></td>
                    <td><%= item.id %></td>
                    <td>
                      <select class="form-select form-select-sm" name="subject_id" form="edit-<%= item.id %>" required>
                        <% (subjects || []).forEach(function(s) { %>
                          <option value="<%= s.id %>" <%= item.subject_id === s.id ? 'selected' : '' %>><%= s.name %></option>
                        <% }); %>
                      </select>
                    </td>
                    <td>
                      <select class="form-select form-select-sm schedule-lesson-type" name="lesson_type" form="edit-<%= item.id %>">
                        <option value="" <%= !item.lesson_type ? 'selected' : '' %>>Auto</option>
                        <option value="lecture" <%= item.lesson_type === 'lecture' ? 'selected' : '' %>>Лекція</option>
                        <option value="seminar" <%= item.lesson_type === 'seminar' ? 'selected' : '' %>>Семінар</option>
                        <option value="lab" <%= item.lesson_type === 'lab' ? 'selected' : '' %>>Лаб</option>
                        <option value="practice" <%= item.lesson_type === 'practice' ? 'selected' : '' %>>Практика</option>
                      </select>
                    </td>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <input class="form-control form-control-sm schedule-group-input" name="group_number" form="edit-<%= item.id %>" value="<%= item.group_number %>" type="number" min="1" max="3" required />
                        <% if (Number(item.slot_group_count || 0) > 1) { %>
                          <span
                            class="badge text-bg-primary"
                            title="Групи: <%= item.slot_group_list || '' %>"
                            data-bs-toggle="tooltip"
                          >
                            Мульти‑групи
                          </span>
                        <% } %>
                      </div>
                    </td>
                    <td>
                      <select class="form-select form-select-sm" name="day_of_week" form="edit-<%= item.id %>" required>
                        <% (activeScheduleDays || ['Monday','Tuesday','Wednesday','Thursday','Friday']).forEach(function(d) { %>
                          <option value="<%= d %>" <%= item.day_of_week === d ? 'selected' : '' %>><%= d %></option>
                        <% }); %>
                      </select>
                    </td>
                    <td>
                      <select class="form-select form-select-sm" name="semester_id" form="edit-<%= item.id %>" required>
                        <% (semesters || []).forEach(function(sem) { %>
                          <option value="<%= sem.id %>" <%= item.semester_id === sem.id ? 'selected' : '' %>><%= sem.title %></option>
                        <% }); %>
                      </select>
                    </td>
                    <td>
                      <select class="form-select form-select-sm" name="class_number" form="edit-<%= item.id %>" required>
                        <% [1,2,3,4,5,6,7].forEach(function(n) { %>
                          <option value="<%= n %>" <%= item.class_number === n ? 'selected' : '' %>><%= n %></option>
                        <% }); %>
                      </select>
                    </td>
                    <td>
                      <input class="form-control form-control-sm" name="week_number" form="edit-<%= item.id %>" value="<%= item.week_number %>" type="number" min="1" max="<%= activeSemester && activeSemester.weeks_count ? activeSemester.weeks_count : 15 %>" required />
                    </td>
                    <td class="d-flex gap-2">
                      <form id="edit-<%= item.id %>" method="POST" action="/admin/schedule/edit/<%= item.id %>" class="d-inline"></form>
                      <button class="btn btn-sm btn-outline-secondary" type="submit" form="edit-<%= item.id %>">Save</button>
                      <form method="POST" action="/admin/schedule/delete/<%= item.id %>" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('Delete this class from schedule?');">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
                <% if (!(schedule || []).length) { %>
                  <tr><td colspan="10" class="text-muted">Нічого не знайдено</td></tr>
                <% } %>
              </tbody>
            </table>
            <form id="deleteScheduleForm" method="POST" action="/admin/schedule/delete-multiple">
              <% if (pagination && pagination.pageBase) { %>
                <input type="hidden" name="return_to" value="<%= pagination.pageBase %><%= pagination.page %>" />
              <% } %>
            </form>
          </div>
        </div>
      </div>

      <nav class="d-flex justify-content-between align-items-center">
        <div class="text-muted">Сторінка <%= pagination.page %> з <%= pagination.totalPages %></div>
        <ul class="pagination mb-0">
          <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.pageBase %><%= pagination.page - 1 %>">Назад</a>
          </li>
          <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.pageBase %><%= pagination.page + 1 %>">Далі</a>
          </li>
        </ul>
      </nav>

      <%- include('partials/app-footer') %>
    </main>

    <div class="modal fade windows-modal" id="courseWindowsModal" tabindex="-1" aria-labelledby="courseWindowsLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="courseWindowsLabel">Спільні вікна курсів</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="windows-note mb-3">
              Оберіть курси та тиждень — покажемо слоти, де у всіх вибраних курсів немає пар.
            </p>
            <form id="courseWindowsForm">
              <div class="mb-3">
                <label class="form-label">Курси</label>
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <button class="btn btn-outline-secondary btn-sm" type="button" data-windows-select="all">Всі</button>
                  <button class="btn btn-outline-secondary btn-sm" type="button" data-windows-select="none">Очистити</button>
                </div>
                <div class="windows-course-list">
                  <% (courses || []).forEach(function(c) { %>
                    <label class="form-check">
                      <input class="form-check-input windows-course" type="checkbox" value="<%= c.id %>" />
                      <span class="form-check-label"><%= c.name %></span>
                    </label>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label" for="courseWindowsWeek">Тиждень</label>
                <input class="form-control" id="courseWindowsWeek" type="number" min="1" max="30" placeholder="Напр. 3" />
              </div>
              <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" type="submit">Показати вікна</button>
                <span class="text-muted small align-self-center" id="courseWindowsStatus"></span>
              </div>
            </form>
            <div class="mt-4">
              <div class="fw-semibold mb-2" id="courseWindowsSummary"></div>
              <div class="d-flex flex-column gap-2" id="courseWindowsWarnings"></div>
              <div class="d-grid gap-2 mt-3" id="courseWindowsResult"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/changelog-modal') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      const labelLight = themeToggle.dataset.lightLabel || 'Light';
      const labelDark = themeToggle.dataset.darkLabel || 'Dark';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggle.textContent = savedTheme === 'theme-dark' ? labelLight : labelDark;
      themeToggle.addEventListener('click', () => {
        const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
        document.body.classList.remove('theme-light', 'theme-dark');
        document.body.classList.add(next);
        localStorage.setItem('ui-theme', next);
        themeToggle.textContent = next === 'theme-dark' ? labelLight : labelDark;
      });

      function wireSelectOpenState(root = document) {
        root.querySelectorAll('select.form-select').forEach((select) => {
          select.addEventListener('pointerdown', () => {
            select.classList.add('select-open');
          });
          select.addEventListener('keydown', (event) => {
            if ([' ', 'Enter', 'ArrowDown'].includes(event.key)) {
              select.classList.add('select-open');
            }
          });
          select.addEventListener('change', () => {
            select.classList.remove('select-open');
          });
          select.addEventListener('blur', () => {
            select.classList.remove('select-open');
          });
        });
      }

      wireSelectOpenState();

      function syncScheduleGroupLocks(root = document) {
        const rows = Array.from(root.querySelectorAll('tbody tr'));
        rows.forEach((row) => {
          const typeSelect = row.querySelector('.schedule-lesson-type');
          const groupInput = row.querySelector('.schedule-group-input');
          if (!typeSelect || !groupInput) return;
          const isLecture = String(typeSelect.value || '') === 'lecture';
          if (isLecture) {
            groupInput.value = '1';
            groupInput.readOnly = true;
            groupInput.classList.add('input-locked');
          } else {
            groupInput.readOnly = false;
            groupInput.classList.remove('input-locked');
          }
        });
      }

      document.querySelectorAll('.schedule-lesson-type').forEach((select) => {
        select.addEventListener('change', () => syncScheduleGroupLocks());
      });
      syncScheduleGroupLocks();

      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
        new bootstrap.Tooltip(el);
      });

      const selectAll = document.getElementById('selectAllSchedule');
      if (selectAll) {
        selectAll.addEventListener('change', () => {
          document.querySelectorAll('input[name="delete_ids"]').forEach((checkbox) => {
            checkbox.checked = selectAll.checked;
          });
        });
      }

      const windowsForm = document.getElementById('courseWindowsForm');
      const windowsWeek = document.getElementById('courseWindowsWeek');
      const windowsStatus = document.getElementById('courseWindowsStatus');
      const windowsSummary = document.getElementById('courseWindowsSummary');
      const windowsWarnings = document.getElementById('courseWindowsWarnings');
      const windowsResult = document.getElementById('courseWindowsResult');
      const windowsCourseInputs = Array.from(document.querySelectorAll('.windows-course'));

      function clearChildren(node) {
        if (!node) return;
        while (node.firstChild) {
          node.removeChild(node.firstChild);
        }
      }

      function renderWindowsEmpty(message) {
        clearChildren(windowsResult);
        const empty = document.createElement('div');
        empty.className = 'windows-empty';
        empty.textContent = message;
        windowsResult.appendChild(empty);
      }

      function renderWindowsWarnings(messages) {
        clearChildren(windowsWarnings);
        (Array.isArray(messages) ? messages : []).forEach((message) => {
          const alert = document.createElement('div');
          alert.className = 'alert alert-warning py-2 px-3 mb-0';
          alert.textContent = String(message || '');
          windowsWarnings.appendChild(alert);
        });
      }

      function renderWindowsDays(days) {
        clearChildren(windowsResult);
        (Array.isArray(days) ? days : []).forEach((day) => {
          const dayCard = document.createElement('div');
          dayCard.className = 'windows-day';

          const title = document.createElement('div');
          title.className = 'windows-day-title';
          title.textContent = String(day && day.day ? day.day : '');
          dayCard.appendChild(title);

          const chipsWrap = document.createElement('div');
          chipsWrap.className = 'd-flex flex-wrap gap-2';
          (Array.isArray(day && day.slots ? day.slots : []) ? day.slots : []).forEach((slot) => {
            const chip = document.createElement('span');
            chip.className = 'window-chip';
            const time = slot && slot.time ? String(slot.time) : '--:--';
            const classNumber = Number(slot && slot.class_number ? slot.class_number : 0) || '—';
            chip.textContent = `${time} · ${classNumber} пара`;
            chipsWrap.appendChild(chip);
          });
          dayCard.appendChild(chipsWrap);
          windowsResult.appendChild(dayCard);
        });
      }

      function renderWindowsDaysSafe(days) {
        clearChildren(windowsResult);
        (Array.isArray(days) ? days : []).forEach((day) => {
          const dayCard = document.createElement('div');
          dayCard.className = 'windows-day';

          const title = document.createElement('div');
          title.className = 'windows-day-title';
          title.textContent = String(day && day.day ? day.day : '');
          dayCard.appendChild(title);

          const chipsWrap = document.createElement('div');
          chipsWrap.className = 'd-flex flex-wrap gap-2';
          const slots = Array.isArray(day && day.slots) ? day.slots : [];
          slots.forEach((slot) => {
            const chip = document.createElement('span');
            chip.className = 'window-chip';
            const time = slot && slot.time ? String(slot.time) : '--:--';
            const classNumber = Number(slot && slot.class_number ? slot.class_number : 0);
            chip.textContent = classNumber > 0 ? `${time} · ${classNumber}` : time;
            chipsWrap.appendChild(chip);
          });
          dayCard.appendChild(chipsWrap);
          windowsResult.appendChild(dayCard);
        });
      }

      function collectSelectedCourses() {
        return windowsCourseInputs.filter((input) => input.checked).map((input) => Number(input.value)).filter((id) => Number.isFinite(id));
      }

      document.querySelectorAll('[data-windows-select]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const mode = btn.dataset.windowsSelect;
          const next = mode === 'all';
          windowsCourseInputs.forEach((input) => {
            input.checked = next;
          });
        });
      });

      if (windowsForm) {
        windowsForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          const courseIds = collectSelectedCourses();
          const weekNumber = Number(windowsWeek.value);
          windowsSummary.textContent = '';
          clearChildren(windowsWarnings);
          clearChildren(windowsResult);
          if (!courseIds.length) {
            renderWindowsEmpty('Оберіть хоча б один курс.');
            return;
          }
          if (!Number.isFinite(weekNumber) || weekNumber < 1) {
            renderWindowsEmpty('Вкажіть коректний тиждень.');
            return;
          }
          windowsStatus.textContent = 'Рахуємо...';
          try {
            const res = await fetch('/admin/schedule-windows', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ course_ids: courseIds, week_number: weekNumber }),
            });
            const payload = await res.json();
            if (!res.ok) {
              throw new Error(payload?.error || 'Помилка');
            }
            if (!payload.ok) {
              if (payload.warnings && payload.warnings.length) {
                renderWindowsWarnings(payload.warnings);
              }
              renderWindowsEmpty(payload.error || 'Немає даних для розрахунку.');
              return;
            }
            windowsSummary.textContent = payload.summary || '';
            if (payload.warnings && payload.warnings.length) {
              renderWindowsWarnings(payload.warnings);
            }
            if (!payload.windows || !payload.windows.length) {
              renderWindowsEmpty('Спільних вікон не знайдено.');
              return;
            }
            renderWindowsDaysSafe(payload.windows);
          } catch (err) {
            renderWindowsEmpty('Не вдалося отримати вікна. Спробуйте ще раз.');
          } finally {
            windowsStatus.textContent = '';
          }
        });
      }
    </script>
      <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
</html>
