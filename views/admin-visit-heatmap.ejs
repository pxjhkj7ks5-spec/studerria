<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Visit heatmap · admin</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <style>
      :root {
        --heat-radius: 18px;
      }
      body {
        min-height: 100vh;
      }
      .admin-nav {
        backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      body.theme-light .admin-nav {
        background: rgba(255, 255, 255, 0.8);
        border-bottom-color: rgba(15, 23, 42, 0.12);
      }
      body.theme-dark .admin-nav {
        background: rgba(10, 10, 20, 0.6);
      }
      .heatmap-shell {
        display: grid;
        gap: 1rem;
      }
      .heatmap-head {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.8rem;
      }
      .heatmap-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.8rem;
      }
      .heat-metric {
        border: 1px solid rgba(148, 163, 184, 0.24);
        border-radius: var(--heat-radius);
        padding: 0.85rem 1rem;
      }
      .heat-metric-value {
        font-size: clamp(1.3rem, 1.8vw, 1.8rem);
        line-height: 1.1;
        font-weight: 700;
        margin-top: 0.2rem;
      }
      .heatmap-map-card {
        overflow: hidden;
      }
      .heatmap-map {
        width: 100%;
        height: min(68vh, 700px);
        min-height: 460px;
        border-radius: var(--heat-radius);
        border: 1px solid rgba(148, 163, 184, 0.2);
      }
      .heatmap-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .heat-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.72rem;
        border-radius: 999px;
        border: 1px solid rgba(99, 102, 241, 0.25);
        font-size: 0.82rem;
      }
      .map-source-table td,
      .map-source-table th {
        vertical-align: middle;
      }
      .ip-cell {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.86rem;
      }
      .users-cell {
        max-width: 320px;
      }
      .users-cell .small {
        display: block;
      }
      @media (max-width: 992px) {
        .heatmap-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .heatmap-map {
          min-height: 420px;
        }
      }
      @media (max-width: 575px) {
        .heatmap-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body class="studerria-theme theme-light visit-heatmap-page">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%
      const numberFormatter = new Intl.NumberFormat('uk-UA');
      const formatNumber = (value) => numberFormatter.format(Number(value || 0));
      const roleLabelMap = {
        admin: 'Адмін',
        deanery: 'Деканат',
        starosta: 'Староста',
        teacher: 'Викладач',
        student: 'Студент',
        guest: 'Гість',
        anonymous: 'Гість',
      };
      const formatRoleLabel = (value) => roleLabelMap[String(value || '').trim().toLowerCase()] || String(value || 'guest');
      const scopeLabel = selectedScope === 'system'
        ? 'Вся система'
        : (selectedCourse && selectedCourse.name ? selectedCourse.name : 'Обраний курс');
      const dataUrl = String(heatmapDataUrl || '/admin/visit-heatmap.json');
      const filtersObj = filters || {};
    %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand">Visit heatmap</span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted">
            <%= role === 'admin' ? t('role.admin') : (role === 'deanery' ? t('role.deanery') : (role === 'starosta' ? t('role.starosta') : t('role.user'))) %>: <%= username %>
          </span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="Toggle theme"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-primary btn-sm me-2" href="<%= analyticsPanelHref || adminHomeHref || '/admin' %>">Security analytics</a>
          <a class="btn btn-outline-secondary btn-sm me-2" href="<%= visitLogHref || '/admin/visit-log' %>">Журнал візитів</a>
          <a class="btn btn-outline-secondary btn-sm me-2" href="<%= adminHomeHref || '/admin' %>">Назад в адмінку</a>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="heatmap-shell">
        <div class="card">
          <div class="card-body">
            <div class="heatmap-head">
              <div>
                <h1 class="h3 mb-1">Heatmap заходів за IP</h1>
                <div class="text-muted">OpenStreetMap + групування за IP. Включає guest трафік.</div>
              </div>
              <div class="heatmap-legend">
                <span class="heat-badge"><strong>Scope:</strong> <%= scopeLabel %></span>
                <span class="heat-badge"><strong>Days:</strong> <%= formatNumber(filtersObj.days || 14) %></span>
                <span class="heat-badge"><strong>Admins:</strong> <%= filtersObj.exclude_admin ? 'excluded' : 'included' %></span>
                <span class="heat-badge"><strong>Guests:</strong> <%= filtersObj.guest_only ? 'only' : 'all' %></span>
              </div>
            </div>
            <form method="GET" action="/admin/visit-heatmap" class="row g-3 align-items-end mt-1">
              <% if (canUseSystemScope) { %>
                <div class="col-12 col-md-3 col-xl-2">
                  <label class="form-label">Scope</label>
                  <select class="form-select" name="scope">
                    <option value="course" <%= selectedScope === 'course' ? 'selected' : '' %>>Курс</option>
                    <option value="system" <%= selectedScope === 'system' ? 'selected' : '' %>>Вся система</option>
                  </select>
                </div>
              <% } %>
              <% if (allowCourseSelect && selectedScope !== 'system') { %>
                <div class="col-12 col-md-3 col-xl-3">
                  <label class="form-label">Курс</label>
                  <select class="form-select" name="course">
                    <% (courses || []).forEach(function(course) { %>
                      <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>><%= course.name %></option>
                    <% }); %>
                  </select>
                </div>
              <% } else if (selectedScope !== 'system') { %>
                <input type="hidden" name="course" value="<%= selectedCourseId %>" />
              <% } %>
              <div class="col-12 col-md-3 col-xl-2">
                <label class="form-label">Період</label>
                <select class="form-select" name="days">
                  <% [7, 14, 30, 60, 90].forEach(function(option) { %>
                    <option value="<%= option %>" <%= Number(filtersObj.days || 14) === option ? 'selected' : '' %>><%= option %> днів</option>
                  <% }); %>
                </select>
              </div>
              <div class="col-12 col-md-3 col-xl-2">
                <input type="hidden" name="exclude_admin" value="0" />
                <div class="form-check form-switch pt-4">
                  <input class="form-check-input" type="checkbox" role="switch" id="excludeAdminFilter" name="exclude_admin" value="1" <%= filtersObj.exclude_admin ? 'checked' : '' %> />
                  <label class="form-check-label" for="excludeAdminFilter">Без адмінів</label>
                </div>
              </div>
              <div class="col-12 col-md-3 col-xl-2">
                <input type="hidden" name="guest_only" value="0" />
                <div class="form-check form-switch pt-4">
                  <input class="form-check-input" type="checkbox" role="switch" id="guestOnlyFilter" name="guest_only" value="1" <%= filtersObj.guest_only ? 'checked' : '' %> />
                  <label class="form-check-label" for="guestOnlyFilter">Лише guest</label>
                </div>
              </div>
              <div class="col-12 col-md-2 col-xl-1 d-grid">
                <button class="btn btn-primary" type="submit">Apply</button>
              </div>
            </form>
          </div>
        </div>

        <div class="heatmap-grid">
          <div class="heat-metric">
            <div class="small text-muted">Побудованих точок</div>
            <div class="heat-metric-value" id="metricPoints">—</div>
          </div>
          <div class="heat-metric">
            <div class="small text-muted">Унікальних IP</div>
            <div class="heat-metric-value" id="metricIps">—</div>
          </div>
          <div class="heat-metric">
            <div class="small text-muted">Всього подій</div>
            <div class="heat-metric-value" id="metricEvents">—</div>
          </div>
          <div class="heat-metric">
            <div class="small text-muted">Guest-подій</div>
            <div class="heat-metric-value" id="metricGuest">—</div>
          </div>
        </div>

        <div class="card heatmap-map-card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
              <h5 class="mb-0">Geo heatmap</h5>
              <div class="small text-muted" id="heatmapStatus">Завантаження...</div>
            </div>
            <div id="visitHeatmap" class="heatmap-map" aria-label="Visit heatmap"></div>
          </div>
        </div>

        <div class="card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
              <h6 class="mb-0">Джерела (топ по IP)</h6>
              <div class="small text-muted" id="unresolvedHint"></div>
            </div>
            <div class="table-responsive">
              <table class="table table-striped table-sm align-middle map-source-table">
                <thead>
                  <tr>
                    <th>IP</th>
                    <th>Локація</th>
                    <th>Візити</th>
                    <th>Guests</th>
                    <th>Користувачі</th>
                    <th>Top pages</th>
                    <th>Last seen</th>
                  </tr>
                </thead>
                <tbody id="sourcesBody">
                  <tr>
                    <td colspan="7" class="text-muted">Завантаження...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      crossorigin="anonymous"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet.heat@0.2.0/dist/leaflet-heat.js" crossorigin="anonymous"></script>
    <script src="/js/design-system.js" defer></script>
    <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
    <script>
      (function initVisitHeatmapPage() {
        const numberFmt = new Intl.NumberFormat('uk-UA');
        const dataUrl = <%- JSON.stringify(dataUrl) %>;
        const statusNode = document.getElementById('heatmapStatus');
        const unresolvedHintNode = document.getElementById('unresolvedHint');
        const sourceBody = document.getElementById('sourcesBody');
        const setMetric = (id, value) => {
          const el = document.getElementById(id);
          if (!el) return;
          el.textContent = numberFmt.format(Number(value || 0));
        };
        const roleLabel = (value) => {
          const key = String(value || '').toLowerCase();
          if (key === 'admin') return 'Адмін';
          if (key === 'deanery') return 'Деканат';
          if (key === 'starosta') return 'Староста';
          if (key === 'teacher') return 'Викладач';
          if (key === 'student') return 'Студент';
          return 'Гість';
        };
        const formatDate = (value) => {
          const date = value ? new Date(value) : null;
          if (!date || Number.isNaN(date.getTime())) return '—';
          return date.toLocaleString('uk-UA');
        };

        const map = L.map('visitHeatmap', {
          zoomControl: true,
          worldCopyJump: true,
        }).setView([20, 0], 2);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors',
        }).addTo(map);

        let activeHeatLayer = null;
        let pointLayer = L.layerGroup().addTo(map);

        const renderSourcesTable = (points = []) => {
          if (!sourceBody) return;
          if (!points.length) {
            sourceBody.innerHTML = '<tr><td colspan="7" class="text-muted">Немає даних для побудови.</td></tr>';
            return;
          }
          const topRows = points.slice(0, 60);
          sourceBody.innerHTML = topRows.map((item) => {
            const users = Array.isArray(item.users) ? item.users : [];
            const pages = Array.isArray(item.pages) ? item.pages : [];
            const usersHtml = users.length
              ? users.map((user) => `<span class="small">${String(user.name || 'Guest')} · ${roleLabel(user.role_key)} · ${numberFmt.format(Number(user.hits || 0))}</span>`).join('')
              : '<span class="small text-muted">—</span>';
            const pagesHtml = pages.length
              ? pages.map((page) => `<span class="badge text-bg-secondary me-1">${String(page.page_key || 'unknown')} (${numberFmt.format(Number(page.hits || 0))})</span>`).join('')
              : '<span class="text-muted">—</span>';
            const location = [item.city, item.region, item.country].filter(Boolean).join(', ') || 'Unknown';
            return `
              <tr>
                <td class="ip-cell">${String(item.ip || '—')}</td>
                <td>${location}</td>
                <td>${numberFmt.format(Number(item.visits || 0))}</td>
                <td>${numberFmt.format(Number(item.guest_visits || 0))}</td>
                <td class="users-cell">${usersHtml}</td>
                <td>${pagesHtml}</td>
                <td>${formatDate(item.last_seen_at)}</td>
              </tr>
            `;
          }).join('');
        };

        const renderMap = (points = []) => {
          pointLayer.clearLayers();
          if (activeHeatLayer) {
            map.removeLayer(activeHeatLayer);
            activeHeatLayer = null;
          }
          if (!points.length) return;
          const maxVisits = points.reduce((max, item) => Math.max(max, Number(item.visits || 0)), 1);
          const heatRows = points.map((item) => [
            Number(item.latitude || 0),
            Number(item.longitude || 0),
            Math.max(0.2, Math.min(1, Number(item.visits || 0) / maxVisits)),
          ]);
          activeHeatLayer = L.heatLayer(heatRows, {
            radius: 28,
            blur: 20,
            maxZoom: 10,
            minOpacity: 0.35,
          }).addTo(map);

          const bounds = [];
          points.forEach((item) => {
            const lat = Number(item.latitude);
            const lon = Number(item.longitude);
            if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;
            bounds.push([lat, lon]);
            const visits = Number(item.visits || 0);
            const users = Array.isArray(item.users) ? item.users : [];
            const pages = Array.isArray(item.pages) ? item.pages : [];
            const userLabel = users.length
              ? users.map((user) => `${String(user.name || 'Guest')} (${roleLabel(user.role_key)})`).join(', ')
              : 'Guest';
            const tooltip = `
              <div style="min-width:240px">
                <div><strong>${String(item.city || item.region || item.country || 'Unknown')}</strong></div>
                <div><small>${String(item.ip || '')}</small></div>
                <div>Візити: <strong>${numberFmt.format(visits)}</strong></div>
                <div>Guest: <strong>${numberFmt.format(Number(item.guest_visits || 0))}</strong></div>
                <div>Користувачі: ${userLabel}</div>
                <div>Сторінки: ${pages.map((page) => `${String(page.page_key || 'unknown')} (${numberFmt.format(Number(page.hits || 0))})`).join(', ') || '—'}</div>
                <div>Last seen: ${formatDate(item.last_seen_at)}</div>
              </div>
            `;
            const marker = L.circleMarker([lat, lon], {
              radius: Math.max(5, Math.min(16, 5 + Math.sqrt(visits))),
              weight: 1.2,
              color: '#93c5fd',
              fillColor: '#2563eb',
              fillOpacity: 0.68,
            });
            marker.bindTooltip(tooltip, { sticky: true, direction: 'top' });
            marker.on('mouseover', () => marker.openTooltip());
            marker.addTo(pointLayer);
          });

          if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [36, 36], maxZoom: 5 });
          }
        };

        const fetchData = async () => {
          if (statusNode) statusNode.textContent = 'Оновлення даних...';
          try {
            const response = await fetch(dataUrl, {
              headers: {
                Accept: 'application/json',
              },
              credentials: 'same-origin',
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || !payload || payload.ok !== true) {
              throw new Error((payload && payload.error) || `http_${response.status}`);
            }
            const summary = payload.summary || {};
            const points = Array.isArray(payload.points) ? payload.points : [];
            const unresolved = Array.isArray(payload.unresolved) ? payload.unresolved : [];
            setMetric('metricPoints', summary.plotted_points || points.length);
            setMetric('metricIps', summary.total_unique_ips || 0);
            setMetric('metricEvents', summary.total_events || 0);
            setMetric('metricGuest', summary.guest_events || 0);
            if (statusNode) {
              statusNode.textContent = `Точок на мапі: ${numberFmt.format(points.length)} · Оновлено: ${new Date().toLocaleTimeString('uk-UA')}`;
            }
            if (unresolvedHintNode) {
              unresolvedHintNode.textContent = unresolved.length
                ? `Нерозвʼязаних IP: ${numberFmt.format(unresolved.length)}`
                : 'Усі IP, які вдалося визначити, нанесено на мапу.';
            }
            renderMap(points);
            renderSourcesTable(points);
          } catch (err) {
            if (statusNode) statusNode.textContent = `Помилка завантаження: ${String(err && err.message ? err.message : err)}`;
            if (sourceBody) {
              sourceBody.innerHTML = '<tr><td colspan="7" class="text-danger">Не вдалося завантажити дані heatmap.</td></tr>';
            }
          }
        };

        fetchData();
      })();
    </script>
  </body>
</html>
