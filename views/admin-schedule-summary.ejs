<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'light' }) %>
    <title>Зведення семестру</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --summary-accent: #4e7d5a;
        --summary-accent-strong: #2f5b3a;
        --summary-border-light: rgba(30, 41, 59, 0.12);
        --summary-border-dark: rgba(255, 255, 255, 0.12);
        --summary-surface-light: rgba(255, 255, 255, 0.8);
        --summary-surface-dark: rgba(13, 23, 19, 0.74);
        --summary-shadow-light: 0 18px 44px rgba(35, 51, 41, 0.14);
        --summary-shadow-dark: 0 20px 50px rgba(0, 0, 0, 0.38);
        --summary-radius: 22px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", Arial, sans-serif;
        min-height: 100vh;
      }

      body.theme-light {
        background:
          radial-gradient(1100px 720px at 8% 10%, rgba(151, 204, 168, 0.24), transparent 60%),
          radial-gradient(900px 640px at 88% 16%, rgba(241, 218, 170, 0.24), transparent 58%),
          linear-gradient(145deg, #edf3ea 0%, #f6f1e7 50%, #edf2f8 100%);
        color: #14221a;
      }

      body.theme-dark {
        background:
          radial-gradient(1100px 720px at 8% 10%, rgba(87, 143, 103, 0.18), transparent 60%),
          radial-gradient(900px 640px at 88% 16%, rgba(164, 131, 82, 0.18), transparent 58%),
          linear-gradient(160deg, #09110d 0%, #0f1b15 46%, #16261d 100%);
        color: #f3f7f2;
      }

      .admin-nav {
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      body.theme-light .admin-nav {
        background: rgba(255, 255, 255, 0.76);
        border-bottom-color: var(--summary-border-light);
      }

      body.theme-dark .admin-nav {
        background: rgba(7, 14, 11, 0.68);
        border-bottom-color: var(--summary-border-dark);
      }

      .summary-card {
        border-radius: var(--summary-radius);
        backdrop-filter: blur(22px);
        overflow: hidden;
      }

      body.theme-light .summary-card {
        background: var(--summary-surface-light);
        border: 1px solid var(--summary-border-light);
        box-shadow: var(--summary-shadow-light);
      }

      body.theme-dark .summary-card {
        background: var(--summary-surface-dark);
        border: 1px solid var(--summary-border-dark);
        box-shadow: var(--summary-shadow-dark);
      }

      .hero-card {
        position: relative;
        overflow: hidden;
      }

      .hero-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(135deg, rgba(78, 125, 90, 0.22), rgba(241, 218, 170, 0.1)),
          linear-gradient(180deg, rgba(255, 255, 255, 0.12), transparent 72%);
        pointer-events: none;
      }

      .hero-card .card-body {
        position: relative;
        z-index: 1;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      body.theme-light .hero-eyebrow {
        background: rgba(255, 255, 255, 0.74);
        color: #355542;
      }

      body.theme-dark .hero-eyebrow {
        background: rgba(255, 255, 255, 0.08);
        color: #dbe8de;
      }

      .hero-title {
        font-size: clamp(2rem, 3vw, 2.8rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
        margin: 0;
      }

      .hero-subtitle {
        max-width: 720px;
        margin: 0;
        font-size: 1rem;
        line-height: 1.6;
        color: rgba(100, 116, 139, 0.92);
      }

      body.theme-dark .hero-subtitle {
        color: rgba(226, 232, 240, 0.76);
      }

      .summary-metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 12px;
      }

      .metric-tile {
        padding: 14px 16px;
        border-radius: 18px;
      }

      body.theme-light .metric-tile {
        background: rgba(255, 255, 255, 0.74);
        border: 1px solid rgba(78, 125, 90, 0.14);
      }

      body.theme-dark .metric-tile {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .metric-label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #64748b;
      }

      body.theme-dark .metric-label {
        color: rgba(226, 232, 240, 0.66);
      }

      .metric-value {
        display: block;
        margin-top: 6px;
        font-size: 1.15rem;
        font-weight: 600;
        color: inherit;
      }

      .summary-form .form-label {
        font-size: 0.88rem;
        font-weight: 600;
        color: #4b5563;
      }

      body.theme-dark .summary-form .form-label {
        color: rgba(226, 232, 240, 0.82);
      }

      .summary-form .form-select {
        border-radius: 16px;
        min-height: 50px;
      }

      .sheet-frame {
        border-radius: 20px;
        overflow: hidden;
      }

      body.theme-light .sheet-frame {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(47, 91, 58, 0.14);
      }

      body.theme-dark .sheet-frame {
        background: rgba(9, 17, 13, 0.68);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .semester-summary-table {
        width: 100%;
        min-width: 960px;
        border-collapse: separate;
        border-spacing: 0;
      }

      .semester-summary-table thead th {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.16);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #f8fdf8;
        background: linear-gradient(135deg, #4e7d5a 0%, #2f5b3a 100%);
      }

      .semester-summary-table thead th + th {
        border-left: 1px solid rgba(255, 255, 255, 0.14);
      }

      .semester-summary-table tbody th,
      .semester-summary-table tbody td {
        padding: 14px 16px;
        vertical-align: middle;
        border-bottom: 1px solid rgba(100, 116, 139, 0.16);
      }

      body.theme-dark .semester-summary-table tbody th,
      body.theme-dark .semester-summary-table tbody td {
        border-bottom-color: rgba(255, 255, 255, 0.08);
      }

      .semester-summary-table tbody td + td,
      .semester-summary-table tbody th + td {
        border-left: 1px solid rgba(100, 116, 139, 0.12);
      }

      body.theme-dark .semester-summary-table tbody td + td,
      body.theme-dark .semester-summary-table tbody th + td {
        border-left-color: rgba(255, 255, 255, 0.08);
      }

      .day-col {
        width: 76px;
      }

      .time-col {
        width: 132px;
      }

      .day-marker {
        min-width: 76px;
        padding: 0;
        text-align: center;
        background:
          linear-gradient(180deg, rgba(78, 125, 90, 0.14), rgba(78, 125, 90, 0.04)),
          rgba(255, 255, 255, 0.58);
      }

      body.theme-dark .day-marker {
        background:
          linear-gradient(180deg, rgba(95, 162, 112, 0.18), rgba(95, 162, 112, 0.06)),
          rgba(255, 255, 255, 0.02);
      }

      .day-marker__wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        width: 100%;
        padding: 12px 0;
      }

      .day-marker__full {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--summary-accent-strong);
      }

      body.theme-dark .day-marker__full {
        color: #d8ead8;
      }

      .day-marker__short {
        display: none;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .time-cell strong {
        display: block;
        font-size: 1rem;
        letter-spacing: -0.02em;
      }

      .time-cell span {
        display: block;
        margin-top: 4px;
        font-size: 0.8rem;
        color: #64748b;
      }

      body.theme-dark .time-cell span {
        color: rgba(226, 232, 240, 0.66);
      }

      .subject-cell strong {
        display: block;
        font-size: 0.98rem;
        line-height: 1.4;
      }

      .subject-cell span {
        display: block;
        margin-top: 6px;
        font-size: 0.82rem;
        color: #64748b;
      }

      body.theme-dark .subject-cell span {
        color: rgba(226, 232, 240, 0.72);
      }

      .cell-muted {
        color: #64748b;
        font-size: 0.92rem;
        line-height: 1.55;
      }

      body.theme-dark .cell-muted {
        color: rgba(226, 232, 240, 0.74);
      }

      .subjects-card,
      .notice-card {
        border-radius: 18px;
        padding: 18px 20px;
      }

      body.theme-light .subjects-card,
      body.theme-light .notice-card {
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(47, 91, 58, 0.1);
      }

      body.theme-dark .subjects-card,
      body.theme-dark .notice-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .section-title {
        margin: 0 0 12px;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .subject-chip-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .subject-chip {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 0.9rem;
        line-height: 1.25;
      }

      body.theme-light .subject-chip {
        background: rgba(78, 125, 90, 0.1);
        color: #24422d;
        border: 1px solid rgba(78, 125, 90, 0.12);
      }

      body.theme-dark .subject-chip {
        background: rgba(95, 162, 112, 0.14);
        color: #e5f2e5;
        border: 1px solid rgba(95, 162, 112, 0.18);
      }

      .empty-state {
        padding: 26px;
        border-radius: 18px;
        text-align: center;
      }

      body.theme-light .empty-state {
        background: rgba(255, 255, 255, 0.72);
        color: #52606f;
      }

      body.theme-dark .empty-state {
        background: rgba(255, 255, 255, 0.05);
        color: rgba(226, 232, 240, 0.74);
      }

      @media (max-width: 767.98px) {
        .hero-title {
          font-size: 1.8rem;
        }

        .semester-summary-table {
          min-width: 840px;
        }

        .day-marker {
          min-width: 62px;
        }

        .day-marker__full {
          display: none;
        }

        .day-marker__short {
          display: block;
        }
      }
    </style>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin.css" />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-light schedule-summary-page">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <nav class="navbar navbar-expand-lg admin-nav">
      <div class="container">
        <span class="navbar-brand">Зведення семестру</span>
        <div class="d-flex align-items-center">
          <span class="me-3 text-muted">
            <%= role === 'admin' ? t('role.admin') : (role === 'deanery' ? t('role.deanery') : (role === 'starosta' ? t('role.starosta') : t('role.user'))) %>: <%= username %>
          </span>
          <button
            class="theme-toggle theme-toggle-min me-2"
            type="button"
            id="themeToggle"
            aria-label="Toggle theme"
            data-light-label="☀️"
            data-dark-label="🌙"
          >
            🌙
          </button>
          <a class="btn btn-outline-primary btn-sm me-2" href="/admin/schedule-list">До списку пар</a>
          <a class="btn btn-outline-secondary btn-sm me-2" href="<%= adminHomeHref || '/admin' %>">Назад в адмінку</a>
          <form method="POST" action="/logout">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t('admin.logout') %></button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4 py-lg-5">
      <section class="summary-card hero-card mb-3">
        <div class="card-body p-4 p-lg-5">
          <span class="hero-eyebrow">Semester Summary</span>
          <div class="mt-3 d-flex flex-column gap-3">
            <h1 class="hero-title">Таблиця активних предметів для вибраного семестру</h1>
            <p class="hero-subtitle">
              Сторінка будує щільну таблицю за зразком навчального документа: лише для вибраного курсу,
              обраного семестру та предметів, які в ньому активні.
            </p>
          </div>

          <div class="summary-metrics mt-4">
            <div class="metric-tile">
              <span class="metric-label">Курс</span>
              <span class="metric-value"><%= selectedCourse ? selectedCourse.name : '—' %></span>
            </div>
            <div class="metric-tile">
              <span class="metric-label">Семестр</span>
              <span class="metric-value"><%= activeSemester ? activeSemester.title : 'Не вибрано' %></span>
            </div>
            <div class="metric-tile">
              <span class="metric-label">Активні предмети</span>
              <span class="metric-value"><%= Number(semesterSummaryStats && semesterSummaryStats.active_subjects_total || 0) %></span>
            </div>
            <div class="metric-tile">
              <span class="metric-label">Рядків у таблиці</span>
              <span class="metric-value"><%= Number(semesterSummaryStats && semesterSummaryStats.table_rows_total || 0) %></span>
            </div>
          </div>
        </div>
      </section>

      <section class="summary-card mb-3">
        <div class="card-body p-4">
          <form id="semesterSummaryScopeForm" class="summary-form" method="GET" action="/admin/schedule-summary">
            <div class="row g-3 align-items-end">
              <div class="col-12 col-md-5">
                <label class="form-label mb-2"><%= t('admin.course') %></label>
                <select
                  id="summaryCourseSelect"
                  name="course_id"
                  class="form-select"
                  <%= allowCourseSelect ? '' : 'disabled' %>
                >
                  <% (courses || []).forEach(function(course) { %>
                    <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>>
                      <%= course.name %>
                    </option>
                  <% }); %>
                </select>
                <% if (!allowCourseSelect) { %>
                  <input type="hidden" name="course_id" value="<%= Number(selectedCourseId || 0) %>" />
                <% } %>
              </div>
              <div class="col-12 col-md-5">
                <label class="form-label mb-2">Семестр</label>
                <select id="summarySemesterSelect" name="semester_id" class="form-select">
                  <% (semesters || []).forEach(function(semester) { %>
                    <option value="<%= semester.id %>" <%= activeSemester && Number(semester.id) === Number(activeSemester.id) ? 'selected' : '' %>>
                      <%= semester.title %> · <%= semester.weeks_count %> тижнів
                    </option>
                  <% }); %>
                </select>
              </div>
            </div>
          </form>
        </div>
      </section>

      <section class="summary-card">
        <div class="card-body p-4">
          <% if (!activeSemester) { %>
            <div class="empty-state">Немає активного семестру для вибраного курсу.</div>
          <% } else if (!semesterSummaryDays || !semesterSummaryDays.length) { %>
            <div class="empty-state">
              <% if (semesterSummarySubjects && semesterSummarySubjects.length) { %>
                Для активних предметів цього семестру ще немає заповнених рядків у таблиці.
              <% } else { %>
                Для цього семестру поки немає активних предметів або даних для побудови таблиці.
              <% } %>
            </div>
          <% } else { %>
            <div class="sheet-frame">
              <div class="table-responsive">
                <table class="semester-summary-table">
                  <thead>
                    <tr>
                      <th class="day-col">День</th>
                      <th class="time-col">Час</th>
                      <th>Навчальна дисципліна</th>
                      <th>Викладач</th>
                      <th>Тижні</th>
                      <th>Аудиторія</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (semesterSummaryDays || []).forEach(function(dayBucket) { %>
                      <% (dayBucket.rows || []).forEach(function(row, rowIndex) { %>
                        <tr>
                          <% if (rowIndex === 0) { %>
                            <th class="day-marker" rowspan="<%= dayBucket.rows.length %>">
                              <div class="day-marker__wrap">
                                <span class="day-marker__full"><%= dayBucket.day_name %></span>
                                <span class="day-marker__short"><%= dayBucket.day_short %></span>
                              </div>
                            </th>
                          <% } %>
                          <td class="time-cell">
                            <strong><%= row.time_label %></strong>
                            <span><%= row.class_number %> пара</span>
                          </td>
                          <td class="subject-cell">
                            <strong><%= row.subject_name %></strong>
                            <span><%= row.subject_meta %></span>
                          </td>
                          <td class="cell-muted"><%= row.teacher_label %></td>
                          <td class="cell-muted"><%= row.weeks_label %></td>
                          <td class="cell-muted"><%= row.room_label %></td>
                        </tr>
                      <% }); %>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>

          <% if (semesterSummarySubjects && semesterSummarySubjects.length) { %>
            <div class="subjects-card mt-4">
              <h2 class="section-title">Активні предмети семестру</h2>
              <div class="subject-chip-grid">
                <% (semesterSummarySubjects || []).forEach(function(subject) { %>
                  <span class="subject-chip"><%= subject.name %></span>
                <% }); %>
              </div>
            </div>
          <% } %>

          <% if (semesterSummaryUnscheduledSubjects && semesterSummaryUnscheduledSubjects.length) { %>
            <div class="notice-card mt-3">
              <h2 class="section-title">Без рядків у таблиці</h2>
              <div class="cell-muted">
                <%= semesterSummaryUnscheduledSubjects.map(function(subject) { return subject.name; }).join(', ') %>
              </div>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <script>
      const themeToggle = document.getElementById('themeToggle');
      const savedTheme = localStorage.getItem('ui-theme') || 'theme-light';
      const labelLight = themeToggle.dataset.lightLabel || 'Light';
      const labelDark = themeToggle.dataset.darkLabel || 'Dark';
      document.body.classList.remove('theme-light', 'theme-dark');
      document.body.classList.add(savedTheme);
      themeToggle.textContent = savedTheme === 'theme-dark' ? labelLight : labelDark;
      themeToggle.addEventListener('click', () => {
        const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
        document.body.classList.remove('theme-light', 'theme-dark');
        document.body.classList.add(next);
        localStorage.setItem('ui-theme', next);
        themeToggle.textContent = next === 'theme-dark' ? labelLight : labelDark;
      });

      const scopeForm = document.getElementById('semesterSummaryScopeForm');
      const courseSelect = document.getElementById('summaryCourseSelect');
      const semesterSelect = document.getElementById('summarySemesterSelect');

      const navigateByScope = (event) => {
        if (!scopeForm) return;
        const params = new URLSearchParams(window.location.search || '');
        const rawCourseValue = courseSelect ? String(courseSelect.value || '').trim() : '';
        if (rawCourseValue) {
          params.set('course_id', rawCourseValue);
        } else {
          params.delete('course_id');
        }
        params.delete('course');
        if (event && event.target === courseSelect) {
          params.delete('semester_id');
        } else {
          const rawSemesterValue = semesterSelect ? String(semesterSelect.value || '').trim() : '';
          if (rawSemesterValue) {
            params.set('semester_id', rawSemesterValue);
          } else {
            params.delete('semester_id');
          }
        }
        const action = scopeForm.getAttribute('action') || '/admin/schedule-summary';
        const nextQuery = params.toString();
        const nextUrl = nextQuery ? `${action}?${nextQuery}` : action;
        window.location.assign(nextUrl);
      };

      if (courseSelect && !courseSelect.disabled) {
        courseSelect.addEventListener('change', navigateByScope);
      }
      if (semesterSelect) {
        semesterSelect.addEventListener('change', navigateByScope);
      }
      if (scopeForm) {
        scopeForm.addEventListener('submit', (event) => {
          event.preventDefault();
          navigateByScope(event);
        });
      }
    </script>
    <script src="/js/design-system.js" defer></script>
    <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
