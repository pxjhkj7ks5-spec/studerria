<!doctype html>
<html lang="<%= lang %>" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title><%= lang === 'en' ? 'Registration closed' : 'Реєстрацію закрито' %></title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/pages/auth.css" />
  </head>
  <body class="td-page td-page--login" data-theme="light">
    <main class="td-login-main">
      <section class="td-login-brand" aria-label="Studerria">
        <span class="td-login-logo" aria-hidden="true"><%- include('partials/test-brand-mark', { className: 'td-brand-glyph td-brand-glyph--login' }) %></span>
      </section>
      <section class="td-login-card td-glass-panel">
        <header class="td-login-card-head">
          <h1><%= lang === 'en' ? 'Registration closed' : 'Реєстрацію закрито' %></h1>
          <p><%= lang === 'en' ? 'New profiles can currently be created only through the Studerria Telegram bot.' : 'Нові профілі зараз можна створити лише через Telegram-бота Studerria.' %></p>
        </header>
        <a class="td-primary-button" href="/login"><%= lang === 'en' ? 'Sign in' : 'Увійти' %></a>
      </section>
    </main>
    <%- include('partials/app-footer') %>
  </body>
</html>
