<!doctype html>
<html lang="uk" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/test-theme-head') %>
    <link rel="icon" href="/favicon.svg?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" type="image/svg+xml" />
    <title>Studerria · Test Home</title>
    <link rel="stylesheet" href="/css/test-design.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="td-page td-page--app" data-theme="light">
    <div class="td-app-shell">
      <section class="td-app-frame td-glass-panel" aria-label="Studerria home concept">
        <%- include('partials/test-top-nav', { active: 'home' }) %>

        <main class="td-app-content">
          <header class="td-dashboard-header">
            <div>
              <h1>Доброго дня, Андрію! 👋</h1>
              <p>Ось що відбувається сьогодні.</p>
            </div>
          </header>

          <section class="td-stats-grid" aria-label="Показники">
            <article class="td-stat-card td-surface-card">
              <span class="td-stat-icon"><%- include('partials/test-icon', { name: 'clipboard', className: 'td-stat-svg' }) %></span>
              <span>Завдання</span>
              <strong>14</strong>
              <small><em>3</em> прострочено</small>
            </article>
            <article class="td-stat-card td-surface-card">
              <span class="td-stat-icon"><%- include('partials/test-icon', { name: 'calendarCheck', className: 'td-stat-svg' }) %></span>
              <span>Пари сьогодні</span>
              <strong>3</strong>
              <small>із 5 запланованих</small>
            </article>
            <article class="td-stat-card td-surface-card">
              <span class="td-stat-icon"><%- include('partials/test-icon', { name: 'folder', className: 'td-stat-svg' }) %></span>
              <span>Матеріали</span>
              <strong>27</strong>
              <small>додано цього тижня</small>
            </article>
            <article class="td-stat-card td-surface-card">
              <span class="td-stat-icon"><%- include('partials/test-icon', { name: 'trending', className: 'td-stat-svg' }) %></span>
              <span>Прогрес</span>
              <strong>72%</strong>
              <small>середній показник</small>
            </article>
          </section>

          <section class="td-dashboard-grid">
            <article class="td-dashboard-card td-surface-card td-schedule-preview">
              <header class="td-card-header">
                <h2>Розклад на сьогодні</h2>
                <a class="td-small-button" href="/testschedule">Весь розклад</a>
              </header>
              <div class="td-schedule-list">
                <div class="td-schedule-row is-current">
                  <time>09:00</time>
                  <div>
                    <strong>Операційні системи</strong>
                    <span>Лекція · ауд. 204</span>
                  </div>
                  <span class="td-badge td-badge--violet">Зараз</span>
                </div>
                <div class="td-schedule-row">
                  <time>11:00</time>
                  <div>
                    <strong>Бази даних</strong>
                    <span>Практичне · ауд. 301</span>
                  </div>
                  <span class="td-badge">Далі</span>
                </div>
                <div class="td-schedule-row">
                  <time>13:00</time>
                  <div>
                    <strong>Англійська мова</strong>
                    <span>Практичне · ауд. 105</span>
                  </div>
                  <span class="td-badge">Заплановано</span>
                </div>
              </div>
            </article>

            <article class="td-dashboard-card td-surface-card" id="tasks">
              <header class="td-card-header">
                <h2>Завдання</h2>
                <button class="td-small-button" type="button">Усі завдання</button>
              </header>
              <div class="td-task-list">
                <div class="td-task-row">
                  <%- include('partials/test-icon', { name: 'checkCircle', className: 'td-task-check' }) %>
                  <div><strong>Лабораторна робота №4</strong><span>Операційні системи</span></div>
                  <time class="is-hot">Сьогодні</time>
                </div>
                <div class="td-task-row">
                  <%- include('partials/test-icon', { name: 'checkCircle', className: 'td-task-check' }) %>
                  <div><strong>Есе: Штучний інтелект</strong><span>Філософія</span></div>
                  <time>Завтра</time>
                </div>
                <div class="td-task-row">
                  <%- include('partials/test-icon', { name: 'checkCircle', className: 'td-task-check' }) %>
                  <div><strong>Проєкт: Бази даних</strong><span>Бази даних</span></div>
                  <time>24 трав.</time>
                </div>
                <div class="td-task-row">
                  <%- include('partials/test-icon', { name: 'checkCircle', className: 'td-task-check' }) %>
                  <div><strong>Тест до модулю 2</strong><span>Математичний аналіз</span></div>
                  <time>26 трав.</time>
                </div>
              </div>
              <a class="td-create-link" href="#create">+ Створити завдання</a>
            </article>
          </section>

          <section class="td-lower-grid">
            <article class="td-dashboard-card td-surface-card">
              <header class="td-card-header">
                <h2>Ваш прогрес</h2>
              </header>
              <div class="td-progress-layout">
                <div class="td-progress-ring" aria-label="Прогрес 72%">
                  <span>72%</span>
                </div>
                <div class="td-progress-content">
                  <strong>+8% до минулого тижня</strong>
                  <div class="td-progress-row">
                    <span>Час навчання</span>
                    <b>18 год. 40 хв</b>
                  </div>
                  <div class="td-progress-row">
                    <span>Виконано завдань</span>
                    <b>28 із 36</b>
                  </div>
                  <div class="td-progress-row">
                    <span>Відвідуваність</span>
                    <b>90%</b>
                  </div>
                  <button class="td-secondary-button" type="button">Детальна аналітика</button>
                </div>
              </div>
            </article>

            <article class="td-dashboard-card td-surface-card" id="analytics">
              <header class="td-card-header">
                <h2>Аналітика навчання</h2>
                <button class="td-small-button" type="button">Тиждень <%- include('partials/test-icon', { name: 'chevronDown', className: 'td-mini-chevron' }) %></button>
              </header>
              <div class="td-bar-chart" aria-label="Навчальна активність за тиждень">
                <div class="td-bar-axis"><span>12</span><span>8</span><span>4</span><span>0</span></div>
                <div class="td-bars">
                  <span style="--bar: 74%"><b>Пн</b></span>
                  <span style="--bar: 68%"><b>Вт</b></span>
                  <span class="is-active" style="--bar: 86%"><b>Ср</b></span>
                  <span style="--bar: 66%"><b>Чт</b></span>
                  <span style="--bar: 80%"><b>Пт</b></span>
                  <span style="--bar: 42%"><b>Сб</b></span>
                  <span style="--bar: 55%"><b>Нд</b></span>
                </div>
              </div>
            </article>
          </section>

          <section class="td-ai-strip" aria-label="AI-помічник">
            <span class="td-ai-icon"><%- include('partials/test-icon', { name: 'sparkles', className: 'td-ai-svg' }) %></span>
            <div>
              <h2>AI-помічник</h2>
              <p>Спробуйте запитати: “Поясни різницю між SQL та NoSQL”.</p>
            </div>
            <button class="td-arrow-button" type="button" aria-label="Відкрити AI-помічника">
              <%- include('partials/test-icon', { name: 'arrowRight', className: 'td-arrow-svg' }) %>
            </button>
          </section>
        </main>
      </section>
    </div>
    <script src="/js/test-design.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
