  <body class="studerria-theme theme-dark page-teacher-workspace page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', { role, username, t, activePage: 'teacher-workspace', pageTitle: 'Teacher workspace', settings: settings }) %>
    <%- include('partials/desktop-menu-drawer', {
      role,
      t,
      activePage: 'teacher-workspace',
      settings: (typeof settings !== 'undefined') ? settings : null,
    }) %>

    <main class="container workspace-shell">
      <% if (error) { %>
        <div class="alert alert-danger glass mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success glass mb-3"><%= success %></div>
      <% } %>

      <section class="glass workspace-hero mb-3">
        <h1 class="workspace-title">Teacher workspace</h1>
        <p class="workspace-subtitle">
          Build reusable homework templates and apply them in one click from class cards in schedule modal.
        </p>
        <div class="hero-actions">
          <a class="btn btn-glass" href="/teacher">Teacher hub</a>
          <a class="btn btn-glass" href="/schedule">Schedule</a>
          <a class="btn btn-glass" href="/teacher/subjects">My subjects</a>
          <a class="btn btn-glass" href="/journal">Journal</a>
        </div>
      </section>

      <section class="glass workspace-panel mb-3">
        <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
          <div>
            <h5 class="mb-1">Live teaching scope</h5>
            <p class="hint mb-0">This list now reads from `teacher_offering_assignments` and shows contexts and semesters attached to each live offering.</p>
          </div>
          <span class="badge bg-secondary"><%= teacherOfferingList.length %></span>
        </div>
        <form method="GET" action="/teacher/workspace" class="row g-2 mb-3">
          <div class="col-12 col-lg-4">
            <label class="form-label" for="workspaceContextId">Study context</label>
            <select class="form-select" id="workspaceContextId" name="study_context_id">
              <option value="">All contexts</option>
              <% workspaceContextList.forEach(function(context) { %>
                <option value="<%= context.id %>" <%= Number(selectedWorkspaceContextId) === Number(context.id) ? 'selected' : '' %>><%= context.label %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-lg-4">
            <label class="form-label" for="workspaceSemesterId">Semester</label>
            <select class="form-select" id="workspaceSemesterId" name="semester_id">
              <option value="">All semesters</option>
              <% workspaceSemesterList.forEach(function(semester) { %>
                <option value="<%= semester.id %>" <%= Number(selectedWorkspaceSemesterId) === Number(semester.id) ? 'selected' : '' %>><%= semester.title %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-lg-4">
            <label class="form-label" for="workspaceCourseId">Course scope</label>
            <select class="form-select" id="workspaceCourseId" name="course">
              <option value="">All visible courses</option>
              <% workspaceCourseList.forEach(function(course) { %>
                <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>><%= course.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12">
            <p class="hint mb-0">Primary scope is `study_context_id + semester_id`. Course is derived from the current offering context and used only when older actions still need it.</p>
          </div>
          <div class="col-12 d-flex flex-wrap gap-2">
            <button class="btn btn-primary" type="submit">Apply filters</button>
            <a class="btn btn-outline-secondary" href="/teacher/workspace">Clear</a>
            <a class="btn btn-outline-info" href="/teacher/subjects">Open subject assignments</a>
          </div>
        </form>
        <% if (teacherOfferingList.length) { %>
          <div class="workspace-scope-list">
            <% teacherOfferingList.forEach(function(offering) { %>
              <article class="workspace-scope-card">
                <div class="workspace-scope-head">
                  <div>
                    <h6 class="workspace-scope-title"><%= offering.name %></h6>
                    <div class="workspace-scope-meta">
                      <%= Array.isArray(offering.course_labels) && offering.course_labels.length ? offering.course_labels.join(' • ') : 'Course not bound yet' %>
                    </div>
                  </div>
                  <span class="badge bg-<%= offering.template_id ? 'info' : 'secondary' %>"><%= offering.template_id ? 'template matched' : 'live override' %></span>
                </div>
                <div class="workspace-scope-chip-row">
                  <span class="workspace-scope-chip">Group: <%= offering.group_number || 'all' %></span>
                  <span class="workspace-scope-chip">Contexts: <%= Array.isArray(offering.contexts) ? offering.contexts.length : 0 %></span>
                  <% if (offering.is_shared) { %><span class="workspace-scope-chip">Shared</span><% } %>
                  <% if (offering.is_general) { %><span class="workspace-scope-chip">General</span><% } %>
                </div>
                <div class="workspace-scope-meta"><%= Array.isArray(offering.context_labels) ? offering.context_labels.join(' • ') : '' %></div>
                <% if (Array.isArray(offering.semester_labels) && offering.semester_labels.length) { %>
                  <div class="workspace-scope-chip-row">
                    <% offering.semester_labels.forEach(function(label) { %>
                      <span class="workspace-scope-chip"><%= label %></span>
                    <% }) %>
                  </div>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="alert alert-info mb-0">No live offerings assigned yet. Use <a href="/teacher/subjects">subject assignments</a> to choose offerings and groups.</div>
        <% } %>
      </section>

      <section class="glass workspace-panel mb-3">
        <% const scopedSelectedCount = workspaceCatalogOfferingList.reduce((total, offering) => (
          workspaceSelectionMap.has(Number(offering.id || 0)) ? total + 1 : total
        ), 0); %>
        <div class="workspace-assignment-toolbar mb-3">
          <div>
            <h5 class="mb-1">Edit live assignments</h5>
            <p class="hint mb-0">This is the primary live editor for the visible scope. Save only live overrides, or also update recurring template rules for future cohorts.</p>
          </div>
          <div class="workspace-assignment-status">
            <span class="badge bg-secondary"><%= workspaceCatalogOfferingList.length %> visible</span>
            <span class="badge bg-info-subtle text-info-emphasis" id="workspaceSelectedOfferingsCount"><%= scopedSelectedCount %> selected</span>
          </div>
        </div>
        <% if (workspaceCatalogOfferingList.length) { %>
          <form method="POST" action="/teacher/workspace/offerings" class="d-grid gap-3">
            <input type="hidden" name="course" value="<%= selectedCourseId || '' %>" />
            <input type="hidden" name="study_context_id" value="<%= selectedWorkspaceContextId || '' %>" />
            <input type="hidden" name="semester_id" value="<%= selectedWorkspaceSemesterId || '' %>" />
            <% workspaceCatalogOfferingList.forEach(function(offering) { %>
              <input type="hidden" name="visible_offering_ids" value="<%= offering.id %>" />
            <% }) %>

            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="workspaceSyncTemplates" name="sync_templates" value="1" />
              <label class="form-check-label" for="workspaceSyncTemplates">
                Also update recurring template rules for these visible offerings
              </label>
            </div>

            <div class="workspace-assignment-list">
              <% workspaceCatalogOfferingList.forEach(function(offering) { %>
                <% const selectedGroup = workspaceSelectionMap.get(Number(offering.id || 0)); %>
                <% const isSelected = workspaceSelectionMap.has(Number(offering.id || 0)); %>
                <% const assignedOffering = workspaceAssignedOfferingMap.get(Number(offering.id || 0)) || null; %>
                <article class="workspace-assignment-card <%= isSelected ? 'is-selected' : '' %>" data-offering-card="<%= offering.id %>">
                  <div class="workspace-assignment-grid">
                    <div>
                      <div class="workspace-scope-head">
                        <div>
                          <h6 class="workspace-scope-title"><%= offering.name %></h6>
                          <div class="workspace-scope-meta">
                            <%= Array.isArray(offering.course_labels) && offering.course_labels.length ? offering.course_labels.join(' • ') : 'Course not bound yet' %>
                          </div>
                        </div>
                        <span class="badge bg-<%= assignedOffering && assignedOffering.template_id ? 'info' : (isSelected ? 'secondary' : 'light text-dark') %>">
                          <%= assignedOffering && assignedOffering.template_id ? 'template matched' : (isSelected ? 'live override' : 'available') %>
                        </span>
                      </div>
                      <div class="workspace-scope-chip-row">
                        <span class="workspace-scope-chip">Contexts: <%= Array.isArray(offering.contexts) ? offering.contexts.length : 0 %></span>
                        <% if (offering.is_shared) { %><span class="workspace-scope-chip">Shared</span><% } %>
                        <% if (offering.is_general) { %><span class="workspace-scope-chip">General</span><% } %>
                        <% if (!offering.is_general) { %><span class="workspace-scope-chip">Groups: <%= Number(offering.group_count || 1) %></span><% } %>
                      </div>
                      <div class="workspace-assignment-description mt-2"><%= Array.isArray(offering.context_labels) ? offering.context_labels.join(' • ') : '' %></div>
                      <% if (Array.isArray(offering.semester_labels) && offering.semester_labels.length) { %>
                        <div class="workspace-scope-chip-row">
                          <% offering.semester_labels.forEach(function(label) { %>
                            <span class="workspace-scope-chip"><%= label %></span>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>

                    <div class="workspace-assignment-controls">
                      <div class="form-check form-switch">
                        <input
                          class="form-check-input"
                          type="checkbox"
                          role="switch"
                          id="assign_offering_<%= offering.id %>"
                          name="assign_offering_<%= offering.id %>"
                          value="1"
                          data-offering-toggle="<%= offering.id %>"
                          <%= isSelected ? 'checked' : '' %>
                        />
                        <label class="form-check-label" for="assign_offering_<%= offering.id %>">Assigned</label>
                      </div>
                      <% if (!offering.is_general) { %>
                        <div class="w-100">
                          <label class="form-label small" for="group_offering_<%= offering.id %>">Group</label>
                          <select
                            class="form-select"
                            id="group_offering_<%= offering.id %>"
                            name="group_offering_<%= offering.id %>"
                            data-offering-group="<%= offering.id %>"
                          >
                            <option value="">Select group</option>
                            <% for (let g = 1; g <= Number(offering.group_count || 1); g += 1) { %>
                              <option value="<%= g %>" <%= Number(selectedGroup) === g ? 'selected' : '' %>><%= g %></option>
                            <% } %>
                          </select>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>

            <div class="workspace-assignment-footer">
              <p class="hint mb-0">Only offerings visible in the current filter scope will change. Everything outside this scope stays untouched.</p>
              <button class="btn btn-primary" type="submit">Save live assignments</button>
            </div>
          </form>
        <% } else { %>
          <div class="alert alert-info mb-0">No live offerings in the current scope. Change the course, context, or semester filter first.</div>
        <% } %>
      </section>

      <section class="glass workspace-panel mb-3">
        <div class="template-preview-toolbar mb-3">
          <div>
            <h5 class="mb-1">Recurring template preview</h5>
            <p class="hint mb-0">This preview is built from the current saved live assignments in the visible scope. Save live assignments first if you changed the toggles above.</p>
          </div>
          <div class="workspace-assignment-status">
            <span class="badge bg-secondary"><%= Number(workspaceTemplatePlanValue.visible_count || 0) %> visible</span>
            <span class="badge bg-info-subtle text-info-emphasis"><%= Number(workspaceTemplatePlanValue.selected_count || 0) %> selected</span>
          </div>
        </div>
        <% if (workspaceCatalogOfferingList.length) { %>
          <div class="template-preview-status-grid mb-3">
            <span class="badge bg-success-subtle text-success-emphasis"><%= Number((workspaceTemplatePlanValue.counts || {}).create || 0) %> create</span>
            <span class="badge bg-warning-subtle text-warning-emphasis"><%= Number((workspaceTemplatePlanValue.counts || {}).update || 0) %> update</span>
            <span class="badge bg-danger-subtle text-danger-emphasis"><%= Number((workspaceTemplatePlanValue.counts || {}).deactivate || 0) %> deactivate</span>
            <span class="badge bg-secondary-subtle text-secondary-emphasis"><%= Number((workspaceTemplatePlanValue.counts || {}).keep || 0) %> keep</span>
          </div>

          <% if (workspaceTemplatePreviewItems.length) { %>
            <div class="template-preview-list mb-3">
              <% workspaceTemplatePreviewItems.forEach(function(item) { %>
                <% const statusKey = String(item.status || 'idle'); %>
                <% const statusBadge = workspaceTemplateStatusBadgeMap[statusKey] || 'secondary'; %>
                <% const statusLabel = workspaceTemplateStatusLabelMap[statusKey] || statusKey; %>
                <article class="template-preview-card status-<%= statusKey %>">
                  <div class="template-preview-head">
                    <div>
                      <h6 class="workspace-scope-title mb-0"><%= Array.isArray(item.offering_names) && item.offering_names.length ? item.offering_names.join(' / ') : 'Recurring rule' %></h6>
                      <div class="template-preview-meta">
                        <%= Array.isArray(item.context_labels) && item.context_labels.length ? item.context_labels.join(' • ') : 'No study context labels yet' %>
                      </div>
                    </div>
                    <span class="badge bg-<%= statusBadge %>"><%= statusLabel %></span>
                  </div>
                  <div class="template-preview-scope">
                    <div class="workspace-scope-chip-row">
                      <span class="workspace-scope-chip">Offerings: <%= Array.isArray(item.offering_ids) ? item.offering_ids.length : 0 %></span>
                      <% if (item.group_number) { %><span class="workspace-scope-chip">Group: <%= item.group_number %></span><% } %>
                      <% if (item.stage_number) { %><span class="workspace-scope-chip">Stage: <%= item.stage_number %></span><% } %>
                      <% if (item.campus_key) { %><span class="workspace-scope-chip">Campus: <%= item.campus_key %></span><% } %>
                      <% if (item.track_key) { %><span class="workspace-scope-chip">Track: <%= item.track_key %></span><% } %>
                    </div>
                    <div class="template-preview-meta">
                      <span>Dedup key: <code><%= item.dedupe_key %></code></span>
                      <% if (item.existing_template_id) { %>
                        <span class="ms-2">Existing rule #<%= item.existing_template_id %></span>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="alert alert-info mb-3">
              No recurring template changes are pending for the current scope. The visible live assignments already match the saved recurring rules.
            </div>
          <% } %>

          <form method="POST" action="/teacher/workspace/offering-templates/sync" class="workspace-assignment-footer">
            <input type="hidden" name="course" value="<%= selectedCourseId || '' %>" />
            <input type="hidden" name="study_context_id" value="<%= selectedWorkspaceContextId || '' %>" />
            <input type="hidden" name="semester_id" value="<%= selectedWorkspaceSemesterId || '' %>" />
            <% workspaceCatalogOfferingList.forEach(function(offering) { %>
              <input type="hidden" name="visible_offering_ids" value="<%= offering.id %>" />
            <% }) %>
            <p class="hint mb-0">Sync touches only recurring template rules that match the visible offerings. It does not change live assignments by itself.</p>
            <button class="btn btn-outline-primary" type="submit" <%= workspaceTemplateActionCount > 0 ? '' : 'disabled' %>>
              Sync recurring templates
            </button>
          </form>
        <% } else { %>
          <div class="alert alert-info mb-0">No live offerings in the current scope, so there are no recurring template rules to preview or sync.</div>
        <% } %>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-5">
          <article class="glass workspace-panel mb-3">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
              <div>
                <h5 class="mb-1">Asset library</h5>
                <p class="hint mb-0">Upload reusable files once and link them to templates or homework.</p>
              </div>
              <span class="badge bg-secondary"><%= (assets || []).length %></span>
            </div>
            <form method="POST" action="/teacher/workspace/assets" enctype="multipart/form-data" class="row g-2 mb-3">
              <input type="hidden" name="study_context_id" value="<%= selectedWorkspaceContextId || '' %>" />
              <input type="hidden" name="semester_id" value="<%= selectedWorkspaceSemesterId || '' %>" />
              <div class="col-12 col-md-6">
                <label class="form-label" for="assetCourseId">Course scope</label>
                <select class="form-select" id="assetCourseId" name="course_id">
                  <option value="">All my courses</option>
                  <% (teacherCourses || []).forEach(function(course) { %>
                    <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>><%= course.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-6">
                <label class="form-label" for="assetName">Asset name</label>
                <input id="assetName" name="name" class="form-control" maxlength="160" placeholder="Week 14 brief" />
              </div>
              <div class="col-12">
                <label class="form-label" for="assetUpload">File</label>
                <input id="assetUpload" name="asset" class="form-control" type="file" required />
              </div>
              <div class="col-12">
                <button class="btn btn-primary" type="submit">Upload asset</button>
              </div>
            </form>
            <% if ((assets || []).length) { %>
              <div class="asset-library-list">
                <% assets.slice(0, 8).forEach(function(asset) { %>
                  <div class="asset-library-item">
                    <div class="d-flex justify-content-between gap-2 align-items-start">
                      <div>
                        <div class="fw-semibold"><%= asset.name || asset.original_name || 'Asset' %></div>
                        <div class="asset-library-meta small">
                          <% if (asset.mime_type) { %><%= asset.mime_type %><% } %>
                          <% if (asset.original_name) { %> · <%= asset.original_name %><% } %>
                        </div>
                      </div>
                      <form method="POST" action="/teacher/workspace/assets/<%= asset.id %>/delete">
                        <input type="hidden" name="course_id" value="<%= selectedCourseId || asset.course_id || '' %>" />
                        <input type="hidden" name="study_context_id" value="<%= selectedWorkspaceContextId || '' %>" />
                        <input type="hidden" name="semester_id" value="<%= selectedWorkspaceSemesterId || '' %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                      </form>
                    </div>
                    <div class="mt-2">
                      <a href="<%= asset.file_path %>" target="_blank" rel="noopener noreferrer">Open file</a>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="alert alert-info mb-0">No assets yet. Upload files you want to reuse across templates.</div>
            <% } %>
          </article>
          <article class="glass workspace-panel h-100">
            <h5 class="mb-3">New template</h5>
            <form method="POST" action="/teacher/workspace/templates" enctype="multipart/form-data" autocomplete="off">
              <input type="hidden" name="study_context_id" value="<%= selectedWorkspaceContextId || '' %>" />
              <input type="hidden" name="semester_id" value="<%= selectedWorkspaceSemesterId || '' %>" />
              <div class="row g-2">
                <div class="col-12 col-md-6">
                  <label for="templateCourseId" class="form-label">Course scope</label>
                  <select class="form-select" id="templateCourseId" name="course_id">
                    <option value="">All my courses</option>
                    <% (teacherCourses || []).forEach(function(course) { %>
                      <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>>
                        <%= course.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateSubjectId" class="form-label">Subject (optional)</label>
                  <select class="form-select" id="templateSubjectId" name="subject_id" <%= (teacherSubjects || []).length ? '' : 'disabled' %>>
                    <option value="">Any subject</option>
                    <% (teacherSubjects || []).forEach(function(subject) { %>
                      <option value="<%= subject.id %>" data-course-id="<%= subject.course_id %>">
                        <%= subject.name %><%= subject.course_name ? ` (${subject.course_name})` : '' %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12">
                  <label for="templateTitle" class="form-label">Title</label>
                  <input id="templateTitle" name="title" class="form-control" maxlength="160" required />
                </div>
                <div class="col-12">
                  <label for="templateDescription" class="form-label">Description</label>
                  <textarea
                    id="templateDescription"
                    name="description"
                    class="form-control"
                    rows="4"
                    maxlength="4000"
                    required
                  ></textarea>
                </div>
                <div class="col-12">
                  <label for="templateTags" class="form-label">Tags (comma separated)</label>
                  <input
                    id="templateTags"
                    name="tags"
                    class="form-control"
                    maxlength="240"
                    placeholder="quiz, seminar, revision"
                  />
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateLinkUrl" class="form-label">Link (optional)</label>
                  <input
                    id="templateLinkUrl"
                    name="link_url"
                    class="form-control"
                    type="text"
                    inputmode="url"
                    autocapitalize="none"
                    autocomplete="off"
                    placeholder="https://example.com"
                  />
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateMeetingUrl" class="form-label">Meeting URL (optional)</label>
                  <input
                    id="templateMeetingUrl"
                    name="meeting_url"
                    class="form-control"
                    type="text"
                    inputmode="url"
                    autocapitalize="none"
                    autocomplete="off"
                    placeholder="https://zoom.us/j/..."
                  />
                </div>
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="templateControl" name="is_control" value="1" />
                      <label class="form-check-label" for="templateControl">Control</label>
                    </div>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="templateCredit" name="is_credit" value="1" />
                      <label class="form-check-label" for="templateCredit">Credit</label>
                    </div>
                  </div>
                </div>
                <div class="col-12">
                  <label class="form-label">Attached assets</label>
                  <% if ((assets || []).length) { %>
                    <div class="asset-picker">
                      <% assets.forEach(function(asset) { %>
                        <label class="asset-picker-item">
                          <input class="form-check-input" type="checkbox" name="asset_ids" value="<%= asset.id %>" />
                          <span class="asset-picker-copy">
                            <strong><%= asset.name || asset.original_name || 'Asset' %></strong>
                            <small><%= asset.original_name || asset.mime_type || 'File' %></small>
                          </span>
                        </label>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <div class="alert alert-info mb-0">No reusable assets yet. Upload files below and they will be linked automatically.</div>
                  <% } %>
                </div>
                <div class="col-12">
                  <div class="template-upload-panel">
                    <div class="template-upload-meta">
                      <strong>Upload files now (optional)</strong>
                      <span>New files will be saved to your asset library and attached to this template automatically. Max 8 files, <%= settings.max_file_size_mb || 20 %> MB each.</span>
                    </div>
                    <input
                      id="templateFiles"
                      name="template_files"
                      class="form-control"
                      type="file"
                      multiple
                      accept=".png,.jpg,.jpeg,.gif,.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt"
                    />
                    <div class="template-upload-list" id="templateFilesList"></div>
                  </div>
                </div>
              </div>
              <button class="btn btn-primary mt-3" type="submit">Save template</button>
            </form>
            <p class="hint mt-3 mb-0">
              Tip: after saving, open any class card in schedule and use "Apply template" in homework modal.
            </p>
            <% if (!(teacherSubjects || []).length) { %>
              <div class="alert alert-warning mt-3 mb-0">
                Choose your teaching subjects first in <a href="/teacher/subjects">subject assignments</a>.
              </div>
            <% } %>
          </article>
        </div>

        <div class="col-12 col-xl-7">
          <article class="glass workspace-panel h-100">
            <div class="template-toolbar mb-3">
              <div class="d-flex align-items-center gap-2">
                <h5 class="mb-0">Saved templates</h5>
                <span class="badge bg-secondary"><%= (templates || []).length %></span>
              </div>
              <div class="template-bulk-controls">
                <button class="btn btn-outline-secondary btn-sm" type="button" id="templateSelectAllToggle">
                  Select all
                </button>
                <button class="btn btn-outline-info btn-sm" type="button" id="templateBulkCloneBtn" disabled>
                  Bulk clone
                </button>
                <button class="btn btn-outline-danger btn-sm" type="button" id="templateBulkDeleteBtn" disabled>
                  Bulk delete
                </button>
                <span class="template-bulk-count" id="templateSelectedCount">0 selected</span>
              </div>
            </div>

            <% if ((templates || []).length) { %>
              <div class="template-list">
                <% templates.forEach(function(template) { %>
                  <div class="template-card">
                    <div class="template-card-head">
                      <h6 class="template-title"><%= template.title %></h6>
                      <label class="template-select-toggle">
                        <input
                          class="form-check-input"
                          type="checkbox"
                          data-template-select="<%= template.id %>"
                        />
                        <span>Select</span>
                      </label>
                    </div>
                    <div class="template-meta">
                      <% if (template.course_name) { %><span><%= template.course_name %></span><% } %>
                      <% if (template.subject_name) { %><span> · <%= template.subject_name %></span><% } %>
                      <% if (template.updated_at) { %><span> · <%= String(template.updated_at).slice(0, 10) %></span><% } %>
                    </div>
                    <p class="template-description"><%= template.description %></p>
                    <div class="template-chips">
                      <% if (Number(template.is_control || 0) === 1) { %>
                        <span class="template-chip">Control</span>
                      <% } %>
                      <% if (Number(template.is_credit || 0) === 1) { %>
                        <span class="template-chip">Credit</span>
                      <% } %>
                      <% (template.tags_list || []).forEach(function(tag) { %>
                        <span class="template-chip">#<%= tag %></span>
                      <% }) %>
                    </div>
                    <% if (Number(template.asset_count || 0) > 0) { %>
                      <div class="template-asset-row">
                        <span class="template-asset-chip"><%= template.asset_count %> files</span>
                        <% (template.assets || []).slice(0, 3).forEach(function(asset) { %>
                          <span class="template-asset-chip"><%= asset.name || asset.original_name || 'Asset' %></span>
                        <% }) %>
                      </div>
