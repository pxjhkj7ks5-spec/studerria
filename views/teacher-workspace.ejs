<%
  const teacherOfferingList = Array.isArray(teacherOfferings) ? teacherOfferings : [];
  const workspaceCatalogOfferingList = Array.isArray(workspaceCatalogOfferings) ? workspaceCatalogOfferings : [];
  const workspaceSelectionMap = workspaceOfferingSelections && typeof workspaceOfferingSelections.get === 'function'
    ? workspaceOfferingSelections
    : new Map();
  const workspaceAssignedOfferingMap = workspaceAssignedOfferingDetails && typeof workspaceAssignedOfferingDetails.get === 'function'
    ? workspaceAssignedOfferingDetails
    : new Map();
  const workspaceCourseList = Array.isArray(workspaceCourseOptions) ? workspaceCourseOptions : [];
  const workspaceContextList = Array.isArray(workspaceContextOptions) ? workspaceContextOptions : [];
  const workspaceSemesterList = Array.isArray(workspaceSemesterOptions) ? workspaceSemesterOptions : [];
  const workspaceTemplatePlanValue = workspaceTemplatePlan && typeof workspaceTemplatePlan === 'object'
    ? workspaceTemplatePlan
    : {
        visible_count: workspaceCatalogOfferingList.length,
        selected_count: 0,
        counts: { create: 0, update: 0, deactivate: 0, keep: 0, idle: 0 },
        items: [],
      };
  const workspaceTemplatePlanItems = Array.isArray(workspaceTemplatePlanValue.items)
    ? workspaceTemplatePlanValue.items
    : [];
  const workspaceTemplatePreviewItems = workspaceTemplatePlanItems.filter((item) => item && item.status !== 'idle');
  const workspaceTemplateActionCount = ['create', 'update', 'deactivate'].reduce(
    (total, key) => total + Number((workspaceTemplatePlanValue.counts || {})[key] || 0),
    0,
  );
  const workspaceTemplateStatusBadgeMap = {
    create: 'success',
    update: 'warning text-dark',
    deactivate: 'danger',
    keep: 'secondary',
    idle: 'light text-dark',
  };
  const workspaceTemplateStatusLabelMap = {
    create: 'Create rule',
    update: 'Update rule',
    deactivate: 'Deactivate rule',
    keep: 'Keep active',
    idle: 'No action',
  };
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title>Teacher workspace</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --surface-border-dark: rgba(255, 255, 255, 0.14);
        --surface-border-light: rgba(15, 23, 42, 0.12);
        --surface-bg-dark: rgba(255, 255, 255, 0.06);
        --surface-bg-light: rgba(255, 255, 255, 0.64);
        --surface-shadow-dark: 0 16px 42px rgba(2, 6, 23, 0.5);
        --surface-shadow-light: 0 16px 40px rgba(15, 23, 42, 0.12);
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", "Inter", Arial, sans-serif;
        min-height: 100vh;
        transition: background 220ms ease, color 220ms ease;
      }
      body.theme-dark {
        background:
          radial-gradient(1100px 760px at 12% 8%, rgba(56, 189, 248, 0.18), transparent 62%),
          radial-gradient(900px 680px at 84% 18%, rgba(129, 140, 248, 0.2), transparent 64%),
          linear-gradient(150deg, #080d19 0%, #111b2f 48%, #15253f 100%);
        color: #f8fafc;
      }
      body.theme-light {
        background:
          radial-gradient(1100px 760px at 16% 10%, rgba(125, 211, 252, 0.2), transparent 62%),
