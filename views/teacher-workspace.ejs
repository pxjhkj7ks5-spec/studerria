<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Teacher workspace</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root {
        --surface-border-dark: rgba(255, 255, 255, 0.14);
        --surface-border-light: rgba(15, 23, 42, 0.12);
        --surface-bg-dark: rgba(255, 255, 255, 0.06);
        --surface-bg-light: rgba(255, 255, 255, 0.64);
        --surface-shadow-dark: 0 16px 42px rgba(2, 6, 23, 0.5);
        --surface-shadow-light: 0 16px 40px rgba(15, 23, 42, 0.12);
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", "Inter", Arial, sans-serif;
        min-height: 100vh;
        transition: background 220ms ease, color 220ms ease;
      }
      body.theme-dark {
        background:
          radial-gradient(1100px 760px at 12% 8%, rgba(56, 189, 248, 0.18), transparent 62%),
          radial-gradient(900px 680px at 84% 18%, rgba(129, 140, 248, 0.2), transparent 64%),
          linear-gradient(150deg, #080d19 0%, #111b2f 48%, #15253f 100%);
        color: #f8fafc;
      }
      body.theme-light {
        background:
          radial-gradient(1100px 760px at 16% 10%, rgba(125, 211, 252, 0.2), transparent 62%),
          radial-gradient(900px 680px at 84% 18%, rgba(167, 139, 250, 0.2), transparent 64%),
          linear-gradient(130deg, #e8eff9 0%, #eff5ff 48%, #f6f8ff 100%);
        color: #0f172a;
      }
      .workspace-shell {
        padding-top: 24px;
        padding-bottom: 48px;
      }
      .glass {
        position: relative;
        isolation: isolate;
        border-radius: 22px;
        backdrop-filter: blur(18px);
      }
      body.theme-dark .glass {
        border: 1px solid var(--surface-border-dark);
        background: var(--surface-bg-dark);
        box-shadow: var(--surface-shadow-dark);
      }
      body.theme-light .glass {
        border: 1px solid var(--surface-border-light);
        background: var(--surface-bg-light);
        box-shadow: var(--surface-shadow-light);
      }
      .workspace-hero {
        padding: 24px;
      }
      .workspace-title {
        margin: 0;
        font-size: clamp(1.7rem, 2.8vw, 2.25rem);
        font-weight: 700;
      }
      .workspace-subtitle {
        margin: 10px 0 0;
        max-width: 760px;
        color: rgba(226, 232, 240, 0.8);
      }
      body.theme-light .workspace-subtitle {
        color: rgba(15, 23, 42, 0.7);
      }
      .hero-actions {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .btn-glass {
        border-radius: 999px;
        padding: 0.45rem 0.95rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.24);
        background: rgba(255, 255, 255, 0.1);
        color: rgba(248, 250, 252, 0.92);
      }
      .btn-glass:hover {
        background: rgba(255, 255, 255, 0.16);
        color: rgba(248, 250, 252, 0.98);
      }
      body.theme-light .btn-glass {
        border-color: rgba(15, 23, 42, 0.16);
        background: rgba(255, 255, 255, 0.86);
        color: #0f172a;
      }
      body.theme-light .btn-glass:hover {
        background: #ffffff;
        color: #0f172a;
      }
      .workspace-panel {
        padding: 20px;
      }
      .workspace-panel h5 {
        margin-bottom: 14px;
      }
      .form-control,
      .form-select {
        border-radius: 12px;
      }
      body.theme-dark .form-control,
      body.theme-dark .form-select {
        background: rgba(15, 23, 42, 0.44);
        border: 1px solid rgba(148, 163, 184, 0.35);
        color: #f8fafc;
      }
      body.theme-dark .form-control::placeholder {
        color: rgba(203, 213, 225, 0.6);
      }
      body.theme-dark .form-select option {
        background: #0f172a;
        color: #f8fafc;
      }
      .template-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 76vh;
        overflow-y: auto;
        padding-right: 4px;
      }
      .template-card {
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.26);
        padding: 14px;
        background: rgba(15, 23, 42, 0.34);
      }
      .template-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .template-bulk-controls {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .template-bulk-count {
        font-size: 0.76rem;
        color: rgba(203, 213, 225, 0.74);
      }
      body.theme-light .template-bulk-count {
        color: rgba(15, 23, 42, 0.58);
      }
      body.theme-light .template-card {
        background: rgba(255, 255, 255, 0.82);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .template-card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
      }
      .template-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 650;
      }
      .template-select-toggle {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.76rem;
        color: rgba(203, 213, 225, 0.78);
        cursor: pointer;
        user-select: none;
      }
      body.theme-light .template-select-toggle {
        color: rgba(15, 23, 42, 0.58);
      }
      .template-meta {
        margin-top: 2px;
        font-size: 0.78rem;
        color: rgba(203, 213, 225, 0.72);
      }
      body.theme-light .template-meta {
        color: rgba(15, 23, 42, 0.58);
      }
      .template-description {
        margin: 10px 0 0;
        font-size: 0.92rem;
        white-space: pre-wrap;
      }
      .template-chips {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .template-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.34);
        padding: 2px 8px;
        font-size: 0.72rem;
        color: rgba(226, 232, 240, 0.88);
        background: rgba(15, 23, 42, 0.5);
      }
      body.theme-light .template-chip {
        color: rgba(15, 23, 42, 0.78);
        background: rgba(255, 255, 255, 0.86);
        border-color: rgba(15, 23, 42, 0.16);
      }
      .template-footer {
        margin-top: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .template-actions {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .template-actions form {
        margin: 0;
      }
      .template-links {
        display: inline-flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .template-link {
        font-size: 0.8rem;
        color: #93c5fd;
        text-decoration: none;
      }
      .template-link:hover {
        text-decoration: underline;
      }
      body.theme-light .template-link {
        color: #1d4ed8;
      }
      .clone-subject-list {
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.3);
        padding: 8px;
        max-height: 42vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
        background: rgba(15, 23, 42, 0.2);
      }
      body.theme-light .clone-subject-list {
        background: rgba(255, 255, 255, 0.78);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .clone-subject-item {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 10px;
        padding: 8px 10px;
        border: 1px solid rgba(148, 163, 184, 0.2);
        background: rgba(15, 23, 42, 0.25);
        cursor: pointer;
      }
      .clone-subject-item:hover {
        border-color: rgba(125, 211, 252, 0.45);
      }
      body.theme-light .clone-subject-item {
        background: rgba(255, 255, 255, 0.92);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .clone-subject-text {
        display: inline-flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }
      .clone-subject-text strong {
        font-size: 0.9rem;
        font-weight: 600;
      }
      .clone-subject-text small {
        font-size: 0.76rem;
        color: rgba(203, 213, 225, 0.75);
      }
      body.theme-light .clone-subject-text small {
        color: rgba(15, 23, 42, 0.58);
      }
      .bulk-source-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        padding: 8px 10px;
        max-height: 18vh;
        overflow-y: auto;
        background: rgba(15, 23, 42, 0.22);
      }
      body.theme-light .bulk-source-list {
        background: rgba(255, 255, 255, 0.78);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .bulk-source-item {
        font-size: 0.84rem;
        color: rgba(226, 232, 240, 0.9);
      }
      body.theme-light .bulk-source-item {
        color: rgba(15, 23, 42, 0.78);
      }
      .hint {
        font-size: 0.82rem;
        color: rgba(203, 213, 225, 0.78);
      }
      body.theme-light .hint {
        color: rgba(15, 23, 42, 0.6);
      }
      .app-footer {
        font-size: 0.85rem;
      }
      body.theme-dark .app-footer {
        color: rgba(203, 213, 225, 0.7);
      }
      body.theme-light .app-footer {
        color: rgba(15, 23, 42, 0.6);
      }
    </style>
    <link rel="stylesheet" href="/css/design-system.css" />
  </head>
  <body class="theme-dark page-teacher-workspace page-journal">
    <%- include('partials/topbar', { role, username, t, activePage: 'teacher-workspace', pageTitle: 'Teacher workspace', settings: settings }) %>
    <%- include('partials/desktop-menu-drawer', {
      role,
      t,
      activePage: 'teacher-workspace',
      settings: (typeof settings !== 'undefined') ? settings : null,
    }) %>

    <main class="container workspace-shell">
      <% if (error) { %>
        <div class="alert alert-danger glass mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success glass mb-3"><%= success %></div>
      <% } %>

      <section class="glass workspace-hero mb-3">
        <h1 class="workspace-title">Teacher workspace</h1>
        <p class="workspace-subtitle">
          Build reusable homework templates and apply them in one click from class cards in schedule modal.
        </p>
        <div class="hero-actions">
          <a class="btn btn-glass" href="/teacher">Teacher hub</a>
          <a class="btn btn-glass" href="/schedule">Schedule</a>
          <a class="btn btn-glass" href="/teacher/subjects">My subjects</a>
          <a class="btn btn-glass" href="/journal">Journal</a>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-5">
          <article class="glass workspace-panel h-100">
            <h5 class="mb-3">New template</h5>
            <form method="POST" action="/teacher/workspace/templates" autocomplete="off">
              <div class="row g-2">
                <div class="col-12 col-md-6">
                  <label for="templateCourseId" class="form-label">Course scope</label>
                  <select class="form-select" id="templateCourseId" name="course_id">
                    <option value="">All my courses</option>
                    <% (teacherCourses || []).forEach(function(course) { %>
                      <option value="<%= course.id %>" <%= Number(selectedCourseId) === Number(course.id) ? 'selected' : '' %>>
                        <%= course.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateSubjectId" class="form-label">Subject (optional)</label>
                  <select class="form-select" id="templateSubjectId" name="subject_id" <%= (teacherSubjects || []).length ? '' : 'disabled' %>>
                    <option value="">Any subject</option>
                    <% (teacherSubjects || []).forEach(function(subject) { %>
                      <option value="<%= subject.id %>" data-course-id="<%= subject.course_id %>">
                        <%= subject.name %><%= subject.course_name ? ` (${subject.course_name})` : '' %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12">
                  <label for="templateTitle" class="form-label">Title</label>
                  <input id="templateTitle" name="title" class="form-control" maxlength="160" required />
                </div>
                <div class="col-12">
                  <label for="templateDescription" class="form-label">Description</label>
                  <textarea
                    id="templateDescription"
                    name="description"
                    class="form-control"
                    rows="4"
                    maxlength="4000"
                    required
                  ></textarea>
                </div>
                <div class="col-12">
                  <label for="templateTags" class="form-label">Tags (comma separated)</label>
                  <input
                    id="templateTags"
                    name="tags"
                    class="form-control"
                    maxlength="240"
                    placeholder="quiz, seminar, revision"
                  />
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateLinkUrl" class="form-label">Link (optional)</label>
                  <input
                    id="templateLinkUrl"
                    name="link_url"
                    class="form-control"
                    type="text"
                    inputmode="url"
                    autocapitalize="none"
                    autocomplete="off"
                    placeholder="https://example.com"
                  />
                </div>
                <div class="col-12 col-md-6">
                  <label for="templateMeetingUrl" class="form-label">Meeting URL (optional)</label>
                  <input
                    id="templateMeetingUrl"
                    name="meeting_url"
                    class="form-control"
                    type="text"
                    inputmode="url"
                    autocapitalize="none"
                    autocomplete="off"
                    placeholder="https://zoom.us/j/..."
                  />
                </div>
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="templateControl" name="is_control" value="1" />
                      <label class="form-check-label" for="templateControl">Control</label>
                    </div>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="templateCredit" name="is_credit" value="1" />
                      <label class="form-check-label" for="templateCredit">Credit</label>
                    </div>
                  </div>
                </div>
              </div>
              <button class="btn btn-primary mt-3" type="submit">Save template</button>
            </form>
            <p class="hint mt-3 mb-0">
              Tip: after saving, open any class card in schedule and use "Apply template" in homework modal.
            </p>
            <% if (!(teacherSubjects || []).length) { %>
              <div class="alert alert-warning mt-3 mb-0">
                Choose your teaching subjects first in <a href="/teacher/subjects">teacher subjects</a>.
              </div>
            <% } %>
          </article>
        </div>

        <div class="col-12 col-xl-7">
          <article class="glass workspace-panel h-100">
            <div class="template-toolbar mb-3">
              <div class="d-flex align-items-center gap-2">
                <h5 class="mb-0">Saved templates</h5>
                <span class="badge bg-secondary"><%= (templates || []).length %></span>
              </div>
              <div class="template-bulk-controls">
                <button class="btn btn-outline-secondary btn-sm" type="button" id="templateSelectAllToggle">
                  Select all
                </button>
                <button class="btn btn-outline-info btn-sm" type="button" id="templateBulkCloneBtn" disabled>
                  Bulk clone
                </button>
                <button class="btn btn-outline-danger btn-sm" type="button" id="templateBulkDeleteBtn" disabled>
                  Bulk delete
                </button>
                <span class="template-bulk-count" id="templateSelectedCount">0 selected</span>
              </div>
            </div>

            <% if ((templates || []).length) { %>
              <div class="template-list">
                <% templates.forEach(function(template) { %>
                  <div class="template-card">
                    <div class="template-card-head">
                      <h6 class="template-title"><%= template.title %></h6>
                      <label class="template-select-toggle">
                        <input
                          class="form-check-input"
                          type="checkbox"
                          data-template-select="<%= template.id %>"
                        />
                        <span>Select</span>
                      </label>
                    </div>
                    <div class="template-meta">
                      <% if (template.course_name) { %><span><%= template.course_name %></span><% } %>
                      <% if (template.subject_name) { %><span> · <%= template.subject_name %></span><% } %>
                      <% if (template.updated_at) { %><span> · <%= String(template.updated_at).slice(0, 10) %></span><% } %>
                    </div>
                    <p class="template-description"><%= template.description %></p>
                    <div class="template-chips">
                      <% if (Number(template.is_control || 0) === 1) { %>
                        <span class="template-chip">Control</span>
                      <% } %>
                      <% if (Number(template.is_credit || 0) === 1) { %>
                        <span class="template-chip">Credit</span>
                      <% } %>
                      <% (template.tags_list || []).forEach(function(tag) { %>
                        <span class="template-chip">#<%= tag %></span>
                      <% }) %>
                    </div>
                    <div class="template-footer">
                      <div class="template-links">
                        <% if (template.link_url) { %>
                          <a class="template-link" href="<%= template.link_url %>" target="_blank" rel="noopener noreferrer">Link</a>
                        <% } %>
                        <% if (template.meeting_url) { %>
                          <a class="template-link" href="<%= template.meeting_url %>" target="_blank" rel="noopener noreferrer">Meeting</a>
                        <% } %>
                      </div>
                      <div class="template-actions">
                        <button
                          class="btn btn-outline-secondary btn-sm"
                          type="button"
                          data-template-edit="<%= template.id %>"
                        >
                          Edit
                        </button>
                        <button
                          class="btn btn-outline-info btn-sm"
                          type="button"
                          data-template-clone="<%= template.id %>"
                        >
                          Clone
                        </button>
                        <form method="POST" action="/teacher/workspace/templates/<%= template.id %>/delete">
                          <input type="hidden" name="course_id" value="<%= selectedCourseId || '' %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="alert alert-info mb-0">No templates yet. Create your first template on the left.</div>
            <% } %>
          </article>
        </div>
      </section>

      <div class="modal fade" id="editTemplateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content">
            <form method="POST" id="editTemplateForm" action="/teacher/workspace/templates/0/update" autocomplete="off">
              <div class="modal-header">
                <h5 class="modal-title">Edit template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="editTemplateCourseContext" name="course_id_context" value="<%= selectedCourseId || '' %>" />
                <div class="row g-2">
                  <div class="col-12 col-md-6">
                    <label for="editTemplateCourseId" class="form-label">Course scope</label>
                    <select class="form-select" id="editTemplateCourseId" name="course_id">
                      <option value="">All my courses</option>
                      <% (teacherCourses || []).forEach(function(course) { %>
                        <option value="<%= course.id %>"><%= course.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="editTemplateSubjectId" class="form-label">Subject (optional)</label>
                    <select class="form-select" id="editTemplateSubjectId" name="subject_id" <%= (teacherSubjects || []).length ? '' : 'disabled' %>>
                      <option value="">Any subject</option>
                      <% (teacherSubjects || []).forEach(function(subject) { %>
                        <option value="<%= subject.id %>" data-course-id="<%= subject.course_id %>">
                          <%= subject.name %><%= subject.course_name ? ` (${subject.course_name})` : '' %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-12">
                    <label for="editTemplateTitle" class="form-label">Title</label>
                    <input id="editTemplateTitle" name="title" class="form-control" maxlength="160" required />
                  </div>
                  <div class="col-12">
                    <label for="editTemplateDescription" class="form-label">Description</label>
                    <textarea
                      id="editTemplateDescription"
                      name="description"
                      class="form-control"
                      rows="4"
                      maxlength="4000"
                      required
                    ></textarea>
                  </div>
                  <div class="col-12">
                    <label for="editTemplateTags" class="form-label">Tags (comma separated)</label>
                    <input
                      id="editTemplateTags"
                      name="tags"
                      class="form-control"
                      maxlength="240"
                      placeholder="quiz, seminar, revision"
                    />
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="editTemplateLinkUrl" class="form-label">Link (optional)</label>
                    <input
                      id="editTemplateLinkUrl"
                      name="link_url"
                      class="form-control"
                      type="text"
                      inputmode="url"
                      autocapitalize="none"
                      autocomplete="off"
                      placeholder="https://example.com"
                    />
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="editTemplateMeetingUrl" class="form-label">Meeting URL (optional)</label>
                    <input
                      id="editTemplateMeetingUrl"
                      name="meeting_url"
                      class="form-control"
                      type="text"
                      inputmode="url"
                      autocapitalize="none"
                      autocomplete="off"
                      placeholder="https://zoom.us/j/..."
                    />
                  </div>
                  <div class="col-12">
                    <div class="d-flex flex-wrap gap-3">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="editTemplateControl" name="is_control" value="1" />
                        <label class="form-check-label" for="editTemplateControl">Control</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="editTemplateCredit" name="is_credit" value="1" />
                        <label class="form-check-label" for="editTemplateCredit">Credit</label>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save changes</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="modal fade" id="cloneTemplateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content">
            <form method="POST" id="cloneTemplateForm" action="/teacher/workspace/templates/0/clone" autocomplete="off">
              <div class="modal-header">
                <h5 class="modal-title">Clone template to subjects</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="cloneTemplateCourseContext" name="course_id_context" value="<%= selectedCourseId || '' %>" />
                <p class="mb-2 small text-muted">
                  Source:
                  <strong id="cloneTemplateSourceTitle">-</strong>
                </p>
                <div class="mb-2">
                  <label for="cloneTemplateSearch" class="form-label">Find subject</label>
                  <input
                    id="cloneTemplateSearch"
                    class="form-control"
                    type="search"
                    placeholder="Type subject or course name"
                    autocomplete="off"
                  />
                </div>
                <div id="cloneTemplateError" class="alert alert-warning py-2 d-none mb-2"></div>
                <% if ((teacherSubjectsAll || []).length) { %>
                  <div class="clone-subject-list" id="cloneSubjectList">
                    <% (teacherSubjectsAll || []).forEach(function(subject) { %>
                      <label class="clone-subject-item" data-clone-subject-item>
                        <input class="form-check-input" type="checkbox" name="target_subject_ids" value="<%= subject.id %>" />
                        <span class="clone-subject-text">
                          <strong><%= subject.name %></strong>
                          <small><%= subject.course_name ? subject.course_name : `Course ${subject.course_id}` %></small>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                  <div id="cloneSubjectEmpty" class="small text-muted mt-2 d-none">No subjects match this filter.</div>
                <% } else { %>
                  <div class="alert alert-warning mb-0">
                    No subjects available yet. Configure your teaching subjects first.
                  </div>
                <% } %>
                <p class="hint mt-2 mb-0">
                  Clones keep title, description, links, tags, and control/credit flags.
                </p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" <%= (teacherSubjectsAll || []).length ? '' : 'disabled' %>>
                  Clone to selected
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="modal fade" id="bulkCloneTemplateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content">
            <form method="POST" id="bulkCloneTemplateForm" action="/teacher/workspace/templates/bulk-clone" autocomplete="off">
              <div class="modal-header">
                <h5 class="modal-title">Bulk clone templates</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="bulkCloneCourseContext" name="course_id_context" value="<%= selectedCourseId || '' %>" />
                <div id="bulkCloneSourceInputs"></div>
                <p class="mb-2 small text-muted">
                  Sources:
                  <strong id="bulkCloneSourceCount">0 selected</strong>
                </p>
                <div class="bulk-source-list mb-3" id="bulkCloneSourceList"></div>
                <div class="mb-2">
                  <label for="bulkCloneTemplateSearch" class="form-label">Find subject</label>
                  <input
                    id="bulkCloneTemplateSearch"
                    class="form-control"
                    type="search"
                    placeholder="Type subject or course name"
                    autocomplete="off"
                  />
                </div>
                <div id="bulkCloneError" class="alert alert-warning py-2 d-none mb-2"></div>
                <% if ((teacherSubjectsAll || []).length) { %>
                  <div class="clone-subject-list" id="bulkCloneSubjectList">
                    <% (teacherSubjectsAll || []).forEach(function(subject) { %>
                      <label class="clone-subject-item" data-bulk-clone-subject-item>
                        <input class="form-check-input" type="checkbox" name="target_subject_ids" value="<%= subject.id %>" />
                        <span class="clone-subject-text">
                          <strong><%= subject.name %></strong>
                          <small><%= subject.course_name ? subject.course_name : `Course ${subject.course_id}` %></small>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                  <div id="bulkCloneSubjectEmpty" class="small text-muted mt-2 d-none">No subjects match this filter.</div>
                <% } else { %>
                  <div class="alert alert-warning mb-0">
                    No subjects available yet. Configure your teaching subjects first.
                  </div>
                <% } %>
                <p class="hint mt-2 mb-0">
                  For each selected source template, one copy will be created per selected subject (duplicates skipped).
                </p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" <%= (teacherSubjectsAll || []).length ? '' : 'disabled' %>>
                  Run bulk clone
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="modal fade" id="bulkDeleteTemplateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content">
            <form method="POST" id="bulkDeleteTemplateForm" action="/teacher/workspace/templates/bulk-delete" autocomplete="off">
              <div class="modal-header">
                <h5 class="modal-title">Bulk delete templates</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="bulkDeleteCourseContext" name="course_id_context" value="<%= selectedCourseId || '' %>" />
                <div id="bulkDeleteSourceInputs"></div>
                <p class="mb-2 small text-muted">
                  Templates selected for deletion:
                  <strong id="bulkDeleteSourceCount">0 selected</strong>
                </p>
                <div id="bulkDeleteSourceList" class="bulk-source-list"></div>
                <div id="bulkDeleteError" class="alert alert-warning py-2 d-none mt-2 mb-0"></div>
                <div class="alert alert-danger mt-3 mb-0">
                  This action permanently deletes selected templates.
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Delete selected templates</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/changelog-modal') %>
    <%- include('partials/mobile-menu-modal', { role, t, activePage: 'teacher-workspace' }) %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script>
      (function applyTheme() {
        const storedTheme = localStorage.getItem('ui-theme') || 'theme-dark';
        document.body.classList.remove('theme-dark', 'theme-light');
        document.body.classList.add(storedTheme);
        const themeToggle = document.getElementById('themeToggle');
        if (!themeToggle) return;
        themeToggle.textContent = storedTheme === 'theme-dark' ? '☀️' : '🌙';
        themeToggle.addEventListener('click', () => {
          const isDark = document.body.classList.contains('theme-dark');
          const next = isDark ? 'theme-light' : 'theme-dark';
          document.body.classList.remove('theme-dark', 'theme-light');
          document.body.classList.add(next);
          localStorage.setItem('ui-theme', next);
          themeToggle.textContent = next === 'theme-dark' ? '☀️' : '🌙';
        });
      })();

      const workspaceTemplates = <%- JSON.stringify(templates || []) %>;
      const selectedCourseContext = <%- JSON.stringify(selectedCourseId || null) %>;

      function bindCourseSubjectFilter(courseSelect, subjectSelect) {
        if (!courseSelect || !subjectSelect) {
          return () => {};
        }
        const syncSubjects = () => {
          const selectedCourseId = Number(courseSelect.value || 0);
          let visibleCount = 0;
          Array.from(subjectSelect.options).forEach((option) => {
            if (!option.value) return;
            const optionCourseId = Number(option.dataset.courseId || 0);
            const visible = !selectedCourseId || selectedCourseId === optionCourseId;
            option.hidden = !visible;
            option.disabled = !visible;
            if (visible) visibleCount += 1;
          });
          if (subjectSelect.value) {
            const current = subjectSelect.selectedOptions[0];
            if (current && current.hidden) {
              subjectSelect.value = '';
            }
          }
          subjectSelect.disabled = visibleCount === 0;
        };
        courseSelect.addEventListener('change', syncSubjects);
        syncSubjects();
        return syncSubjects;
      }

      const createCourseSelect = document.getElementById('templateCourseId');
      const createSubjectSelect = document.getElementById('templateSubjectId');
      bindCourseSubjectFilter(createCourseSelect, createSubjectSelect);

      const editModalEl = document.getElementById('editTemplateModal');
      const editModal = editModalEl && window.bootstrap ? new window.bootstrap.Modal(editModalEl) : null;
      const editTemplateForm = document.getElementById('editTemplateForm');
      const editCourseSelect = document.getElementById('editTemplateCourseId');
      const editSubjectSelect = document.getElementById('editTemplateSubjectId');
      const editCourseContextInput = document.getElementById('editTemplateCourseContext');
      const editTitleInput = document.getElementById('editTemplateTitle');
      const editDescriptionInput = document.getElementById('editTemplateDescription');
      const editTagsInput = document.getElementById('editTemplateTags');
      const editLinkInput = document.getElementById('editTemplateLinkUrl');
      const editMeetingInput = document.getElementById('editTemplateMeetingUrl');
      const editControlInput = document.getElementById('editTemplateControl');
      const editCreditInput = document.getElementById('editTemplateCredit');
      const syncEditSubjects = bindCourseSubjectFilter(editCourseSelect, editSubjectSelect);
      const cloneModalEl = document.getElementById('cloneTemplateModal');
      const cloneModal = cloneModalEl && window.bootstrap ? new window.bootstrap.Modal(cloneModalEl) : null;
      const cloneTemplateForm = document.getElementById('cloneTemplateForm');
      const cloneTemplateCourseContextInput = document.getElementById('cloneTemplateCourseContext');
      const cloneTemplateSourceTitle = document.getElementById('cloneTemplateSourceTitle');
      const cloneTemplateSearch = document.getElementById('cloneTemplateSearch');
      const cloneTemplateError = document.getElementById('cloneTemplateError');
      const cloneSubjectList = document.getElementById('cloneSubjectList');
      const cloneSubjectEmpty = document.getElementById('cloneSubjectEmpty');
      const cloneSubjectItems = cloneSubjectList
        ? Array.from(cloneSubjectList.querySelectorAll('[data-clone-subject-item]'))
        : [];
      const templateSelectAllToggle = document.getElementById('templateSelectAllToggle');
      const templateBulkCloneBtn = document.getElementById('templateBulkCloneBtn');
      const templateBulkDeleteBtn = document.getElementById('templateBulkDeleteBtn');
      const templateSelectedCount = document.getElementById('templateSelectedCount');
      const templateSelectToggles = Array.from(document.querySelectorAll('[data-template-select]'));
      const bulkCloneModalEl = document.getElementById('bulkCloneTemplateModal');
      const bulkCloneModal = bulkCloneModalEl && window.bootstrap ? new window.bootstrap.Modal(bulkCloneModalEl) : null;
      const bulkCloneTemplateForm = document.getElementById('bulkCloneTemplateForm');
      const bulkCloneCourseContext = document.getElementById('bulkCloneCourseContext');
      const bulkCloneSourceInputs = document.getElementById('bulkCloneSourceInputs');
      const bulkCloneSourceCount = document.getElementById('bulkCloneSourceCount');
      const bulkCloneSourceList = document.getElementById('bulkCloneSourceList');
      const bulkCloneTemplateSearch = document.getElementById('bulkCloneTemplateSearch');
      const bulkCloneError = document.getElementById('bulkCloneError');
      const bulkCloneSubjectList = document.getElementById('bulkCloneSubjectList');
      const bulkCloneSubjectEmpty = document.getElementById('bulkCloneSubjectEmpty');
      const bulkCloneSubjectItems = bulkCloneSubjectList
        ? Array.from(bulkCloneSubjectList.querySelectorAll('[data-bulk-clone-subject-item]'))
        : [];
      const bulkDeleteModalEl = document.getElementById('bulkDeleteTemplateModal');
      const bulkDeleteModal = bulkDeleteModalEl && window.bootstrap ? new window.bootstrap.Modal(bulkDeleteModalEl) : null;
      const bulkDeleteTemplateForm = document.getElementById('bulkDeleteTemplateForm');
      const bulkDeleteCourseContext = document.getElementById('bulkDeleteCourseContext');
      const bulkDeleteSourceInputs = document.getElementById('bulkDeleteSourceInputs');
      const bulkDeleteSourceCount = document.getElementById('bulkDeleteSourceCount');
      const bulkDeleteSourceList = document.getElementById('bulkDeleteSourceList');
      const bulkDeleteError = document.getElementById('bulkDeleteError');

      const templateById = new Map();
      (workspaceTemplates || []).forEach((template) => {
        const templateId = Number(template.id);
        if (Number.isInteger(templateId) && templateId > 0) {
          templateById.set(templateId, template);
        }
      });

      function hideCloneError() {
        if (!cloneTemplateError) return;
        cloneTemplateError.classList.add('d-none');
        cloneTemplateError.textContent = '';
      }

      function syncCloneSubjectFilter() {
        if (!cloneSubjectItems.length) return;
        const query = String(cloneTemplateSearch && cloneTemplateSearch.value ? cloneTemplateSearch.value : '')
          .trim()
          .toLowerCase();
        let visibleCount = 0;
        cloneSubjectItems.forEach((item) => {
          const text = String(item.textContent || '').toLowerCase();
          const visible = !query || text.includes(query);
          item.hidden = !visible;
          if (visible) {
            visibleCount += 1;
          }
        });
        if (cloneSubjectEmpty) {
          cloneSubjectEmpty.classList.toggle('d-none', visibleCount > 0);
        }
      }

      function clearCloneSelection() {
        cloneSubjectItems.forEach((item) => {
          const checkbox = item.querySelector('input[type="checkbox"][name="target_subject_ids"]');
          if (checkbox) {
            checkbox.checked = false;
          }
          item.hidden = false;
        });
        if (cloneTemplateSearch) {
          cloneTemplateSearch.value = '';
        }
        if (cloneSubjectEmpty) {
          cloneSubjectEmpty.classList.add('d-none');
        }
        hideCloneError();
      }

      function getSelectedTemplateIds() {
        return templateSelectToggles
          .filter((input) => input.checked)
          .map((input) => Number(input.getAttribute('data-template-select')))
          .filter((value) => Number.isInteger(value) && value > 0);
      }

      function syncTemplateSelectionState() {
        const selectedIds = getSelectedTemplateIds();
        if (templateSelectedCount) {
          templateSelectedCount.textContent = `${selectedIds.length} selected`;
        }
        if (templateBulkCloneBtn) {
          templateBulkCloneBtn.disabled = selectedIds.length < 1;
        }
        if (templateBulkDeleteBtn) {
          templateBulkDeleteBtn.disabled = selectedIds.length < 1;
        }
        if (templateSelectAllToggle) {
          if (!templateSelectToggles.length) {
            templateSelectAllToggle.disabled = true;
            templateSelectAllToggle.textContent = 'Select all';
          } else if (selectedIds.length === templateSelectToggles.length) {
            templateSelectAllToggle.disabled = false;
            templateSelectAllToggle.textContent = 'Clear all';
          } else {
            templateSelectAllToggle.disabled = false;
            templateSelectAllToggle.textContent = 'Select all';
          }
        }
      }

      function hideBulkCloneError() {
        if (!bulkCloneError) return;
        bulkCloneError.classList.add('d-none');
        bulkCloneError.textContent = '';
      }

      function hideBulkDeleteError() {
        if (!bulkDeleteError) return;
        bulkDeleteError.classList.add('d-none');
        bulkDeleteError.textContent = '';
      }

      function syncBulkCloneSubjectFilter() {
        if (!bulkCloneSubjectItems.length) return;
        const query = String(bulkCloneTemplateSearch && bulkCloneTemplateSearch.value ? bulkCloneTemplateSearch.value : '')
          .trim()
          .toLowerCase();
        let visibleCount = 0;
        bulkCloneSubjectItems.forEach((item) => {
          const text = String(item.textContent || '').toLowerCase();
          const visible = !query || text.includes(query);
          item.hidden = !visible;
          if (visible) {
            visibleCount += 1;
          }
        });
        if (bulkCloneSubjectEmpty) {
          bulkCloneSubjectEmpty.classList.toggle('d-none', visibleCount > 0);
        }
      }

      function resetBulkCloneSubjectSelection() {
        bulkCloneSubjectItems.forEach((item) => {
          const checkbox = item.querySelector('input[type="checkbox"][name="target_subject_ids"]');
          if (checkbox) {
            checkbox.checked = false;
          }
          item.hidden = false;
        });
        if (bulkCloneTemplateSearch) {
          bulkCloneTemplateSearch.value = '';
        }
        if (bulkCloneSubjectEmpty) {
          bulkCloneSubjectEmpty.classList.add('d-none');
        }
        hideBulkCloneError();
      }

      function openBulkCloneModal() {
        if (!bulkCloneModal || !bulkCloneTemplateForm) return;
        const selectedTemplateIds = getSelectedTemplateIds();
        if (!selectedTemplateIds.length) {
          syncTemplateSelectionState();
          return;
        }
        if (bulkCloneSourceInputs) {
          bulkCloneSourceInputs.innerHTML = '';
          selectedTemplateIds.forEach((templateId) => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'source_template_ids';
            input.value = String(templateId);
            bulkCloneSourceInputs.appendChild(input);
          });
        }
        if (bulkCloneCourseContext) {
          bulkCloneCourseContext.value = Number.isInteger(Number(selectedCourseContext)) && Number(selectedCourseContext) > 0
            ? String(Number(selectedCourseContext))
            : '';
        }
        if (bulkCloneSourceCount) {
          bulkCloneSourceCount.textContent = `${selectedTemplateIds.length} selected`;
        }
        if (bulkCloneSourceList) {
          bulkCloneSourceList.innerHTML = '';
          selectedTemplateIds.forEach((templateId) => {
            const template = templateById.get(templateId);
            const item = document.createElement('div');
            item.className = 'bulk-source-item';
            item.textContent = template && template.title
              ? String(template.title)
              : `Template #${templateId}`;
            bulkCloneSourceList.appendChild(item);
          });
        }
        resetBulkCloneSubjectSelection();
        bulkCloneModal.show();
      }

      function resetBulkDeleteSelection() {
        if (bulkDeleteSourceInputs) {
          bulkDeleteSourceInputs.innerHTML = '';
        }
        if (bulkDeleteSourceList) {
          bulkDeleteSourceList.innerHTML = '';
        }
        if (bulkDeleteSourceCount) {
          bulkDeleteSourceCount.textContent = '0 selected';
        }
        hideBulkDeleteError();
      }

      function openBulkDeleteModal() {
        if (!bulkDeleteModal || !bulkDeleteTemplateForm) return;
        const selectedTemplateIds = getSelectedTemplateIds();
        if (!selectedTemplateIds.length) {
          syncTemplateSelectionState();
          return;
        }
        resetBulkDeleteSelection();
        if (bulkDeleteSourceInputs) {
          selectedTemplateIds.forEach((templateId) => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'source_template_ids';
            input.value = String(templateId);
            bulkDeleteSourceInputs.appendChild(input);
          });
        }
        if (bulkDeleteCourseContext) {
          bulkDeleteCourseContext.value = Number.isInteger(Number(selectedCourseContext)) && Number(selectedCourseContext) > 0
            ? String(Number(selectedCourseContext))
            : '';
        }
        if (bulkDeleteSourceCount) {
          bulkDeleteSourceCount.textContent = `${selectedTemplateIds.length} selected`;
        }
        if (bulkDeleteSourceList) {
          selectedTemplateIds.forEach((templateId) => {
            const template = templateById.get(templateId);
            const item = document.createElement('div');
            item.className = 'bulk-source-item';
            item.textContent = template && template.title
              ? String(template.title)
              : `Template #${templateId}`;
            bulkDeleteSourceList.appendChild(item);
          });
        }
        bulkDeleteModal.show();
      }

      function openTemplateEditor(templateIdRaw) {
        const templateId = Number(templateIdRaw);
        if (!Number.isInteger(templateId) || templateId < 1 || !editModal || !editTemplateForm) {
          return;
        }
        const template = templateById.get(templateId);
        if (!template) {
          return;
        }

        editTemplateForm.setAttribute('action', `/teacher/workspace/templates/${templateId}/update`);
        if (editCourseContextInput) {
          editCourseContextInput.value = Number.isInteger(Number(selectedCourseContext)) && Number(selectedCourseContext) > 0
            ? String(Number(selectedCourseContext))
            : '';
        }
        if (editCourseSelect) {
          editCourseSelect.value = Number.isInteger(Number(template.course_id)) && Number(template.course_id) > 0
            ? String(Number(template.course_id))
            : '';
          syncEditSubjects();
        }
        if (editSubjectSelect) {
          editSubjectSelect.value = Number.isInteger(Number(template.subject_id)) && Number(template.subject_id) > 0
            ? String(Number(template.subject_id))
            : '';
          const selectedOption = editSubjectSelect.selectedOptions && editSubjectSelect.selectedOptions[0];
          if (selectedOption && selectedOption.hidden) {
            editSubjectSelect.value = '';
          }
        }
        if (editTitleInput) {
          editTitleInput.value = String(template.title || '');
        }
        if (editDescriptionInput) {
          editDescriptionInput.value = String(template.description || '');
        }
        if (editTagsInput) {
          editTagsInput.value = String(template.tags || '');
        }
        if (editLinkInput) {
          editLinkInput.value = String(template.link_url || '');
        }
        if (editMeetingInput) {
          editMeetingInput.value = String(template.meeting_url || '');
        }
        if (editControlInput) {
          editControlInput.checked = Number(template.is_control || 0) === 1;
        }
        if (editCreditInput) {
          editCreditInput.checked = Number(template.is_credit || 0) === 1;
        }
        editModal.show();
      }

      function openTemplateCloner(templateIdRaw) {
        const templateId = Number(templateIdRaw);
        if (!Number.isInteger(templateId) || templateId < 1 || !cloneModal || !cloneTemplateForm) {
          return;
        }
        const template = templateById.get(templateId);
        if (!template) {
          return;
        }
        cloneTemplateForm.setAttribute('action', `/teacher/workspace/templates/${templateId}/clone`);
        if (cloneTemplateCourseContextInput) {
          const preferredCourseId = Number.isInteger(Number(selectedCourseContext)) && Number(selectedCourseContext) > 0
            ? Number(selectedCourseContext)
            : (Number.isInteger(Number(template.course_id)) && Number(template.course_id) > 0 ? Number(template.course_id) : null);
          cloneTemplateCourseContextInput.value = preferredCourseId ? String(preferredCourseId) : '';
        }
        if (cloneTemplateSourceTitle) {
          cloneTemplateSourceTitle.textContent = String(template.title || `Template #${templateId}`);
        }
        clearCloneSelection();
        cloneModal.show();
      }

      if (cloneTemplateSearch) {
        cloneTemplateSearch.addEventListener('input', syncCloneSubjectFilter);
      }
      if (cloneSubjectList) {
        cloneSubjectList.addEventListener('change', hideCloneError);
      }
      if (cloneModalEl) {
        cloneModalEl.addEventListener('hidden.bs.modal', clearCloneSelection);
      }
      if (cloneTemplateForm) {
        cloneTemplateForm.addEventListener('submit', (event) => {
          const checkedCount = cloneSubjectList
            ? cloneSubjectList.querySelectorAll('input[name="target_subject_ids"]:checked').length
            : 0;
          if (checkedCount < 1) {
            event.preventDefault();
            if (cloneTemplateError) {
              cloneTemplateError.textContent = 'Select at least one subject to clone this template.';
              cloneTemplateError.classList.remove('d-none');
            }
          }
        });
      }
      if (bulkCloneTemplateSearch) {
        bulkCloneTemplateSearch.addEventListener('input', syncBulkCloneSubjectFilter);
      }
      if (bulkCloneSubjectList) {
        bulkCloneSubjectList.addEventListener('change', hideBulkCloneError);
      }
      if (bulkCloneModalEl) {
        bulkCloneModalEl.addEventListener('hidden.bs.modal', () => {
          resetBulkCloneSubjectSelection();
          if (bulkCloneSourceInputs) {
            bulkCloneSourceInputs.innerHTML = '';
          }
          if (bulkCloneSourceList) {
            bulkCloneSourceList.innerHTML = '';
          }
          if (bulkCloneSourceCount) {
            bulkCloneSourceCount.textContent = '0 selected';
          }
        });
      }
      if (bulkCloneTemplateForm) {
        bulkCloneTemplateForm.addEventListener('submit', (event) => {
          const sourceCount = bulkCloneSourceInputs
            ? bulkCloneSourceInputs.querySelectorAll('input[name="source_template_ids"]').length
            : 0;
          const targetCount = bulkCloneSubjectList
            ? bulkCloneSubjectList.querySelectorAll('input[name="target_subject_ids"]:checked').length
            : 0;
          if (sourceCount < 1 || targetCount < 1) {
            event.preventDefault();
            if (bulkCloneError) {
              bulkCloneError.textContent = sourceCount < 1
                ? 'Select at least one source template first.'
                : 'Select at least one target subject.';
              bulkCloneError.classList.remove('d-none');
            }
          }
        });
      }
      templateSelectToggles.forEach((input) => {
        input.addEventListener('change', syncTemplateSelectionState);
      });
      if (templateSelectAllToggle) {
        templateSelectAllToggle.addEventListener('click', () => {
          const selectedCount = getSelectedTemplateIds().length;
          const shouldSelectAll = selectedCount !== templateSelectToggles.length;
          templateSelectToggles.forEach((input) => {
            input.checked = shouldSelectAll;
          });
          syncTemplateSelectionState();
        });
      }
      if (templateBulkCloneBtn) {
        templateBulkCloneBtn.addEventListener('click', openBulkCloneModal);
      }
      if (templateBulkDeleteBtn) {
        templateBulkDeleteBtn.addEventListener('click', openBulkDeleteModal);
      }
      if (bulkDeleteModalEl) {
        bulkDeleteModalEl.addEventListener('hidden.bs.modal', resetBulkDeleteSelection);
      }
      if (bulkDeleteTemplateForm) {
        bulkDeleteTemplateForm.addEventListener('submit', (event) => {
          const sourceCount = bulkDeleteSourceInputs
            ? bulkDeleteSourceInputs.querySelectorAll('input[name="source_template_ids"]').length
            : 0;
          if (sourceCount < 1) {
            event.preventDefault();
            if (bulkDeleteError) {
              bulkDeleteError.textContent = 'Select at least one source template first.';
              bulkDeleteError.classList.remove('d-none');
            }
          }
        });
      }
      syncTemplateSelectionState();

      document.querySelectorAll('[data-template-edit]').forEach((button) => {
        button.addEventListener('click', () => {
          openTemplateEditor(button.getAttribute('data-template-edit'));
        });
      });
      document.querySelectorAll('[data-template-clone]').forEach((button) => {
        button.addEventListener('click', () => {
          openTemplateCloner(button.getAttribute('data-template-clone'));
        });
      });
    </script>
    <script src="/js/design-system.js" defer></script>
  </body>
</html>
