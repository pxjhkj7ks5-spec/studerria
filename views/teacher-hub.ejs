<%
  const hubLinks = (journalHubLinks && typeof journalHubLinks === 'object') ? journalHubLinks : {};
  const teacherJournalHref = hubLinks.journalHref || '/journal';
  const teacherInsightsHref = hubLinks.insightsHref || '/journal/insights';
  const teacherScheduleHref = hubLinks.scheduleHref || '/schedule';
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title><%= t('teacherHub.pageTitle') %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/design-system.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <style>
      :root {
        --hub-border-dark: rgba(255, 255, 255, 0.14);
        --hub-border-light: rgba(15, 23, 42, 0.12);
        --hub-bg-dark: rgba(255, 255, 255, 0.06);
        --hub-bg-light: rgba(255, 255, 255, 0.7);
      }
      body {
        min-height: 100vh;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display",
          "Helvetica Neue", "Inter", Arial, sans-serif;
      }
      body.theme-dark {
        background:
          radial-gradient(1200px 800px at 12% 6%, rgba(56, 189, 248, 0.16), transparent 62%),
          radial-gradient(1000px 720px at 84% 16%, rgba(129, 140, 248, 0.2), transparent 64%),
          linear-gradient(150deg, #070c18 0%, #101b31 48%, #15263f 100%);
        color: #f8fafc;
      }
      body.theme-light {
        background:
          radial-gradient(1200px 800px at 15% 8%, rgba(125, 211, 252, 0.2), transparent 62%),
          radial-gradient(1000px 720px at 84% 16%, rgba(167, 139, 250, 0.2), transparent 64%),
          linear-gradient(130deg, #e8eff9 0%, #eef4ff 48%, #f6f8ff 100%);
        color: #0f172a;
      }
      .hub-shell {
        padding-top: 24px;
        padding-bottom: 48px;
      }
      .glass {
        border-radius: 22px;
        backdrop-filter: blur(18px);
      }
      body.theme-dark .glass {
        border: 1px solid var(--hub-border-dark);
        background: var(--hub-bg-dark);
        box-shadow: 0 18px 44px rgba(2, 6, 23, 0.5);
      }
      body.theme-light .glass {
        border: 1px solid var(--hub-border-light);
        background: var(--hub-bg-light);
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
      }
      .hub-hero {
        padding: 24px;
      }
      .hub-title {
        margin: 0;
        font-size: clamp(1.8rem, 2.8vw, 2.4rem);
        font-weight: 700;
      }
      .hub-subtitle {
        margin: 10px 0 0;
        max-width: 760px;
        color: rgba(226, 232, 240, 0.82);
      }
      body.theme-light .hub-subtitle {
        color: rgba(15, 23, 42, 0.66);
      }
      .hub-actions {
        margin-top: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .btn-hub {
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.25);
        background: rgba(255, 255, 255, 0.12);
        color: rgba(248, 250, 252, 0.94);
        font-weight: 600;
      }
      .btn-hub:hover {
        background: rgba(255, 255, 255, 0.18);
        color: rgba(248, 250, 252, 1);
      }
      body.theme-light .btn-hub {
        border-color: rgba(15, 23, 42, 0.16);
        background: rgba(255, 255, 255, 0.9);
        color: #0f172a;
      }
      body.theme-light .btn-hub:hover {
        background: #ffffff;
      }
      .hub-panel {
        padding: 20px;
      }
      .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
      }
      .stat-card {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(15, 23, 42, 0.28);
      }
      body.theme-light .stat-card {
        background: rgba(255, 255, 255, 0.86);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .stat-label {
        font-size: 0.78rem;
        color: rgba(203, 213, 225, 0.72);
      }
      body.theme-light .stat-label {
        color: rgba(15, 23, 42, 0.58);
      }
      .stat-value {
        margin-top: 4px;
        font-size: 1.5rem;
        font-weight: 700;
      }
      .quick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 12px;
      }
      .quick-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
        border-radius: 14px;
        padding: 14px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: rgba(15, 23, 42, 0.3);
        color: inherit;
        transform: translateY(10px);
        opacity: 0;
        animation: hub-quick-rise 420ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
      }
      .quick-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 10%, rgba(255, 255, 255, 0.22) 50%, transparent 90%);
        opacity: 0;
        transform: translateX(-135%);
        pointer-events: none;
        animation: hub-quick-gloss 7.2s ease-in-out infinite;
      }
      .quick-card:hover {
        border-color: rgba(125, 211, 252, 0.44);
        transform: translateY(-2px);
        box-shadow: 0 16px 26px rgba(2, 6, 23, 0.24);
      }
      .quick-grid .quick-card:nth-child(1) {
        animation-delay: 30ms;
      }
      .quick-grid .quick-card:nth-child(2) {
        animation-delay: 90ms;
      }
      .quick-grid .quick-card:nth-child(3) {
        animation-delay: 150ms;
      }
      .quick-grid .quick-card:nth-child(4) {
        animation-delay: 210ms;
      }
      body.theme-light .quick-card {
        background: rgba(255, 255, 255, 0.88);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .quick-title {
        font-size: 1rem;
        font-weight: 650;
      }
      .quick-desc {
        font-size: 0.84rem;
        color: rgba(203, 213, 225, 0.76);
      }
      body.theme-light .quick-desc {
        color: rgba(15, 23, 42, 0.6);
      }
      .course-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 4px 10px;
        border: 1px solid rgba(148, 163, 184, 0.3);
        background: rgba(15, 23, 42, 0.28);
        font-size: 0.8rem;
      }
      body.theme-light .course-chip {
        border-color: rgba(15, 23, 42, 0.12);
        background: rgba(255, 255, 255, 0.88);
      }
      .hub-list {
        display: grid;
        gap: 10px;
      }
      .hub-list-item {
        border-radius: 14px;
        padding: 12px 14px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(15, 23, 42, 0.24);
      }
      body.theme-light .hub-list-item {
        background: rgba(255, 255, 255, 0.86);
        border-color: rgba(15, 23, 42, 0.12);
      }
      .hub-list-title {
        font-weight: 650;
      }
      .hub-list-meta {
        margin-top: 4px;
        font-size: 0.84rem;
        color: rgba(203, 213, 225, 0.76);
      }
      body.theme-light .hub-list-meta {
        color: rgba(15, 23, 42, 0.6);
      }
      .hub-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 14px;
      }
      .hub-panel-head p {
        margin: 0;
        font-size: 0.82rem;
        color: rgba(203, 213, 225, 0.72);
      }
      body.theme-light .hub-panel-head p {
        color: rgba(15, 23, 42, 0.58);
      }
      .hub-brief-card {
        border-radius: 18px;
        padding: 18px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(15, 23, 42, 0.28);
      }
      .hub-brief-card.is-risk {
        border-color: rgba(248, 113, 113, 0.38);
        background: linear-gradient(145deg, rgba(127, 29, 29, 0.4), rgba(15, 23, 42, 0.32));
      }
      .hub-brief-card.is-focus {
        border-color: rgba(251, 191, 36, 0.34);
        background: linear-gradient(145deg, rgba(120, 53, 15, 0.34), rgba(15, 23, 42, 0.3));
      }
      .hub-brief-card.is-growth {
        border-color: rgba(74, 222, 128, 0.28);
        background: linear-gradient(145deg, rgba(20, 83, 45, 0.34), rgba(15, 23, 42, 0.28));
      }
      .hub-brief-card.is-calm {
        border-color: rgba(125, 211, 252, 0.28);
        background: linear-gradient(145deg, rgba(8, 47, 73, 0.34), rgba(15, 23, 42, 0.28));
      }
      body.theme-light .hub-brief-card {
        background: rgba(255, 255, 255, 0.88);
        border-color: rgba(15, 23, 42, 0.1);
      }
      body.theme-light .hub-brief-card.is-risk {
        background: linear-gradient(145deg, rgba(254, 242, 242, 0.98), rgba(255, 255, 255, 0.9));
      }
      body.theme-light .hub-brief-card.is-focus {
        background: linear-gradient(145deg, rgba(255, 251, 235, 0.98), rgba(255, 255, 255, 0.9));
      }
      body.theme-light .hub-brief-card.is-growth {
        background: linear-gradient(145deg, rgba(240, 253, 244, 0.98), rgba(255, 255, 255, 0.9));
      }
      body.theme-light .hub-brief-card.is-calm {
        background: linear-gradient(145deg, rgba(239, 246, 255, 0.98), rgba(255, 255, 255, 0.9));
      }
      .hub-kicker {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(226, 232, 240, 0.58);
      }
      body.theme-light .hub-kicker {
        color: rgba(15, 23, 42, 0.48);
      }
      .hub-brief-title {
        margin-top: 8px;
        font-size: 1.15rem;
        font-weight: 720;
        line-height: 1.2;
      }
      .hub-reason-list {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .hub-reason-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 5px 10px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(255, 255, 255, 0.08);
        font-size: 0.8rem;
      }
      body.theme-light .hub-reason-chip {
        border-color: rgba(15, 23, 42, 0.1);
        background: rgba(255, 255, 255, 0.82);
      }
      .hub-priority-list {
        display: grid;
        gap: 10px;
      }
      .hub-priority-item {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        border-radius: 16px;
        padding: 14px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(15, 23, 42, 0.22);
      }
      body.theme-light .hub-priority-item {
        background: rgba(255, 255, 255, 0.84);
        border-color: rgba(15, 23, 42, 0.1);
      }
      .hub-priority-main {
        min-width: 0;
      }
      .hub-priority-title {
        font-weight: 650;
      }
      .hub-priority-meta {
        margin-top: 4px;
        font-size: 0.84rem;
        color: rgba(203, 213, 225, 0.74);
      }
      body.theme-light .hub-priority-meta {
        color: rgba(15, 23, 42, 0.58);
      }
      .hub-priority-link {
        white-space: nowrap;
      }
      @keyframes hub-quick-rise {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes hub-quick-gloss {
        0%,
        74%,
        100% {
          opacity: 0;
          transform: translateX(-135%);
        }
        80% {
          opacity: 0.9;
          transform: translateX(135%);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .quick-card {
          animation: none;
          transition: none;
          transform: none;
          opacity: 1;
        }
        .quick-card::after {
          animation: none;
        }
      }
    </style>
    <link rel="stylesheet" href="/css/studerria-ui.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
    <link rel="stylesheet" href="/css/dynamic-bg.css?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" />
  </head>
  <body class="studerria-theme theme-dark page-teacher-hub page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', { role, username, t, activePage: 'teacher-hub', pageTitle: t('teacherHub.title'), settings: settings }) %>
    <%- include('partials/desktop-menu-drawer', {
      role,
      t,
      activePage: 'teacher-hub',
      settings: (typeof settings !== 'undefined') ? settings : null,
    }) %>

    <main class="container hub-shell">
      <%
        const hubLocale = lang === 'en' ? 'en-US' : 'uk-UA';
        const formatHubDate = (value) => {
          if (!value) return lang === 'en' ? 'No date' : 'Без дати';
          const parsed = new Date(value);
          if (Number.isNaN(parsed.getTime())) return String(value);
          return parsed.toLocaleString(hubLocale, {
            day: '2-digit',
            month: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
          });
        };
      %>
      <% if (error) { %>
        <div class="alert alert-danger glass mb-3"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success glass mb-3"><%= success %></div>
      <% } %>

      <section class="glass hub-hero mb-3">
        <h1 class="hub-title"><%= t('teacherHub.title') %></h1>
        <p class="hub-subtitle">
          <%= t('teacherHub.subtitle') %>
        </p>
        <div class="hub-actions">
          <a class="btn btn-hub" href="<%= teacherScheduleHref %>"><%= t('teacherHub.action.schedule') %></a>
          <a class="btn btn-hub" href="/teacher/workspace"><%= t('teacherHub.action.workspace') %></a>
          <a class="btn btn-hub" href="/teacher/subjects"><%= t('teacherHub.action.subjects') %></a>
          <a class="btn btn-hub" href="<%= teacherJournalHref %>"><%= t('teacherHub.action.journal') %></a>
        </div>
      </section>

      <%
        const teacherBriefTone = teacherBrief && teacherBrief.tone ? String(teacherBrief.tone) : 'calm';
        const teacherBriefReasons = teacherBrief && Array.isArray(teacherBrief.reasons) ? teacherBrief.reasons.filter(Boolean).slice(0, 3) : [];
        const teacherPriorities = Array.isArray(teacherTopPriorities) ? teacherTopPriorities : [];
        const activitySummary = teacherActivitySummary || {};
        const ratingTopEntry = latestRatingSnapshot && latestRatingSnapshot.top_entry ? latestRatingSnapshot.top_entry : null;
        const hasRecentTemplates = Array.isArray(recentTemplates) && recentTemplates.length > 0;
        const hasTeacherAssets = Array.isArray(teacherAssets) && teacherAssets.length > 0;
      %>

      <section class="row g-3 mb-1">
        <div class="col-12 col-xl-7">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'What needs attention now' : 'Що потребує уваги зараз' %></h5>
                <p><%= lang === 'en' ? 'Keep the next move obvious: one brief, a short reason stack, and direct links to action.' : 'Тут має бути очевидний наступний крок: один brief, короткі причини й прямі переходи до дії.' %></p>
              </div>
              <% if (teacherBrief && teacherBrief.action_href) { %>
                <a class="btn btn-hub btn-sm" href="<%= teacherBrief.action_href %>"><%= teacherBrief.action_label || (lang === 'en' ? 'Open' : 'Відкрити') %></a>
              <% } %>
            </div>
            <div class="hub-brief-card is-<%= teacherBriefTone %>">
              <div class="hub-kicker"><%= lang === 'en' ? 'Operational digest' : 'Оперативний зріз' %></div>
              <div class="hub-brief-title"><%= teacherBrief && teacherBrief.title ? teacherBrief.title : (lang === 'en' ? 'Stable working rhythm' : 'Стабільний робочий ритм') %></div>
              <div class="hub-list-meta mt-2">
                <%= teacherBrief && teacherBrief.message ? teacherBrief.message : (lang === 'en' ? 'No critical blockers surfaced right now. Use the dashboard cards below to move into schedule, journal, or workspace.' : 'Критичних блокерів зараз не видно. Нижче є прямі переходи в розклад, журнал і workspace.') %>
              </div>
              <% if (teacherBriefReasons.length) { %>
                <div class="hub-reason-list">
                  <% teacherBriefReasons.forEach(function(reason) { %>
                    <span class="hub-reason-chip"><%= reason %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <% if (teacherPriorities.length) { %>
              <div class="hub-priority-list mt-3">
                <% teacherPriorities.forEach(function(item) { %>
                  <div class="hub-priority-item">
                    <div class="hub-priority-main">
                      <div class="hub-priority-title"><%= item.subject_name || item.description || (lang === 'en' ? 'Priority item' : 'Пріоритет') %></div>
                      <div class="hub-priority-meta">
                        <%= item.description || (lang === 'en' ? 'Needs attention in the current teaching window.' : 'Потребує уваги в поточному викладацькому вікні.') %>
                        <% if (item.deadline_date) { %>
                          · <%= formatHubDate(item.deadline_date) %>
                        <% } %>
                      </div>
                    </div>
                    <a class="btn btn-hub btn-sm hub-priority-link" href="<%= item.action_href || teacherJournalHref %>"><%= item.action_label || (lang === 'en' ? 'Open' : 'Відкрити') %></a>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </article>
        </div>
        <div class="col-12 col-xl-5">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'Operational pulse' : 'Операційний пульс' %></h5>
                <p><%= lang === 'en' ? 'Small numbers that show whether review, deadlines, and follow-up stay under control.' : 'Короткий набір метрик, який показує, чи контрольовані перевірка, дедлайни та follow-up.' %></p>
              </div>
              <a class="btn btn-hub btn-sm" href="/home"><%= lang === 'en' ? 'Open home' : 'На головну' %></a>
            </div>
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Due soon' : 'Скоро дедлайни' %></div>
                <div class="stat-value"><%= Number(activitySummary && activitySummary.due_soon ? activitySummary.due_soon : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Overdue' : 'Прострочено' %></div>
                <div class="stat-value"><%= Number(activitySummary && activitySummary.overdue ? activitySummary.overdue : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Recent feedback' : 'Свіжий фідбек' %></div>
                <div class="stat-value"><%= Number(activitySummary && activitySummary.recent_feedback ? activitySummary.recent_feedback : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Open reminders' : 'Активні нагадування' %></div>
                <div class="stat-value"><%= Number(activitySummary && activitySummary.open_reminders ? activitySummary.open_reminders : 0) %></div>
              </div>
            </div>
            <div class="hub-list mt-3">
              <div class="hub-list-item">
                <div class="hub-list-title"><%= lang === 'en' ? 'Latest published rating' : 'Останній опублікований рейтинг' %></div>
                <% if (latestRatingSnapshot) { %>
                  <div class="hub-list-meta">
                    <%= latestRatingSnapshot.scope_label || (lang === 'en' ? 'Selected scope' : 'Обраний контур') %>
                    <% if (latestRatingSnapshot.target_label) { %> · <%= latestRatingSnapshot.target_label %><% } %>
                    <% if (latestRatingSnapshot.period_label) { %> · <%= latestRatingSnapshot.period_label %><% } %>
                    <% if (latestRatingSnapshot.updated_label) { %> · <%= latestRatingSnapshot.updated_label %><% } %>
                  </div>
                  <% if (ratingTopEntry) { %>
                    <div class="hub-list-meta mt-2">
                      <strong><%= lang === 'en' ? 'Leader' : 'Лідер' %>:</strong> <%= ratingTopEntry.full_name %>
                      <% if (ratingTopEntry.score_label) { %> · <%= ratingTopEntry.score_label %><% } %>
                    </div>
                  <% } %>
                  <div class="mt-3">
                    <a class="btn btn-hub btn-sm" href="<%= teacherInsightsHref %>"><%= lang === 'en' ? 'Open insights' : 'Відкрити інсайти' %></a>
                  </div>
                <% } else { %>
                  <div class="hub-list-meta"><%= lang === 'en' ? 'Publish a rating from Journal Insights to keep this dashboard aligned with the same snapshot used in My Day and the schedule inbox.' : 'Опублікуйте рейтинг із Journal Insights, щоб цей дашборд бачив той самий snapshot, що й My Day та inbox розкладу.' %></div>
                  <div class="mt-3">
                    <a class="btn btn-hub btn-sm" href="<%= teacherInsightsHref %>"><%= lang === 'en' ? 'Go to insights' : 'До інсайтів' %></a>
                  </div>
                <% } %>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12 col-xl-5">
          <article class="glass hub-panel h-100">
            <h5 class="mb-3"><%= t('teacherHub.snapshot') %></h5>
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-label"><%= t('teacherHub.stat.assignedSubjects') %></div>
                <div class="stat-value"><%= Number(stats && stats.subjects ? stats.subjects : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= t('teacherHub.stat.courses') %></div>
                <div class="stat-value"><%= Number(stats && stats.courses ? stats.courses : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= t('teacherHub.stat.savedTemplates') %></div>
                <div class="stat-value"><%= Number(stats && stats.templates ? stats.templates : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Assets' : 'Асети' %></div>
                <div class="stat-value"><%= Number(stats && stats.assets ? stats.assets : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= t('teacherHub.stat.homeworkCreated') %></div>
                <div class="stat-value"><%= Number(stats && stats.created_homework ? stats.created_homework : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= t('teacherHub.stat.last30Days') %></div>
                <div class="stat-value"><%= Number(stats && stats.recent_homework ? stats.recent_homework : 0) %></div>
              </div>
            </div>
          </article>
        </div>
        <div class="col-12 col-xl-7">
          <article class="glass hub-panel h-100">
            <h5 class="mb-3"><%= t('teacherHub.quickActions') %></h5>
            <div class="quick-grid">
              <a class="quick-card" href="/teacher/workspace">
                <span class="quick-title"><%= t('teacherHub.quick.manageTemplates.title') %></span>
                <span class="quick-desc"><%= t('teacherHub.quick.manageTemplates.desc') %></span>
              </a>
              <a class="quick-card" href="/teacher/subjects">
                <span class="quick-title"><%= t('teacherHub.quick.updateScope.title') %></span>
                <span class="quick-desc"><%= t('teacherHub.quick.updateScope.desc') %></span>
              </a>
              <a class="quick-card" href="<%= teacherScheduleHref %>">
                <span class="quick-title"><%= t('teacherHub.quick.openSchedule.title') %></span>
                <span class="quick-desc"><%= t('teacherHub.quick.openSchedule.desc') %></span>
              </a>
              <a class="quick-card" href="<%= teacherJournalHref %>">
                <span class="quick-title"><%= t('teacherHub.quick.goJournal.title') %></span>
                <span class="quick-desc"><%= t('teacherHub.quick.goJournal.desc') %></span>
              </a>
            </div>
            <% if ((teacherCourses || []).length) { %>
              <div class="mt-3 d-flex flex-wrap gap-2">
                <% (teacherCourses || []).forEach(function(course) { %>
                  <span class="course-chip"><%= course.name %></span>
                <% }) %>
              </div>
            <% } %>
          </article>
        </div>
      </section>

      <section class="row g-3 mt-1">
        <div class="col-12 col-xl-6">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'Upcoming sessions' : 'Найближчі сесії' %></h5>
                <p><%= lang === 'en' ? 'What requires action from the next timetable window.' : 'Що варто закрити до найближчих пар.' %></p>
              </div>
              <a class="btn btn-hub btn-sm" href="<%= teacherScheduleHref %>"><%= lang === 'en' ? 'Open schedule' : 'До розкладу' %></a>
            </div>
            <% if ((upcomingClasses || []).length) { %>
              <div class="hub-list">
                <% upcomingClasses.forEach(function(item) { %>
                  <div class="hub-list-item">
                    <div class="hub-list-title"><%= item.subject_name || (lang === 'en' ? 'Class' : 'Пара') %></div>
                    <div class="hub-list-meta">
                      <%= item.day_context === 'tomorrow' ? (lang === 'en' ? 'Tomorrow' : 'Завтра') : (lang === 'en' ? 'Today' : 'Сьогодні') %>
                      · <%= item.start || '--:--' %>-<%= item.end || '--:--' %>
                      <% if (item.class_number) { %> · <%= lang === 'en' ? 'Class' : 'Пара' %> <%= item.class_number %><% } %>
                      <% if (item.group_number) { %> · <%= lang === 'en' ? 'Group' : 'Група' %> <%= item.group_number %><% } %>
                      <% if (item.room_label) { %> · <%= item.room_label %><% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="hub-list-item"><%= lang === 'en' ? 'No upcoming classes yet.' : 'Наразі немає найближчих пар.' %></div>
            <% } %>
          </article>
        </div>
        <div class="col-12 col-xl-6">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'Review queue' : 'Черга перевірки' %></h5>
                <p><%= lang === 'en' ? 'Homework and templates waiting for your review pass.' : 'Домашки й шаблони, які чекають на перевірку.' %></p>
              </div>
              <a class="btn btn-hub btn-sm" href="/home#reviewQueueBlock"><%= lang === 'en' ? 'Open queue' : 'Відкрити' %></a>
            </div>
            <div class="stat-grid">
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Total' : 'Всього' %></div>
                <div class="stat-value"><%= Number(reviewQueue && reviewQueue.total ? reviewQueue.total : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'Overdue' : 'Прострочено' %></div>
                <div class="stat-value"><%= Number(reviewQueue && reviewQueue.counts && reviewQueue.counts.overdue ? reviewQueue.counts.overdue : 0) %></div>
              </div>
              <div class="stat-card">
                <div class="stat-label"><%= lang === 'en' ? 'No comment' : 'Без коментаря' %></div>
                <div class="stat-value"><%= Number(reviewQueue && reviewQueue.counts && reviewQueue.counts.no_comment ? reviewQueue.counts.no_comment : 0) %></div>
              </div>
            </div>
          </article>
        </div>
        <% if (hasRecentTemplates) { %>
        <div class="col-12 col-xl-6">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'Recent templates' : 'Останні шаблони' %></h5>
                <p><%= lang === 'en' ? 'Reusable starts for upcoming homework and session tasks.' : 'База для швидкого створення домашок і сесійних задач.' %></p>
              </div>
              <a class="btn btn-hub btn-sm" href="/teacher/workspace"><%= lang === 'en' ? 'Workspace' : 'Робоча зона' %></a>
            </div>
              <div class="hub-list">
                <% recentTemplates.forEach(function(template) { %>
                  <div class="hub-list-item">
                    <div class="hub-list-title"><%= template.title %></div>
                    <div class="hub-list-meta">
                      <% if (template.subject_name) { %><%= template.subject_name %><% } %>
                      <% if (template.course_name) { %> · <%= template.course_name %><% } %>
                      <% if (template.asset_count) { %> · <%= template.asset_count %> <%= lang === 'en' ? 'files' : 'файлів' %><% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
          </article>
        </div>
        <% } %>
        <% if (hasTeacherAssets) { %>
        <div class="col-12 col-xl-6">
          <article class="glass hub-panel h-100">
            <div class="hub-panel-head">
              <div>
                <h5 class="mb-1"><%= lang === 'en' ? 'Asset library' : 'Бібліотека асетів' %></h5>
                <p><%= lang === 'en' ? 'Reusable files linked to templates and homework.' : 'Файли, які можна повторно використовувати в шаблонах і домашках.' %></p>
              </div>
              <a class="btn btn-hub btn-sm" href="/teacher/workspace"><%= lang === 'en' ? 'Manage files' : 'Керувати' %></a>
            </div>
              <div class="hub-list">
                <% teacherAssets.forEach(function(asset) { %>
                  <div class="hub-list-item">
                    <div class="hub-list-title"><%= asset.name || asset.original_name || (lang === 'en' ? 'File' : 'Файл') %></div>
                    <div class="hub-list-meta">
                      <% if (asset.course_id) { %>#<%= asset.course_id %><% } %>
                      <% if (asset.mime_type) { %> · <%= asset.mime_type %><% } %>
                      <% if (asset.created_at) { %> · <%= formatHubDate(asset.created_at) %><% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
          </article>
        </div>
        <% } %>
      </section>

      <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/changelog-modal') %>
    <%- include('partials/mobile-menu-modal', {
      role,
      t,
      activePage: 'teacher-hub',
      settings: (typeof settings !== 'undefined') ? settings : null,
    }) %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script src="/js/design-system.js" defer></script>
    <script>
      (function initThemeToggles() {
        function applyStandaloneTheme(rawTheme) {
          const theme = rawTheme === 'theme-light' || rawTheme === 'light' ? 'light' : 'dark';
          const storedTheme = theme === 'light' ? 'theme-light' : 'theme-dark';
          document.documentElement.setAttribute('data-theme', theme);
          document.body.setAttribute('data-theme', theme);
          document.body.classList.remove('theme-light', 'theme-dark');
          document.body.classList.add(storedTheme);
          localStorage.setItem('ui-theme', storedTheme);
          return storedTheme;
        }

        const themeToggles = document.querySelectorAll('.theme-toggle');
        const activeTheme = applyStandaloneTheme(localStorage.getItem('ui-theme') || 'theme-dark');

        themeToggles.forEach((btn) => {
          btn.textContent = activeTheme === 'theme-dark' ? btn.dataset.lightLabel : btn.dataset.darkLabel;
          btn.addEventListener('click', () => {
            const next = document.body.classList.contains('theme-dark') ? 'theme-light' : 'theme-dark';
            const nextStoredTheme = applyStandaloneTheme(next);
            themeToggles.forEach((toggle) => {
              toggle.textContent = nextStoredTheme === 'theme-dark' ? toggle.dataset.lightLabel : toggle.dataset.darkLabel;
            });
          });
        });
      })();
    </script>
      <script src="/js/dynamic-bg.js?v=<%= encodeURIComponent(String(appVersion || '0.0.0')) %>" defer></script>
  </body>
</html>
