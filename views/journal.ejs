      const navigateCell = (columnStep, studentStep) => {
        const currentColumnIndex = findColumnIndex(currentCellColumnId);
        const currentStudentIndex = findStudentIndex(currentCellStudentId);
        if (currentColumnIndex < 0 || currentStudentIndex < 0) return;
        const nextColumnIndex = Math.max(0, Math.min(journalColumnsData.length - 1, currentColumnIndex + columnStep));
        const nextStudentIndex = Math.max(0, Math.min(journalStudentsData.length - 1, currentStudentIndex + studentStep));
        const nextColumn = journalColumnsData[nextColumnIndex];
        const nextStudent = journalStudentsData[nextStudentIndex];
        if (!nextColumn || !nextStudent) return;
        openJournalCell(nextColumn.id, nextStudent.id);
      };

      async function openJournalCell(columnId, studentId) {
        if (!modal) return;
        try {
          const res = await fetch(`/journal/cell.json?column_id=${encodeURIComponent(columnId)}&student_id=${encodeURIComponent(studentId)}`);
          if (!res.ok) throw new Error('Request failed');
          const data = await res.json();
          titleEl.textContent = data && data.column ? data.column.title : 'Оцінювання';
          studentEl.textContent = data && data.student ? data.student.full_name : '-';
          setStatusLabel(data ? data.submission_status : '');
          renderCellOverview(data || null);
          renderSubmission(data ? data.submission : null, data ? data.column : null);
          currentCellColumnId = Number(columnId);
          currentCellStudentId = Number(studentId);
          currentCellLocked = Boolean(data && data.column && data.column.is_locked);
          syncStaticWorkflowForms();
          renderRetakes(data || null);
          renderAppeals(data || null);
          renderModeration(data || null);
          renderCompetencies(data || null);

          columnInput.value = String(columnId);
          studentInput.value = String(studentId);
          if (deleteColumnInput) deleteColumnInput.value = String(columnId);
          if (deleteStudentInput) deleteStudentInput.value = String(studentId);
          scoreEl.max = data && data.column ? String(data.column.max_points || 0) : '';
          scoreEl.value = data && data.grade && Number.isFinite(Number(data.grade.score))
            ? String(data.grade.score)
            : '';
          const existingComment = data && data.grade && data.grade.teacher_comment ? data.grade.teacher_comment : '';
          commentEl.value = existingComment;
          const canEditCurrent = Boolean(canEditJournal && data && data.can_edit && !currentCellLocked);
          scoreEl.disabled = !canEditCurrent;
          commentEl.disabled = !canEditCurrent;
          if (!existingComment && pendingPrefillComment && canEditCurrent) {
            commentEl.value = pendingPrefillComment;
            pendingPrefillComment = '';
          }
          if (gradeForm) {
            const submitBtn = gradeForm.querySelector('button[type="submit"]');
            if (submitBtn) {
              submitBtn.style.display = canEditJournal ? '' : 'none';
              submitBtn.disabled = !canEditCurrent;
            }
          }
          if (deleteForm) {
            deleteForm.style.display = canEditJournal ? '' : 'none';
          }
          if (deleteBtn) {
            const hasGrade = Boolean(data && data.grade && Number.isFinite(Number(data.grade.score)));
            deleteBtn.disabled = !canEditCurrent || !hasGrade;
          }
          if (prevCellBtn) {
            prevCellBtn.disabled = !canEditJournal || currentCellLocked;
          }
          if (nextCellBtn) {
            nextCellBtn.disabled = !canEditJournal || currentCellLocked;
          }
          if (lockedNotice) {
            lockedNotice.classList.toggle('d-none', !currentCellLocked);
          }
          modal.show();
        } catch (err) {
          console.error(err);
        }
      }

      const parseBulkInput = () => {
        if (!bulkPasteEl || !bulkPreviewMetaEl || !bulkPreviewEl) return false;
        const lines = String(bulkPasteEl.value || '').replace(/\r/g, '').split('\n');
        const entries = [];
        const errors = [];
        const previewRows = [];
        const maxRows = Math.min(lines.length, journalStudentsData.length);
        for (let index = 0; index < maxRows; index += 1) {
          const student = journalStudentsData[index];
          const rawLine = String(lines[index] || '');
          if (!rawLine.trim()) continue;
          const parts = rawLine.split('\t');
          const scoreRaw = String(parts[0] || '').trim();
          if (!scoreRaw) continue;
          const score = Number(scoreRaw.replace(',', '.'));
          const comment = parts.slice(1).join(' ').trim();
          if (!Number.isFinite(score) || score < 0 || score > bulkCurrentMax) {
            errors.push(`Рядок ${index + 1}: бал має бути від 0 до ${formatNumber(bulkCurrentMax)}`);
            continue;
          }
          const normalizedScore = Math.round(score * 100) / 100;
          entries.push({
            student_id: student.id,
            score: normalizedScore,
            teacher_comment: comment,
          });
          if (previewRows.length < 12) {
            previewRows.push(`${student.full_name}: ${formatNumber(normalizedScore)}${comment ? ` (${comment})` : ''}`);
          }
        }
        const linesExtra = lines.length > journalStudentsData.length
          ? `, зайві рядки: ${lines.length - journalStudentsData.length}`
          : '';
        if (errors.length) {
          bulkPreviewMetaEl.textContent = `Попередній перегляд: помилки (${errors.length})${linesExtra}`;
          renderBulkPreviewMessages(errors, 'text-danger small');
        } else {
          bulkPreviewMetaEl.textContent = `Попередній перегляд: ${entries.length} записів${linesExtra}`;
          if (previewRows.length) {
            renderBulkPreviewMessages(previewRows, 'small');
          } else {
            renderBulkPreviewEmpty('Немає даних для збереження.');
          }
        }
        const canSubmit = !bulkCurrentLocked && entries.length > 0 && errors.length === 0;
        if (bulkSubmitBtn) bulkSubmitBtn.disabled = !canSubmit;
        if (bulkEntriesInput) bulkEntriesInput.value = canSubmit ? JSON.stringify(entries) : '';
        return canSubmit;
      };

      const openBulkModal = (buttonEl) => {
        if (!bulkModal || !buttonEl) return;
        const columnId = Number(buttonEl.dataset.columnId || 0);
        const columnTitle = String(buttonEl.dataset.columnTitle || '');
        const maxPoints = Number(buttonEl.dataset.columnMax || 0);
        const isLocked = Number(buttonEl.dataset.columnLocked || 0) === 1;
        if (!columnId) return;
        bulkCurrentLocked = isLocked;
        bulkCurrentMax = Number.isFinite(maxPoints) && maxPoints > 0 ? maxPoints : 100;
        if (bulkColumnIdInput) bulkColumnIdInput.value = String(columnId);
        if (bulkColumnTitleEl) {
          bulkColumnTitleEl.textContent = `${columnTitle || 'Колонка'} · Макс ${formatNumber(bulkCurrentMax)} б.`;
        }
        if (bulkPasteEl) {
          bulkPasteEl.value = '';
          bulkPasteEl.disabled = isLocked;
        }
        if (bulkLockedAlert) {
          bulkLockedAlert.classList.toggle('d-none', !isLocked);
        }
        if (bulkEntriesInput) bulkEntriesInput.value = '';
        if (bulkPreviewMetaEl) bulkPreviewMetaEl.textContent = 'Попередній перегляд: 0 записів';
        renderBulkPreviewEmpty('Вставте дані для попереднього перегляду.');
        if (bulkSubmitBtn) bulkSubmitBtn.disabled = true;
        bulkModal.show();
      };

      const serializeAttendanceRows = () => {
        if (!attendanceRowEls.length) return [];
        return attendanceRowEls.map((rowEl) => {
          const studentId = Number(rowEl.dataset.studentId || 0);
          const statusEl = rowEl.querySelector('[data-attendance-status]');
          const reasonEl = rowEl.querySelector('[data-attendance-reason]');
          return {
            student_id: studentId,
            status: String(statusEl ? statusEl.value : '').trim(),
            reason: String(reasonEl ? reasonEl.value : '').trim(),
          };
        }).filter((row) => Number.isFinite(row.student_id) && row.student_id > 0);
      };

      const resolveAttendanceClassLabel = (classNumberRaw) => {
        const classNumber = Number(classNumberRaw || 0);
        if (!Number.isFinite(classNumber) || classNumber < 1) return `${journalText.classLabel} ${journalText.dash}`;
        const option = document.querySelector(
          `.journal-attendance-editor select[name="attendance_class_number"] option[value="${classNumber}"]`
        );
        if (option && String(option.textContent || '').trim()) {
          return String(option.textContent || '').trim();
        }
        return `${journalText.classLabel} ${classNumber}`;
      };

      const normalizeAttendanceRowState = (row) => {
        const status = String(row && row.status ? row.status : '').trim();
        const reasonRaw = String(row && row.reason ? row.reason : '').trim();
        return {
          status,
          reason: status ? reasonRaw : '',
        };
      };

      const getAttendanceInitialRowState = (rowEl) => normalizeAttendanceRowState({
        status: rowEl ? rowEl.dataset.initialStatus : '',
        reason: rowEl ? rowEl.dataset.initialReason : '',
      });

      const getAttendanceCurrentRowState = (rowEl) => {
        const statusEl = rowEl ? rowEl.querySelector('[data-attendance-status]') : null;
        const reasonEl = rowEl ? rowEl.querySelector('[data-attendance-reason]') : null;
        return normalizeAttendanceRowState({
          status: statusEl ? statusEl.value : '',
          reason: reasonEl ? reasonEl.value : '',
        });
      };

      const renderAttendanceWorkflowState = () => {
        let marked = 0;
        let changed = 0;
        let removed = 0;
        attendanceRowEls.forEach((rowEl) => {
          const initial = getAttendanceInitialRowState(rowEl);
          const current = getAttendanceCurrentRowState(rowEl);
          const isDirty = initial.status !== current.status || initial.reason !== current.reason;
          if (current.status) marked += 1;
          if (isDirty) changed += 1;
          if (initial.status && !current.status) removed += 1;
          rowEl.classList.toggle('is-dirty', isDirty);
        });
        if (attendanceMarkedCountEl) attendanceMarkedCountEl.textContent = String(marked);
        if (attendanceChangedCountEl) attendanceChangedCountEl.textContent = String(changed);
        if (attendanceRemovedCountEl) attendanceRemovedCountEl.textContent = String(removed);
        if (attendanceStateChipEl) {
          attendanceStateChipEl.className = changed > 0
            ? 'status-chip status-chip--warning'
            : 'status-chip status-chip--neutral';
          attendanceStateChipEl.textContent = changed > 0
            ? journalText.attendanceStatusDirty
            : journalText.attendanceStatusClean;
        }
        if (attendanceSaveBtn) {
          attendanceSaveBtn.disabled = changed < 1;
        }
        return { marked, changed, removed };
      };

      const setAttendanceEditorVisible = (visible) => {
        if (!attendanceEditorEl || !attendanceToggleEditorBtn) return;
        attendanceEditorEl.classList.toggle('d-none', !visible);
        const openLabel = attendanceToggleEditorBtn.dataset.openLabel || journalText.attendanceEditorOpen;
        const closeLabel = attendanceToggleEditorBtn.dataset.closeLabel || journalText.attendanceEditorClose;
        attendanceToggleEditorBtn.textContent = visible ? closeLabel : openLabel;
      };

      if (attendanceToggleEditorBtn && attendanceEditorEl) {
        setAttendanceEditorVisible(false);
        attendanceToggleEditorBtn.addEventListener('click', () => {
          const next = attendanceEditorEl.classList.contains('d-none');
          setAttendanceEditorVisible(next);
        });
      }

      const attendanceQuickState = {
        rows: [],
        index: 0,
      };

      const buildAttendanceQuickRows = () => (
        attendanceRowEls.map((rowEl) => {
          const studentId = Number(rowEl.dataset.studentId || 0);
          const statusEl = rowEl.querySelector('[data-attendance-status]');
          const reasonEl = rowEl.querySelector('[data-attendance-reason]');
        return {
          student_id: studentId,
          full_name: String(rowEl.dataset.studentName || '').trim() || `${journalText.studentFallbackPrefix} #${studentId}`,
          group_number: Number(rowEl.dataset.groupNumber || 0),
          status: String(statusEl ? statusEl.value : '').trim(),
          reason: String(reasonEl ? reasonEl.value : '').trim(),
          };
        }).filter((row) => Number.isFinite(row.student_id) && row.student_id > 0)
      );

      const syncAttendanceQuickRowToEditor = (entry) => {
        if (!entry) return;
        const rowEl = attendanceRowEls.find((item) => Number(item.dataset.studentId || 0) === Number(entry.student_id));
        if (!rowEl) return;
        const statusEl = rowEl.querySelector('[data-attendance-status]');
        const reasonEl = rowEl.querySelector('[data-attendance-reason]');
        if (statusEl) statusEl.value = String(entry.status || '').trim();
        if (reasonEl) reasonEl.value = String(entry.reason || '').trim();
        renderAttendanceWorkflowState();
      };

      const countAttendanceQuickSummary = (rows) => {
        const counters = { present: 0, absent: 0, excused: 0, unset: 0 };
        (rows || []).forEach((row) => {
          const status = String(row && row.status ? row.status : '').trim();
          if (status === 'present' || status === 'absent' || status === 'excused') {
            counters[status] += 1;
          } else {
            counters.unset += 1;
          }
        });
        return counters;
      };

      const renderAttendanceQuickStep = () => {
        const rows = attendanceQuickState.rows || [];
        const total = rows.length;
        if (!total) {
          if (attendanceQuickProgressEl) attendanceQuickProgressEl.textContent = '0 / 0';
          if (attendanceQuickSummaryEl) attendanceQuickSummaryEl.textContent = journalText.quickAttendanceNone;
          if (attendanceQuickStudentNameEl) attendanceQuickStudentNameEl.textContent = journalText.dash;
          if (attendanceQuickStudentGroupEl) attendanceQuickStudentGroupEl.textContent = journalText.dash;
          if (attendanceQuickReasonEl) {
            attendanceQuickReasonEl.value = '';
            attendanceQuickReasonEl.disabled = true;
          }
          attendanceQuickStatusButtons.forEach((button) => {
            button.disabled = true;
          });
          if (attendanceQuickBackBtn) attendanceQuickBackBtn.disabled = true;
          if (attendanceQuickSkipBtn) attendanceQuickSkipBtn.disabled = true;
          if (attendanceQuickSaveBtn) attendanceQuickSaveBtn.disabled = true;
          return;
        }
        if (attendanceQuickState.index >= total) {
          const summary = countAttendanceQuickSummary(rows);
          if (attendanceQuickProgressEl) attendanceQuickProgressEl.textContent = `${total} / ${total}`;
          if (attendanceQuickSummaryEl) {
            attendanceQuickSummaryEl.textContent = `${journalText.readySummaryPrefix}: ${journalText.attendancePresent.toLowerCase()} ${summary.present}, ${journalText.attendanceAbsent.toLowerCase()} ${summary.absent}, ${journalText.attendanceExcused.toLowerCase()} ${summary.excused}, ${journalText.attendanceNotMarked.replace(/—/g, '').trim().toLowerCase()} ${summary.unset}.`;
          }
          if (attendanceQuickStudentNameEl) attendanceQuickStudentNameEl.textContent = journalText.readyToSave;
          if (attendanceQuickStudentGroupEl) attendanceQuickStudentGroupEl.textContent = journalText.readyToSaveHint;
          if (attendanceQuickReasonEl) {
            attendanceQuickReasonEl.value = '';
            attendanceQuickReasonEl.disabled = true;
          }
          attendanceQuickStatusButtons.forEach((button) => {
            button.disabled = true;
          });
          if (attendanceQuickBackBtn) attendanceQuickBackBtn.disabled = total < 1;
          if (attendanceQuickSkipBtn) attendanceQuickSkipBtn.disabled = true;
          if (attendanceQuickSaveBtn) attendanceQuickSaveBtn.disabled = false;
          return;
        }
        const current = rows[attendanceQuickState.index];
        if (attendanceQuickProgressEl) attendanceQuickProgressEl.textContent = `${attendanceQuickState.index + 1} / ${total}`;
        if (attendanceQuickSummaryEl) attendanceQuickSummaryEl.textContent = journalText.chooseStatusHint;
        if (attendanceQuickStudentNameEl) attendanceQuickStudentNameEl.textContent = current.full_name || `${journalText.studentFallbackPrefix} #${current.student_id}`;
        if (attendanceQuickStudentGroupEl) {
          const groupNumber = Number(current.group_number || 0);
          attendanceQuickStudentGroupEl.textContent = Number.isFinite(groupNumber) && groupNumber > 0 ? `${journalText.groupPrefix} ${groupNumber}` : journalText.groupNotSpecified;
        }
        if (attendanceQuickReasonEl) {
          attendanceQuickReasonEl.disabled = false;
          attendanceQuickReasonEl.value = String(current.reason || '');
        }
        attendanceQuickStatusButtons.forEach((button) => {
          button.disabled = false;
        });
        if (attendanceQuickBackBtn) attendanceQuickBackBtn.disabled = attendanceQuickState.index < 1;
        if (attendanceQuickSkipBtn) attendanceQuickSkipBtn.disabled = false;
        if (attendanceQuickSaveBtn) attendanceQuickSaveBtn.disabled = false;
      };

      const openAttendanceQuickModal = () => {
        if (!attendanceQuickModal) return;
        const dateInputEl = attendanceForm ? attendanceForm.querySelector('input[name="attendance_date"]') : null;
        const classInputEl = attendanceForm ? attendanceForm.querySelector('input[name="attendance_class_number"]') : null;
        const dateValue = String(dateInputEl ? dateInputEl.value : '').trim();
        const classNumber = Number(classInputEl ? classInputEl.value : 0);
        if (attendanceQuickDateInput) attendanceQuickDateInput.value = dateValue;
        if (attendanceQuickClassInput) attendanceQuickClassInput.value = Number.isFinite(classNumber) ? String(classNumber) : '';
        if (attendanceQuickScopeEl) {
          attendanceQuickScopeEl.textContent = `${dateValue || journalText.dash} · ${resolveAttendanceClassLabel(classNumber)}`;
        }
        attendanceQuickState.rows = buildAttendanceQuickRows();
        attendanceQuickState.index = 0;
        renderAttendanceQuickStep();
        attendanceQuickModal.show();
      };

      if (attendanceQuickSelectedBtn) {
        attendanceQuickSelectedBtn.addEventListener('click', () => {
          openAttendanceQuickModal();
        });
      }
      if (attendanceQuickBackBtn) {
        attendanceQuickBackBtn.addEventListener('click', () => {
          if (!attendanceQuickState.rows.length) return;
          attendanceQuickState.index = Math.max(0, attendanceQuickState.index - 1);
          renderAttendanceQuickStep();
        });
      }
      if (attendanceQuickSkipBtn) {
        attendanceQuickSkipBtn.addEventListener('click', () => {
          if (!attendanceQuickState.rows.length) return;
          attendanceQuickState.index = Math.min(attendanceQuickState.rows.length, attendanceQuickState.index + 1);
          renderAttendanceQuickStep();
        });
      }
      attendanceQuickStatusButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const status = String(button.dataset.attendanceQuickStatus || '').trim();
          if (!status) return;
          const rows = attendanceQuickState.rows || [];
          if (!rows.length) return;
          if (attendanceQuickState.index >= rows.length) return;
          const current = rows[attendanceQuickState.index];
          if (!current) return;
          current.status = status;
          current.reason = String(attendanceQuickReasonEl ? attendanceQuickReasonEl.value : '').trim();
          syncAttendanceQuickRowToEditor(current);
          attendanceQuickState.index = Math.min(rows.length, attendanceQuickState.index + 1);
          renderAttendanceQuickStep();
        });
      });

      if (attendanceQuickForm && attendanceQuickRowsJsonInput) {
        attendanceQuickForm.addEventListener('submit', () => {
          const rows = attendanceQuickState.rows || [];
          const payload = rows.map((row) => ({
            student_id: Number(row.student_id),
            status: String(row.status || '').trim(),
            reason: String(row.reason || '').trim(),
          }));
          attendanceQuickRowsJsonInput.value = JSON.stringify(payload);
        });
      }

      const undoBtn = document.getElementById('journalUndoDeleteBtn');
      const undoCountdownEl = document.getElementById('journalUndoCountdown');
      if (undoBtn && undoCountdownEl) {
        const undoUntil = Number(undoBtn.dataset.undoUntil || 0);
        const syncUndoTimer = () => {
          const leftMs = undoUntil - Date.now();
          const leftSec = Math.max(0, Math.ceil(leftMs / 1000));
          undoCountdownEl.textContent = String(leftSec);
          if (leftSec < 1) {
            undoBtn.disabled = true;
            undoBtn.textContent = journalText.timeExpired;
            return false;
          }
          return true;
        };
        syncUndoTimer();
        const timer = setInterval(() => {
          if (!syncUndoTimer()) {
            clearInterval(timer);
          }
        }, 1000);
      }

      const presetSelectEl = document.getElementById('journalPresetSelect');
      const applyPresetBtn = document.getElementById('journalApplyPresetBtn');
      const normalizeBtn = document.getElementById('journalNormalizeWeightsBtn');
      if (applyPresetBtn && presetSelectEl) {
        applyPresetBtn.addEventListener('click', () => {
          if (!presetSelectEl.value) return;
          applyGradingPreset(presetSelectEl.value);
        });
      }
      if (normalizeBtn) {
        normalizeBtn.addEventListener('click', normalizeWeightsToHundred);
      }
      document.querySelectorAll('.journal-enabled-input, .journal-weight-input').forEach((el) => {
        el.addEventListener('input', refreshWeightSummary);
        el.addEventListener('change', refreshWeightSummary);
      });
      refreshWeightSummary();

      if (prevCellBtn) {
        prevCellBtn.addEventListener('click', () => navigateCell(0, -1));
      }
      if (nextCellBtn) {
        nextCellBtn.addEventListener('click', () => navigateCell(0, 1));
      }
      if (modalEl) {
        modalEl.addEventListener('keydown', (event) => {
          if (!modalEl.classList.contains('show')) return;
          if (event.ctrlKey && event.key === 'Enter') {
            if (gradeForm && canEditJournal && !currentCellLocked && !scoreEl.disabled) {
              event.preventDefault();
              gradeForm.requestSubmit();
            }
            return;
          }
          if (!event.altKey) return;
          if (event.key === 'ArrowUp') {
            event.preventDefault();
            navigateCell(0, -1);
          } else if (event.key === 'ArrowDown') {
            event.preventDefault();
            navigateCell(0, 1);
          } else if (event.key === 'ArrowLeft') {
            event.preventDefault();
            navigateCell(-1, 0);
          } else if (event.key === 'ArrowRight') {
            event.preventDefault();
            navigateCell(1, 0);
          }
        });
      }

      document.querySelectorAll('.journal-cell-btn[data-can-open="1"]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const columnId = Number(btn.dataset.columnId);
          const studentId = Number(btn.dataset.studentId);
          if (!columnId || !studentId) return;
          openJournalCell(columnId, studentId);
        });
      });
      document.querySelectorAll('.journal-bulk-open-btn').forEach((btn) => {
        btn.addEventListener('click', () => openBulkModal(btn));
      });
      if (bulkPasteEl) {
        bulkPasteEl.addEventListener('input', parseBulkInput);
      }
      if (bulkForm) {
        bulkForm.addEventListener('submit', (event) => {
          const valid = parseBulkInput();
          if (!valid) {
            event.preventDefault();
            return;
          }
          if (canEditJournal) {
            const typed = window.prompt('Для масового оцінювання введіть BULK');
            if (String(typed || '').trim().toUpperCase() !== 'BULK') {
              event.preventDefault();
              return;
            }
            if (bulkStepupInput) {
              bulkStepupInput.value = 'BULK';
            }
          }
        });
      }
      if (attendanceForm && attendanceRowsJsonInput) {
        attendanceRowEls.forEach((rowEl) => {
          const statusEl = rowEl.querySelector('[data-attendance-status]');
          const reasonEl = rowEl.querySelector('[data-attendance-reason]');
          if (statusEl) {
            statusEl.addEventListener('input', renderAttendanceWorkflowState);
            statusEl.addEventListener('change', renderAttendanceWorkflowState);
          }
          if (reasonEl) {
            reasonEl.addEventListener('input', renderAttendanceWorkflowState);
            reasonEl.addEventListener('change', renderAttendanceWorkflowState);
          }
        });
        renderAttendanceWorkflowState();
        attendanceForm.addEventListener('submit', (event) => {
          const workflowState = renderAttendanceWorkflowState();
          if (workflowState.changed < 1) {
            event.preventDefault();
            return;
          }
          const rows = serializeAttendanceRows();
          attendanceRowsJsonInput.value = JSON.stringify(rows);
          if (attendanceSaveBtn) {
            attendanceSaveBtn.disabled = true;
            attendanceSaveBtn.textContent = journalText.loadingSave;
          }
          if (attendanceStateChipEl) {
            attendanceStateChipEl.className = 'status-chip status-chip--info';
            attendanceStateChipEl.textContent = journalText.loadingSave;
          }
        });
      }
      if (retakeCreateForm) {
        retakeCreateForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          await submitAndRefreshCell(retakeCreateForm, journalText.loadingAdd);
        });
      }
      if (appealCreateForm) {
        appealCreateForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          await submitAndRefreshCell(appealCreateForm, journalText.loadingSend);
        });
      }
      if (retakeListEl) {
        retakeListEl.addEventListener('submit', async (event) => {
          const form = event.target.closest('form[action="/journal/retakes/update"]');
          if (!form) return;
          event.preventDefault();
          await submitAndRefreshCell(form, journalText.loadingSave);
        });
      }
      if (appealListEl) {
        appealListEl.addEventListener('submit', async (event) => {
          const form = event.target.closest('form[action="/journal/appeals/update"]');
          if (!form) return;
          event.preventDefault();
          await submitAndRefreshCell(form, journalText.loadingSave);
        });
      }
      if (competencyChecklistForm) {
        competencyChecklistForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          await submitAndRefreshCell(competencyChecklistForm, journalText.loadingSave);
        });
      }
      syncStaticWorkflowForms();
      if (feedbackTemplateButtons.length && commentEl) {
        feedbackTemplateButtons.forEach((button) => {
          button.addEventListener('click', () => {
            if (commentEl.disabled) return;
            if (button.dataset.feedbackClear === '1') {
              commentEl.value = '';
              commentEl.focus();
              return;
            }
            const template = String(button.dataset.feedbackTemplate || '').trim();
            if (!template) return;
            const current = String(commentEl.value || '').trim();
            if (!current) {
              commentEl.value = template;
            } else if (!current.includes(template)) {
              commentEl.value = `${current}\n${template}`;
            }
            commentEl.focus();
            commentEl.selectionStart = commentEl.value.length;
            commentEl.selectionEnd = commentEl.value.length;
          });
        });
      }
      if (autoOpenColumnId > 0 && autoOpenStudentId > 0) {
        openJournalCell(autoOpenColumnId, autoOpenStudentId);
      }
      if (canEditAttendance && attendanceQuickAutoOpen && attendanceQuickModal && attendanceRowEls.length) {
        openAttendanceQuickModal();
      }
    </script>
    <%- include('partials/desktop-menu-drawer-script') %>
    <script src="/js/design-system.js" defer></script>
      <script src="/js/dynamic-bg.js" defer></script>
  </body>
</html>
