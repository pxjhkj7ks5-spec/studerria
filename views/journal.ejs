              </div>
              <div id="journalRetakeSummary" class="journal-review-summary mb-3">
                <div class="text-muted small"><%= journalCopy.dash %></div>
              </div>
              <div id="journalRetakeList" class="journal-retake-list">
                <div class="text-muted small">Спроб поки немає.</div>
              </div>
