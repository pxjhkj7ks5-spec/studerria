          if (moderationRequired) {
            const moderationChipClass = moderation
              ? getModerationStatusChipClass(moderation.status)
              : (hasGrade ? 'status-chip--warning' : 'status-chip--neutral');
            const moderationChipLabel = moderation
              ? String(moderation.status_label || moderation.status || journalText.cellSummaryReviewPending)
              : (hasGrade ? journalText.cellSummaryReviewPending : journalText.cellSummaryModeration);
            chips.push(createStatusChipNode(moderationChipClass, moderationChipLabel));
