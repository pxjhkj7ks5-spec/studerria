        reviewCompetencyCurrentNote: 'Чекліст уже відображає цю роботу. Оновлюйте його лише якщо competency reading змінився.',
        reviewCompetencyStudentTitle: 'Лише competency trail',
        reviewCompetencyStudentNote: 'Студент тут переглядає вже записані competency signals.',
        actionAddAttempt: 'Додати спробу',
        actionReviewAttempts: 'Переглянути спроби',
        actionOpenAppeal: 'Подати апеляцію',
        actionReviewAppeals: 'Переглянути апеляції',
        actionModerateNow: 'Відкрити модерацію',
        actionOpenChecklist: 'Відкрити checklist',
        gradingSummaryTeacher: 'Налаштування системи оцінювання',
        gradingSummaryStudent: 'Як формується оцінка',
        gradingSummaryHint: 'Натисніть, щоб',
        gradingSummaryOpen: 'розгорнути',
        gradingSummaryClose: 'згорнути',
        weightTotal: 'Сума внесків (активні)',
        finalFixed: 'Фінал: 100 (фіксовано)',
        gradingConfigTitle: 'Налаштування системи оцінювання',
        importTemplateConfirm: 'Імпортувати ручні колонки з попереднього семестру?',
        importTemplateAction: 'Імпортувати шаблон',
        quickPreset: 'Швидкий пресет',
        chooseTemplate: 'Оберіть шаблон...',
        presetBalanced: 'Балансований (20/20/40/10/10)',
        presetExamFocus: 'Фокус на екзамені (15/15/60/10/0)',
        presetContinuous: 'Безперервний контроль (35/35/20/10/0)',
        presetHomeworkOnly: 'Лише ДЗ (100/0/0/0/0)',
        applyPreset: 'Застосувати пресет',
        normalizeWeights: 'Авто-розподіл ваг до 100',
        configType: 'Тип',
        configEnabled: 'Увімк.',
        configMaxPoints: 'Бал за 1 роботу',
        configContribution: 'Внесок у фінал / 100',
        saveSystem: 'Зберегти систему',
        newColumn: 'Нова колонка',
        titleLabel: 'Назва',
        typeLabel: 'Тип',
        maxPointsLabel: 'Макс. бал',
        includeInFinal: 'Враховувати у фінальному розрахунку',
        addColumn: 'Додати колонку',
        gradingStudentHint: 'Нижче показано, як рахується фінальний бал для цього предмета.',
        activityType: 'Вид діяльності',
        disabled: 'Вимкнено',
        subjectNotSelected: 'Предмет не обрано.',
        noColumns: 'Поки що немає колонок у журналі. Додайте завдання у розкладі або створіть ручну колонку.',
        noStudentsForSubject: 'Немає студентів у цьому предметі для поточного доступу.',
        pointsShort: 'б.',
        credit: 'Залік',
        excluded: 'Не враховується',
        locked: 'Заблоковано',
        openState: 'Відкрито',
        excludeFromFinalTitle: 'Виключити з фіналу',
        includeInFinalTitle: 'Врахувати у фіналі',
        finalMinus: 'Фінал-',
        finalPlus: 'Фінал+',
        unlock: 'Розблокувати',
        lock: 'Заблокувати',
        bulkAction: 'Масово',
        bulkGradingTitle: 'Масове оцінювання',
        totalOutOfHundred: 'Підсумок / 100',
        groupPrefix: 'Група',
        rawPrefix: 'сирі',
        quickAttendanceTitle: 'Швидка відмітка відвідуваності',
        quickAttendanceNone: 'Немає студентів для відмітки.',
        quickPresent: 'Присутній',
        quickAbsent: 'Відсутній',
        quickExcused: 'Поважна причина',
        commentReasonOptional: 'Коментар / причина (опц.)',
        commentIfNeeded: 'Потрібно лише за потреби',
        back: 'Назад',
        skip: 'Пропустити',
        readySummaryPrefix: 'Готово',
        readyToSave: 'Готово до збереження',
        readyToSaveHint: 'За потреби натисніть "Назад" і змініть відмітку.',
        chooseStatusHint: 'Оберіть статус, і система відкриє наступного студента.',
        groupNotSpecified: 'Група не вказана',
        studentFallbackPrefix: 'Студент',
        timeExpired: 'Час минув',
        loadingAdd: 'Додаємо...',
        loadingSend: 'Надсилаємо...',
        loadingSave: 'Зберігаємо...',
      };
%>
<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include('partials/theme-bootstrap-head', { defaultTheme: 'dark' }) %>
    <title><%= journalCopy.pageTitle %> • Studerria</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/journal.css" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/studerria-ui.css" />
    <link rel="stylesheet" href="/css/dynamic-bg.css" />
  </head>
  <body class="studerria-theme theme-dark page-journal page-local-topbar">
    <%- include('partials/theme-bootstrap-body') %>
    <%- include('partials/dynamic-bg') %>
    <%- include('partials/topbar', { role, username, t, activePage: 'journal', pageTitle: journalCopy.pageTitle }) %>
    <%- include('partials/desktop-menu-drawer', { role, t, activePage: 'journal' }) %>

    <main class="container py-4">
      <%
        const journalLinks = (journalWorkflowLinks && typeof journalWorkflowLinks === 'object') ? journalWorkflowLinks : {};
        const selectedJournalSubjectId = selectedSubject ? Number(selectedSubject.subject_id || 0) : 0;
        const selectedJournalCourseId = selectedSubject ? Number(selectedSubject.course_id || 0) : 0;
        const journalInsightsHref = journalLinks.insightsHref
          || `/journal/insights?course_id=${selectedJournalCourseId}&subject_id=${selectedJournalSubjectId}&scope_type=subject&period=semester`;
        const journalCloseExportHref = journalLinks.closeExportHref
          || `/journal/subject/close-export?subject_id=${selectedJournalSubjectId}`;
      %>
      <% if (messages && messages.error) { %>
        <div class="alert alert-danger"><%= messages.error %></div>
      <% } %>
      <% if (messages && messages.success) { %>
        <div class="alert alert-success"><%= messages.success %></div>
      <% } %>
      <% if (compatibilityMessage) { %>
        <div class="alert alert-warning"><%= compatibilityMessage %></div>
      <% } %>
      <% if (undoGrade && canEditJournal) { %>
        <form method="POST" action="/journal/grades/restore" class="alert alert-warning d-flex flex-wrap gap-2 align-items-center">
          <input type="hidden" name="column_id" value="<%= undoGrade.column_id %>" />
          <input type="hidden" name="student_id" value="<%= undoGrade.student_id %>" />
          <span><%= journalCopy.undoDeletedPrefix %> <strong id="journalUndoCountdown"><%= undoGrade.seconds_left %></strong> <%= journalCopy.secondsShort %></span>
          <button class="btn btn-sm btn-outline-dark" type="submit" id="journalUndoDeleteBtn" data-undo-until="<%= undoGrade.until %>">
            <%= journalCopy.undoDeletedAction %>
          </button>
        </form>
      <% } %>

      <section class="glass liquid-card p-3 mb-3">
        <form method="GET" action="/journal" class="row g-3 align-items-end">
          <% if (attendanceContext && attendanceContext.date) { %>
            <input type="hidden" name="attendance_date" value="<%= attendanceContext.date %>" />
          <% } %>
          <% if (attendanceContext && attendanceContext.class_number) { %>
            <input type="hidden" name="attendance_class_number" value="<%= attendanceContext.class_number %>" />
          <% } %>
          <div class="col-12 col-lg-7">
            <label class="form-label"><%= journalCopy.subjectLabel %></label>
            <select class="form-select" name="subject_id" onchange="this.form.submit()">
              <% if (!subjects || !subjects.length) { %>
                <option value=""><%= journalCopy.noSubjects %></option>
              <% } else { %>
                <% subjects.forEach(function(subject) { %>
                  <option value="<%= subject.subject_id %>" <%= selectedSubject && selectedSubject.subject_id === subject.subject_id ? 'selected' : '' %>>
                    <%= subject.subject_name %> · <%= subject.course_name %> · <%= subject.group_label %>
                  </option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="col-12 col-lg-5">
            <% if (selectedSubject) { %>
              <div class="journal-subject-meta">
                <span class="status-chip status-chip--info"><%= selectedSubject.course_name %></span>
                <% if (selectedSemester && selectedSemester.title) { %>
                  <span class="status-chip status-chip--neutral"><%= selectedSemester.title %></span>
                <% } %>
                <span class="status-chip status-chip--neutral"><%= selectedSubject.group_label %></span>
                <% if (subjectClosure && subjectClosure.is_closed) { %>
                  <span class="status-chip status-chip--danger"><%= journalCopy.subjectClosed %></span>
                <% } else { %>
                  <span class="status-chip status-chip--success"><%= journalCopy.journalOpen %></span>
                <% } %>
                <% if (canManageAllSubjects) { %>
                  <span class="status-chip status-chip--success"><%= journalCopy.fullAccess %></span>
                <% } %>
              </div>
              <div class="d-flex justify-content-lg-end mt-2">
                <a
                  class="btn btn-sm btn-outline-secondary"
                  href="<%= journalInsightsHref %>"
                >
                  📊 <%= journalCopy.journalInsights %>
                </a>
              </div>
            <% } %>
          </div>
        </form>
      </section>

      <% if (selectedSubject) { %>
        <%
          const attendance = attendanceContext || {};
          const attendanceRows = Array.isArray(attendance.rows) ? attendance.rows : [];
          const attendanceSummary = attendance.summary || {};
          const attendanceStatuses = Array.isArray(attendance.statuses) ? attendance.statuses : [];
          const attendanceStudentSummary = attendance.student_summary || null;
          const attendanceClassOptions = Array.isArray(attendance.class_options) ? attendance.class_options : [];
          const attendanceQuickCurrent = attendance.quick_current_slot || {};
          const attendanceStatusChipClass = {
            present: 'status-chip--success',
            late: 'status-chip--warning',
            absent: 'status-chip--danger',
            excused: 'status-chip--info',
          };
          const attendanceStatusLabelMap = attendanceStatuses.reduce((acc, item) => {
            if (!item || !item.key) return acc;
            acc[item.key] = item.label || item.key;
            return acc;
          }, {});
          const attendanceStatusLabel = (key) => attendanceStatusLabelMap[key] || journalCopy.dash;
          const attendanceMarkedRate = attendanceSummary.students_total
            ? Math.round((Number(attendanceSummary.marked_total || 0) / Number(attendanceSummary.students_total || 1)) * 100)
            : 0;
          const attendanceMarkedCount = attendanceRows.filter((row) => String(row && row.status ? row.status : '').trim()).length;
          const gradingTypeRows = [
            { key: 'homework', label: journalCopy.gradingTypeHomework },
            { key: 'seminar', label: journalCopy.gradingTypeSeminar },
            { key: 'exam', label: journalCopy.gradingTypeExam },
            { key: 'credit', label: journalCopy.gradingTypeCredit },
            { key: 'custom', label: journalCopy.gradingTypeCustom },
          ];
          let enabledWeightTotal = 0;
          gradingTypeRows.forEach((cfg) => {
            const enabled = Number(gradingSettings && gradingSettings[`${cfg.key}_enabled`]) === 1;
            const weight = Number(gradingSettings && gradingSettings[`${cfg.key}_weight_points`]);
            if (enabled && Number.isFinite(weight)) enabledWeightTotal += weight;
          });
          const activeColumnCount = Array.isArray(columns)
            ? columns.filter((column) => Number(column && column.is_archived ? column.is_archived : 0) !== 1).length
            : 0;
          const closureStudentCount = Array.isArray(journalRows) ? journalRows.length : 0;
          const latestClosureEvent = subjectClosure && subjectClosure.latest_event ? subjectClosure.latest_event : null;
        %>
        <section class="glass liquid-card p-3 mb-3">
          <div class="journal-closure-shell">
            <div class="journal-closure-copy">
              <div class="d-flex flex-wrap align-items-start justify-content-between gap-2">
                <div>
                  <div class="fw-semibold"><%= journalCopy.closureTitle %></div>
                  <% if (subjectClosure && subjectClosure.is_closed) { %>
                    <div class="text-muted small">
                      <%= journalCopy.closureClosedPrefix %> <%= subjectClosure.closed_at ? new Date(subjectClosure.closed_at).toLocaleString(localeCode) : '' %>. <%= journalCopy.closureClosedSuffix %>
                    </div>
                  <% } else { %>
                    <div class="text-muted small"><%= journalCopy.closureOpenHint %></div>
                  <% } %>
                </div>
                <div class="journal-closure-status-chips">
                  <% if (subjectClosure && subjectClosure.is_closed) { %>
                    <span class="status-chip status-chip--danger"><%= journalCopy.subjectClosed %></span>
                  <% } else { %>
                    <span class="status-chip status-chip--success"><%= journalCopy.journalOpen %></span>
                  <% } %>
                  <% if (canManageAllSubjects) { %>
                    <span class="status-chip status-chip--info"><%= journalCopy.fullAccess %></span>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="journal-closure-impact">
              <article class="journal-closure-impact-card">
                <div class="text-muted small"><%= lang === 'en' ? 'Columns' : 'Колонки' %></div>
                <div class="journal-closure-impact-value"><%= activeColumnCount %></div>
                <div class="small text-muted"><%= journalCopy.closureImpactColumnsHint %></div>
              </article>
              <article class="journal-closure-impact-card">
                <div class="text-muted small"><%= lang === 'en' ? 'Students' : 'Студенти' %></div>
                <div class="journal-closure-impact-value"><%= closureStudentCount %></div>
                <div class="small text-muted"><%= journalCopy.closureImpactStudentsHint %></div>
              </article>
              <article class="journal-closure-impact-card">
                <div class="text-muted small"><%= lang === 'en' ? 'Snapshot' : 'Знімок' %></div>
                <% if (subjectClosure && subjectClosure.is_closed && latestClosureEvent && (Number(latestClosureEvent.export_rows_count || 0) > 0 || Number(latestClosureEvent.export_columns_count || 0) > 0)) { %>
                  <div class="journal-closure-impact-value"><%= Number(latestClosureEvent.export_rows_count || 0) %> × <%= Number(latestClosureEvent.export_columns_count || 0) %></div>
                  <div class="small text-muted"><%= journalCopy.closureImpactSnapshotReady %></div>
                <% } else { %>
                  <div class="journal-closure-impact-value"><%= journalCopy.dash %></div>
                  <div class="small text-muted"><%= journalCopy.closureImpactSnapshotPending %></div>
                <% } %>
              </article>
            </div>
            <div class="journal-closure-actions-panel">
              <div class="journal-closure-actions-copy">
                <div class="text-muted small"><%= journalCopy.closureActionTitle %></div>
                <% if (subjectClosure && subjectClosure.is_closed) { %>
                  <div class="fw-semibold"><%= journalCopy.closureActionClosedTitle %></div>
                  <div class="small text-muted"><%= journalCopy.closureActionClosedNote %></div>
                  <div class="small text-muted"><%= journalCopy.closureActionExportNote %></div>
                <% } else { %>
                  <div class="fw-semibold"><%= journalCopy.closureActionOpenTitle %></div>
                  <div class="small text-muted"><%= journalCopy.closureActionOpenNote %></div>
                  <div class="small text-muted"><%= journalCopy.closureActionOpenReturnNote %></div>
                <% } %>
              </div>
              <div class="journal-closure-actions">
                <% if (canCloseSubject) { %>
                  <form class="journal-closure-action-form" method="POST" action="/journal/subject/close" onsubmit="return confirm(<%- JSON.stringify(journalCopy.closeSubjectConfirm) %>)">
                    <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                    <% if (attendance && attendance.date) { %>
                      <input type="hidden" name="attendance_date" value="<%= attendance.date %>" />
                    <% } %>
                    <% if (attendance && attendance.class_number) { %>
                      <input type="hidden" name="attendance_class_number" value="<%= attendance.class_number %>" />
                    <% } %>
                    <% if (attendanceQuickAutoOpen) { %>
                      <input type="hidden" name="attendance_quick" value="1" />
                    <% } %>
                    <button class="btn btn-danger btn-sm" type="submit"><%= journalCopy.closeSubject %></button>
                  </form>
                <% } %>
                <% if (canReopenSubject) { %>
                  <form class="journal-closure-action-form" method="POST" action="/journal/subject/reopen" onsubmit="return confirm(<%- JSON.stringify(journalCopy.reopenSubjectConfirm) %>)">
                    <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                    <% if (attendance && attendance.date) { %>
                      <input type="hidden" name="attendance_date" value="<%= attendance.date %>" />
                    <% } %>
                    <% if (attendance && attendance.class_number) { %>
                      <input type="hidden" name="attendance_class_number" value="<%= attendance.class_number %>" />
                    <% } %>
                    <% if (attendanceQuickAutoOpen) { %>
                      <input type="hidden" name="attendance_quick" value="1" />
                    <% } %>
                    <button class="btn btn-success btn-sm" type="submit"><%= journalCopy.reopenSubject %></button>
                  </form>
                <% } %>
                <% if (teacherJournalMode && subjectClosure && subjectClosure.is_closed && (canManageAllSubjects || selectedSubject.has_all_groups)) { %>
                  <a class="btn btn-outline-secondary btn-sm" href="<%= journalCloseExportHref %>"><%= journalCopy.exportStatement %></a>
                <% } %>
              </div>
            </div>
          </div>
        </section>
        <section class="glass liquid-card p-3 mb-3">
          <details class="journal-attendance-details" open>
            <summary class="journal-attendance-summary">
              <div class="journal-attendance-summary-main">
                <span class="journal-attendance-summary-title"><%= canEditAttendance ? journalCopy.attendanceTitleTeacher : journalCopy.attendanceTitleStudent %></span>
                <span class="journal-attendance-summary-subtitle">
                  <%= attendance.date || journalCopy.dash %> · <%= journalCopy.classLabel %> <%= attendance.class_number || journalCopy.dash %>
                </span>
              </div>
              <div class="journal-attendance-summary-chips">
                <span class="status-chip status-chip--success"><%= journalCopy.attendancePresent %>: <%= Number(attendanceSummary.present || 0) %></span>
                <span class="status-chip status-chip--warning"><%= journalCopy.attendanceLate %>: <%= Number(attendanceSummary.late || 0) %></span>
                <span class="status-chip status-chip--danger"><%= journalCopy.attendanceAbsent %>: <%= Number(attendanceSummary.absent || 0) %></span>
                <span class="status-chip status-chip--info"><%= journalCopy.attendanceExcused %>: <%= Number(attendanceSummary.excused || 0) %></span>
                <span class="status-chip status-chip--neutral"><%= journalCopy.attendanceFilled %>: <%= attendanceMarkedRate %>%</span>
              </div>
            </summary>
            <div class="journal-attendance-body">
              <% if (!canEditAttendance) { %>
                <form method="GET" action="/journal" class="row g-2 align-items-end mb-3">
                  <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                  <div class="col-12 col-md-4 col-xl-3">
                    <label class="form-label"><%= journalCopy.dateLabel %></label>
                    <input class="form-control form-control-sm" type="date" name="attendance_date" value="<%= attendance.date || '' %>" required />
                  </div>
                  <div class="col-12 col-md-4 col-xl-3">
                    <label class="form-label"><%= journalCopy.classLabel %></label>
                    <select class="form-select form-select-sm" name="attendance_class_number">
                      <% attendanceClassOptions.forEach((item) => { %>
                        <option value="<%= item.value %>" <%= Number(attendance.class_number) === Number(item.value) ? 'selected' : '' %>><%= item.label %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-12 col-md-4 col-xl-3">
                    <button class="btn btn-outline-secondary btn-sm w-100" type="submit"><%= journalCopy.show %></button>
                  </div>
                </form>
              <% } %>

              <% if (canEditAttendance) { %>
                <div class="journal-attendance-quick-panel mb-3">
                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    <% if (attendanceQuickCurrent && attendanceQuickCurrent.available) { %>
                      <a
                        class="btn btn-success btn-sm"
                        href="/journal?subject_id=<%= selectedSubject.subject_id %>&attendance_date=<%= encodeURIComponent(String(attendanceQuickCurrent.class_date || attendance.date || '')) %>&attendance_class_number=<%= Number(attendanceQuickCurrent.class_number || attendance.class_number || 1) %>&attendance_quick=1"
                      >
                        <%= journalCopy.fillCurrentClass %>
                      </a>
                    <% } else { %>
                      <button class="btn btn-outline-secondary btn-sm" type="button" disabled>
                        <%= journalCopy.currentClassUnavailable %>
                      </button>
                    <% } %>
                    <button
                      class="btn btn-primary btn-sm"
                      type="button"
                      id="journalAttendanceQuickSelectedBtn"
                      <%= attendanceRows.length ? '' : 'disabled' %>
                    >
                      <%= journalCopy.fillSelectedClass %>
                    </button>
                    <button
                      class="btn btn-outline-info btn-sm"
                      type="button"
                      id="journalAttendanceToggleEditorBtn"
                      data-open-label="<%= journalCopy.attendanceEditorOpen %>"
                      data-close-label="<%= journalCopy.attendanceEditorClose %>"
                    >
                      <%= journalCopy.attendanceEditorOpen %>
                    </button>
                  </div>
                  <div class="small text-muted mt-2">
                    <% if (attendanceQuickCurrent && attendanceQuickCurrent.available) { %>
                      <%= journalCopy.currentSchedulePrefix %>: <%= attendanceQuickCurrent.label || `${journalCopy.classLabel} ${attendanceQuickCurrent.class_number}` %>.
                    <% } else { %>
                      <%= journalCopy.currentScheduleMissing %>
                    <% } %>
                  </div>
                </div>

                <div class="journal-attendance-editor d-none" id="journalAttendanceEditor">
                  <form method="GET" action="/journal" class="row g-2 align-items-end mb-3">
                    <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                    <div class="col-12 col-md-4 col-xl-3">
                      <label class="form-label"><%= journalCopy.dateLabel %></label>
                      <input class="form-control form-control-sm" type="date" name="attendance_date" value="<%= attendance.date || '' %>" required />
                    </div>
                    <div class="col-12 col-md-4 col-xl-3">
                      <label class="form-label"><%= journalCopy.classLabel %></label>
                      <select class="form-select form-select-sm" name="attendance_class_number">
                        <% attendanceClassOptions.forEach((item) => { %>
                          <option value="<%= item.value %>" <%= Number(attendance.class_number) === Number(item.value) ? 'selected' : '' %>><%= item.label %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-4 col-xl-3">
                      <button class="btn btn-outline-secondary btn-sm w-100" type="submit"><%= journalCopy.show %></button>
                    </div>
                  </form>

                  <% if (!attendanceRows.length) { %>
                    <div class="text-muted"><%= journalCopy.attendanceNoStudentsAccess %></div>
                  <% } else { %>
                    <form method="POST" action="/journal/attendance/save" id="journalAttendanceForm" autocomplete="off">
                      <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                      <input type="hidden" name="attendance_date" value="<%= attendance.date || '' %>" />
                      <input type="hidden" name="attendance_class_number" value="<%= attendance.class_number || '' %>" />
                      <input type="hidden" name="rows_json" id="journalAttendanceRowsJson" />
                      <div class="journal-attendance-table-wrap">
                        <table class="table table-sm align-middle mb-0 journal-attendance-table">
                          <thead>
                            <tr>
                              <th><%= journalCopy.studentTableName %></th>
                              <th><%= journalCopy.studentTableStatus %></th>
                              <th><%= journalCopy.studentTableReason %></th>
                              <th><%= journalCopy.studentTableUpdated %></th>
                            </tr>
                          </thead>
                          <tbody>
                            <% attendanceRows.forEach((row) => { %>
                              <tr
                                data-attendance-row
                                data-student-id="<%= row.student_id %>"
                                data-student-name="<%= row.full_name %>"
                                data-group-number="<%= row.group_number || '' %>"
                                data-initial-status="<%= row.status || '' %>"
                                data-initial-reason="<%= row.reason || '' %>"
                              >
                                <td>
                                  <div class="fw-semibold"><%= row.full_name %></div>
                                  <% if (row.group_number) { %>
                                    <div class="text-muted small"><%= journalCopy.groupPrefix %> <%= row.group_number %></div>
                                  <% } %>
                                </td>
                                <td>
                                  <select class="form-select form-select-sm journal-attendance-status" data-attendance-status>
                                    <option value=""><%= journalCopy.attendanceNotMarked %></option>
                                    <% attendanceStatuses.forEach((status) => { %>
                                      <option value="<%= status.key %>" <%= row.status === status.key ? 'selected' : '' %>><%= status.label %></option>
                                    <% }) %>
                                  </select>
                                </td>
                                <td>
                                  <input
                                    class="form-control form-control-sm"
                                    type="text"
                                    maxlength="<%= attendance.reason_max_length || 240 %>"
                                    value="<%= row.reason || '' %>"
                                    data-attendance-reason
                                    placeholder="<%= journalCopy.attendanceReasonPlaceholder %>"
                                  />
                                </td>
                                <td class="text-muted small">
                                  <%= row.marked_at ? new Date(row.marked_at).toLocaleString(localeCode) : journalCopy.dash %>
                                </td>
                              </tr>
                            <% }) %>
                          </tbody>
                        </table>
                      </div>
                      <div class="journal-attendance-workflow mt-3">
                        <div class="journal-attendance-workflow-main">
                          <div class="journal-attendance-workflow-chips">
                            <span class="status-chip status-chip--success">
                              <%= journalCopy.attendanceMarkedNow %>: <span id="journalAttendanceMarkedCount"><%= attendanceMarkedCount %></span>
                            </span>
                            <span class="status-chip status-chip--warning">
                              <%= journalCopy.attendanceChanged %>: <span id="journalAttendanceChangedCount">0</span>
                            </span>
                            <span class="status-chip status-chip--danger">
                              <%= journalCopy.attendanceRemoved %>: <span id="journalAttendanceRemovedCount">0</span>
                            </span>
                          </div>
                          <span class="text-muted small"><%= journalCopy.emptyStatusMeansRemoved %></span>
                        </div>
                        <div class="journal-attendance-workflow-actions">
                          <span class="status-chip status-chip--neutral" id="journalAttendanceStateChip"><%= journalCopy.attendanceStatusClean %></span>
                          <button class="btn btn-primary btn-sm" type="submit" id="journalAttendanceSaveBtn" disabled><%= journalCopy.saveAttendance %></button>
                        </div>
                      </div>
                    </form>
                  <% } %>
                </div>
              <% } else { %>
                <div class="row g-3">
                  <div class="col-12 col-lg-5">
                    <div class="journal-student-attendance-card">
                      <div class="small text-muted mb-1"><%= journalCopy.currentSubjectSnapshot %></div>
                      <div class="d-flex flex-wrap gap-2">
                        <span class="status-chip status-chip--success"><%= journalCopy.attendancePresent %>: <%= Number(attendanceStudentSummary ? attendanceStudentSummary.present : attendanceSummary.present || 0) %></span>
                        <span class="status-chip status-chip--warning"><%= journalCopy.attendanceLate %>: <%= Number(attendanceStudentSummary ? attendanceStudentSummary.late : attendanceSummary.late || 0) %></span>
                        <span class="status-chip status-chip--danger"><%= journalCopy.attendanceAbsent %>: <%= Number(attendanceStudentSummary ? attendanceStudentSummary.absent : attendanceSummary.absent || 0) %></span>
                        <span class="status-chip status-chip--info"><%= journalCopy.attendanceExcused %>: <%= Number(attendanceStudentSummary ? attendanceStudentSummary.excused : attendanceSummary.excused || 0) %></span>
                        <% if (attendanceStudentSummary && Number.isFinite(Number(attendanceStudentSummary.attendance_rate))) { %>
                          <span class="status-chip status-chip--neutral"><%= journalCopy.attendanceRate %>: <%= attendanceStudentSummary.attendance_rate %>%</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-lg-7">
                    <div class="journal-attendance-table-wrap">
                      <table class="table table-sm align-middle mb-0 journal-attendance-table">
                        <thead>
                          <tr>
                            <th><%= journalCopy.dateLabel %></th>
                            <th><%= journalCopy.classLabel %></th>
                            <th><%= journalCopy.studentTableStatus %></th>
                            <th><%= journalCopy.attendanceReason %></th>
                          </tr>
                        </thead>
                        <tbody>
                          <% const studentRecentRecords = attendanceStudentSummary && Array.isArray(attendanceStudentSummary.recent_records)
                            ? attendanceStudentSummary.recent_records
                            : []; %>
                          <% if (!studentRecentRecords.length) { %>
                            <tr>
                              <td colspan="4" class="text-muted"><%= journalCopy.attendanceNoRecords %></td>
                            </tr>
                          <% } %>
                          <% studentRecentRecords.forEach((record) => { %>
                            <% const statusKey = record.status || ''; %>
                            <tr>
                              <td><%= record.class_date || journalCopy.dash %></td>
                              <td><%= record.class_number || journalCopy.dash %></td>
                              <td>
                                <span class="status-chip <%= attendanceStatusChipClass[statusKey] || 'status-chip--neutral' %>">
                                  <%= attendanceStatusLabel(statusKey) %>
                                </span>
                              </td>
                              <td class="small text-muted"><%= record.reason || journalCopy.dash %></td>
                            </tr>
                          <% }) %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </details>
        </section>
        <section class="glass liquid-card p-3 mb-3">
          <details class="journal-grading-details">
            <summary class="journal-grading-summary">
              <div class="journal-grading-summary-main">
                <span class="journal-grading-summary-title"><%= canEditJournal ? journalCopy.gradingSummaryTeacher : journalCopy.gradingSummaryStudent %></span>
                <span class="journal-grading-summary-subtitle"><%= journalCopy.gradingSummaryHint %> <span class="journal-grading-summary-open-text"><%= journalCopy.gradingSummaryOpen %></span><span class="journal-grading-summary-close-text"><%= journalCopy.gradingSummaryClose %></span></span>
              </div>
              <div class="journal-grading-summary-chips">
                <span class="status-chip status-chip--info"><%= journalCopy.weightTotal %>: <%= enabledWeightTotal.toFixed(2).replace(/\.00$/, '') %> / 100</span>
                <span class="status-chip status-chip--neutral"><%= journalCopy.finalFixed %></span>
              </div>
            </summary>
            <div class="journal-grading-body">
              <% if (canEditJournal) { %>
                <div class="row g-3">
                  <div class="col-12 col-xl-8">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                      <h6 class="mb-0"><%= journalCopy.gradingConfigTitle %></h6>
                      <form method="POST" action="/journal/template/import-previous" onsubmit="return confirm(<%- JSON.stringify(journalCopy.importTemplateConfirm) %>)">
                        <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                        <button class="btn btn-sm btn-outline-secondary" type="submit"><%= journalCopy.importTemplateAction %></button>
                      </form>
                    </div>
                    <form method="POST" action="/journal/config/save" class="row g-3" id="journalConfigForm">
                      <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                      <div class="col-12">
                        <div class="row g-2 align-items-end">
                          <div class="col-12 col-lg-5">
                            <label class="form-label" for="journalPresetSelect"><%= journalCopy.quickPreset %></label>
                            <select class="form-select form-select-sm" id="journalPresetSelect">
                              <option value=""><%= journalCopy.chooseTemplate %></option>
                              <option value="balanced"><%= journalCopy.presetBalanced %></option>
                              <option value="exam_focus"><%= journalCopy.presetExamFocus %></option>
                              <option value="continuous"><%= journalCopy.presetContinuous %></option>
                              <option value="homework_only"><%= journalCopy.presetHomeworkOnly %></option>
                            </select>
                          </div>
                          <div class="col-12 col-lg-7 d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-outline-secondary" type="button" id="journalApplyPresetBtn"><%= journalCopy.applyPreset %></button>
                            <button class="btn btn-sm btn-outline-info" type="button" id="journalNormalizeWeightsBtn"><%= journalCopy.normalizeWeights %></button>
                          </div>
                        </div>
                      </div>
                      <div class="col-12 journal-config-table-wrap">
                        <table class="table table-sm journal-config-table align-middle mb-0">
                          <thead>
                            <tr>
                              <th><%= journalCopy.configType %></th>
                              <th class="text-center"><%= journalCopy.configEnabled %></th>
                              <th><%= journalCopy.configMaxPoints %></th>
                              <th><%= journalCopy.configContribution %></th>
                            </tr>
                          </thead>
                          <tbody>
                            <% gradingTypeRows.forEach(function(cfg) { %>
                              <% const enabledField = `${cfg.key}_enabled`; %>
                              <% const maxField = `${cfg.key}_max_points`; %>
                              <% const weightField = `${cfg.key}_weight_points`; %>
                              <% const enabledValue = Number(gradingSettings && gradingSettings[enabledField]) === 1; %>
                              <tr>
                                <td><strong><%= cfg.label %></strong></td>
                                <td class="text-center">
                                  <input type="hidden" name="<%= enabledField %>" value="0" />
                                  <input
                                    class="form-check-input journal-enabled-input"
                                    type="checkbox"
                                    name="<%= enabledField %>"
                                    value="1"
                                    data-type-key="<%= cfg.key %>"
                                    <%= enabledValue ? 'checked' : '' %>
                                  />
                                </td>
                                <td>
                                  <input
                                    class="form-control form-control-sm journal-max-input"
                                    type="number"
                                    step="0.01"
                                    min="0.01"
                                    name="<%= maxField %>"
                                    data-type-key="<%= cfg.key %>"
                                    value="<%= gradingSettings[maxField] %>"
                                    required
                                  />
                                </td>
                                <td>
                                  <input
                                    class="form-control form-control-sm journal-weight-input"
                                    type="number"
                                    step="0.01"
                                    min="0"
                                    name="<%= weightField %>"
                                    data-type-key="<%= cfg.key %>"
                                    value="<%= gradingSettings[weightField] %>"
                                    required
                                  />
                                </td>
                              </tr>
                            <% }); %>
                          </tbody>
                        </table>
                      </div>
                      <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
                        <span class="status-chip status-chip--info"><%= journalCopy.weightTotal %>: <span id="journalEnabledWeightTotal"><%= enabledWeightTotal.toFixed(2).replace(/\.00$/, '') %></span> / 100</span>
                        <span class="status-chip status-chip--neutral"><%= journalCopy.finalFixed %></span>
                      </div>
                      <div class="col-12">
                        <button class="btn btn-primary" type="submit"><%= journalCopy.saveSystem %></button>
                      </div>
                    </form>
                  </div>
                  <div class="col-12 col-xl-4">
                    <h6 class="mb-2"><%= journalCopy.newColumn %></h6>
                    <form method="POST" action="/journal/columns/create" class="row g-2">
                      <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                      <div class="col-12">
                        <label class="form-label"><%= journalCopy.titleLabel %></label>
                        <input class="form-control" name="title" maxlength="140" required />
                      </div>
                      <div class="col-6">
                        <label class="form-label"><%= journalCopy.typeLabel %></label>
                        <select class="form-select" name="column_type">
                          <option value="custom"><%= journalCopy.gradingTypeCustom %></option>
                          <option value="seminar"><%= journalCopy.gradingTypeSeminar %></option>
                          <option value="exam"><%= journalCopy.gradingTypeExam %></option>
                          <option value="credit"><%= journalCopy.gradingTypeCredit %></option>
                          <option value="homework"><%= journalCopy.gradingTypeHomework %></option>
                        </select>
                      </div>
                      <div class="col-6">
                        <label class="form-label"><%= journalCopy.maxPointsLabel %></label>
                        <input class="form-control" type="number" step="0.01" min="0.01" name="max_points" />
                      </div>
                      <div class="col-12">
                        <input type="hidden" name="include_in_final" value="0" />
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="journalIncludeFinal" name="include_in_final" value="1" checked />
                          <label class="form-check-label" for="journalIncludeFinal"><%= journalCopy.includeInFinal %></label>
                        </div>
                      </div>
                      <div class="col-12">
                        <button class="btn btn-outline-primary w-100" type="submit"><%= journalCopy.addColumn %></button>
                      </div>
                    </form>
                  </div>
                </div>
              <% } else { %>
                <div class="journal-grading-student-view">
                  <p class="text-muted mb-2"><%= journalCopy.gradingStudentHint %></p>
                  <div class="journal-config-table-wrap">
                    <table class="table table-sm journal-config-table journal-config-table--readonly align-middle mb-0">
                      <thead>
                        <tr>
                          <th><%= journalCopy.activityType %></th>
                          <th><%= journalCopy.configMaxPoints %></th>
                          <th><%= journalCopy.configContribution %></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% gradingTypeRows.forEach(function(cfg) { %>
                          <% const enabledField = `${cfg.key}_enabled`; %>
                          <% const maxField = `${cfg.key}_max_points`; %>
                          <% const weightField = `${cfg.key}_weight_points`; %>
                          <% const enabledValue = Number(gradingSettings && gradingSettings[enabledField]) === 1; %>
                          <% const maxValueRaw = Number(gradingSettings && gradingSettings[maxField]); %>
                          <% const maxValue = Number.isFinite(maxValueRaw) ? maxValueRaw.toFixed(2).replace(/\.00$/, '') : '0'; %>
                          <% const weightValueRaw = Number(gradingSettings && gradingSettings[weightField]); %>
                          <% const weightValue = Number.isFinite(weightValueRaw) ? weightValueRaw.toFixed(2).replace(/\.00$/, '') : '0'; %>
                          <tr class="<%= enabledValue ? '' : 'is-disabled' %>">
                            <td><strong><%= cfg.label %></strong></td>
                            <td><%= maxValue %></td>
                            <td>
                              <% if (enabledValue) { %>
                                <span class="status-chip status-chip--info"><%= weightValue %></span>
                              <% } else { %>
                                <span class="status-chip status-chip--neutral"><%= journalCopy.disabled %></span>
                              <% } %>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                  <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
                    <span class="status-chip status-chip--info"><%= journalCopy.weightTotal %>: <%= enabledWeightTotal.toFixed(2).replace(/\.00$/, '') %> / 100</span>
                    <span class="status-chip status-chip--neutral"><%= journalCopy.finalFixed %></span>
                  </div>
                </div>
              <% } %>
            </div>
          </details>
        </section>
      <% } %>

      <section class="glass liquid-card p-3">
        <% if (!selectedSubject) { %>
          <div class="text-muted"><%= journalCopy.subjectNotSelected %></div>
        <% } else if (!columns || !columns.length) { %>
          <div class="text-muted"><%= journalCopy.noColumns %></div>
        <% } else if (!journalRows || !journalRows.length) { %>
          <div class="text-muted"><%= journalCopy.noStudentsForSubject %></div>
        <% } else { %>
          <div class="journal-table-wrap">
            <table class="table journal-table mb-0 align-middle">
              <thead>
                <tr>
                  <th class="journal-th-student"><%= journalCopy.studentTableName %></th>
                  <% columns.forEach(function(column) { %>
                    <th class="journal-th-column">
                      <div class="journal-col-title"><%= column.title %></div>
                      <div class="journal-col-meta">
                        <span><%= Number(column.max_points).toFixed(2).replace(/\.00$/, '') %> <%= journalCopy.pointsShort %></span>
                        <% if (column.is_credit) { %>
                          <span class="status-chip status-chip--warning"><%= journalCopy.credit %></span>
                        <% } %>
                        <% if (!column.include_in_final) { %>
                          <span class="status-chip status-chip--neutral"><%= journalCopy.excluded %></span>
                        <% } %>
                        <% if (column.is_locked) { %>
                          <span class="status-chip status-chip--danger"><%= journalCopy.locked %></span>
                        <% } else { %>
                          <span class="status-chip status-chip--success"><%= journalCopy.openState %></span>
                        <% } %>
                        <% if (column.source_homework_id && column.homework_meeting_url) { %>
                          <span class="status-chip status-chip--info">Meet</span>
                        <% } %>
                      </div>
                      <% if (canEditJournal) { %>
                        <div class="journal-col-actions">
                          <form method="POST" action="/journal/columns/final-toggle" class="journal-column-toggle-form">
                            <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                            <input type="hidden" name="column_id" value="<%= column.id %>" />
                            <input type="hidden" name="include_in_final" value="<%= column.include_in_final ? 0 : 1 %>" />
                            <button
                              class="btn btn-sm journal-col-action-btn <%= column.include_in_final ? 'btn-outline-warning' : 'btn-outline-success' %>"
                              type="submit"
                              title="<%= column.include_in_final ? journalCopy.excludeFromFinalTitle : journalCopy.includeInFinalTitle %>"
                            >
                              <%= column.include_in_final ? journalCopy.finalMinus : journalCopy.finalPlus %>
                            </button>
                          </form>
                          <form method="POST" action="/journal/columns/lock-toggle" class="journal-column-toggle-form">
                            <input type="hidden" name="subject_id" value="<%= selectedSubject.subject_id %>" />
                            <input type="hidden" name="column_id" value="<%= column.id %>" />
                            <input type="hidden" name="is_locked" value="<%= column.is_locked ? 0 : 1 %>" />
                            <button
                              class="btn btn-sm journal-col-action-btn <%= column.is_locked ? 'btn-outline-success' : 'btn-outline-danger' %>"
                              type="submit"
                              title="<%= column.is_locked ? journalCopy.unlock : journalCopy.lock %>"
                            >
                              <%= column.is_locked ? journalCopy.unlock : journalCopy.lock %>
                            </button>
                          </form>
                          <button
                            class="btn btn-sm btn-outline-primary journal-col-action-btn journal-bulk-open-btn"
                            type="button"
                            data-column-id="<%= column.id %>"
                            data-column-title="<%= column.title %>"
                            data-column-max="<%= Number(column.max_points).toFixed(2) %>"
                            data-column-locked="<%= column.is_locked ? 1 : 0 %>"
                            title="<%= journalCopy.bulkGradingTitle %>"
                          >
                            <%= journalCopy.bulkAction %>
                          </button>
                        </div>
                      <% } %>
                    </th>
                  <% }); %>
                  <th class="journal-th-final final-col"><%= journalCopy.totalOutOfHundred %></th>
                </tr>
              </thead>
              <tbody>
                <% journalRows.forEach(function(row, rowIndex) { %>
                  <tr>
                    <td class="journal-student-cell">
                      <div class="journal-student-name"><%= row.student.full_name %></div>
                      <div class="journal-student-meta"><%= journalCopy.groupPrefix %> <%= row.student.group_number %></div>
                    </td>
                    <% row.cells.forEach(function(cell, cellIndex) { %>
                      <% const cellColumn = columns[cellIndex] || null; %>
                      <% const lockedClass = cellColumn && cellColumn.is_locked ? 'is-locked' : ''; %>
                      <% const statusClass = cell.status === 'on_time' ? 'is-on-time' : cell.status === 'late' ? 'is-late' : cell.status === 'manual' ? 'is-manual' : 'is-missing'; %>
                      <td class="journal-cell">
                        <button
                          class="journal-cell-btn <%= statusClass %> <%= lockedClass %>"
                          type="button"
                          data-column-id="<%= cell.column_id %>"
                          data-student-id="<%= cell.student_id %>"
                          data-row-index="<%= rowIndex %>"
                          data-column-index="<%= cellIndex %>"
                          data-can-open="1"
                        >
                          <span class="journal-cell-score"><%= Number.isFinite(cell.score) ? String(cell.score).replace(/\.00$/, '') : '—' %></span>
                        </button>
                      </td>
                    <% }); %>
                    <td class="journal-final-cell final-col">
                      <% const weightedEarned = Number.isFinite(Number(row.weighted_earned)) ? Number(row.weighted_earned) : Number(row.final_score || 0); %>
                      <div class="journal-final-value"><%= row.final_score.toFixed(2).replace(/\.00$/, '') %></div>
                      <div class="journal-final-meta"><%= weightedEarned.toFixed(2).replace(/\.00$/, '') %> / 100 · <%= journalCopy.rawPrefix %> <%= row.raw_earned.toFixed(2).replace(/\.00$/, '') %> / <%= row.raw_max.toFixed(2).replace(/\.00$/, '') %></div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>

    <%- include('partials/app-footer') %>
    <%- include('partials/mobile-menu-modal', { role, t, activePage: 'journal' }) %>
    <%- include('partials/changelog-modal') %>

    <div class="modal fade" id="journalCellModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="journalCellTitle">Оцінювання</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <div class="text-muted small mb-1">Студент</div>
              <div class="fw-semibold" id="journalCellStudent">-</div>
            </div>
            <div class="mb-3">
              <div class="text-muted small mb-1">Статус здачі</div>
              <span class="status-chip status-chip--neutral" id="journalCellStatus">-</span>
            </div>
            <div class="alert alert-warning d-none py-2" id="journalLockedNotice">
              Колонка заблокована: редагування оцінок вимкнено.
            </div>
            <div id="journalCellOverview" class="journal-cell-overview mb-4">
              <div class="journal-cell-overview-head">
                <div class="journal-cell-overview-copy">
                  <div class="text-muted small"><%= journalCopy.cellSummaryTitle %></div>
                  <div class="small text-muted"><%= journalCopy.cellSummaryEffective %></div>
                  <div class="journal-cell-overview-scoreline">
                    <span class="journal-cell-overview-score" id="journalCellOverviewScore"><%= journalCopy.dash %></span>
                    <span class="journal-cell-overview-max" id="journalCellOverviewMax"></span>
                  </div>
                  <div class="small text-muted" id="journalCellOverviewMeta"><%= journalCopy.cellSummaryNoGrade %></div>
                </div>
                <div class="journal-cell-overview-chips" id="journalCellOverviewChips"></div>
              </div>
              <div class="journal-cell-overview-grid">
                <div class="journal-cell-overview-metric">
                  <span class="text-muted small"><%= journalCopy.cellSummaryRetakes %></span>
                  <strong class="journal-cell-overview-value" id="journalCellRetakeCount">0</strong>
                </div>
                <div class="journal-cell-overview-metric">
                  <span class="text-muted small"><%= journalCopy.cellSummaryAppeals %></span>
                  <strong class="journal-cell-overview-value" id="journalCellAppealCount">0</strong>
                </div>
                <div class="journal-cell-overview-metric">
                  <span class="text-muted small"><%= journalCopy.cellSummaryModeration %></span>
                  <strong class="journal-cell-overview-value" id="journalCellModerationState"><%= journalCopy.cellSummaryModerationNotRequired %></strong>
                </div>
                <div class="journal-cell-overview-metric">
                  <span class="text-muted small"><%= journalCopy.cellSummaryCompetencies %></span>
                  <strong class="journal-cell-overview-value" id="journalCellCompetencyCount">0</strong>
                </div>
              </div>
              <div class="journal-cell-overview-note" id="journalCellOverviewNote">
                <div class="small text-muted"><%= journalCopy.cellSummaryNoGradeHint %></div>
              </div>
            </div>
            <div id="journalSubmissionBox" class="journal-submission-box mb-4">
              <div class="text-muted">Здача відсутня.</div>
            </div>
            <section id="journalRetakeSection" class="journal-retake-section mb-4">
