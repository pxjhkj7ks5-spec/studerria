        const moderationMeta = data && data.moderation_meta ? data.moderation_meta : {};
        const moderation = data && data.moderation ? data.moderation : null;
        const moderationRequired = Boolean(moderationMeta.required);
        const maxPoints = Number(column && column.max_points);
        const hasMaxPoints = Number.isFinite(maxPoints) && maxPoints > 0;
        const hasGrade = Boolean(grade && Number.isFinite(Number(grade.original_score)));
        const originalScore = hasGrade ? formatNumber(grade.original_score) : journalText.dash;
        const effectiveScore = hasGrade ? formatNumber(grade.score) : journalText.dash;
        const moderationAdjusted = Boolean(
          moderation
          && Number.isFinite(Number(moderation.moderated_score))
          && Number(moderation.moderated_score) !== Number(grade && grade.original_score)
        );

        if (cellOverviewScoreEl) {
          cellOverviewScoreEl.textContent = hasGrade ? effectiveScore : journalText.dash;
        }
        if (cellOverviewMaxEl) {
          cellOverviewMaxEl.textContent = hasMaxPoints ? `/ ${formatNumber(maxPoints)}` : '';
        }
        if (cellOverviewMetaEl) {
          if (hasGrade) {
            const maxText = hasMaxPoints ? ` / ${formatNumber(maxPoints)}` : '';
            const tail = moderationAdjusted ? journalText.cellSummaryGradeAdjusted : journalText.cellSummaryGradeSaved;
            cellOverviewMetaEl.textContent = `${journalText.cellSummaryOriginal}: ${originalScore}${maxText}. ${tail}`;
          } else {
            cellOverviewMetaEl.textContent = `${journalText.cellSummaryNoGrade}. ${journalText.cellSummaryNoGradeHint}`;
          }
        }
        if (cellRetakeCountEl) cellRetakeCountEl.textContent = String(retakes.length);
        if (cellAppealCountEl) cellAppealCountEl.textContent = String(appeals.length);
        if (cellCompetencyCountEl) cellCompetencyCountEl.textContent = String(signals.length);
        if (cellModerationStateEl) {
          cellModerationStateEl.textContent = moderationRequired
            ? (moderation
                ? String(moderation.status_label || moderation.status || journalText.cellSummaryReviewPending)
                : (hasGrade ? journalText.cellSummaryReviewPending : journalText.cellSummaryNoGrade))
            : journalText.cellSummaryModerationNotRequired;
        }

        if (cellOverviewChipsEl) {
          const chips = [];
          if (data && data.subject_is_closed) {
            chips.push(createStatusChipNode('status-chip--danger', journalText.cellSummaryClosed));
          }
          if (column && column.is_locked) {
            chips.push(createStatusChipNode('status-chip--danger', journalText.cellSummaryLocked));
