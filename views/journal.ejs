      const applyGradingPreset = (presetKey) => {
        const presets = {
          balanced: {
            homework: { enabled: 1, max: 10, weight: 20 },
            seminar: { enabled: 1, max: 10, weight: 20 },
            exam: { enabled: 1, max: 40, weight: 40 },
