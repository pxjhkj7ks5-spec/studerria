                text: String(note || journalText.dash),
              }),
            ],
          }),
        ];
        if (Array.isArray(metrics) && metrics.length) {
          shellChildren.push(createElement('div', {
            className: 'journal-review-summary-metrics',
            children: metrics.map((metric) => createReviewSummaryMetricNode(metric && metric.label, metric && metric.value)),
          }));
        }
        if (actionLabel) {
          const actionButton = createElement('button', {
            className: actionClassName,
            attrs: { type: 'button' },
            props: { disabled: Boolean(actionDisabled) },
            text: actionLabel,
          });
          if (typeof onAction === 'function') {
            actionButton.addEventListener('click', (event) => {
              event.preventDefault();
              onAction();
            });
          }
          shellChildren.push(createElement('div', {
            className: 'journal-review-summary-actions',
            children: [actionButton],
          }));
        }
        renderNodeChildren(node, createElement('div', {
          className: 'journal-review-summary-shell',
          children: shellChildren,
        }));
      }

      function renderSubmission(submission, column) {
        if (!(submissionBox instanceof HTMLElement)) {
          return;
        }
        submissionBox.replaceChildren();
        let hasContent = false;

        const appendTextRow = ({ label = '', value = '', className = 'mb-2', valueClassName = '' } = {}) => {
          const safeValue = String(value || '').trim();
          if (!safeValue) return;
          const row = document.createElement('div');
          row.className = className;
          if (label) {
            const strong = document.createElement('strong');
            strong.textContent = label;
            row.appendChild(strong);
            if (!valueClassName) {
              row.appendChild(document.createTextNode(` ${safeValue}`));
            }
          }
          if (valueClassName) {
            const valueEl = document.createElement('div');
            valueEl.className = valueClassName;
            valueEl.textContent = safeValue;
            row.appendChild(valueEl);
          }
          submissionBox.appendChild(row);
          hasContent = true;
        };

        const appendLinkRow = ({ href = '', label = '', uploadsOnly = false } = {}) => {
          const safeHref = resolveSafeHref(href, { uploadsOnly });
          const safeLabel = String(label || '').trim();
          if (!safeHref || !safeLabel) return;
          const row = document.createElement('div');
          row.className = 'mb-2';
          const link = document.createElement('a');
          link.href = safeHref;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.textContent = safeLabel;
          row.appendChild(link);
          submissionBox.appendChild(row);
          hasContent = true;
        };

        appendTextRow({
          label: 'Завдання:',
          value: column && column.homework_description ? column.homework_description : '',
        });
        appendTextRow({
          value: column && column.due_date ? `Дедлайн: ${column.due_date}` : '',
          className: 'mb-2 text-muted small',
        });
        appendTextRow({
          value: submission && submission.submitted_at
            ? `Здано: ${new Date(submission.submitted_at).toLocaleString('uk-UA')}`
            : '',
          className: 'mb-2 text-muted small',
        });
        appendTextRow({
          label: 'Текст:',
          value: submission && submission.submission_text ? submission.submission_text : '',
          valueClassName: 'journal-submission-text',
        });
        appendLinkRow({
          href: submission && submission.link_url ? submission.link_url : '',
          label: 'Відкрити посилання',
        });
        appendLinkRow({
          href: submission && submission.file_path ? submission.file_path : '',
          label: submission && submission.file_name ? submission.file_name : 'Файл',
          uploadsOnly: true,
        });

        if (!hasContent) {
          const empty = document.createElement('div');
          empty.className = 'text-muted';
          empty.textContent = 'Здача відсутня.';
          submissionBox.appendChild(empty);
        }
      }

      function renderRetakes(data) {
        if (!retakeSectionEl || !retakeListEl) return;
        const attempts = Array.isArray(data && data.retake_attempts) ? data.retake_attempts : [];
        const canManage = Boolean(canEditJournal && data && data.can_manage_retakes);
        const isClosed = Boolean(data && data.subject_is_closed);
        const isLocked = Boolean(data && data.column && data.column.is_locked);
        const activeAttemptCount = attempts.filter((attempt) => {
          const status = String(attempt && attempt.status ? attempt.status : 'planned');
          return status !== 'graded' && status !== 'cancelled';
        }).length;
        const finalAttemptCount = attempts.filter((attempt) => Boolean(attempt && attempt.count_in_final)).length;
        const retakeMeta = data && data.retake_meta ? data.retake_meta : {};
        const statusOptions = Array.isArray(retakeMeta.statuses) && retakeMeta.statuses.length
          ? retakeMeta.statuses
          : [
              { key: 'planned', label: 'Заплановано' },
              { key: 'submitted', label: 'Здано' },
              { key: 'graded', label: 'Оцінено' },
              { key: 'cancelled', label: 'Скасовано' },
            ];
        const noteMaxLength = Number(retakeMeta.note_max_length || 1200);
        const commentMaxLength = Number(retakeMeta.comment_max_length || 2000);
        const maxScore = Number(data && data.column ? data.column.max_points : 0);

        renderReviewState(retakeStateEl, canManage
          ? {
              chipClass: 'status-chip--info',
              chipText: journalText.reviewStateOpen,
              body: journalText.reviewStateRetakeManage,
            }
          : canEditJournal
            ? {
                chipClass: 'status-chip--danger',
                chipText: journalText.reviewStatePaused,
                body: isClosed
                  ? journalText.cellSummaryClosedNote
                  : isLocked
                    ? journalText.cellSummaryLockedNote
                    : journalText.reviewStateRetakePaused,
              }
            : {
                chipClass: 'status-chip--neutral',
                chipText: journalText.reviewStateStudent,
                body: journalText.reviewStateRetakeReadonly,
              });

        renderReviewSummary(retakeSummaryEl, canManage
          ? (!attempts.length
            ? {
                title: journalText.reviewRetakeStartTitle,
                note: journalText.reviewRetakeStartNote,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: 0 },
                  { label: journalText.reviewMetricActive, value: 0 },
                  { label: journalText.reviewMetricFinal, value: 0 },
                ],
                actionLabel: journalText.actionAddAttempt,
                actionClassName: 'btn btn-sm btn-info',
                onAction: () => focusReviewTarget(retakeCreateKindInput || findFocusableReviewTarget(retakeCreateForm)),
              }
            : activeAttemptCount > 0
              ? {
                  title: journalText.reviewRetakePendingTitle,
                  note: journalText.reviewRetakePendingNote,
                  metrics: [
                    { label: journalText.reviewMetricTotal, value: attempts.length },
                    { label: journalText.reviewMetricActive, value: activeAttemptCount },
                    { label: journalText.reviewMetricFinal, value: finalAttemptCount },
                  ],
                  actionLabel: journalText.actionReviewAttempts,
                  actionClassName: 'btn btn-sm btn-primary',
                  onAction: () => focusReviewTarget(findFocusableReviewTarget(retakeListEl)),
                }
              : {
                  title: journalText.reviewRetakeCurrentTitle,
                  note: journalText.reviewRetakeCurrentNote,
                  metrics: [
                    { label: journalText.reviewMetricTotal, value: attempts.length },
                    { label: journalText.reviewMetricActive, value: activeAttemptCount },
                    { label: journalText.reviewMetricFinal, value: finalAttemptCount },
                  ],
                  actionLabel: journalText.actionAddAttempt,
                  actionClassName: 'btn btn-sm btn-outline-info',
                  onAction: () => focusReviewTarget(retakeCreateKindInput || findFocusableReviewTarget(retakeCreateForm)),
                })
          : canEditJournal
            ? {
                title: journalText.reviewStatePaused,
                note: isClosed
                  ? journalText.cellSummaryClosedNote
                  : isLocked
                    ? journalText.cellSummaryLockedNote
                    : journalText.reviewStateRetakePaused,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: attempts.length },
                  { label: journalText.reviewMetricActive, value: activeAttemptCount },
                  { label: journalText.reviewMetricFinal, value: finalAttemptCount },
                ],
              }
            : {
                title: journalText.reviewRetakeStudentTitle,
                note: journalText.reviewRetakeStudentNote,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: attempts.length },
                  { label: journalText.reviewMetricActive, value: activeAttemptCount },
                  { label: journalText.reviewMetricFinal, value: finalAttemptCount },
                ],
              });

        if (retakeCreateColumnInput) retakeCreateColumnInput.value = String(currentCellColumnId || 0);
        if (retakeCreateStudentInput) retakeCreateStudentInput.value = String(currentCellStudentId || 0);
        if (retakeCreateSubmitBtn) retakeCreateSubmitBtn.disabled = !canManage;
        if (retakeCreateForm) {
          retakeCreateForm.classList.toggle('d-none', !canEditJournal);
          const kindSelect = retakeCreateForm.querySelector('[name="kind"]');
          const dueDateInput = retakeCreateForm.querySelector('[name="due_date"]');
          const noteInput = retakeCreateForm.querySelector('[name="note"]');
          if (kindSelect) kindSelect.disabled = !canManage;
          if (dueDateInput) {
            dueDateInput.disabled = !canManage;
            dueDateInput.value = '';
          }
          if (noteInput) {
            noteInput.disabled = !canManage;
            noteInput.maxLength = noteMaxLength;
            noteInput.value = '';
          }
        }

        if (!attempts.length) {
          renderNodeChildren(retakeListEl, createEmptyStateNode('Спроб поки немає.'));
          return;
        }

        renderNodeChildren(retakeListEl, attempts.map((attempt) => {
          const statusKey = String(attempt && attempt.status ? attempt.status : 'planned');
          const statusClass = getRetakeStatusChipClass(statusKey);
          const scoreValue = Number(attempt && attempt.score);
          const scoreDisplay = Number.isFinite(scoreValue) ? formatNumber(scoreValue) : '—';
          const noteText = String(attempt && attempt.note ? attempt.note : '');
          const commentText = String(attempt && attempt.teacher_comment ? attempt.teacher_comment : '');
          const dueDate = String(attempt && attempt.due_date ? attempt.due_date : '');
          const approvedBy = String(attempt && attempt.approved_by_name ? attempt.approved_by_name : '');
          const gradedBy = String(attempt && attempt.graded_by_name ? attempt.graded_by_name : '');
          const scoreInputValue = Number.isFinite(scoreValue) ? String(scoreValue) : '';

          const article = createElement('article', { className: 'journal-retake-item' });
          const head = createElement('div', { className: 'journal-retake-item-head' });
          const headStatus = createElement('div', { className: 'd-flex flex-wrap gap-2 align-items-center' });
          headStatus.appendChild(createElement('strong', {
            text: `#${Number(attempt && attempt.attempt_no ? attempt.attempt_no : 1)} · ${String(attempt && attempt.kind_label ? attempt.kind_label : 'Спроба')}`,
          }));
          headStatus.appendChild(createStatusChipNode(statusClass, String(attempt && attempt.status_label ? attempt.status_label : statusKey)));
          if (attempt && attempt.count_in_final) {
            headStatus.appendChild(createStatusChipNode('status-chip--success', 'У фіналі'));
          }
          const headMeta = createElement('div', { className: 'journal-retake-item-meta' });
          headMeta.appendChild(createElement('span', {
            text: dueDate ? `Дедлайн: ${dueDate}` : 'Дедлайн: —',
          }));
          if (attempt && attempt.approved_at) {
            headMeta.appendChild(createElement('span', {
              text: `Додано: ${formatDateTime(attempt.approved_at)}${approvedBy ? ` · ${approvedBy}` : ''}`,
            }));
          }
          if (attempt && attempt.graded_at) {
            headMeta.appendChild(createElement('span', {
              text: `Оцінено: ${formatDateTime(attempt.graded_at)}${gradedBy ? ` · ${gradedBy}` : ''}`,
            }));
          }
          appendChildren(head, [headStatus, headMeta]);
          article.appendChild(head);

          if (noteText) {
            article.appendChild(createElement('div', {
              className: 'journal-retake-note small',
              text: noteText,
            }));
          }

          if (canManage) {
            const form = createElement('form', {
              className: 'journal-retake-item-form mt-2',
              attrs: {
                method: 'POST',
                action: '/journal/retakes/update',
                autocomplete: 'off',
              },
            });
            appendChildren(form, [
              createHiddenInput('attempt_id', Number(attempt && attempt.id ? attempt.id : 0)),
              createHiddenInput('column_id', currentCellColumnId),
              createHiddenInput('student_id', currentCellStudentId),
            ]);
            syncWorkflowContextInputs(form, { includeOpenCell: true });

            const topRow = createElement('div', { className: 'row g-2 align-items-end' });
            const statusCol = createElement('div', { className: 'col-12 col-md-4' });
            statusCol.appendChild(createElement('label', {
              className: 'form-label form-label-sm mb-1',
              text: 'Статус',
            }));
            const statusSelect = createElement('select', {
              className: 'form-select form-select-sm',
              props: { name: 'status' },
            });
            populateSelectOptions(statusSelect, statusOptions, statusKey);
            statusCol.appendChild(statusSelect);

            const dueDateCol = createElement('div', { className: 'col-12 col-md-4' });
            dueDateCol.appendChild(createElement('label', {
              className: 'form-label form-label-sm mb-1',
              text: 'Дедлайн',
            }));
            dueDateCol.appendChild(createElement('input', {
              className: 'form-control form-control-sm',
              attrs: { type: 'date' },
              props: { name: 'due_date', value: dueDate },
            }));

            const scoreCol = createElement('div', { className: 'col-12 col-md-4' });
            scoreCol.appendChild(createElement('label', {
              className: 'form-label form-label-sm mb-1',
              text: 'Бал',
            }));
            scoreCol.appendChild(createElement('input', {
              className: 'form-control form-control-sm',
              attrs: { type: 'number', step: '0.01', min: '0', max: formatNumber(maxScore) },
              props: {
                name: 'score',
                value: scoreInputValue,
                placeholder: 'напр. 10',
              },
            }));
            appendChildren(topRow, [statusCol, dueDateCol, scoreCol]);

            const detailsRow = createElement('div', { className: 'row g-2 mt-1' });
            const noteCol = createElement('div', { className: 'col-12 col-md-6' });
            noteCol.appendChild(createElement('label', {
              className: 'form-label form-label-sm mb-1',
              text: 'Нотатка',
            }));
            noteCol.appendChild(createElement('textarea', {
              className: 'form-control form-control-sm',
              attrs: { maxlength: noteMaxLength },
              props: {
                name: 'note',
                rows: 2,
                placeholder: 'Що потрібно перездати',
                value: noteText,
              },
            }));

            const commentCol = createElement('div', { className: 'col-12 col-md-6' });
            commentCol.appendChild(createElement('label', {
              className: 'form-label form-label-sm mb-1',
              text: 'Коментар',
            }));
            commentCol.appendChild(createElement('textarea', {
              className: 'form-control form-control-sm',
              attrs: { maxlength: commentMaxLength },
              props: {
                name: 'teacher_comment',
                rows: 2,
                placeholder: 'Фідбек викладача',
                value: commentText,
              },
            }));
            appendChildren(detailsRow, [noteCol, commentCol]);

            const actionRow = createElement('div', { className: 'd-flex flex-wrap align-items-center gap-2 mt-2' });
            actionRow.appendChild(createHiddenInput('count_in_final', 0));
            const countLabel = createElement('label', {
              className: 'form-check d-inline-flex align-items-center gap-2 m-0',
            });
            appendChildren(countLabel, [
              createElement('input', {
                className: 'form-check-input mt-0',
                attrs: { type: 'checkbox', value: '1' },
                props: {
                  name: 'count_in_final',
                  checked: Boolean(attempt && attempt.count_in_final),
                },
              }),
              createElement('span', {
                className: 'small',
                text: 'Врахувати у фінальному розрахунку',
              }),
            ]);
            actionRow.appendChild(countLabel);
            actionRow.appendChild(createElement('button', {
              className: 'btn btn-sm btn-primary ms-auto',
              attrs: { type: 'submit' },
              text: 'Зберегти спробу',
            }));
            appendChildren(form, [topRow, detailsRow, actionRow]);
            article.appendChild(form);
          } else {
            const readonlyBlock = createElement('div', {
              className: 'journal-retake-readonly small',
            });
            const scoreLine = createElement('div');
            appendChildren(scoreLine, [
              'Бал: ',
              createElement('strong', { text: scoreDisplay }),
              attempt && attempt.count_in_final ? ' · враховано у фіналі' : '',
            ]);
            readonlyBlock.appendChild(scoreLine);
            if (commentText) {
              readonlyBlock.appendChild(createElement('div', {
                className: 'mt-1',
                text: commentText,
              }));
            }
            article.appendChild(readonlyBlock);
          }

          return article;
        }));
      }
      function renderAppeals(data) {
        if (!appealSectionEl || !appealListEl) return;
        const appeals = Array.isArray(data && data.appeals) ? data.appeals : [];
        const canCreate = Boolean(data && data.can_create_appeals);
        const canManage = Boolean(canEditJournal && data && data.can_manage_appeals);
        const isClosed = Boolean(data && data.subject_is_closed);
        const isLocked = Boolean(data && data.column && data.column.is_locked);
        const activeAppealCount = appeals.filter((appeal) => {
          const status = String(appeal && appeal.status ? appeal.status : 'pending');
          return status === 'pending' || status === 'in_review';
        }).length;
        const resolvedAppealCount = appeals.length - activeAppealCount;
        const appealMeta = data && data.appeal_meta ? data.appeal_meta : {};
        const reasonMaxLength = Number(appealMeta.reason_max_length || 2400);
        const commentMaxLength = Number(appealMeta.comment_max_length || 2400);
        const maxScore = Number(data && data.column ? data.column.max_points : 0);
        const hasGrade = Boolean(data && data.grade && Number.isFinite(Number(data.grade.original_score)));
        const statusOptions = Array.isArray(appealMeta.statuses) && appealMeta.statuses.length
          ? appealMeta.statuses
          : [
              { key: 'pending', label: 'Нова' },
              { key: 'in_review', label: 'На розгляді' },
              { key: 'approved', label: 'Підтверджено' },
              { key: 'rejected', label: 'Відхилено' },
            ];

        renderReviewState(appealStateEl, canManage
          ? {
              chipClass: 'status-chip--info',
              chipText: journalText.reviewStateOpen,
              body: journalText.reviewStateAppealManage,
            }
          : canCreate
            ? {
                chipClass: 'status-chip--warning',
                chipText: journalText.reviewStateOpen,
                body: journalText.reviewStateAppealCreate,
              }
            : canEditJournal && !hasGrade && !isClosed && !isLocked
              ? {
                  chipClass: 'status-chip--neutral',
                  chipText: journalText.cellSummaryNoGrade,
                  body: journalText.cellSummaryNoGradeHint,
                }
            : canEditJournal
              ? {
                  chipClass: 'status-chip--danger',
                  chipText: journalText.reviewStatePaused,
                  body: isClosed
                    ? journalText.cellSummaryClosedNote
                    : isLocked
                      ? journalText.cellSummaryLockedNote
                      : journalText.reviewStateAppealPaused,
                }
              : hasGrade
                ? {
                    chipClass: 'status-chip--neutral',
                    chipText: journalText.reviewStateStudent,
                    body: journalText.reviewStateAppealReadonly,
                  }
                : {
                    chipClass: 'status-chip--neutral',
                    chipText: journalText.cellSummaryNoGrade,
                    body: journalText.cellSummaryNoGradeHint,
                  });

        renderReviewSummary(appealSummaryEl, canManage
          ? (activeAppealCount > 0
            ? {
                title: journalText.reviewAppealQueueTitle,
                note: journalText.reviewAppealQueueNote,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: appeals.length },
                  { label: journalText.reviewMetricActive, value: activeAppealCount },
                  { label: journalText.reviewMetricResolved, value: resolvedAppealCount },
                ],
                actionLabel: journalText.actionReviewAppeals,
                actionClassName: 'btn btn-sm btn-primary',
                onAction: () => focusReviewTarget(findFocusableReviewTarget(appealListEl)),
              }
            : {
                title: journalText.reviewAppealCurrentTitle,
                note: journalText.reviewAppealCurrentNote,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: appeals.length },
                  { label: journalText.reviewMetricActive, value: activeAppealCount },
                  { label: journalText.reviewMetricResolved, value: resolvedAppealCount },
                ],
              })
          : canCreate
            ? {
                title: journalText.reviewAppealCreateTitle,
                note: journalText.reviewAppealCreateNote,
                metrics: [
                  { label: journalText.reviewMetricTotal, value: appeals.length },
                  { label: journalText.reviewMetricActive, value: activeAppealCount },
                  { label: journalText.reviewMetricResolved, value: resolvedAppealCount },
                ],
                actionLabel: journalText.actionOpenAppeal,
                actionClassName: 'btn btn-sm btn-warning',
                onAction: () => focusReviewTarget(appealCreateRequestedScore || appealCreateReason || findFocusableReviewTarget(appealCreateForm)),
                actionDisabled: !canCreate,
              }
            : canEditJournal
              ? {
                  title: !hasGrade
                    ? journalText.cellSummaryNoGrade
                    : journalText.reviewStatePaused,
                  note: !hasGrade
                    ? journalText.cellSummaryNoGradeHint
                    : isClosed
                      ? journalText.cellSummaryClosedNote
                      : isLocked
                        ? journalText.cellSummaryLockedNote
                        : journalText.reviewStateAppealPaused,
                  metrics: [
                    { label: journalText.reviewMetricTotal, value: appeals.length },
                    { label: journalText.reviewMetricActive, value: activeAppealCount },
                    { label: journalText.reviewMetricResolved, value: resolvedAppealCount },
                  ],
                }
              : {
                  title: journalText.reviewAppealStudentTitle,
                  note: journalText.reviewAppealStudentNote,
                  metrics: [
                    { label: journalText.reviewMetricTotal, value: appeals.length },
                    { label: journalText.reviewMetricActive, value: activeAppealCount },
                    { label: journalText.reviewMetricResolved, value: resolvedAppealCount },
                  ],
                });

        if (appealCreateColumnInput) appealCreateColumnInput.value = String(currentCellColumnId || 0);
        if (appealCreateStudentInput) appealCreateStudentInput.value = String(currentCellStudentId || 0);
        if (appealCreateRequestedScore) {
          appealCreateRequestedScore.max = formatNumber(maxScore);
          appealCreateRequestedScore.disabled = !canCreate;
          appealCreateRequestedScore.value = '';
        }
        if (appealCreateReason) {
          appealCreateReason.maxLength = reasonMaxLength;
          appealCreateReason.disabled = !canCreate;
          appealCreateReason.value = '';
        }
        if (appealCreateSubmitBtn) appealCreateSubmitBtn.disabled = !canCreate;
        if (appealCreateForm) {
          appealCreateForm.classList.toggle('d-none', canEditJournal);
        }

        if (!appeals.length) {
          renderNodeChildren(appealListEl, createEmptyStateNode('Апеляцій поки немає.'));
          return;
        }

        renderNodeChildren(appealListEl, appeals.map((appeal) => {
          const statusKey = String(appeal && appeal.status ? appeal.status : 'pending');
          const statusClass = getAppealStatusChipClass(statusKey);
          const requestedScore = Number(appeal && appeal.requested_score);
          const resolvedScore = Number(appeal && appeal.resolved_score);
          const requestedScoreDisplay = Number.isFinite(requestedScore) ? formatNumber(requestedScore) : '—';
          const resolvedScoreDisplay = Number.isFinite(resolvedScore) ? formatNumber(resolvedScore) : '—';
          const reasonText = String(appeal && appeal.reason ? appeal.reason : '');
          const decisionText = String(appeal && appeal.decision_comment ? appeal.decision_comment : '');
          const resolvedScoreInputValue = Number.isFinite(resolvedScore) ? String(resolvedScore) : '';
          const createdBy = String(appeal && appeal.created_by_name ? appeal.created_by_name : '');
          const reviewedBy = String(appeal && appeal.reviewed_by_name ? appeal.reviewed_by_name : '');
          const createdAt = appeal && appeal.created_at ? formatDateTime(appeal.created_at) : '';
          const reviewedAt = appeal && appeal.reviewed_at ? formatDateTime(appeal.reviewed_at) : '';
          const slaDueAt = appeal && appeal.sla_due_at ? formatDateTime(appeal.sla_due_at) : '';
          const isOverdue = Boolean(appeal && appeal.is_overdue);

          const article = createElement('article', { className: 'journal-appeal-item' });
          const head = createElement('div', { className: 'journal-appeal-item-head' });
          const headStatus = createElement('div', { className: 'd-flex flex-wrap gap-2 align-items-center' });
          headStatus.appendChild(createElement('strong', {
            text: `Апеляція #${Number(appeal && appeal.id ? appeal.id : 0)}`,
          }));
          headStatus.appendChild(createStatusChipNode(statusClass, String(appeal && appeal.status_label ? appeal.status_label : statusKey)));
          if (isOverdue) {
            headStatus.appendChild(createStatusChipNode('status-chip--danger', 'SLA прострочено'));
          }
          const headMeta = createElement('div', { className: 'journal-appeal-item-meta' });
          appendChildren(headMeta, [
            createElement('span', { text: `Запитуваний бал: ${requestedScoreDisplay}` }),
            createElement('span', { text: `Поточне рішення: ${resolvedScoreDisplay}` }),
            slaDueAt ? createElement('span', { text: `SLA до: ${slaDueAt}` }) : null,
            createdAt ? createElement('span', { text: `Подано: ${createdAt}${createdBy ? ` · ${createdBy}` : ''}` }) : null,
            reviewedAt ? createElement('span', { text: `Розглянуто: ${reviewedAt}${reviewedBy ? ` · ${reviewedBy}` : ''}` }) : null,
          ]);
          appendChildren(head, [headStatus, headMeta]);
          article.appendChild(head);
          article.appendChild(createElement('div', {
            className: 'journal-appeal-reason small',
            text: reasonText,
          }));

          if (canManage) {
            const form = createElement('form', {
              className: 'journal-appeal-item-form mt-2',
              attrs: {
                method: 'POST',
                action: '/journal/appeals/update',
                autocomplete: 'off',
