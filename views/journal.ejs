          if (canEditJournal) {
            chips.push(createStatusChipNode(
              data && data.can_edit ? 'status-chip--success' : 'status-chip--neutral',
              data && data.can_edit ? journalText.cellSummaryEditable : journalText.cellSummaryReadOnly
            ));
          } else {
            chips.push(createStatusChipNode('status-chip--neutral', journalText.cellSummaryReadOnly));
            if (data && data.can_create_appeals) {
              chips.push(createStatusChipNode('status-chip--warning', journalText.cellSummaryAppealAvailable));
            }
          }
          if (!hasGrade) {
            chips.push(createStatusChipNode('status-chip--neutral', journalText.cellSummaryNoGrade));
