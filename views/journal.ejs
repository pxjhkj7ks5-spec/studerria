        try {
          const formData = new window.FormData(formEl);
          const bodyParams = new URLSearchParams();
          formData.forEach((value, key) => {
            bodyParams.append(key, String(value == null ? '' : value));
          });
          const response = await fetch(formEl.action, {
            method: String(formEl.method || 'POST').toUpperCase(),
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            },
            body: bodyParams.toString(),
            credentials: 'same-origin',
          });
          if (!response.ok) {
            throw new Error('Помилка збереження');
          }
          const errMessage = getMessageFromUrl(response.url, 'err');
          if (errMessage) {
            throw new Error(errMessage);
