# App
NODE_ENV=development
APP_PORT=3000
APP_PORT_FORWARD=3000
SESSION_SECRET=change-me-local-session-secret
SESSION_STORE_DRIVER=redis
REDIS_URL=redis://redis:6379
SESSION_REDIS_PREFIX=kma:sess:
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_KEEPALIVE_MS=30000
BOOTSTRAP_TOKEN=
TRUST_PROXY=false
STUDERRIA_PUBLIC_URL=https://studerria.com
STUDERRIA_TG_BOT_TOKEN=
STUDERRIA_TG_BOT_USERNAME=
STUDERRIA_TG_APP_SHORT_NAME=
STUDERRIA_TG_MINI_APP_DEEP_LINK=
STUDERRIA_TG_MINI_APP_URL=
STUDERRIA_TG_USE_WEB_APP_BUTTON=true
STUDERRIA_TG_BOT_POLLING_ENABLED=true
STUDERRIA_TG_BOT_DROP_PENDING_UPDATES=true
STUDERRIA_TG_INIT_DATA_MAX_AGE_SECONDS=86400
STUDERRIA_TG_DEV_TELEGRAM_ID=

# Charredmap
CHARREDMAP_NODE_ENV=development
CHARREDMAP_ADMIN_PATH=admin
CHARREDMAP_ADMIN_PASSWORD=change-me-charredmap-admin
CHARREDMAP_SESSION_SECRET=change-me-charredmap-session-secret-change-this
CHARREDMAP_OVERLAY_FILE=/data/occupied-territories-editorial.geojson

# Narada Druk
NARADADRUK_NODE_ENV=development
NARADADRUK_IMAGE=ghcr.io/pxjhkj7ks5-spec/studerria-naradadruk:latest
NARADADRUK_ADMIN_PATH=admin
NARADADRUK_ADMIN_PASSWORD=change-me-naradadruk-admin
NARADADRUK_SESSION_SECRET=change-me-naradadruk-session-secret-change-this
NARADADRUK_TELEGRAM_CHANNEL_URL=https://web.telegram.org/k/#@naradaprint

# Slash TG
SLASHTG_NODE_ENV=development
SLASHTG_IMAGE=ghcr.io/pxjhkj7ks5-spec/studerria-slashtg:latest
SLASHTG_BOT_TOKEN=
SLASHTG_SESSION_SECRET=change-me-slashtg-session-secret-change-this
SLASHTG_USER_A_TELEGRAM_ID=
SLASHTG_USER_B_TELEGRAM_ID=
SLASHTG_USER_A_LABEL=Person A
SLASHTG_USER_B_LABEL=Person B
SLASHTG_INIT_DATA_MAX_AGE_SECONDS=86400
SLASHTG_DEV_TELEGRAM_USER_ID=
SLASHTG_BASE_PATH=/tg

# Postgres
POSTGRES_DB=student_portal
POSTGRES_USER=studerria
POSTGRES_PASSWORD=studerria_local
POSTGRES_PORT_FORWARD=5433

# Redis
REDIS_PORT_FORWARD=6379

# Loki
LOKI_PORT_FORWARD=3100

# Server profile (HTTPS, production runtime)
# NODE_ENV=production
# CHARREDMAP_NODE_ENV=production
# NARADADRUK_NODE_ENV=production
# SLASHTG_NODE_ENV=production
